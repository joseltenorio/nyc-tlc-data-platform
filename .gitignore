.env
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/
*.log
.ipynb_checkpoints/

# Bronze runtime data
data/bronze/trip_records/**/*.parquet
data/bronze/versions/trip_records/**/*.parquet
data/bronze/reference/**/*.csv
data/bronze/reference/**/*.parquet

# Silver runtime data
data/silver/**/*.parquet
data/silver/**/_SUCCESS
data/silver/**/*.crc

# Temporary files, manifests and append-only audit evidence
data/tmp/**
data/manifests/**/*.json
data/manifests/**/*.part
data/manifests/**/*.tmp
data/audit/**/*.jsonl
data/audit/**/*.json
data/audit/**/*.tmp

# Preserve only directory markers
!data/bronze/trip_records/.gitkeep
!data/bronze/versions/trip_records/.gitkeep
!data/bronze/reference/taxi_zones/.gitkeep
!data/bronze/reference/base_lookup/.gitkeep
!data/silver/**/.gitkeep
!data/tmp/
!data/tmp/silver/
!data/tmp/silver/.gitkeep
!data/manifests/
!data/manifests/**/
!data/manifests/**/.gitkeep
!data/audit/
!data/audit/**/
!data/audit/**/.gitkeep

# Gold runtime data
data/gold/**/*.parquet
data/gold/**/_SUCCESS
data/gold/**/*.crc

# Machine-learning outputs and persisted Spark models
data/ml/**/*.parquet
data/ml/**/_SUCCESS
data/ml/**/*.crc
data/models/**
# Streamlit local secrets and caches
.streamlit/secrets.toml
dashboard/**/__pycache__/
