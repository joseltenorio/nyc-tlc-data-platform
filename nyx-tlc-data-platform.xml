263:     @staticmethod
264:     def _find_column(df: Any, aliases: list[str]) -> str | None:
265:         lookup = {name.lower().replace(" ", "_"): name for name in df.columns}
266:         for alias in aliases:
267:             value = lookup.get(alias.lower().replace(" ", "_"))
268:             if value:
269:                 return value
270:         return None
