 50: def _read_jsonl(path: Path, limit: int) -> list[dict[str, Any]]:
 51:     rows: list[dict[str, Any]] = []
 52:     try:
 53:         with path.open("r", encoding="utf-8") as handle:
 54:             for line_number, line in enumerate(handle, start=1):
 55:                 text = line.strip()
 56:                 if not text:
 57:                     continue
 58:                 try:
 59:                     payload = json.loads(text)
 60:                 except json.JSONDecodeError:
 61:                     continue
 62:                 if isinstance(payload, dict):
 63:                     payload["_source_file"] = str(path)
 64:                     payload["_source_line"] = line_number
 65:                     rows.append(payload)
 66:     except OSError:
 67:         return []
 68:     if limit > 0 and len(rows) > limit:
 69:         return rows[-limit:]
 70:     return rows
