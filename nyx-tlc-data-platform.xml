 93: def _normalize_manifest(path: Path, root: Path) -> tuple[dict[str, Any], list[dict[str, Any]]]:
 94:     payload = json.loads(path.read_text(encoding="utf-8"))
 95:     summary = payload.get("summary") if isinstance(payload.get("summary"), dict) else payload
 96:     layer = _infer_layer(path, payload, summary)
 97:     execution_id = str(
 98:         summary.get("execution_id")
 99:         or summary.get("run_id")
100:         or payload.get("execution_id")
101:         or path.stem
102:     )
103:     status = str(summary.get("status") or "UNKNOWN").upper()
104:     source_files = _first_number(summary, ("source_files", "expected_periods", "applicable_periods"))
105:     processed_files = _first_number(
106:         summary,
107:         ("processed_files", "ready_files", "downloaded_files", "datasets_built", "trained_models"),
108:     )
109:     failed_files = _first_number(summary, ("failed_files", "failed_datasets", "failed_models"))
110:     denominator = source_files
111:     if layer == "gold":
112:         built = _first_number(summary, ("datasets_built",))
113:         failed = _first_number(summary, ("failed_datasets",))
114:         denominator = built + failed if built is not None and failed is not None else None
115:     elif layer == "ml":
116:         trained = _first_number(summary, ("trained_models",))
117:         failed = _first_number(summary, ("failed_models",))
118:         denominator = trained + failed if trained is not None and failed is not None else None
119:     error_rate = _first_number(summary, ("error_rate",))
120:     if (
121:         error_rate is None
122:         and failed_files is not None
123:         and denominator is not None
124:         and denominator > 0
125:     ):
126:         error_rate = float(failed_files / denominator)
127: 
128:     row = {
129:         "execution_id": execution_id,
130:         "layer": layer,
131:         "execution_type": str(summary.get("execution_type") or "run"),
132:         "status": status,
133:         "started_at": _parse_datetime(summary.get("started_at") or payload.get("started_at")),
134:         "finished_at": _parse_datetime(
135:             summary.get("finished_at") or payload.get("finished_at") or payload.get("refreshed_at")
136:         ),
137:         "duration_seconds": _duration(
138:             summary.get("started_at") or payload.get("started_at"),
139:             summary.get("finished_at") or payload.get("finished_at") or payload.get("refreshed_at"),
140:             summary.get("duration_seconds"),
141:         ),
142:         "source_files": source_files,
143:         "processed_files": processed_files,
144:         "skipped_files": _first_number(summary, ("skipped_files",)),
145:         "failed_files": failed_files,
146:         "rows_input": _first_number(summary, ("rows_read", "source_rows", "parquet_num_rows")),
147:         "rows_valid": _first_number(summary, ("rows_valid",)),
148:         "rows_rejected": _first_number(summary, ("rows_rejected",)),
149:         "warning_rows": _first_number(summary, ("warning_rows",)),
150:         "datasets_built": _first_number(summary, ("datasets_built",)),
151:         "failed_datasets": _first_number(summary, ("failed_datasets",)),
152:         "trained_models": _first_number(summary, ("trained_models",)),
153:         "failed_models": _first_number(summary, ("failed_models",)),
154:         "error_rate": error_rate,
155:         "total_download_seconds": _first_number(summary, ("total_download_seconds",)),
156:         "average_download_mbps": _first_number(summary, ("average_download_mbps",)),
157:         "manifest_path": str(path.relative_to(root.parent)),
158:     }
159: 
160:     errors: list[dict[str, Any]] = []
161:     declared_errors = summary.get("errors") or payload.get("errors") or []
162:     if isinstance(declared_errors, list):
163:         for error in declared_errors:
164:             if not isinstance(error, dict):
165:                 continue
166:             errors.append(
167:                 {
168:                     "execution_id": execution_id,
169:                     "layer": layer,
170:                     "status": status,
171:                     "error_type": error.get("error_type") or error.get("type") or "UnknownError",
172:                     "error_message": error.get("error_message") or error.get("message") or "",
173:                     "subject": error.get("model_name") or error.get("dataset_name") or error.get("file_name"),
174:                     "occurred_at": row["finished_at"],
175:                     "source": "manifest",
176:                 }
177:             )
178:     if summary.get("error_type") or summary.get("error_message"):
179:         errors.append(
180:             {
181:                 "execution_id": execution_id,
182:                 "layer": layer,
183:                 "status": status,
184:                 "error_type": summary.get("error_type") or "UnknownError",
185:                 "error_message": summary.get("error_message") or "",
186:                 "subject": None,
187:                 "occurred_at": row["finished_at"],
188:                 "source": "manifest",
189:             }
190:         )
191: 
192:     for collection_name in ("files", "outcomes", "results"):
193:         items = payload.get(collection_name)
194:         if not isinstance(items, list):
195:             items = summary.get(collection_name)
196:         if not isinstance(items, list):
197:             continue
198:         for item in items:
199:             if not isinstance(item, dict):
200:                 continue
201:             item_status = str(item.get("status") or "").upper()
202:             error_type = item.get("error_type") or item.get("type")
203:             error_message = item.get("error_message") or item.get("message")
204:             if item_status not in {"FAILED", "ERROR", "EXHAUSTED"} and not (
205:                 error_type or error_message
206:             ):
207:                 continue
208:             errors.append(
209:                 {
210:                     "execution_id": execution_id,
211:                     "layer": layer,
212:                     "status": item_status or status,
213:                     "error_type": error_type or "UnknownError",
214:                     "error_message": error_message or "",
215:                     "subject": (
216:                         item.get("file_name")
217:                         or item.get("dataset_name")
218:                         or item.get("model_name")
219:                         or item.get("period_id")
220:                         or item.get("path")
221:                     ),
222:                     "service": item.get("service"),
223:                     "year": item.get("year"),
224:                     "month": item.get("month"),
225:                     "occurred_at": (
226:                         _parse_datetime(item.get("finished_at"))
227:                         if item.get("finished_at")
228:                         else row["finished_at"]
229:                     ),
230:                     "source": f"manifest.{collection_name}",
231:                 }
232:             )
233:     return row, errors
