 39: def _mongo_documents(
 40:     collection: Any,
 41:     *,
 42:     sort_field: str,
 43:     limit: int = 20000,
 44: ) -> list[dict[str, Any]]:
 45:     return list(collection.find({}, {"_id": 0}).sort(sort_field, -1).limit(limit))
