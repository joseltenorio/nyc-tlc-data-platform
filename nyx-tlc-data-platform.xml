<file path="src/tlc_data_platform/orchestration/medallion_pipeline.py">
 1: from __future__ import annotations
 2: 
 3: from dataclasses import dataclass
 4: from typing import Any
 5: 
 6: from tlc_data_platform.bronze.models import ExecutionSummary
 7: from tlc_data_platform.core.settings import AppConfig, RunSelection
 8: from tlc_data_platform.orchestration.bronze_pipeline import run_bronze_pipeline
 9: from tlc_data_platform.orchestration.silver_pipeline import run_silver_pipeline
10: from tlc_data_platform.silver.models import SilverExecutionSummary
11: 
12: 
13: @dataclass(frozen=True)
14: class MedallionExecutionSummary:
15:     status: str
16:     bronze: ExecutionSummary
17:     silver: SilverExecutionSummary | None
18: 
19:     def to_dict(self) -> dict[str, Any]:
20:         return {
21:             "status": self.status,
22:             "bronze": self.bronze.to_dict(),
23:             "silver": self.silver.to_dict() if self.silver else None,
24:         }
25: 
26: 
27: def run_medallion_to_silver(
28:     config: AppConfig,
29:     selection: RunSelection,
30:     *,
31:     execution_type: str,
32:     force_bronze: bool = False,
33:     force_silver: bool = False,
34:     refresh_references: bool | None = None,
35: ) -> MedallionExecutionSummary:
36:     bronze = run_bronze_pipeline(
37:         config,
38:         selection,
39:         execution_type=execution_type,
40:         force=force_bronze,
41:     )
42:     # Silver must only start after a complete Bronze execution. A
43:     # PARTIAL_SUCCESS can contain missing, deferred or claimed periods and is
44:     # therefore not a valid input boundary for the next Medallion layer.
45:     if bronze.status != "SUCCESS":
46:         return MedallionExecutionSummary(bronze.status, bronze, None)
47:     silver = run_silver_pipeline(
48:         config,
49:         selection,
50:         execution_type=execution_type,
51:         force=force_silver,
52:         refresh_references=refresh_references,
53:     )
54:     if bronze.status == "PARTIAL_SUCCESS" or silver.status == "PARTIAL_SUCCESS":
55:         status = "PARTIAL_SUCCESS"
56:     elif silver.status in {"SUCCESS", "NO_INPUT"}:
57:         status = "SUCCESS"
58:     else:
59:         status = "FAILED"
60:     return MedallionExecutionSummary(status, bronze, silver)
</file>

<file path="src/tlc_data_platform/silver/transformers/fhvhv.py">
  1: from __future__ import annotations
  2: 
  3: from typing import Any
  4: 
  5: from tlc_data_platform.core.settings import SilverQualityConfig
  6: from tlc_data_platform.silver.models import SilverTransformContext
  7: from tlc_data_platform.silver.transformers.common import (
  8:     Rule,
  9:     add_common_metadata,
 10:     add_trip_business_id,
 11:     apply_rules,
 12:     col_from_aliases,
 13:     common_rules,
 14:     normalize_boolean,
 15:     normalize_string,
 16: )
 17: 
 18: 
 19: HVFHS_COMPANIES = {
 20:     "HV0002": "Juno",
 21:     "HV0003": "Uber",
 22:     "HV0004": "Via",
 23:     "HV0005": "Lyft",
 24: }
 25: 
 26: 
 27: def transform(raw: Any, context: SilverTransformContext, quality: SilverQualityConfig) -> Any:
 28:     from pyspark.sql import functions as F
 29: 
 30:     money = {
 31:         "base_passenger_fare": ["base_passenger_fare"],
 32:         "tolls": ["tolls"],
 33:         "black_car_fund": ["bcf"],
 34:         "sales_tax": ["sales_tax"],
 35:         "congestion_surcharge": ["congestion_surcharge"],
 36:         "airport_fee": ["airport_fee"],
 37:         "tips": ["tips"],
 38:         "driver_pay": ["driver_pay"],
 39:         "cbd_congestion_fee": ["cbd_congestion_fee"],
 40:     }
 41:     flag_aliases = {
 42:         "shared_request_flag": ["shared_request_flag"],
 43:         "shared_match_flag": ["shared_match_flag"],
 44:         "access_a_ride_flag": ["access_a_ride_flag"],
 45:         "wav_request_flag": ["wav_request_flag"],
 46:         "wav_match_flag": ["wav_match_flag"],
 47:     }
 48:     raw_flags = {
 49:         name: normalize_string(col_from_aliases(raw, aliases, "string"))
 50:         for name, aliases in flag_aliases.items()
 51:     }
 52:     df = raw.select(
 53:         F.upper(F.trim(col_from_aliases(raw, ["hvfhs_license_num"], "string"))).alias(
 54:             "hvfhs_license_num"
 55:         ),
 56:         F.upper(
 57:             F.trim(col_from_aliases(raw, ["dispatching_base_num"], "string"))
 58:         ).alias("dispatching_base_num"),
 59:         F.upper(
 60:             F.trim(col_from_aliases(raw, ["originating_base_num"], "string"))
 61:         ).alias("originating_base_num"),
 62:         col_from_aliases(raw, ["request_datetime"], "timestamp_ntz").alias(
 63:             "request_datetime"
 64:         ),
 65:         col_from_aliases(raw, ["on_scene_datetime"], "timestamp_ntz").alias(
 66:             "on_scene_datetime"
 67:         ),
 68:         col_from_aliases(raw, ["pickup_datetime"], "timestamp_ntz").alias(
 69:             "pickup_datetime"
 70:         ),
 71:         col_from_aliases(raw, ["dropoff_datetime"], "timestamp_ntz").alias(
 72:             "dropoff_datetime"
 73:         ),
 74:         col_from_aliases(raw, ["PULocationID", "pulocationid"], "int").alias(
 75:             "pickup_location_id"
 76:         ),
 77:         col_from_aliases(raw, ["DOLocationID", "dolocationid"], "int").alias(
 78:             "dropoff_location_id"
 79:         ),
 80:         col_from_aliases(raw, ["trip_miles"], "double").alias("trip_miles"),
 81:         col_from_aliases(raw, ["trip_time"], "long").alias("trip_time"),
 82:         *[
 83:             col_from_aliases(raw, aliases, "double", 0.0).alias(name)
 84:             for name, aliases in money.items()
 85:         ],
 86:         *[column.alias(f"{name}_raw") for name, column in raw_flags.items()],
 87:     )
 88:     for name in money:
 89:         df = df.withColumn(name, F.coalesce(F.col(name), F.lit(0.0)).cast("double"))
 90:     for name in flag_aliases:
 91:         df = df.withColumn(
 92:             name,
 93:             F.when(
 94:                 F.col(f"{name}_raw").isin(*quality.allowed_boolean_flags),
 95:                 F.col(f"{name}_raw"),
 96:             ).otherwise(F.lit(None).cast("string")),
 97:         )
 98: 
 99:     company_expr = F.create_map(
100:         *[
101:             item
102:             for code, company in HVFHS_COMPANIES.items()
103:             for item in (F.lit(code), F.lit(company))
104:         ]
105:     )
106:     df = (
107:         df.withColumn("hvfhs_company_name", company_expr[F.col("hvfhs_license_num")])
108:         .withColumn("shared_requested", normalize_boolean(F.col("shared_request_flag")))
109:         .withColumn("shared_matched", normalize_boolean(F.col("shared_match_flag")))
110:         .withColumn("access_a_ride", normalize_boolean(F.col("access_a_ride_flag")))
111:         .withColumn("wav_requested", normalize_boolean(F.col("wav_request_flag")))
112:         .withColumn("wav_matched", normalize_boolean(F.col("wav_match_flag")))
113:         .withColumn(
114:             "trip_duration_seconds",
115:             F.timestamp_diff(
116:                 "SECOND", F.col("pickup_datetime"), F.col("dropoff_datetime")
117:             ).cast("long"),
118:         )
119:         .withColumn(
120:             "request_to_pickup_seconds",
121:             F.timestamp_diff(
122:                 "SECOND", F.col("request_datetime"), F.col("pickup_datetime")
123:             ).cast("long"),
124:         )
125:         .withColumn(
126:             "driver_wait_seconds",
127:             F.when(
128:                 F.col("on_scene_datetime").isNotNull(),
129:                 F.timestamp_diff(
130:                     "SECOND", F.col("on_scene_datetime"), F.col("pickup_datetime")
131:                 ),
132:             ).cast("long"),
133:         )
134:         .withColumn(
135:             "average_speed_mph",
136:             F.when(
137:                 (F.col("trip_duration_seconds") > 0) & (F.col("trip_miles") >= 0),
138:                 F.col("trip_miles")
139:                 / (F.col("trip_duration_seconds") / F.lit(3600.0)),
140:             ).cast("double"),
141:         )
142:         .withColumn(
143:             "airport_trip_flag",
144:             F.col("pickup_location_id").isin(1, 132, 138)
145:             | F.col("dropoff_location_id").isin(1, 132, 138),
146:         )
147:     )
148:     df = add_common_metadata(df, context)
149:     df = add_trip_business_id(
150:         df,
151:         [
152:             "service_type",
153:             "hvfhs_license_num",
154:             "dispatching_base_num",
155:             "request_datetime",
156:             "pickup_datetime",
157:             "dropoff_datetime",
158:             "pickup_location_id",
159:             "dropoff_location_id",
160:             "trip_miles",
161:             "base_passenger_fare",
162:         ],
163:     )
164:     rules = common_rules(df, context, quality, quality.fhv_max_duration_hours)
165:     rules.extend(
166:         [
167:             Rule(
168:                 "MISSING_HVFHS_LICENSE",
169:                 "ERROR",
170:                 F.col("hvfhs_license_num").isNull()
171:                 | (F.length("hvfhs_license_num") == 0),
172:             ),
173:             Rule(
174:                 "UNKNOWN_HVFHS_LICENSE",
175:                 "WARNING",
176:                 F.col("hvfhs_license_num").isNotNull()
177:                 & F.col("hvfhs_company_name").isNull(),
178:             ),
179:             Rule(
180:                 "MISSING_DISPATCHING_BASE",
181:                 "ERROR",
182:                 F.col("dispatching_base_num").isNull()
183:                 | (F.length("dispatching_base_num") == 0),
184:             ),
185:             Rule(
186:                 "REQUEST_AFTER_PICKUP",
187:                 "ERROR",
188:                 F.col("request_datetime").isNull()
189:                 | (F.col("request_datetime") > F.col("pickup_datetime")),
190:             ),
191:             Rule(
192:                 "ON_SCENE_AFTER_PICKUP",
193:                 "WARNING",
194:                 F.col("on_scene_datetime").isNotNull()
195:                 & (F.col("on_scene_datetime") > F.col("pickup_datetime")),
196:             ),
197:             Rule(
198:                 "NEGATIVE_REQUEST_TO_PICKUP",
199:                 "ERROR",
200:                 F.col("request_to_pickup_seconds") < 0,
201:             ),
202:             Rule(
203:                 "NEGATIVE_DRIVER_WAIT",
204:                 "WARNING",
205:                 F.col("driver_wait_seconds") < 0,
206:             ),
207:             Rule(
208:                 "INVALID_TRIP_MILES",
209:                 "ERROR",
210:                 F.col("trip_miles").isNull()
211:                 | (F.col("trip_miles") < 0)
212:                 | (F.col("trip_miles") > quality.max_trip_distance_miles),
213:             ),
214:             Rule(
215:                 "INVALID_TRIP_TIME",
216:                 "ERROR",
217:                 F.col("trip_time").isNull() | (F.col("trip_time") <= 0),
218:             ),
219:             Rule(
220:                 "TRIP_TIME_MISMATCH",
221:                 "WARNING",
222:                 F.abs(F.col("trip_time") - F.col("trip_duration_seconds")) > 600,
223:             ),
224:             Rule(
225:                 "SHARED_MATCH_WITHOUT_REQUEST",
226:                 "WARNING",
227:                 F.col("shared_matched").eqNullSafe(F.lit(True))
228:                 & F.col("shared_requested").eqNullSafe(F.lit(False)),
229:             ),
230:             Rule(
231:                 "WAV_MATCH_WITHOUT_REQUEST",
232:                 "WARNING",
233:                 F.col("wav_matched").eqNullSafe(F.lit(True))
234:                 & F.col("wav_requested").eqNullSafe(F.lit(False)),
235:             ),
236:         ]
237:     )
238:     for name in flag_aliases:
239:         rules.append(
240:             Rule(
241:                 f"INVALID_{name.upper()}",
242:                 "WARNING",
243:                 F.col(f"{name}_raw").isNotNull()
244:                 & ~F.col(f"{name}_raw").isin(*quality.allowed_boolean_flags),
245:             )
246:         )
247:     negative = [
248:         F.when(F.col(name) < 0, F.lit(1)).otherwise(F.lit(0)) for name in money
249:     ]
250:     rules.append(
251:         Rule("NEGATIVE_FINANCIAL_AMOUNT", "ERROR", F.greatest(*negative) == 1)
252:     )
253:     return apply_rules(df, rules).drop(
254:         *[f"{name}_raw" for name in flag_aliases]
255:     )
