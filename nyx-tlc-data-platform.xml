  9: def _service_key() -> Any:
 10:     from pyspark.sql import functions as F
 11: 
 12:     expression = F.lit(None).cast("int")
 13:     for service, key in reversed(list(SERVICE_KEYS.items())):
 14:         expression = F.when(F.col("service_type") == service, F.lit(key)).otherwise(expression)
 15:     return expression
