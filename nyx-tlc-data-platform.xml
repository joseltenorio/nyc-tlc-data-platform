 60: def _infer_layer(path: Path, payload: dict[str, Any], summary: dict[str, Any]) -> str:
 61:     declared = str(summary.get("layer") or payload.get("layer") or "").lower()
 62:     if declared:
 63:         if declared.startswith("silver"):
 64:             return "silver"
 65:         if declared.startswith("gold"):
 66:             return "gold"
 67:         if declared.startswith("ml"):
 68:             return "ml"
 69:         if declared.startswith("bronze"):
 70:             return "bronze"
 71:     parts = {part.lower() for part in path.parts}
 72:     if "silver" in parts:
 73:         return "silver"
 74:     if "gold" in parts:
 75:         return "gold"
 76:     if "ml" in parts:
 77:         return "ml"
 78:     return "bronze"
 79: 
 80: 
 81: def _first_number(summary: dict[str, Any], names: Iterable[str]) -> float | None:
 82:     for name in names:
 83:         value = summary.get(name)
 84:         if value is None:
 85:             continue
 86:         try:
 87:             return float(value)
 88:         except (TypeError, ValueError):
 89:             continue
 90:     return None
