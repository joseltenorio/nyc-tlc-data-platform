 26: def _json_safe(value: Any) -> Any:
 27:     if value is None or isinstance(value, (str, bool, int)):
 28:         return value
 29:     if isinstance(value, float):
 30:         return value if math.isfinite(value) else None
 31:     if isinstance(value, (datetime, date)):
 32:         return value.isoformat()
 33:     if isinstance(value, Path):
 34:         return str(value)
 35:     if isinstance(value, Decimal):
 36:         return str(value)
 37:     if isinstance(value, UUID):
 38:         return str(value)
 39:     if isinstance(value, Enum):
 40:         return _json_safe(value.value)
 41:     if is_dataclass(value):
 42:         return _json_safe(asdict(value))
 43:     if isinstance(value, dict):
 44:         return {str(key): _json_safe(item) for key, item in value.items()}
 45:     if isinstance(value, (list, tuple, set)):
 46:         return [_json_safe(item) for item in value]
 47:     as_py = getattr(value, "as_py", None)
 48:     if callable(as_py):
 49:         return _json_safe(as_py())
 50:     scalar = getattr(value, "item", None)
 51:     if callable(scalar):
 52:         return _json_safe(scalar())
 53:     to_dict = getattr(value, "to_dict", None)
 54:     if callable(to_dict):
 55:         return _json_safe(to_dict())
 56:     raise TypeError(f"Tipo no serializable en auditoría JSONL: {type(value).__name__}")
