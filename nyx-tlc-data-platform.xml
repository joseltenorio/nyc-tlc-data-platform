 574:     def _validate_and_publish(
 575:         self,
 576:         result: DownloadResult,
 577:         existing: dict[str, Any] | None,
 578:         execution_id: str,
 579:         spark: Any,
 580:         audit: AuditRepositories,
 581:         *,
 582:         spark_guard: Any | None = None,
 583:     ) -> FileOutcome:
 584:         candidate = result.candidate
 585:         outcome = FileOutcome(
 586:             candidate=candidate,
 587:             status="VALIDATING",
 588:             remote_metadata=result.remote_metadata,
 589:             bytes_downloaded=result.bytes_downloaded,
 590:             sha256=result.sha256,
 591:             attempt_count=result.attempt_count,
 592:             retry_count=result.retry_count,
 593:             download_started_at=result.download_started_at,
 594:             download_finished_at=result.download_finished_at,
 595:             download_duration_seconds=result.download_duration_seconds,
 596:             throughput_bytes_per_second=result.throughput_bytes_per_second,
 597:         )
 598:         current = (existing or {}).get("current") or {}
 599:         previous_sha = current.get("sha256")
 600:         destination = self._storage.final_path(candidate)
 601: 
 602:         try:
 603:             audit.registry.set_status(candidate, execution_id, "VALIDATING")
 604:             if previous_sha == result.sha256 and destination.is_file():
 605:                 result.path.unlink(missing_ok=True)
 606:                 outcome.status = "SKIPPED_UNCHANGED"
 607:                 outcome.local_path = str(destination)
 608:                 outcome.finish()
 609:                 audit.registry.release_claim(candidate, execution_id)
 610:                 return outcome
 611: 
 612:             def validation_action() -> Any:
 613:                 return self._validator.validate(result.path, candidate, spark)
 614:             validation = (
 615:                 spark_guard.run(validation_action)
 616:                 if spark_guard is not None
 617:                 else validation_action()
 618:             )
 619:             final_path, archived_path = self._storage.promote(
 620:                 result.path,
 621:                 candidate,
 622:                 previous_sha256=previous_sha,
 623:                 new_sha256=result.sha256,
 624:             )
 625:             outcome.validation = validation
 626:             outcome.local_path = str(final_path)
 627:             outcome.archived_previous_path = (
 628:                 str(archived_path) if archived_path is not None else None
 629:             )
 630:             outcome.status = "READY"
 631:             outcome.finish()
 632: 
 633:             if archived_path is not None:
 634:                 audit.versions.mark_archived(
 635:                     candidate.service,
 636:                     candidate.year,
 637:                     candidate.month,
 638:                     previous_sha,
 639:                     str(archived_path),
 640:                     execution_id,
 641:                 )
 642:             audit.versions.insert_current(outcome, execution_id)
 643:             audit.registry.mark_ready(outcome, execution_id)
 644:             return outcome
 645:         except Exception as exc:
 646:             result.path.unlink(missing_ok=True)
 647:             outcome.status = "FAILED"
 648:             outcome.error_type = type(exc).__name__
 649:             outcome.error_message = str(exc)
 650:             outcome.finish()
 651:             audit.registry.mark_failed(outcome, execution_id)
 652:             return outcome
