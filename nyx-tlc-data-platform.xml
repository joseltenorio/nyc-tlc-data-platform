  1: from __future__ import annotations
  2: 
  3: from typing import Any
  4: 
  5: 
  6: # Gold owns feature engineering that is deterministic and reusable. Model-only
  7: # operations (algorithm fitting, threshold selection and metrics) remain in ML.
  8: 
  9: 
 10: def _add_exact_lag(frame: Any, hours: int, output_name: str) -> Any:
 11:     """Joins the value observed at the exact same zone/service N hours before.
 12: 
 13:     A normal row-based `lag()` would incorrectly use the previous available row
 14:     when an inactive zone has gaps. This timestamp join preserves the meaning of
 15:     "24 hours ago" and leaves the value null when no observation exists.
 16:     """
 17:     from pyspark.sql import functions as F
 18: 
 19:     keys = ["pickup_location_id", "service_type"]
 20:     previous = frame.select(
 21:         *keys,
 22:         F.expr(f"event_timestamp + INTERVAL {hours} HOURS").alias("event_timestamp"),
 23:         F.col("trip_count").alias(output_name),
 24:     )
 25:     return frame.join(previous, [*keys, "event_timestamp"], "left")
 26: 
 27: 
 28: def build_zone_hourly_demand_features(trip_activity: Any, dim_zone: Any) -> Any:
 29:     """Builds the revised forecast grain: zone + hour + service.
 30: 
 31:     The former daily/service dataset was too coarse for a mobility case. This
 32:     table supports future maps and rankings of expected demand by TLC zone.
 33:     """
 34:     from pyspark.sql import Window
 35:     from pyspark.sql import functions as F
 36: 
 37:     zones = dim_zone.select(
 38:         F.col("zone_key").alias("pickup_location_id"),
 39:         F.col("zone_name").alias("pickup_zone_name"),
 40:         F.col("borough").alias("pickup_borough"),
 41:         F.col("is_airport").alias("airport_zone_flag"),
 42:     )
 43:     demand = (
 44:         trip_activity.groupBy(
 45:             F.date_trunc("hour", "pickup_datetime").alias("event_timestamp"),
 46:             F.col("pickup_zone_key").alias("pickup_location_id"),
 47:             "service_type",
 48:         )
 49:         .agg(F.sum("trip_count").cast("double").alias("trip_count"))
 50:         .join(zones, "pickup_location_id", "left")
 51:     )
 52: 
 53:     for hours, name in (
 54:         (1, "lag_1_hour"),
 55:         (2, "lag_2_hours"),
 56:         (24, "lag_24_hours"),
 57:         (48, "lag_48_hours"),
 58:         (168, "lag_168_hours"),
 59:     ):
 60:         demand = _add_exact_lag(demand, hours, name)
 61: 
 62:     order_seconds = F.col("event_timestamp").cast("long")
 63:     partition = ["pickup_location_id", "service_type"]
 64:     for hours, name in (
 65:         (6, "rolling_mean_6h"),
 66:         (24, "rolling_mean_24h"),
 67:         (168, "rolling_mean_168h"),
 68:     ):
 69:         window = (
 70:             Window.partitionBy(*partition)
 71:             .orderBy(order_seconds)
 72:             .rangeBetween(-hours * 3600, -1)
 73:         )
 74:         demand = demand.withColumn(name, F.avg("trip_count").over(window))
 75: 
 76:     std_window = (
 77:         Window.partitionBy(*partition)
 78:         .orderBy(order_seconds)
 79:         .rangeBetween(-24 * 3600, -1)
 80:     )
 81:     return (
 82:         demand.withColumn("rolling_stddev_24h", F.stddev_pop("trip_count").over(std_window))
 83:         .withColumn("same_hour_previous_day", F.col("lag_24_hours"))
 84:         .withColumn("same_hour_previous_week", F.col("lag_168_hours"))
 85:         .withColumn("event_date", F.to_date("event_timestamp"))
 86:         .withColumn("event_hour", F.hour("event_timestamp"))
 87:         .withColumn("hour_of_day", F.hour("event_timestamp"))
 88:         .withColumn("day_of_week", F.dayofweek("event_timestamp"))
 89:         .withColumn("month", F.month("event_timestamp"))
 90:         .withColumn("is_weekend", F.dayofweek("event_timestamp").isin(1, 7))
 91:         .withColumn("is_peak_hour", F.hour("event_timestamp").isin(7, 8, 9, 16, 17, 18, 19))
 92:         .select(
 93:             "event_date",
 94:             "event_hour",
 95:             "event_timestamp",
 96:             "pickup_location_id",
 97:             "pickup_zone_name",
 98:             "pickup_borough",
 99:             "service_type",
100:             "trip_count",
101:             "lag_1_hour",
102:             "lag_2_hours",
103:             "lag_24_hours",
104:             "lag_48_hours",
105:             "lag_168_hours",
106:             "rolling_mean_6h",
107:             "rolling_mean_24h",
108:             "rolling_mean_168h",
109:             "rolling_stddev_24h",
110:             "same_hour_previous_day",
111:             "same_hour_previous_week",
112:             "hour_of_day",
113:             "day_of_week",
114:             "month",
115:             "is_weekend",
116:             "is_peak_hour",
117:             "airport_zone_flag",
118:         )
119:     )
120: 
121: 
122: def build_zone_profile_features(
123:     trip_activity: Any,
124:     hvfhv_operations: Any,
125:     dim_zone: Any,
126: ) -> Any:
127:     """Creates one behavioral profile per TLC pickup zone for K-Means."""
128:     from pyspark.sql import functions as F
129: 
130:     pickup = trip_activity.groupBy(F.col("pickup_zone_key").alias("zone_key")).agg(
131:         F.sum("trip_count").alias("total_pickups"),
132:         F.avg("trip_duration_seconds").alias("average_duration_seconds"),
133:         F.avg("trip_distance_miles").alias("average_distance_miles"),
134:         F.avg("average_speed_mph").alias("average_speed_mph"),
135:         F.avg(F.col("night_trip_flag").cast("double")).alias("night_trip_share"),
136:         F.avg(F.col("weekend_trip_flag").cast("double")).alias("weekend_trip_share"),
137:         F.avg(F.col("airport_trip_flag").cast("double")).alias("airport_trip_share"),
138:         F.sum(F.when(F.col("service_type") == "yellow", F.col("trip_count")).otherwise(0)).alias("yellow_trips"),
139:         F.sum(F.when(F.col("service_type") == "green", F.col("trip_count")).otherwise(0)).alias("green_trips"),
140:         F.sum(F.when(F.col("service_type") == "fhv", F.col("trip_count")).otherwise(0)).alias("fhv_trips"),
141:         F.sum(F.when(F.col("service_type") == "fhvhv", F.col("trip_count")).otherwise(0)).alias("fhvhv_trips"),
142:         F.countDistinct("service_type").alias("service_diversity"),
143:     )
144:     dropoff = trip_activity.groupBy(F.col("dropoff_zone_key").alias("zone_key")).agg(
145:         F.sum("trip_count").alias("total_dropoffs")
146:     )
147:     hourly = trip_activity.groupBy(
148:         F.col("pickup_zone_key").alias("zone_key"),
149:         F.date_trunc("hour", "pickup_datetime").alias("event_hour"),
150:     ).agg(F.sum("trip_count").alias("hourly_trip_count"))
151:     variability = hourly.groupBy("zone_key").agg(
152:         F.count("event_hour").alias("active_hours"),
153:         F.stddev_pop("hourly_trip_count").alias("demand_stddev"),
154:         F.avg("hourly_trip_count").alias("average_hourly_demand"),
155:     ).withColumn(
156:         "demand_coefficient_of_variation",
157:         F.when(
158:             F.col("average_hourly_demand") > 0,
159:             F.col("demand_stddev") / F.col("average_hourly_demand"),
160:         ),
161:     )
162:     wait = hvfhv_operations.groupBy(F.col("pickup_zone_key").alias("zone_key")).agg(
163:         F.avg("request_to_pickup_seconds").alias("average_request_to_pickup_seconds"),
164:         F.avg(F.col("shared_matched").cast("double")).alias("shared_match_share"),
165:         F.avg(F.col("wav_matched").cast("double")).alias("wav_match_share"),
166:     )
167:     zones = dim_zone.select(
168:         "zone_key", "location_id", "zone_name", "borough", "service_zone", "is_airport"
169:     )
170: 
171:     result = (
172:         zones.join(pickup, "zone_key", "left")
173:         .join(dropoff, "zone_key", "left")
174:         .join(variability, "zone_key", "left")
175:         .join(wait, "zone_key", "left")
176:         .fillna(
177:             0,
178:             subset=[
179:                 "total_pickups",
180:                 "total_dropoffs",
181:                 "yellow_trips",
182:                 "green_trips",
183:                 "fhv_trips",
184:                 "fhvhv_trips",
185:                 "service_diversity",
186:                 "active_hours",
187:             ],
188:         )
189:     )
190:     for service in ("yellow", "green", "fhv", "fhvhv"):
191:         result = result.withColumn(
192:             f"{service}_share",
193:             F.when(F.col("total_pickups") > 0, F.col(f"{service}_trips") / F.col("total_pickups")).otherwise(0.0),
194:         )
195:     return result.drop("yellow_trips", "green_trips", "fhv_trips", "fhvhv_trips")
196: 
197: 
198: def build_hvfhv_wait_features(hvfhv_operations: Any, dim_zone: Any) -> Any:
199:     """Selects only information available when an HVFHV trip is requested.
200: 
201:     Post-pickup outcomes such as trip duration, driver wait, fare and driver pay
202:     are deliberately excluded from the predictor table to prevent target leakage.
203:     The observed request-to-pickup time is retained only as the training target.
204:     """
205:     from pyspark.sql import functions as F
206: 
207:     zones = dim_zone.select(
208:         F.col("zone_key").alias("pickup_zone_key"),
209:         F.col("zone_name").alias("pickup_zone_name"),
210:         F.col("borough").alias("pickup_borough"),
211:         F.col("is_airport").alias("airport_zone_flag"),
212:     )
213:     return (
214:         hvfhv_operations.join(zones, "pickup_zone_key", "left")
215:         .filter(
216:             F.col("request_datetime").isNotNull()
217:             & F.col("request_to_pickup_seconds").isNotNull()
218:             & (F.col("request_to_pickup_seconds") >= 0)
219:         )
220:         .select(
221:             "trip_key",
222:             "request_datetime",
223:             F.hour("request_datetime").alias("request_hour"),
224:             F.dayofweek("request_datetime").alias("request_day_of_week"),
225:             F.month("request_datetime").alias("request_month"),
226:             F.dayofweek("request_datetime").isin(1, 7).alias("is_weekend"),
227:             F.hour("request_datetime").isin(7, 8, 9, 16, 17, 18, 19).alias("is_peak_hour"),
228:             "pickup_zone_key",
229:             "pickup_zone_name",
230:             "pickup_borough",
231:             "airport_zone_flag",
232:             "provider_key",
233:             "hvfhs_license_num",
234:             "hvfhs_company_name",
235:             F.coalesce("shared_requested", F.lit(False)).alias("shared_requested"),
236:             F.coalesce("access_a_ride", F.lit(False)).alias("access_a_ride"),
237:             F.coalesce("wav_requested", F.lit(False)).alias("wav_requested"),
238:             "request_to_pickup_seconds",
239:             "source_year",
240:             "source_month",
241:         )
242:     )
