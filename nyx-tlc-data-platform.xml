<file path="scripts/configure-wsl.ps1">
 1: [CmdletBinding()]
 2: param(
 3:     [ValidateRange(4, 64)]
 4:     [int]$MemoryGB = 8,
 5: 
 6:     [ValidateRange(1, 32)]
 7:     [int]$Processors = 4,
 8: 
 9:     [ValidateRange(0, 16)]
10:     [int]$SwapGB = 2
11: )
12: 
13: $ErrorActionPreference = "Stop"
14: $configPath = Join-Path $env:USERPROFILE ".wslconfig"
15: $content = @"
16: [wsl2]
17: memory=${MemoryGB}GB
18: processors=$Processors
19: swap=${SwapGB}GB
20: localhostForwarding=true
21: 
22: [experimental]
23: autoMemoryReclaim=gradual
24: "@
25: 
26: Set-Content -Path $configPath -Value $content -Encoding ASCII
27: Write-Host "Configuración WSL guardada en $configPath" -ForegroundColor Green
28: Write-Host "RAM: ${MemoryGB} GB | CPU: $Processors | Swap: ${SwapGB} GB" -ForegroundColor Cyan
29: 
30: # Docker Desktop debe estar cerrado para que el apagado sea limpio.
31: wsl --shutdown
32: Write-Host "WSL detenido. Abre Docker Desktop nuevamente para aplicar los límites." -ForegroundColor Green
</file>

<file path="scripts/run-all.ps1">
  1: [CmdletBinding()]
  2: param(
  3:     [ValidateSet("historical", "incremental", "all")]
  4:     [string]$Mode = "all",
  5: 
  6:     [switch]$SkipML,
  7: 
  8:     # 0 aplica un mínimo conservador según el modo.
  9:     [int]$MinimumFreeGB = 0,
 10: 
 11:     # El pipeline se diseñó para una VM WSL limitada. Aumentar este valor es
 12:     # explícito, no accidental.
 13:     [ValidateRange(4, 64)]
 14:     [int]$MaximumWSLMemoryGB = 8,
 15: 
 16:     [ValidateRange(1, 32)]
 17:     [int]$MaximumWSLProcessors = 4
 18: )
 19: 
 20: $ErrorActionPreference = "Stop"
 21: $projectRoot = Split-Path -Parent $PSScriptRoot
 22: Set-Location $projectRoot
 23: 
 24: function Assert-WSLSafety {
 25:     $wslConfig = Join-Path $env:USERPROFILE ".wslconfig"
 26:     if (-not (Test-Path $wslConfig)) {
 27:         throw "No existe $wslConfig. Ejecuta una vez: .\scripts\configure-wsl.ps1"
 28:     }
 29: 
 30:     $content = Get-Content $wslConfig -Raw
 31:     $memoryMatch = [regex]::Match($content, "(?im)^memory\s*=\s*(\d+)GB\s*$")
 32:     $processorMatch = [regex]::Match($content, "(?im)^processors\s*=\s*(\d+)\s*$")
 33:     if (-not $memoryMatch.Success -or -not $processorMatch.Success) {
 34:         throw ".wslconfig debe declarar memory=<n>GB y processors=<n>. Ejecuta .\scripts\configure-wsl.ps1"
 35:     }
 36: 
 37:     $memoryGB = [int]$memoryMatch.Groups[1].Value
 38:     $processors = [int]$processorMatch.Groups[1].Value
 39:     if ($memoryGB -gt $MaximumWSLMemoryGB) {
 40:         throw "WSL tiene $memoryGB GB; el máximo autorizado por este comando es $MaximumWSLMemoryGB GB."
 41:     }
 42:     if ($processors -gt $MaximumWSLProcessors) {
 43:         throw "WSL tiene $processors procesadores; el máximo autorizado es $MaximumWSLProcessors."
 44:     }
 45: 
 46:     Write-Host "WSL seguro: ${memoryGB} GB RAM, $processors CPU." -ForegroundColor DarkGray
 47: }
 48: 
 49: function Assert-DockerReady {
 50:     & docker info *> $null
 51:     if ($LASTEXITCODE -ne 0) {
 52:         throw "Docker Desktop no está disponible. Ábrelo y espera a que el motor esté listo."
 53:     }
 54: }
 55: 
 56: function Get-FreeSpaceGB {
 57:     $driveName = [System.IO.Path]::GetPathRoot($projectRoot).Substring(0, 1)
 58:     $drive = Get-PSDrive -Name $driveName
 59:     return [math]::Round($drive.Free / 1GB, 2)
 60: }
 61: 
 62: function Assert-FreeSpace([int]$RequiredGB, [string]$Stage) {
 63:     $freeGB = Get-FreeSpaceGB
 64:     if ($freeGB -lt $RequiredGB) {
 65:         throw "Espacio libre insuficiente antes de $($Stage): $freeGB GB. Se requieren al menos $RequiredGB GB."
 66:     }
 67:     Write-Host "Espacio libre antes de $($Stage): $freeGB GB" -ForegroundColor DarkGray
 68: }
 69: 
 70: function Clear-SparkTemporaryData {
 71:     $sparkTmp = Join-Path $projectRoot "data\tmp\spark"
 72:     if (Test-Path $sparkTmp) {
 73:         Get-ChildItem $sparkTmp -Force -ErrorAction SilentlyContinue |
 74:             Remove-Item -Recurse -Force -ErrorAction SilentlyContinue
 75:     }
 76: }
 77: 
 78: $requiredFreeGB = if ($MinimumFreeGB -gt 0) {
 79:     $MinimumFreeGB
 80: } elseif ($Mode -eq "incremental") {
 81:     80
 82: } else {
 83:     250
 84: }
 85: 
 86: Assert-WSLSafety
 87: Assert-DockerReady
 88: Assert-FreeSpace $requiredFreeGB "iniciar la plataforma"
 89: New-Item -ItemType Directory -Force -Path ".\data\tmp\spark" | Out-Null
 90: 
 91: $compose = @("compose", "-f", "docker-compose.yml", "-f", "docker-compose.dashboard.yml")
 92: 
 93: # Un dashboard anterior puede consumir hasta 2 GB. Se detiene antes del build y
 94: # durante todas las acciones Spark; vuelve a levantarse incluso si una capa falla.
 95: & docker @compose stop dashboard 2>$null
 96: 
 97: Write-Host "[1/5] Construyendo imagen de pipeline y dashboard..." -ForegroundColor Cyan
 98: & docker @compose build pipeline dashboard
 99: if ($LASTEXITCODE -ne 0) { throw "Falló docker compose build." }
100: 
101: Write-Host "[2/5] Iniciando MongoDB..." -ForegroundColor Cyan
102: & docker @compose up -d mongodb
103: if ($LASTEXITCODE -ne 0) { throw "Falló el inicio de MongoDB." }
104: 
105: $pipelineFailure = $null
106: try {
107:     if ($Mode -in @("historical", "all")) {
108:         Assert-FreeSpace $requiredFreeGB "Bronze -> Silver -> Gold -> ML histórico"
109:         Write-Host "[3/5] Ejecutando alcance histórico" -ForegroundColor Cyan
110:         $historicalArgs = @("run", "--rm", "pipeline", "platform-historical")
111:         if ($SkipML) { $historicalArgs += "--no-train-ml" }
112:         & docker @compose @historicalArgs
113:         if ($LASTEXITCODE -ne 0) {
114:             throw "Falló platform-historical. Revisa auditoría y manifiestos; Gold/ML no publican salidas incompletas."
115:         }
116:         Clear-SparkTemporaryData
117:     }
118: 
119:     if ($Mode -in @("incremental", "all")) {
120:         Assert-FreeSpace 80 "actualización incremental 2026"
121:         Write-Host "[4/5] Ejecutando 2026 disponible para Yellow, Green y FHV..." -ForegroundColor Cyan
122:         & docker @compose run --rm pipeline platform-incremental --no-train-ml
123:         if ($LASTEXITCODE -ne 0) {
124:             throw "Falló platform-incremental. Revisa auditoría y manifiestos."
125:         }
126:         Clear-SparkTemporaryData
127:     }
128: }
129: catch {
130:     $pipelineFailure = $_
131: }
132: finally {
133:     # El spill queda en el bind mount data/tmp/spark, no oculto en docker_data.vhdx.
134:     Clear-SparkTemporaryData
135: }
136: 
137: Write-Host "[5/5] Iniciando Streamlit..." -ForegroundColor Cyan
138: & docker @compose up -d dashboard
139: if ($LASTEXITCODE -ne 0) { throw "Falló el inicio del dashboard." }
140: 
141: Write-Host "Dashboard disponible en http://localhost:8501" -ForegroundColor Green
142: if ($null -ne $pipelineFailure) {
143:     throw $pipelineFailure
144: }
145: Write-Host "Pipeline finalizado correctamente." -ForegroundColor Green
</file>

