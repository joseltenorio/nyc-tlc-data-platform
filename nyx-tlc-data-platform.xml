242: @st.cache_data(ttl=60, show_spinner=False)
243: def _load_manifests_cached(root_text: str, signature: tuple[int, int]) -> ManifestAuditData:
244:     del signature
245:     root = Path(root_text)
246:     rows: list[dict[str, Any]] = []
247:     errors: list[dict[str, Any]] = []
248:     if root.is_dir():
249:         for path in sorted(root.rglob("*.json")):
250:             try:
251:                 row, manifest_errors = _normalize_manifest(path, root)
252:             except (OSError, json.JSONDecodeError, TypeError, ValueError):
253:                 continue
254:             rows.append(row)
255:             errors.extend(manifest_errors)
256:     runs = pd.DataFrame(rows, columns=RUN_COLUMNS)
257:     if not runs.empty:
258:         runs = runs.sort_values("started_at", ascending=False, na_position="last").reset_index(drop=True)
259:     error_frame = pd.DataFrame(errors)
260:     return ManifestAuditData(runs=runs, errors=error_frame)
