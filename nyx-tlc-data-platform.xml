  1: from __future__ import annotations
  2: 
  3: import os
  4: import time
  5: from datetime import datetime, timezone
  6: from pathlib import Path
  7: from typing import Any, Callable
  8: 
  9: import requests
 10: 
 11: from tlc_data_platform.bronze.models import DownloadResult, FileCandidate, RemoteMetadata
 12: from tlc_data_platform.bronze.storage import BronzeStorage
 13: from tlc_data_platform.core.exceptions import DownloadError, InsufficientDiskSpaceError
 14: from tlc_data_platform.core.settings import DownloadConfig
 15: from tlc_data_platform.ingestion.checksum import calculate_sha256
 16: from tlc_data_platform.ingestion.http_client import HttpClient
 17: 
 18: 
 19: def has_parquet_signature(path: Path) -> bool:
 20:     if not path.is_file() or path.stat().st_size < 8:
 21:         return False
 22:     with path.open("rb") as handle:
 23:         start = handle.read(4)
 24:         handle.seek(-4, os.SEEK_END)
 25:         end = handle.read(4)
 26:     return start == b"PAR1" and end == b"PAR1"
 27: 
 28: 
 29: def response_metadata(response: Any) -> RemoteMetadata:
 30:     content_length = response.headers.get("Content-Length")
 31:     return RemoteMetadata(
 32:         available=response.status_code in {200, 206},
 33:         status_code=response.status_code,
 34:         content_length=int(content_length)
 35:         if content_length and content_length.isdigit()
 36:         else None,
 37:         etag=response.headers.get("ETag"),
 38:         last_modified=response.headers.get("Last-Modified"),
 39:         content_type=response.headers.get("Content-Type"),
 40:     )
 41: 
 42: 
 43: class FileDownloader:
 44:     """Downloads one complete Parquet with five bounded whole-file retries.
 45: 
 46:     Retries cover the HTTP request *and* streamed transfer. This is deliberately
 47:     separate from discovery/probe retries: a broken stream, HTTP 202, 403, 429 or
 48:     transient 5xx response must restart the complete `.part` file rather than
 49:     leave a partial download that later fails validation.
 50:     """
 51: 
 52:     DOWNLOAD_RETRYABLE_STATUS_CODES = HttpClient.RETRYABLE_STATUS_CODES | {202, 403}
 53: 
 54:     def __init__(
 55:         self,
 56:         http: HttpClient,
 57:         storage: BronzeStorage,
 58:         config: DownloadConfig,
 59:     ) -> None:
 60:         self._http = http
 61:         self._storage = storage
 62:         self._config = config
 63: 
 64:     def download(
 65:         self,
 66:         candidate: FileCandidate,
 67:         execution_id: str,
 68:         remote_metadata: RemoteMetadata,
 69:         attempt_callback: Callable[[dict[str, Any]], None] | None = None,
 70:     ) -> DownloadResult:
 71:         temporary = self._storage.temporary_path(candidate, execution_id)
 72:         temporary.parent.mkdir(parents=True, exist_ok=True)
 73:         temporary.unlink(missing_ok=True)
 74: 
 75:         max_attempts = self._config.max_retries + 1
 76:         backoff = self._config.initial_backoff_seconds
 77:         last_error: Exception | None = None
 78:         download_started_at = datetime.now(timezone.utc)
 79:         download_started_perf = time.perf_counter()
 80: 
 81:         for attempt in range(1, max_attempts + 1):
 82:             self._assert_disk_space(remote_metadata)
 83:             response: Any | None = None
 84:             temporary.unlink(missing_ok=True)
 85:             attempt_started_at = datetime.now(timezone.utc)
 86:             attempt_started_perf = time.perf_counter()
 87:             try:
 88:                 # FileDownloader owns the retry loop. Disable HttpClient's inner
 89:                 # retries so one audit event equals one complete transfer attempt.
 90:                 response = self._http.request(
 91:                     "GET",
 92:                     candidate.url,
 93:                     stream=True,
 94:                     allow_redirects=True,
 95:                     retryable_status_codes=set(),
 96:                     max_retries_override=0,
 97:                 )
 98:                 status_code = int(response.status_code)
 99:                 if status_code in self.DOWNLOAD_RETRYABLE_STATUS_CODES:
100:                     error = requests.HTTPError(
101:                         f"HTTP temporal {status_code} durante la descarga",
102:                         response=response,
103:                     )
104:                     raise error
105:                 response.raise_for_status()
106:                 if status_code not in {200, 206}:
107:                     raise DownloadError(
108:                         f"Estado HTTP inesperado durante la descarga: {status_code}"
109:                     )
110: 
111:                 content_type = (response.headers.get("Content-Type") or "").lower()
112:                 effective_remote_metadata = response_metadata(response)
113:                 if "text/html" in content_type:
114:                     raise DownloadError("El servidor devolvió HTML en lugar de Parquet")
115: 
116:                 with temporary.open("wb") as handle:
117:                     for chunk in response.iter_content(self._config.chunk_size_bytes):
118:                         if chunk:
119:                             handle.write(chunk)
120:                     handle.flush()
121:                     os.fsync(handle.fileno())
122: 
123:                 size = temporary.stat().st_size
124:                 self._validate_download(
125:                     temporary,
126:                     size=size,
127:                     content_type=content_type,
128:                     expected_size=remote_metadata.content_length,
129:                 )
130:                 sha256 = (
131:                     calculate_sha256(temporary)
132:                     if self._config.calculate_sha256
133:                     else ""
134:                 )
135:                 attempt_finished_at = datetime.now(timezone.utc)
136:                 attempt_duration = max(0.0, time.perf_counter() - attempt_started_perf)
137:                 attempt_throughput = size / attempt_duration if attempt_duration > 0 else None
138:                 self._emit_attempt(
139:                     attempt_callback,
140:                     attempt_number=attempt,
141:                     max_attempts=max_attempts,
142:                     outcome="SUCCESS",
143:                     status_code=status_code,
144:                     started_at=attempt_started_at,
145:                     finished_at=attempt_finished_at,
146:                     duration_seconds=attempt_duration,
147:                     bytes_downloaded=size,
148:                     expected_bytes=remote_metadata.content_length,
149:                     throughput_bytes_per_second=attempt_throughput,
150:                 )
151:                 download_finished_at = attempt_finished_at
152:                 download_duration = max(0.0, time.perf_counter() - download_started_perf)
153:                 return DownloadResult(
154:                     candidate=candidate,
155:                     path=temporary,
156:                     bytes_downloaded=size,
157:                     sha256=sha256,
158:                     remote_metadata=effective_remote_metadata,
159:                     attempt_count=attempt,
160:                     retry_count=attempt - 1,
161:                     download_started_at=download_started_at,
162:                     download_finished_at=download_finished_at,
163:                     download_duration_seconds=download_duration,
164:                     throughput_bytes_per_second=(
165:                         size / download_duration if download_duration > 0 else None
166:                     ),
167:                 )
168:             except Exception as exc:
169:                 last_error = exc
170:                 retryable = self._is_retryable_transfer_error(exc)
171:                 final = attempt == max_attempts or not retryable
172:                 delay = None
173:                 if not final:
174:                     delay = self._retry_delay(response, backoff)
175:                 attempt_finished_at = datetime.now(timezone.utc)
176:                 attempt_duration = max(0.0, time.perf_counter() - attempt_started_perf)
177:                 partial_bytes = temporary.stat().st_size if temporary.is_file() else 0
178:                 self._emit_attempt(
179:                     attempt_callback,
180:                     attempt_number=attempt,
181:                     max_attempts=max_attempts,
182:                     outcome="EXHAUSTED" if final else "RETRY",
183:                     status_code=(
184:                         int(response.status_code)
185:                         if response is not None
186:                         and getattr(response, "status_code", None) is not None
187:                         else None
188:                     ),
189:                     retry_delay_seconds=delay,
190:                     error_type=type(exc).__name__,
191:                     error_message=str(exc)[:2000],
192:                     started_at=attempt_started_at,
193:                     finished_at=attempt_finished_at,
194:                     duration_seconds=attempt_duration,
195:                     bytes_downloaded=partial_bytes,
196:                     expected_bytes=remote_metadata.content_length,
197:                     throughput_bytes_per_second=(
198:                         partial_bytes / attempt_duration if attempt_duration > 0 else None
199:                     ),
200:                 )
201:                 temporary.unlink(missing_ok=True)
202:                 if final:
203:                     setattr(exc, "attempt_count", attempt)
204:                     setattr(exc, "retry_count", attempt - 1)
205:                     setattr(exc, "download_started_at", download_started_at)
206:                     setattr(exc, "download_finished_at", attempt_finished_at)
207:                     setattr(
208:                         exc,
209:                         "download_duration_seconds",
210:                         max(0.0, time.perf_counter() - download_started_perf),
211:                     )
212:                     raise
213:                 time.sleep(float(delay or 0.0))
214:                 backoff = min(
215:                     backoff * 2, self._config.max_backoff_seconds
216:                 )
217:             finally:
218:                 if response is not None:
219:                     response.close()
220: 
221:         # Defensive fallback; the loop always returns or raises.
222:         if last_error is not None:
223:             raise last_error
224:         raise DownloadError("La descarga terminó sin resultado")
225: 
226:     def _assert_disk_space(self, remote_metadata: RemoteMetadata) -> None:
227:         expected_size = remote_metadata.content_length or 0
228:         free = self._storage.free_space_bytes()
229:         required = (
230:             max(expected_size, self._config.minimum_file_size_bytes)
231:             + self._storage.minimum_free_space_bytes
232:         )
233:         if free < required:
234:             raise InsufficientDiskSpaceError(
235:                 f"Espacio insuficiente: libres={free}, requeridos={required}"
236:             )
237: 
238:     def _validate_download(
239:         self,
240:         temporary: Path,
241:         *,
242:         size: int,
243:         content_type: str,
244:         expected_size: int | None,
245:     ) -> None:
246:         if size < self._config.minimum_file_size_bytes:
247:             raise DownloadError(
248:                 f"Archivo incompleto: {size} bytes; mínimo "
249:                 f"{self._config.minimum_file_size_bytes}"
250:             )
251:         if "text/html" in content_type:
252:             raise DownloadError("El servidor devolvió HTML en lugar de Parquet")
253:         if self._config.validate_parquet_signature and not has_parquet_signature(
254:             temporary
255:         ):
256:             raise DownloadError("Firma Parquet inválida después de la descarga")
257:         if expected_size is not None and size != expected_size:
258:             raise DownloadError(
259:                 f"Tamaño descargado {size} distinto de Content-Length {expected_size}"
260:             )
261: 
262:     def _retry_delay(self, response: Any | None, fallback: float) -> float:
263:         if response is not None:
264:             try:
265:                 return min(
266:                     float(HttpClient._retry_delay(response, fallback)),
267:                     self._config.max_backoff_seconds,
268:                 )
269:             except Exception:
270:                 pass
271:         return min(float(fallback), self._config.max_backoff_seconds)
272: 
273:     def _is_retryable_transfer_error(self, error: Exception) -> bool:
274:         if isinstance(error, requests.HTTPError) and error.response is not None:
275:             return error.response.status_code in self.DOWNLOAD_RETRYABLE_STATUS_CODES
276:         # Streaming failures commonly surface as ChunkedEncodingError,
277:         # ConnectionError or Timeout after headers were already accepted.
278:         return isinstance(
279:             error,
280:             (
281:                 requests.Timeout,
282:                 requests.ConnectionError,
283:                 requests.exceptions.ChunkedEncodingError,
284:             ),
285:         )
286: 
287:     @staticmethod
288:     def _emit_attempt(
289:         callback: Callable[[dict[str, Any]], None] | None,
290:         *,
291:         attempt_number: int,
292:         max_attempts: int,
293:         outcome: str,
294:         status_code: int | None,
295:         retry_delay_seconds: float | None = None,
296:         error_type: str | None = None,
297:         error_message: str | None = None,
298:         started_at: datetime | None = None,
299:         finished_at: datetime | None = None,
300:         duration_seconds: float | None = None,
301:         bytes_downloaded: int | None = None,
302:         expected_bytes: int | None = None,
303:         throughput_bytes_per_second: float | None = None,
304:     ) -> None:
305:         if callback is None:
306:             return
307:         callback(
308:             {
309:                 "attempt_number": attempt_number,
310:                 "max_attempts": max_attempts,
311:                 "outcome": outcome,
312:                 "status_code": status_code,
313:                 "retry_delay_seconds": retry_delay_seconds,
314:                 "error_type": error_type,
315:                 "error_message": error_message,
316:                 "started_at": started_at,
317:                 "finished_at": finished_at,
318:                 "duration_seconds": duration_seconds,
319:                 "bytes_downloaded": bytes_downloaded,
320:                 "expected_bytes": expected_bytes,
321:                 "throughput_bytes_per_second": throughput_bytes_per_second,
322:             }
323:         )
