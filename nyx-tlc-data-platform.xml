 48: @st.cache_data(ttl=60, show_spinner=False)
 49: def _load_mongo(uri: str, database_name: str, timeout_ms: int) -> dict[str, pd.DataFrame]:
 50:     from pymongo import MongoClient
 51: 
 52:     client = MongoClient(
 53:         uri,
 54:         serverSelectionTimeoutMS=timeout_ms,
 55:         connectTimeoutMS=timeout_ms,
 56:     )
 57:     try:
 58:         client.admin.command("ping")
 59:         database = client[database_name]
 60:         gold = gold_config().get("mongo_collections", {})
 61:         ml = ml_config().get("mongo_collections", {})
 62:         unified = audit_config().get("collections", {})
 63:         limit = int(audit_config().get("retention", {}).get("max_dashboard_documents", 20000))
 64:         definitions = {
 65:             "bronze_runs": ("pipeline_executions", "started_at"),
 66:             "silver_runs": ("silver_pipeline_executions", "started_at"),
 67:             "gold_runs": (
