 654:     def _finish_execution(
 655:         self,
 656:         audit: AuditRepositories,
 657:         manifest: ManifestWriter,
 658:         execution_id: str,
 659:         execution_type: str,
 660:         started_at: Any,
 661:         selection: RunSelection,
 662:         discovery: Any,
 663:         availability: list[AvailabilityRecord],
 664:         outcomes: list[FileOutcome],
 665:     ) -> ExecutionSummary:
 666:         finished_at = utc_now()
 667:         failed = sum(outcome.status == "FAILED" for outcome in outcomes)
 668:         deferred = sum(
 669:             outcome.status == DEFERRED_REMOTE_ACCESS for outcome in outcomes
 670:         ) + sum(item.status == DEFERRED_REMOTE_ACCESS for item in availability)
 671:         failed_probes = sum(item.status == "FAILED_TO_PROBE" for item in availability)
 672:         completed = sum(
 673:             outcome.status in {"READY", "SKIPPED_UNCHANGED", "DRY_RUN"}
 674:             for outcome in outcomes
 675:         )
 676:         claimed = sum(
 677:             outcome.status == "SKIPPED_CLAIMED" for outcome in outcomes
 678:         )
 679:         available = sum(item.status == "AVAILABLE" for item in availability)
 680:         incomplete = completed < available
 681: 
 682:         # SUCCESS means that every remotely available period has a usable result.
 683:         # A claim is not evidence of an existing file: it only means that another
 684:         # execution owns (or previously owned) the period. Treating claimed files
 685:         # as successful allowed Silver to start with an incomplete Bronze layer.
 686:         status = "SUCCESS"
 687:         if failed or deferred or failed_probes or claimed or incomplete:
 688:             status = "PARTIAL_SUCCESS" if completed else "FAILED"
 689:         summary = self._build_summary(
 690:             execution_id,
 691:             execution_type,
 692:             status,
 693:             started_at,
 694:             finished_at,
 695:             selection,
 696:             discovery,
 697:             availability,
 698:             outcomes,
 699:             str(manifest.path),
 700:         )
 701:         manifest.write(summary)
 702:         self._cleanup_execution_state(audit, execution_id)
 703:         audit.executions.finish(summary)
 704:         self._record_unified_audit(
 705:             audit, execution_id, summary, availability, outcomes
 706:         )
 707:         return summary
