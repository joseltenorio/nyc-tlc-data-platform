<file path="src/tlc_data_platform/gold/marts.py">
  1: from __future__ import annotations
  2: 
  3: from typing import Any
  4: 
  5: 
  6: # Los marts son tablas deliberadamente pequeñas. Streamlit podrá consultarlas
  7: # con DuckDB sin lanzar Spark ni leer cada viaje individual en cada interacción.
  8: 
  9: 
 10: def build_marts(
 11:     trip_activity: Any,
 12:     taxi_financial: Any,
 13:     hvfhv_operations: Any,
 14:     dim_zone: Any,
 15: ) -> dict[str, Any]:
 16:     from pyspark.sql import functions as F
 17: 
 18:     pickup_zones = dim_zone.select(
 19:         F.col("zone_key").alias("pickup_zone_key"),
 20:         F.col("zone_name").alias("pickup_zone_name"),
 21:         F.col("borough").alias("pickup_borough"),
 22:     )
 23:     dropoff_zones = dim_zone.select(
 24:         F.col("zone_key").alias("dropoff_zone_key"),
 25:         F.col("zone_name").alias("dropoff_zone_name"),
 26:         F.col("borough").alias("dropoff_borough"),
 27:     )
 28:     trips = trip_activity.join(pickup_zones, "pickup_zone_key", "left").join(
 29:         dropoff_zones, "dropoff_zone_key", "left"
 30:     )
 31: 
 32:     monthly_keys = ["source_year", "source_month", "service_type"]
 33:     executive_monthly = trips.groupBy(*monthly_keys).agg(
 34:         F.sum("trip_count").alias("trip_count"),
 35:         F.avg("trip_duration_seconds").alias("average_duration_seconds"),
 36:         F.avg("trip_distance_miles").alias("average_distance_miles"),
 37:         F.avg("average_speed_mph").alias("average_speed_mph"),
 38:         F.sum(F.col("airport_trip_flag").cast("long")).alias("airport_trip_count"),
 39:         F.sum(F.col("quality_warning_count")).alias("quality_warning_count"),
 40:     )
 41: 
 42:     service_totals = trips.groupBy("source_year", "source_month").agg(
 43:         F.sum("trip_count").alias("all_services_trip_count")
 44:     )
 45:     service_share = executive_monthly.join(
 46:         service_totals, ["source_year", "source_month"], "left"
 47:     ).withColumn(
 48:         "service_share",
 49:         F.when(
 50:             F.col("all_services_trip_count") > 0,
 51:             F.col("trip_count") / F.col("all_services_trip_count"),
 52:         ),
 53:     )
 54: 
 55:     daily_demand = trips.groupBy(
 56:         F.to_date("pickup_datetime").alias("event_date"), "service_type"
 57:     ).agg(F.sum("trip_count").alias("trip_count"))
 58: 
 59:     zone_demand = trips.groupBy(
 60:         "source_year",
 61:         "source_month",
 62:         "service_type",
 63:         "pickup_zone_key",
 64:         "pickup_zone_name",
 65:         "pickup_borough",
 66:     ).agg(
 67:         F.sum("trip_count").alias("pickup_trip_count"),
 68:         F.avg("trip_duration_seconds").alias("average_duration_seconds"),
 69:         F.avg("trip_distance_miles").alias("average_distance_miles"),
 70:         F.avg("average_speed_mph").alias("average_speed_mph"),
 71:     )
 72: 
 73:     od_routes = trips.groupBy(
 74:         "source_year",
 75:         "source_month",
 76:         "service_type",
 77:         "pickup_zone_key",
 78:         "pickup_zone_name",
 79:         "pickup_borough",
 80:         "dropoff_zone_key",
 81:         "dropoff_zone_name",
 82:         "dropoff_borough",
 83:     ).agg(
 84:         F.sum("trip_count").alias("trip_count"),
 85:         F.avg("trip_duration_seconds").alias("average_duration_seconds"),
 86:         F.avg("trip_distance_miles").alias("average_distance_miles"),
 87:         F.avg("average_speed_mph").alias("average_speed_mph"),
 88:     )
 89: 
 90:     time_heatmap = trips.groupBy(
 91:         "service_type",
 92:         F.dayofweek("pickup_datetime").alias("day_of_week"),
 93:         F.hour("pickup_datetime").alias("hour_of_day"),
 94:     ).agg(
 95:         F.sum("trip_count").alias("trip_count"),
 96:         F.avg("trip_duration_seconds").alias("average_duration_seconds"),
 97:     )
 98: 
 99:     financial_profile = taxi_financial.groupBy(*monthly_keys).agg(
100:         F.sum("trip_count").alias("trip_count"),
101:         F.sum("fare_amount").alias("fare_amount"),
102:         F.sum("tip_amount").alias("tip_amount"),
103:         F.sum("tolls_amount").alias("tolls_amount"),
104:         F.sum("total_amount").alias("total_amount"),
105:         F.avg("total_amount").alias("average_total_amount"),
106:         F.avg("tip_percentage").alias("average_tip_percentage"),
107:     )
108: 
109:     airport_activity = trips.groupBy(
110:         "source_year", "source_month", "service_type", "airport_trip_flag"
111:     ).agg(
112:         F.sum("trip_count").alias("trip_count"),
113:         F.avg("trip_duration_seconds").alias("average_duration_seconds"),
114:         F.avg("trip_distance_miles").alias("average_distance_miles"),
115:     )
116: 
117:     taxi_with_zone = taxi_financial.join(pickup_zones, "pickup_zone_key", "left")
118:     profitability_drivers = taxi_with_zone.groupBy(
119:         "service_type",
120:         "source_year",
121:         "source_month",
122:         "pickup_zone_key",
123:         "pickup_zone_name",
124:         "pickup_borough",
125:         "time_key",
126:         "airport_trip_flag",
127:     ).agg(
128:         F.sum("trip_count").alias("trip_count"),
129:         F.avg("total_amount").alias("average_total_amount"),
130:         F.avg("fare_per_mile").alias("average_fare_per_mile"),
131:         F.avg("revenue_per_minute").alias("average_revenue_per_minute"),
132:         F.avg("tip_percentage").alias("average_tip_percentage"),
133:     )
134: 
135:     # Tip analysis is intentionally restricted to card payments. TLC does not
136:     # record cash tips, so mixing cash records would create a false zero-tip rate.
137:     tip_behavior = taxi_with_zone.filter(F.col("payment_type_key") == 1).groupBy(
138:         "service_type",
139:         "source_year",
140:         "source_month",
141:         "pickup_zone_key",
142:         "pickup_zone_name",
143:         "pickup_borough",
144:         "time_key",
145:     ).agg(
146:         F.sum("trip_count").alias("credit_card_trip_count"),
147:         F.avg("tip_amount").alias("average_tip_amount"),
148:         F.avg("tip_percentage").alias("average_tip_percentage"),
149:         F.expr("percentile_approx(tip_percentage, 0.5)").alias("median_tip_percentage"),
150:     )
151: 
152:     operational_efficiency = trips.groupBy(
153:         "service_type", "source_year", "source_month", F.hour("pickup_datetime").alias("hour_of_day")
154:     ).agg(
155:         F.sum("trip_count").alias("trip_count"),
156:         F.avg("trip_duration_seconds").alias("average_duration_seconds"),
157:         F.expr("percentile_approx(trip_duration_seconds, 0.95)").alias("p95_duration_seconds"),
158:         F.avg("average_speed_mph").alias("average_speed_mph"),
159:     )
160: 
161:     route_efficiency = od_routes.select(
162:         "source_year",
163:         "source_month",
164:         "service_type",
165:         "pickup_zone_key",
166:         "pickup_zone_name",
167:         "dropoff_zone_key",
168:         "dropoff_zone_name",
169:         "trip_count",
170:         "average_duration_seconds",
171:         "average_distance_miles",
172:         "average_speed_mph",
173:     )
174: 
175:     zone_congestion = trips.groupBy(
176:         "source_year",
177:         "source_month",
178:         "service_type",
179:         "pickup_zone_key",
180:         "pickup_zone_name",
181:         "pickup_borough",
182:         F.hour("pickup_datetime").alias("hour_of_day"),
183:     ).agg(
184:         F.sum("trip_count").alias("trip_count"),
185:         F.avg("average_speed_mph").alias("average_speed_mph"),
186:         F.avg("trip_duration_seconds").alias("average_duration_seconds"),
187:         F.expr("percentile_approx(trip_duration_seconds, 0.95)").alias("p95_duration_seconds"),
188:     ).withColumn(
189:         "congestion_index",
190:         F.when(
191:             F.col("average_speed_mph") > 0,
192:             F.col("p95_duration_seconds") / F.col("average_speed_mph"),
193:         ),
194:     )
195: 
196:     zone_month_total = trips.groupBy(
197:         "source_year", "source_month", "pickup_zone_key"
198:     ).agg(F.sum("trip_count").alias("zone_total_trip_count"))
199:     service_competition = zone_demand.join(
200:         zone_month_total, ["source_year", "source_month", "pickup_zone_key"], "left"
201:     ).withColumn(
202:         "zone_service_share",
203:         F.when(
204:             F.col("zone_total_trip_count") > 0,
205:             F.col("pickup_trip_count") / F.col("zone_total_trip_count"),
206:         ),
207:     )
208: 
209:     hv_zone = hvfhv_operations.join(pickup_zones, "pickup_zone_key", "left")
210:     hvfhv_service_quality = hv_zone.groupBy(
211:         "source_year",
212:         "source_month",
213:         "provider_key",
214:         "hvfhs_company_name",
215:         "pickup_zone_key",
216:         "pickup_zone_name",
217:         "pickup_borough",
218:         "request_time_key",
219:     ).agg(
220:         F.sum("trip_count").alias("trip_count"),
221:         F.avg("request_to_pickup_seconds").alias("average_request_to_pickup_seconds"),
222:         F.expr("percentile_approx(request_to_pickup_seconds, 0.95)").alias("p95_request_to_pickup_seconds"),
223:         F.avg("driver_wait_seconds").alias("average_driver_wait_seconds"),
224:         F.avg("driver_pay").alias("average_driver_pay"),
225:     )
226: 
227:     shared_ride_performance = hvfhv_operations.groupBy(
228:         "source_year", "source_month", "provider_key", "hvfhs_company_name"
229:     ).agg(
230:         F.sum("trip_count").alias("trip_count"),
231:         F.sum(F.col("shared_requested").cast("long")).alias("shared_requested_count"),
232:         F.sum(F.col("shared_matched").cast("long")).alias("shared_matched_count"),
233:     ).withColumn(
234:         "shared_match_rate",
235:         F.when(
236:             F.col("shared_requested_count") > 0,
237:             F.col("shared_matched_count") / F.col("shared_requested_count"),
238:         ),
239:     )
240: 
241:     accessibility_performance = hvfhv_operations.groupBy(
242:         "source_year", "source_month", "provider_key", "hvfhs_company_name"
243:     ).agg(
244:         F.sum("trip_count").alias("trip_count"),
245:         F.sum(F.col("access_a_ride").cast("long")).alias("access_a_ride_count"),
246:         F.sum(F.col("wav_requested").cast("long")).alias("wav_requested_count"),
247:         F.sum(F.col("wav_matched").cast("long")).alias("wav_matched_count"),
248:     ).withColumn(
249:         "wav_match_rate",
250:         F.when(
251:             F.col("wav_requested_count") > 0,
252:             F.col("wav_matched_count") / F.col("wav_requested_count"),
253:         ),
254:     )
255: 
256:     return {
257:         "executive_monthly": executive_monthly,
258:         "service_share": service_share,
259:         "daily_demand": daily_demand,
260:         "zone_demand": zone_demand,
261:         "od_routes": od_routes,
262:         "time_heatmap": time_heatmap,
263:         "financial_profile": financial_profile,
264:         "airport_activity": airport_activity,
265:         "profitability_drivers": profitability_drivers,
266:         "tip_behavior": tip_behavior,
267:         "operational_efficiency": operational_efficiency,
268:         "route_efficiency": route_efficiency,
269:         "zone_congestion": zone_congestion,
270:         "service_competition": service_competition,
271:         "hvfhv_service_quality": hvfhv_service_quality,
272:         "shared_ride_performance": shared_ride_performance,
273:         "accessibility_performance": accessibility_performance,
274:     }
