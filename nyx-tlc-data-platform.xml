  1: from __future__ import annotations
  2: 
  3: from datetime import date
  4: from typing import Any
  5: 
  6: 
  7: # Estas dimensiones son "conformadas": las mismas claves se reutilizan en
  8: # todas las tablas de hechos. Esto evita que cada dashboard interprete fechas,
  9: # servicios o zonas de una forma distinta.
 10: 
 11: 
 12: def build_date_dimension(spark: Any, start_year: int, end_year: int) -> Any:
 13:     """Creates one row per calendar day for the configured analytical range."""
 14:     from pyspark.sql import functions as F
 15: 
 16:     start = date(start_year, 1, 1)
 17:     end = date(end_year, 12, 31)
 18:     number_of_days = (end - start).days + 1
 19:     return (
 20:         spark.range(number_of_days)
 21:         .select(F.date_add(F.lit(start.isoformat()), F.col("id").cast("int")).alias("full_date"))
 22:         .withColumn("date_key", F.date_format("full_date", "yyyyMMdd").cast("int"))
 23:         .withColumn("year", F.year("full_date"))
 24:         .withColumn("quarter", F.quarter("full_date"))
 25:         .withColumn("month_number", F.month("full_date"))
 26:         .withColumn("month_name", F.date_format("full_date", "MMMM"))
 27:         .withColumn("year_month", F.date_format("full_date", "yyyy-MM"))
 28:         .withColumn("week_number", F.weekofyear("full_date"))
 29:         .withColumn("day_of_month", F.dayofmonth("full_date"))
 30:         .withColumn("day_of_week_number", F.dayofweek("full_date"))
 31:         .withColumn("day_of_week_name", F.date_format("full_date", "EEEE"))
 32:         .withColumn("is_weekend", F.dayofweek("full_date").isin(1, 7))
 33:         .withColumn("is_month_start", F.col("full_date") == F.trunc("full_date", "month"))
 34:         .withColumn("is_month_end", F.col("full_date") == F.last_day("full_date"))
 35:         .select(
 36:             "date_key",
 37:             "full_date",
 38:             "year",
 39:             "quarter",
 40:             "month_number",
 41:             "month_name",
 42:             "year_month",
 43:             "week_number",
 44:             "day_of_month",
 45:             "day_of_week_number",
 46:             "day_of_week_name",
 47:             "is_weekend",
 48:             "is_month_start",
 49:             "is_month_end",
 50:         )
 51:     )
 52: 
 53: 
 54: def build_time_dimension(spark: Any) -> Any:
 55:     """Creates the 24 hourly buckets used by the facts and dashboards."""
 56:     from pyspark.sql import functions as F
 57: 
 58:     return (
 59:         spark.range(24)
 60:         .select(F.col("id").cast("int").alias("hour"))
 61:         .withColumn("time_key", F.col("hour"))
 62:         .withColumn("hour_label", F.format_string("%02d:00", F.col("hour")))
 63:         .withColumn(
 64:             "time_band",
 65:             F.when(F.col("hour") <= 5, "MADRUGADA")
 66:             .when(F.col("hour") <= 11, "MANANA")
 67:             .when(F.col("hour") <= 16, "TARDE")
 68:             .when(F.col("hour") <= 21, "PICO_NOCTURNO")
 69:             .otherwise("NOCHE"),
 70:         )
 71:         .withColumn("is_peak_hour", F.col("hour").isin(7, 8, 9, 16, 17, 18, 19))
 72:         .withColumn("is_night", (F.col("hour") <= 5) | (F.col("hour") >= 22))
 73:         .select("time_key", "hour", "hour_label", "time_band", "is_peak_hour", "is_night")
 74:     )
