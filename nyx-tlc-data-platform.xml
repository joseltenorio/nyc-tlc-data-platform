<file path="src/tlc_data_platform/silver/transformers/taxi.py">
  1: from __future__ import annotations
  2: 
  3: from typing import Any
  4: 
  5: from tlc_data_platform.core.settings import SilverQualityConfig
  6: from tlc_data_platform.silver.models import SilverTransformContext
  7: from tlc_data_platform.silver.transformers.common import (
  8:     add_common_metadata,
  9:     add_trip_business_id,
 10:     apply_rules,
 11:     col_from_aliases,
 12:     normalize_string,
 13:     taxi_rules,
 14: )
 15: 
 16: 
 17: TAXI_MONEY_COLUMNS = (
 18:     "fare_amount",
 19:     "extra",
 20:     "mta_tax",
 21:     "tip_amount",
 22:     "tolls_amount",
 23:     "improvement_surcharge",
 24:     "total_amount",
 25:     "congestion_surcharge",
 26:     "airport_fee",
 27:     "cbd_congestion_fee",
 28: )
 29: 
 30: 
 31: def transform_taxi(
 32:     raw: Any,
 33:     context: SilverTransformContext,
 34:     quality: SilverQualityConfig,
 35:     *,
 36:     pickup_alias: str,
 37:     dropoff_alias: str,
 38:     vendor_values: tuple[int, ...],
 39:     include_trip_type: bool,
 40:     include_ehail_fee: bool,
 41: ) -> Any:
 42:     from pyspark.sql import functions as F
 43: 
 44:     passenger_raw = col_from_aliases(raw, ["passenger_count"], "double")
 45:     vendor_raw = col_from_aliases(raw, ["VendorID", "vendorid"], "long")
 46:     rate_raw = col_from_aliases(raw, ["RatecodeID", "ratecodeid"], "long")
 47:     payment_raw = col_from_aliases(raw, ["payment_type"], "long")
 48:     store_raw = normalize_string(col_from_aliases(raw, ["store_and_fwd_flag"], "string"))
 49: 
 50:     df = raw.select(
 51:         vendor_raw.alias("vendor_id_raw"),
 52:         col_from_aliases(raw, [pickup_alias], "timestamp_ntz").alias("pickup_datetime"),
 53:         col_from_aliases(raw, [dropoff_alias], "timestamp_ntz").alias("dropoff_datetime"),
 54:         passenger_raw.alias("passenger_count_raw"),
 55:         col_from_aliases(raw, ["trip_distance"], "double").alias("trip_distance"),
 56:         rate_raw.alias("rate_code_id_raw"),
 57:         store_raw.alias("store_and_fwd_flag_raw"),
 58:         col_from_aliases(raw, ["PULocationID", "pulocationid"], "int").alias("pickup_location_id"),
 59:         col_from_aliases(raw, ["DOLocationID", "dolocationid"], "int").alias("dropoff_location_id"),
 60:         payment_raw.alias("payment_type_raw"),
 61:         *[
 62:             col_from_aliases(
 63:                 raw,
 64:                 ["Airport_fee", "airport_fee"] if name == "airport_fee" else [name],
 65:                 "double",
 66:                 0.0 if name not in {"fare_amount", "total_amount"} else None,
 67:             ).alias(name)
 68:             for name in TAXI_MONEY_COLUMNS
 69:         ],
 70:         col_from_aliases(raw, ["trip_type"], "long").alias("trip_type") if include_trip_type else F.lit(None).cast("long").alias("trip_type"),
 71:         col_from_aliases(raw, ["ehail_fee"], "double", 0.0).alias("ehail_fee") if include_ehail_fee else F.lit(None).cast("double").alias("ehail_fee"),
 72:     )
 73: 
 74:     df = (
 75:         df.withColumn("vendor_normalized", ~F.col("vendor_id_raw").isin(*vendor_values) | F.col("vendor_id_raw").isNull())
 76:         .withColumn("vendor_id", F.when(F.col("vendor_id_raw").isin(*vendor_values), F.col("vendor_id_raw")).otherwise(F.lit(99)).cast("int"))
 77:         .withColumn("rate_code_normalized", ~F.col("rate_code_id_raw").isin(1, 2, 3, 4, 5, 6, 99) | F.col("rate_code_id_raw").isNull())
 78:         .withColumn("rate_code_id", F.when(F.col("rate_code_id_raw").isin(1, 2, 3, 4, 5, 6, 99), F.col("rate_code_id_raw")).otherwise(F.lit(99)).cast("int"))
 79:         .withColumn("payment_type_normalized", ~F.col("payment_type_raw").between(0, 6) | F.col("payment_type_raw").isNull())
 80:         .withColumn("payment_type", F.when(F.col("payment_type_raw").between(0, 6), F.col("payment_type_raw")).otherwise(F.lit(5)).cast("int"))
 81:         .withColumn("store_flag_normalized", ~F.col("store_and_fwd_flag_raw").isin(*quality.allowed_store_and_forward_flags) | F.col("store_and_fwd_flag_raw").isNull())
 82:         .withColumn("store_and_fwd_flag", F.when(F.col("store_and_fwd_flag_raw").isin(*quality.allowed_store_and_forward_flags), F.col("store_and_fwd_flag_raw")).otherwise(F.lit("N")))
 83:         .withColumn("passenger_count_imputed", F.col("passenger_count_raw").isNull() | (F.col("passenger_count_raw") == 0))
 84:         .withColumn(
 85:             "passenger_count",
 86:             F.when(
 87:                 F.lit(quality.impute_zero_or_null_passenger_count)
 88:                 & (F.col("passenger_count_raw").isNull() | (F.col("passenger_count_raw") == 0)),
 89:                 F.lit(1),
 90:             ).otherwise(F.round(F.col("passenger_count_raw"))).cast("int"),
 91:         )
 92:         .withColumn("trip_duration_seconds", F.timestamp_diff("SECOND", F.col("pickup_datetime"), F.col("dropoff_datetime")).cast("long"))
 93:         .withColumn(
 94:             "average_speed_mph",
 95:             F.when(
 96:                 (F.col("trip_duration_seconds") > 0) & (F.col("trip_distance") >= 0),
 97:                 F.col("trip_distance") / (F.col("trip_duration_seconds") / F.lit(3600.0)),
 98:             ).cast("double"),
 99:         )
100:         .withColumn("airport_trip_flag", F.col("pickup_location_id").isin(1, 132, 138) | F.col("dropoff_location_id").isin(1, 132, 138))
101:         .withColumn(
102:             "fare_per_mile",
103:             F.when(F.col("trip_distance") > 0, F.col("fare_amount") / F.col("trip_distance")).cast("double"),
104:         )
105:         .withColumn(
106:             "tip_percentage",
107:             F.when(F.col("fare_amount") > 0, (F.col("tip_amount") / F.col("fare_amount")) * 100.0).cast("double"),
108:         )
109:         .withColumn(
110:             "revenue_per_minute",
111:             F.when(F.col("trip_duration_seconds") > 0, F.col("total_amount") / (F.col("trip_duration_seconds") / 60.0)).cast("double"),
112:         )
113:     )
114:     for name in TAXI_MONEY_COLUMNS:
115:         if name not in {"fare_amount", "total_amount"}:
116:             df = df.withColumn(name, F.coalesce(F.col(name), F.lit(0.0)).cast("double"))
117: 
118:     if include_trip_type:
119:         invalid_trip_type = ~F.col("trip_type").isin(1, 2) | F.col("trip_type").isNull()
120:         df = df.withColumn("trip_type_normalized", invalid_trip_type).withColumn(
121:             "trip_type", F.when(F.col("trip_type").isin(1, 2), F.col("trip_type")).otherwise(F.lit(None).cast("long"))
122:         )
123:     else:
124:         df = df.withColumn("trip_type_normalized", F.lit(False))
125: 
126:     df = add_common_metadata(df, context)
127:     df = add_trip_business_id(
128:         df,
129:         [
130:             "service_type",
131:             "pickup_datetime",
132:             "dropoff_datetime",
133:             "pickup_location_id",
134:             "dropoff_location_id",
135:             "vendor_id",
136:             "trip_distance",
137:             "total_amount",
138:         ],
139:     )
140:     rules = taxi_rules(df, context, quality)
141:     if include_trip_type:
142:         from tlc_data_platform.silver.transformers.common import Rule
143: 
144:         rules.append(Rule("INVALID_TRIP_TYPE", "WARNING", F.col("trip_type_normalized")))
145:     df = apply_rules(df, rules)
146:     return df.drop(
147:         "vendor_id_raw",
148:         "rate_code_id_raw",
149:         "payment_type_raw",
150:         "store_and_fwd_flag_raw",
151:         "passenger_count_raw",
152:         "vendor_normalized",
153:         "rate_code_normalized",
154:         "payment_type_normalized",
155:         "store_flag_normalized",
156:         "trip_type_normalized",
157:     )
</file>

