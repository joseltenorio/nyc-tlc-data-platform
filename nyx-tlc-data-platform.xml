205:     def mark_ready(self, outcome, execution_id):
206:         key = self._key(outcome.candidate)
207:         self.docs[key] = {
208:             "status": "READY",
209:             "current": {
210:                 "status": "READY",
211:                 "sha256": outcome.sha256,
212:                 "bytes_downloaded": outcome.bytes_downloaded,
213:                 "local_path": outcome.local_path,
214:                 "remote_metadata": outcome.remote_metadata.to_dict(),
215:             },
216:         }
217:         self.claims.discard(key)
218: 
219:     def mark_failed(self, outcome, execution_id):
220:         self.docs[self._key(outcome.candidate)] = {"status": "FAILED"}
221:         self.claims.discard(self._key(outcome.candidate))
222: 
223:     def mark_deferred(self, outcome, execution_id):
224:         self.docs[self._key(outcome.candidate)] = {"status": outcome.status}
225:         self.claims.discard(self._key(outcome.candidate))
226: 
227:     def release_claim(self, candidate, execution_id):
228:         self.claims.discard(self._key(candidate))
