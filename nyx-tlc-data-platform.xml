 21: def _read_parquet_cached(path_text: str, signature: tuple[int, int]) -> pd.DataFrame:
 22:     del signature
 23:     path = Path(path_text)
 24:     parquet_files = list(path.rglob("*.parquet")) if path.is_dir() else []
 25:     if not parquet_files:
