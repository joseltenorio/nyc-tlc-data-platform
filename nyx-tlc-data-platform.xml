36: def test_partial_bronze_does_not_start_silver(monkeypatch):
37:     calls = {"silver": 0}
38:     monkeypatch.setattr(
39:         module,
40:         "run_bronze_pipeline",
41:         lambda *args, **kwargs: bronze_summary("PARTIAL_SUCCESS"),
42:     )
43: 
44:     def fake_silver(*args, **kwargs):
45:         calls["silver"] += 1
46:         raise AssertionError("Silver must not start with incomplete Bronze")
47: 
48:     monkeypatch.setattr(module, "run_silver_pipeline", fake_silver)
49: 
50:     result = module.run_medallion_to_silver(
51:         object(),
52:         object(),
53:         execution_type="historical",
54:     )
55: 
56:     assert result.status == "PARTIAL_SUCCESS"
57:     assert result.silver is None
58:     assert calls["silver"] == 0
59: 
60: 
61: def test_failed_bronze_does_not_start_silver(monkeypatch):
62:     monkeypatch.setattr(
63:         module,
64:         "run_bronze_pipeline",
65:         lambda *args, **kwargs: bronze_summary("FAILED"),
66:     )
67:     monkeypatch.setattr(
68:         module,
69:         "run_silver_pipeline",
70:         lambda *args, **kwargs: (_ for _ in ()).throw(
71:             AssertionError("Silver must not start after failed Bronze")
72:         ),
73:     )
74: 
75:     result = module.run_medallion_to_silver(
76:         object(),
77:         object(),
78:         execution_type="historical",
