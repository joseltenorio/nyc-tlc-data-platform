  1: from __future__ import annotations
  2: 
  3: import logging
  4: import re
  5: from urllib.parse import urljoin, urlparse
  6: 
  7: from bs4 import BeautifulSoup
  8: 
  9: from tlc_data_platform.bronze.models import (
 10:     AvailabilityRecord,
 11:     DiscoveryResult,
 12:     FileCandidate,
 13:     classify_remote_availability,
 14: )
 15: from tlc_data_platform.core.settings import AppConfig
 16: from tlc_data_platform.ingestion.expected_periods import generate_expected_periods
 17: from tlc_data_platform.ingestion.http_client import HttpClient
 18: from tlc_data_platform.ingestion.remote_probe import RemoteProbe
 19: 
 20: LOGGER = logging.getLogger(__name__)
 21: FILE_PATTERN = re.compile(
 22:     r"(?P<prefix>yellow|green|fhv|fhvhv)_tripdata_"
 23:     r"(?P<year>\d{4})-(?P<month>\d{2})\.parquet$",
 24:     re.IGNORECASE,
 25: )
 26: 
 27: 
 28: class FileDiscovery:
 29:     """HTML-first discovery completed by deterministic probes for missing periods."""
 30: 
 31:     def __init__(
 32:         self,
 33:         config: AppConfig,
 34:         http: HttpClient,
 35:         probe: RemoteProbe,
 36:     ) -> None:
 37:         self._config = config
 38:         self._http = http
 39:         self._probe = probe
 40: 
 41:     def discover(
 42:         self,
 43:         execution_id: str,
 44:         services: list[str],
 45:         start_year: int,
 46:         end_year: int,
 47:         months: list[int],
 48:     ) -> DiscoveryResult:
 49:         if self._config.discovery.strategy != "html_with_deterministic_fallback":
 50:             raise ValueError(
 51:                 f"Estrategia de descubrimiento no soportada: {self._config.discovery.strategy}"
 52:             )
 53:         expected = generate_expected_periods(
 54:             self._config, services, start_year, end_year, months
 55:         )
 56:         expected_map = {(p.service, p.year, p.month): p for p in expected}
 57:         candidates: dict[tuple[str, int, int], FileCandidate] = {}
 58:         html_error: str | None = None
 59: 
 60:         try:
 61:             html = self._http.get_text(self._config.source.landing_page)
 62:             for candidate in self._parse_html(html):
 63:                 key = (candidate.service, candidate.year, candidate.month)
 64:                 period = expected_map.get(key)
 65:                 if period is not None and period.applicable:
 66:                     candidates[key] = candidate
 67:         except Exception as exc:
 68:             html_error = str(exc)
 69:             LOGGER.warning("No se pudo descubrir desde HTML: %s", exc)
 70: 
 71:         availability: list[AvailabilityRecord] = []
 72:         for period in expected:
 73:             key = (period.service, period.year, period.month)
 74:             if not period.applicable:
 75:                 availability.append(
 76:                     AvailabilityRecord(
 77:                         execution_id=execution_id,
 78:                         service=period.service,
 79:                         year=period.year,
 80:                         month=period.month,
 81:                         status="NOT_APPLICABLE",
 82:                         applicable=False,
 83:                         expected=True,
 84:                     )
 85:                 )
 86:                 continue
 87: 
 88:             if key in candidates:
 89:                 candidate = candidates[key]
 90:                 availability.append(
 91:                     AvailabilityRecord(
 92:                         execution_id=execution_id,
 93:                         service=period.service,
 94:                         year=period.year,
 95:                         month=period.month,
 96:                         status="AVAILABLE",
 97:                         applicable=True,
 98:                         expected=True,
 99:                         candidate_url=candidate.url,
100:                         discovery_method="html",
101:                     )
102:                 )
103:                 continue
104: 
105:             candidate = self._deterministic_candidate(period.service, period.year, period.month)
106:             remote = self._probe.probe(candidate.url)
107:             status = classify_remote_availability(remote)
108:             if status == "AVAILABLE":
109:                 candidates[key] = candidate
110:             availability.append(
111:                 AvailabilityRecord(
112:                     execution_id=execution_id,
113:                     service=period.service,
114:                     year=period.year,
115:                     month=period.month,
116:                     status=status,
117:                     applicable=True,
118:                     expected=True,
119:                     candidate_url=candidate.url,
120:                     discovery_method="deterministic_fallback",
121:                     remote_metadata=remote,
122:                 )
123:             )
124: 
125:         return DiscoveryResult(
126:             expected_periods=expected,
127:             candidates=sorted(candidates.values()),
128:             availability=availability,
129:             html_error=html_error,
130:         )
131: 
132:     def _parse_html(self, html: str) -> list[FileCandidate]:
133:         soup = BeautifulSoup(html, "html.parser")
134:         found: dict[tuple[str, int, int], FileCandidate] = {}
135:         for anchor in soup.find_all("a", href=True):
136:             url = urljoin(self._config.source.landing_page, anchor["href"].strip())
137:             parsed = urlparse(url)
138:             if parsed.hostname is None or parsed.hostname.lower() not in self._config.source.allowed_hosts:
139:                 continue
140:             file_name = parsed.path.rsplit("/", 1)[-1]
141:             match = FILE_PATTERN.search(file_name)
142:             if not match:
143:                 continue
144:             service = match.group("prefix").lower()
145:             year = int(match.group("year"))
146:             month = int(match.group("month"))
147:             found[(service, year, month)] = FileCandidate(
148:                 service=service,
149:                 year=year,
150:                 month=month,
151:                 url=url,
152:                 file_name=file_name,
153:                 discovery_method="html",
154:             )
155:         return sorted(found.values())
156: 
157:     def _deterministic_candidate(self, service: str, year: int, month: int) -> FileCandidate:
158:         prefix = self._config.services[service].file_prefix
159:         file_name = f"{prefix}_{year}-{month:02d}.parquet"
160:         return FileCandidate(
161:             service=service,
162:             year=year,
163:             month=month,
164:             url=f"{self._config.source.parquet_base_url}/{file_name}",
165:             file_name=file_name,
166:             discovery_method="deterministic_fallback",
167:         )
</file>

<file path="src/tlc_data_platform/ingestion/remote_probe.py">
 1: from __future__ import annotations
 2: 
 3: import requests
 4: 
 5: from tlc_data_platform.bronze.models import RemoteMetadata
 6: from tlc_data_platform.ingestion.http_client import HttpClient
 7: 
 8: 
 9: def _metadata(response: requests.Response, available: bool) -> RemoteMetadata:
10:     content_length = response.headers.get("Content-Length")
11:     return RemoteMetadata(
12:         available=available,
13:         status_code=response.status_code,
14:         content_length=int(content_length) if content_length and content_length.isdigit() else None,
15:         etag=response.headers.get("ETag"),
16:         last_modified=response.headers.get("Last-Modified"),
17:         content_type=response.headers.get("Content-Type"),
18:     )
19: 
20: 
21: def _is_html_response(response: requests.Response) -> bool:
22:     content_type = (response.headers.get("Content-Type") or "").lower()
23:     return "text/html" in content_type
24: 
25: 
26: class RemoteProbe:
27:     def __init__(self, http: HttpClient) -> None:
28:         self._http = http
29: 
30:     def probe(self, url: str) -> RemoteMetadata:
31:         try:
32:             response = self._http.request("HEAD", url, allow_redirects=True)
33:             try:
34:                 if response.status_code == 200 and not _is_html_response(response):
35:                     return _metadata(response, True)
36:                 if response.status_code in {404, 410}:
37:                     return _metadata(response, False)
38:                 if response.status_code not in {202, 403, 405} and not _is_html_response(
39:                     response
40:                 ):
41:                     return _metadata(response, False)
42:             finally:
43:                 response.close()
44: 
45:             response = self._http.request(
46:                 "GET",
47:                 url,
48:                 headers={"Range": "bytes=0-0"},
49:                 stream=True,
50:                 allow_redirects=True,
51:             )
52:             try:
53:                 available = response.status_code in {200, 206} and not _is_html_response(
54:                     response
55:                 )
56:                 return _metadata(response, available)
57:             finally:
58:                 response.close()
59:         except requests.RequestException as exc:
60:             return RemoteMetadata(
61:                 available=False,
62:                 probe_failed=True,
63:                 error_message=str(exc),
64:             )
</file>

