21:         self.calls = []
22: 
23:     def probe(self, url):
24:         self.calls.append(url)
25:         if url in self.failed_urls:
26:             return RemoteMetadata(False, probe_failed=True, error_message="timeout")
27:         if url in self.deferred_urls:
28:             return RemoteMetadata(
29:                 False,
30:                 status_code=202,
31:                 content_type="text/html; charset=UTF-8",
32:             )
33:         return RemoteMetadata(url in self.available_urls, status_code=200 if url in self.available_urls else 404)
34: 
