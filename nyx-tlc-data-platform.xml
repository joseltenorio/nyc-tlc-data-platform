<file path="src/tlc_data_platform/bronze/manifest.py">
 1: from __future__ import annotations
 2: 
 3: import json
 4: from dataclasses import asdict, is_dataclass
 5: from datetime import date, datetime
 6: from pathlib import Path
 7: from typing import Any
 8: 
 9: from tlc_data_platform.bronze.models import AvailabilityRecord, ExecutionSummary, FileOutcome
10: 
11: 
12: class JsonEncoder(json.JSONEncoder):
13:     def default(self, value: Any) -> Any:
14:         if isinstance(value, (datetime, date)):
15:             return value.isoformat()
16:         if isinstance(value, Path):
17:             return str(value)
18:         if is_dataclass(value):
19:             return asdict(value)
20:         return super().default(value)
21: 
22: 
23: class ManifestWriter:
24:     def __init__(self, root: Path, execution_id: str) -> None:
25:         self.path = root / f"{execution_id}.json"
26:         self._outcomes: list[FileOutcome] = []
27:         self._availability: list[AvailabilityRecord] = []
28: 
29:     def add_outcome(self, outcome: FileOutcome) -> None:
30:         self._outcomes.append(outcome)
31: 
32:     def set_availability(self, availability: list[AvailabilityRecord]) -> None:
33:         self._availability = availability
34: 
35:     def write(self, summary: ExecutionSummary) -> Path:
36:         self.path.parent.mkdir(parents=True, exist_ok=True)
37:         payload = {
38:             "manifest_schema_version": "1.0",
39:             "layer": "bronze",
40:             "manifest_type": "pipeline_execution",
41:             "summary": summary.to_dict(),
42:             "availability": [item.to_dict() for item in self._availability],
43:             "files": [item.to_dict() for item in self._outcomes],
44:         }
45:         temporary = self.path.with_suffix(".json.tmp")
46:         temporary.write_text(
47:             json.dumps(payload, cls=JsonEncoder, ensure_ascii=False, indent=2),
48:             encoding="utf-8",
49:         )
50:         temporary.replace(self.path)
51:         return self.path
</file>

<file path="src/tlc_data_platform/bronze/storage.py">
  1: from __future__ import annotations
  2: 
  3: import os
  4: import re
  5: import shutil
  6: from datetime import datetime, timezone
  7: from pathlib import Path
  8: 
  9: from tlc_data_platform.bronze.models import FileCandidate
 10: from tlc_data_platform.core.settings import StorageConfig
 11: 
 12: TEMPORARY_FILE_PATTERN = re.compile(
 13:     r"^(?P<file_name>.+\.parquet)\.(?P<execution_id>[^.]+)\.part$"
 14: )
 15: 
 16: 
 17: class BronzeStorage:
 18:     def __init__(self, config: StorageConfig) -> None:
 19:         self._config = config
 20: 
 21:     def ensure_directories(self) -> None:
 22:         for path in (
 23:             self._config.bronze_root,
 24:             self._config.versions_root,
 25:             self._config.temporary_root,
 26:             self._config.manifests_root,
 27:         ):
 28:             path.mkdir(parents=True, exist_ok=True)
 29: 
 30:     def final_path(self, candidate: FileCandidate) -> Path:
 31:         return (
 32:             self._config.bronze_root
 33:             / candidate.service
 34:             / f"year={candidate.year}"
 35:             / f"month={candidate.month:02d}"
 36:             / candidate.file_name
 37:         )
 38: 
 39:     def temporary_path(self, candidate: FileCandidate, execution_id: str) -> Path:
 40:         safe_execution = execution_id.replace(":", "-")
 41:         return self._config.temporary_root / f"{candidate.file_name}.{safe_execution}.part"
 42: 
 43:     def version_path(self, candidate: FileCandidate, sha256: str) -> Path:
 44:         timestamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
 45:         stem = candidate.file_name.removesuffix(".parquet")
 46:         return (
 47:             self._config.versions_root
 48:             / candidate.service
 49:             / f"year={candidate.year}"
 50:             / f"month={candidate.month:02d}"
 51:             / f"{stem}.{timestamp}.{sha256[:12]}.parquet"
 52:         )
 53: 
 54:     def promote(
 55:         self,
 56:         temporary: Path,
 57:         candidate: FileCandidate,
 58:         previous_sha256: str | None,
 59:         new_sha256: str,
 60:     ) -> tuple[Path, Path | None]:
 61:         destination = self.final_path(candidate)
 62:         destination.parent.mkdir(parents=True, exist_ok=True)
 63:         archived: Path | None = None
 64: 
 65:         if destination.exists() and previous_sha256 != new_sha256:
 66:             archived = self.version_path(candidate, previous_sha256 or "unknown")
 67:             archived.parent.mkdir(parents=True, exist_ok=True)
 68:             os.replace(destination, archived)
 69: 
 70:         os.replace(temporary, destination)
 71:         return destination, archived
 72: 
 73:     def discard_temporary(self, candidate: FileCandidate, execution_id: str) -> None:
 74:         self.temporary_path(candidate, execution_id).unlink(missing_ok=True)
 75: 
 76:     def temporary_entries(self) -> list[tuple[Path, str]]:
 77:         entries: list[tuple[Path, str]] = []
 78:         self._config.temporary_root.mkdir(parents=True, exist_ok=True)
 79:         for path in self._config.temporary_root.glob("*.part"):
 80:             match = TEMPORARY_FILE_PATTERN.match(path.name)
 81:             if match is None:
 82:                 continue
 83:             entries.append((path, match.group("execution_id")))
 84:         return entries
 85: 
 86:     def discard_temporary_path(self, path: Path) -> None:
 87:         path.unlink(missing_ok=True)
 88: 
 89:     def discard_temporary_for_execution(self, execution_id: str) -> int:
 90:         removed = 0
 91:         for path, owner_execution_id in self.temporary_entries():
 92:             if owner_execution_id != execution_id:
 93:                 continue
 94:             path.unlink(missing_ok=True)
 95:             removed += 1
 96:         return removed
 97: 
 98:     def free_space_bytes(self) -> int:
 99:         target = self._config.temporary_root
100:         target.mkdir(parents=True, exist_ok=True)
101:         return shutil.disk_usage(target).free
102: 
103:     @property
104:     def minimum_free_space_bytes(self) -> int:
105:         return self._config.minimum_free_space_bytes
</file>

