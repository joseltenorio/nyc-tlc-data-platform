117: def _normalize_layer_runs(frames: dict[str, pd.DataFrame]) -> pd.DataFrame:
118:     layers = {
119:         "bronze_runs": "bronze",
120:         "silver_runs": "silver",
121:         "gold_runs": "gold",
122:         "ml_runs": "ml",
123:     }
124:     normalized: list[pd.DataFrame] = []
125:     unified = frames.get("unified_runs", pd.DataFrame()).copy()
126:     if not unified.empty:
127:         if "run_id" in unified.columns and "execution_id" not in unified.columns:
128:             unified = unified.rename(columns={"run_id": "execution_id"})
129:         normalized.append(unified)
130: 
131:     for key, layer in layers.items():
132:         frame = frames.get(key, pd.DataFrame()).copy()
133:         if frame.empty:
134:             continue
135:         if "run_id" in frame.columns and "execution_id" not in frame.columns:
136:             frame = frame.rename(columns={"run_id": "execution_id"})
137:         frame["layer"] = layer
138:         normalized.append(frame)
139: 
140:     if not normalized:
141:         return pd.DataFrame()
142:     result = pd.concat(normalized, ignore_index=True, sort=False)
143:     for column in ("started_at", "finished_at"):
144:         if column in result.columns:
145:             result[column] = pd.to_datetime(result[column], utc=True, errors="coerce")
146:     if "duration_seconds" not in result.columns:
147:         result["duration_seconds"] = pd.NA
148:     if {"started_at", "finished_at"}.issubset(result.columns):
149:         calculated = (result["finished_at"] - result["started_at"]).dt.total_seconds()
150:         result["duration_seconds"] = pd.to_numeric(
151:             result["duration_seconds"], errors="coerce"
152:         ).fillna(calculated)
153:     if "execution_id" in result.columns:
154:         result = result.sort_values(
155:             ["execution_id", "started_at"],
156:             ascending=[True, False],
157:             na_position="last",
158:         ).drop_duplicates("execution_id", keep="first")
159:     return result.sort_values("started_at", ascending=False, na_position="last")
160: 
161: 
162: def _present(value: Any) -> bool:
163:     if value is None:
164:         return False
165:     try:
166:         return not bool(pd.isna(value))
167:     except (TypeError, ValueError):
168:         return True
169: 
170: 
171: def _freshness_value(row: dict[str, Any], preferred: str | None = None) -> int:
172:     candidates = [
173:         "updated_at",
174:         "written_at",
175:         "finished_at",
176:         preferred,
177:         "checked_at",
178:         "recorded_at",
179:         "attempted_at",
180:         "started_at",
181:         "occurred_at",
182:     ]
183:     values: list[int] = []
184:     for column in candidates:
185:         if not column or column not in row or not _present(row.get(column)):
186:             continue
187:         parsed = pd.to_datetime(row.get(column), utc=True, errors="coerce")
188:         if not pd.isna(parsed):
189:             values.append(int(parsed.value))
190:     return max(values, default=-(2**63))
191: 
192: 
193: def _coalesce_frames(
194:     frames: Iterable[pd.DataFrame],
195:     *,
196:     keys: list[str],
197:     sort_column: str | None = None,
198: ) -> pd.DataFrame:
199:     buckets: dict[tuple[Any, ...], list[tuple[int, int, dict[str, Any]]]] = {}
200:     order: list[tuple[Any, ...]] = []
201:     for source_rank, frame in enumerate(frames):
202:         if frame.empty or not all(key in frame.columns for key in keys):
203:             continue
204:         for row_rank, row in enumerate(frame.to_dict(orient="records")):
205:             identity = tuple(row.get(key) for key in keys)
206:             if any(not _present(value) for value in identity):
207:                 continue
208:             if identity not in buckets:
209:                 buckets[identity] = []
210:                 order.append(identity)
211:             buckets[identity].append((source_rank, row_rank, row))
212: 
213:     merged_rows: list[dict[str, Any]] = []
214:     for identity in order:
215:         candidates = sorted(
216:             buckets[identity],
217:             key=lambda item: (
218:                 -_freshness_value(item[2], sort_column),
219:                 item[0],
220:                 item[1],
221:             ),
222:         )
223:         target: dict[str, Any] = {}
224:         all_columns = {column for _, _, row in candidates for column in row}
225:         for _, _, row in candidates:
226:             for column, value in row.items():
227:                 if column not in target or not _present(target[column]):
228:                     if _present(value):
229:                         target[column] = value
230:         for column in all_columns:
231:             target.setdefault(column, pd.NA)
232:         merged_rows.append(target)
233: 
234:     result = pd.DataFrame(merged_rows)
235:     if sort_column and sort_column in result.columns:
236:         result = result.sort_values(sort_column, ascending=False, na_position="last")
237:     return result.reset_index(drop=True)
238: 
239: 
240: def _concat_nonempty(frames: Iterable[pd.DataFrame]) -> pd.DataFrame:
241:     selected = [frame for frame in frames if not frame.empty]
242:     return pd.concat(selected, ignore_index=True, sort=False) if selected else pd.DataFrame()
243: 
244: 
245: def _normalize_legacy_quality(frame: pd.DataFrame, layer: str) -> pd.DataFrame:
246:     if frame.empty:
247:         return frame
248:     result = frame.copy()
249:     if "layer" not in result.columns:
250:         result["layer"] = layer
251:     else:
252:         result["layer"] = result["layer"].fillna(layer)
253:     if "checked_at" not in result.columns and "recorded_at" in result.columns:
254:         result["checked_at"] = result["recorded_at"]
255:     if "failed_rows" not in result.columns:
256:         if "affected_rows" in result.columns:
257:             result["failed_rows"] = pd.to_numeric(
258:                 result["affected_rows"], errors="coerce"
259:             )
260:         else:
261:             result["failed_rows"] = pd.Series(
262:                 pd.NA, index=result.index, dtype="Float64"
263:             )
264:     if "dimension" not in result.columns:
265:         result["dimension"] = "validity"
266:     if "dataset_name" not in result.columns:
267:         if "service" in result.columns:
268:             result["dataset_name"] = result["service"].astype(str) + "_trips"
269:         else:
270:             result["dataset_name"] = "legacy_quality"
271:     if "status" not in result.columns:
272:         affected = pd.to_numeric(
273:             result.get(
274:                 "affected_rows",
275:                 pd.Series(pd.NA, index=result.index, dtype="Float64"),
276:             ),
277:             errors="coerce",
278:         )
279:         severity = result.get(
280:             "severity", pd.Series("UNKNOWN", index=result.index)
281:         ).astype(str).str.upper()
282:         result["status"] = "UNKNOWN"
283:         result.loc[affected.eq(0), "status"] = "PASSED"
284:         result.loc[affected.gt(0) & severity.eq("ERROR"), "status"] = "FAILED"
285:         result.loc[affected.gt(0) & ~severity.eq("ERROR"), "status"] = "WARNING"
286:     result["source_store"] = "mongodb_legacy"
287:     return result
288: 
289: 
290: def _quality_key(frame: pd.DataFrame) -> pd.Series:
291:     def values(*names: str) -> pd.Series:
292:         result = pd.Series("", index=frame.index, dtype="object")
293:         for name in names:
294:             if name not in frame.columns:
295:                 continue
296:             candidate = frame[name].fillna("").astype(str)
297:             result = result.mask(result.eq(""), candidate)
298:         return result
299: 
300:     parts = [
301:         values("execution_id"),
302:         values("layer"),
303:         values("dataset_name"),
304:         values("rule_code"),
305:         values("service", "context.service"),
306:         values("year", "context.year"),
307:         values("month", "context.month"),
308:     ]
309:     key = parts[0]
310:     for part in parts[1:]:
311:         key = key + "|" + part
312:     return key
313: 
314: 
315: def _merge_quality(
316:     mongo_unified: pd.DataFrame,
317:     jsonl_quality: pd.DataFrame,
318:     silver_legacy: pd.DataFrame,
319:     gold_legacy: pd.DataFrame,
320: ) -> pd.DataFrame:
321:     unified = _coalesce_frames(
322:         [mongo_unified, jsonl_quality],
323:         keys=["quality_id"],
324:         sort_column="checked_at",
325:     )
326:     legacy = _concat_nonempty(
327:         [
328:             _normalize_legacy_quality(silver_legacy, "silver"),
329:             _normalize_legacy_quality(gold_legacy, "gold"),
330:         ]
331:     )
332:     combined = _concat_nonempty([unified, legacy])
333:     if combined.empty:
334:         return combined
335:     combined["_quality_key"] = _quality_key(combined)
336:     combined = _coalesce_frames(
337:         [combined], keys=["_quality_key"], sort_column="checked_at"
338:     )
339:     return combined.drop(columns=["_quality_key"], errors="ignore")
340: 
341: 
342: def _failed_documents(frame: pd.DataFrame, source: str) -> pd.DataFrame:
343:     if frame.empty or "status" not in frame.columns:
344:         return pd.DataFrame()
345:     failed = frame[
346:         frame["status"].astype(str).str.upper().isin(["FAILED", "ERROR", "EXHAUSTED"])
347:     ].copy()
348:     if failed.empty:
349:         return failed
350:     failed["source"] = source
351:     return failed
352: 
353: 
354: def _dedupe_errors(frame: pd.DataFrame) -> pd.DataFrame:
355:     if frame.empty:
356:         return frame
357:     result = frame.copy()
358:     identity_columns = [
359:         column
360:         for column in (
361:             "execution_id",
362:             "layer",
363:             "service",
364:             "year",
365:             "month",
366:             "dataset_name",
367:             "rule_code",
368:             "attempt_number",
369:             "error_type",
370:             "error_message",
371:             "subject",
372:         )
373:         if column in result.columns
374:     ]
375:     if not identity_columns:
376:         return result.reset_index(drop=True)
377:     normalized = result[identity_columns].copy()
378:     for column in identity_columns:
379:         normalized[column] = normalized[column].map(
380:             lambda value: "" if not _present(value) else str(value)
381:         )
382:     result["_error_identity"] = normalized.agg("|".join, axis=1)
383:     time_column = next(
384:         (
385:             column
386:             for column in (
387:                 "occurred_at",
388:                 "attempted_at",
389:                 "recorded_at",
390:                 "checked_at",
391:                 "finished_at",
392:             )
393:             if column in result.columns
394:         ),
395:         None,
396:     )
397:     if time_column:
398:         result[time_column] = pd.to_datetime(
399:             result[time_column], utc=True, errors="coerce"
400:         )
401:         result = result.sort_values(time_column, ascending=False, na_position="last")
402:     return (
403:         result.drop_duplicates("_error_identity", keep="first")
404:         .drop(columns=["_error_identity"], errors="ignore")
405:         .reset_index(drop=True)
406:     )
407: 
408: 
409: class AuditRepository:
410:     """Loads real audit facts from MongoDB, JSONL and legacy run manifests."""
411: 
412:     def load(self) -> AuditData:
413:         manifests: ManifestAuditData = ManifestAuditRepository().load()
414:         jsonl: JsonlAuditData = JsonlAuditRepository().load()
415:         config = load_dashboard_config().get("mongo", {})
416:         env_name = str(config.get("uri_environment_variable", "MONGODB_URI"))
417:         uri = os.getenv(env_name, str(config.get("default_uri", "mongodb://localhost:27017")))
418:         database = str(config.get("database", "nyc_tlc_audit"))
419:         timeout_ms = int(config.get("connect_timeout_ms", 1500))
420: 
421:         mongo_available = False
422:         mongo: dict[str, pd.DataFrame] = {}
423:         try:
424:             mongo = _load_mongo(uri, database, timeout_ms)
425:             mongo_available = True
426:         except Exception:
427:             mongo = {}
428: 
429:         mongo_runs = _normalize_layer_runs(mongo) if mongo_available else pd.DataFrame()
430:         runs = _coalesce_frames(
431:             [mongo_runs, jsonl.runs, manifests.runs],
432:             keys=["execution_id"],
433:             sort_column="started_at",
434:         )
435: 
436:         processing = mongo.get("processing_attempts", pd.DataFrame()).copy()
437:         if not processing.empty:
438:             processing["attempt_kind"] = "processing"
439:         mongo_downloads = mongo.get("download_attempts", pd.DataFrame()).copy()
440:         if not mongo_downloads.empty:
441:             mongo_downloads["attempt_kind"] = "download"
442:             if "attempted_at" in mongo_downloads.columns and "started_at" not in mongo_downloads.columns:
443:                 mongo_downloads["started_at"] = mongo_downloads["attempted_at"]
444:         downloads = _coalesce_frames(
445:             [mongo_downloads, jsonl.attempts],
446:             keys=["execution_id", "service", "year", "month", "attempt_number"],
447:             sort_column="attempted_at",
448:         )
449:         attempts = _concat_nonempty([processing, downloads])
450: 
451:         quality = _merge_quality(
452:             mongo.get("unified_quality", pd.DataFrame()),
453:             jsonl.quality,
454:             mongo.get("silver_quality", pd.DataFrame()),
455:             mongo.get("gold_quality", pd.DataFrame()),
456:         )
457:         reconciliations = _concat_nonempty(
458:             [
459:                 mongo.get("silver_reconciliations", pd.DataFrame()),
460:                 mongo.get("gold_reconciliations", pd.DataFrame()),
461:             ]
462:         )
463:         datasets = _coalesce_frames(
464:             [mongo.get("datasets", pd.DataFrame()), jsonl.datasets],
465:             keys=["event_id"],
466:             sort_column="recorded_at",
467:         )
468:         coverage = _coalesce_frames(
469:             [mongo.get("coverage", pd.DataFrame()), jsonl.coverage],
470:             keys=["execution_id", "layer"],
471:             sort_column="checked_at",
472:         )
473: 
474:         errors = _dedupe_errors(
475:             _concat_nonempty(
476:                 [
477:                     manifests.errors,
478:                     _failed_documents(runs, "pipeline_run"),
479:                     _failed_documents(attempts, "attempt"),
480:                     _failed_documents(datasets, "dataset_event"),
481:                     _failed_documents(quality, "quality_event"),
482:                 ]
483:             )
484:         )
485:         active_sources: list[str] = []
486:         if mongo_available:
487:             active_sources.append("MongoDB")
488:         if any(
489:             not frame.empty
490:             for frame in (
491:                 jsonl.runs,
492:                 jsonl.attempts,
493:                 jsonl.quality,
494:                 jsonl.datasets,
495:                 jsonl.coverage,
496:                 jsonl.inventory,
497:             )
498:         ):
499:             active_sources.append("auditoría JSONL")
500:         if not manifests.runs.empty or not manifests.errors.empty:
501:             active_sources.append("manifests de compatibilidad")
502:         source_note = " + ".join(active_sources) or "sin fuentes de auditoría disponibles"
503:         if not mongo_available:
504:             source_note += " (MongoDB no disponible)"
505:         return AuditData(
506:             runs=runs,
507:             errors=errors,
508:             attempts=attempts,
509:             quality=quality,
510:             reconciliations=reconciliations,
511:             datasets=datasets,
512:             coverage=coverage,
513:             inventory=jsonl.inventory,
514:             source_note=source_note,
515:         )
