 221:         manifest = ManifestWriter(self._config.storage.manifests_root, execution_id)
 222:         audit.executions.start(
 223:             execution_id,
 224:             "DRY_RUN" if dry_run else execution_type.upper(),
 225:             started_at,
 226:             {
 227:                 "services": selection.services,
