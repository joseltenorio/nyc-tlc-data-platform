 73: def _records_for(root: Path, file_name: str, limit: int) -> list[dict[str, Any]]:
 74:     records: list[dict[str, Any]] = []
 75:     if not root.is_dir():
 76:         return records
 77:     for path in sorted(root.glob(f"*/{file_name}")):
 78:         records.extend(_read_jsonl(path, limit))
 79:     records.sort(
 80:         key=lambda item: (
 81:             str(item.get("written_at") or item.get("checked_at") or item.get("recorded_at") or ""),
 82:             str(item.get("_source_file") or ""),
 83:             int(item.get("_source_line") or 0),
 84:         )
 85:     )
 86:     if limit > 0 and len(records) > limit:
 87:         records = records[-limit:]
 88:     return records
