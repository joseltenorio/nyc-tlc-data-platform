  3: from typing import Any
  4: 
  5: from tlc_data_platform.core.settings import SilverQualityConfig
  6: from tlc_data_platform.silver.models import SilverTransformContext
  7: from tlc_data_platform.silver.transformers.common import (
  8:     Rule,
  9:     add_common_metadata,
 10:     add_trip_business_id,
 11:     apply_rules,
 12:     col_from_aliases,
 13:     common_rules,
 14:     normalize_string,
 15: )
 16: 
 17: 
 18: def transform(raw: Any, context: SilverTransformContext, quality: SilverQualityConfig) -> Any:
 19:     from pyspark.sql import functions as F
 20: 
 21:     sr_raw = normalize_string(col_from_aliases(raw, ["SR_Flag", "sr_flag"], "string"))
 22:     df = raw.select(
 23:         F.upper(
 24:             F.trim(col_from_aliases(raw, ["dispatching_base_num"], "string"))
 25:         ).alias("dispatching_base_num"),
 26:         col_from_aliases(raw, ["pickup_datetime"], "timestamp_ntz").alias(
 27:             "pickup_datetime"
 28:         ),
 29:         col_from_aliases(
 30:             raw, ["dropOff_datetime", "dropoff_datetime"], "timestamp_ntz"
 31:         ).alias("dropoff_datetime"),
 32:         col_from_aliases(
 33:             raw, ["PUlocationID", "PULocationID", "pulocationid"], "int"
 34:         ).alias("pickup_location_id"),
 35:         col_from_aliases(
 36:             raw, ["DOlocationID", "DOLocationID", "dolocationid"], "int"
 37:         ).alias("dropoff_location_id"),
 38:         sr_raw.alias("shared_ride_flag_raw"),
 39:         F.upper(
 40:             F.trim(
 41:                 col_from_aliases(
 42:                     raw,
 43:                     ["Affiliated_base_number", "affiliated_base_number"],
 44:                     "string",
 45:                 )
 46:             )
 47:         ).alias("affiliated_base_number"),
 48:     )
 49:     df = (
 50:         df.withColumn(
 51:             "shared_ride_flag",
 52:             F.when(F.col("shared_ride_flag_raw").isin("1", "1.0"), F.lit(True))
 53:             .when(
 54:                 F.col("shared_ride_flag_raw").isNull()
 55:                 | F.col("shared_ride_flag_raw").isin("0", "0.0"),
 56:                 F.lit(False),
 57:             )
 58:             .otherwise(F.lit(None).cast("boolean")),
 59:         )
 60:         .withColumn("shared_matched", F.col("shared_ride_flag"))
 61:         .withColumn(
 62:             "trip_duration_seconds",
 63:             F.timestamp_diff(
 64:                 "SECOND", F.col("pickup_datetime"), F.col("dropoff_datetime")
 65:             ).cast("long"),
 66:         )
 67:         .withColumn(
 68:             "airport_trip_flag",
 69:             F.col("pickup_location_id").isin(1, 132, 138)
 70:             | F.col("dropoff_location_id").isin(1, 132, 138),
 71:         )
 72:     )
 73:     df = add_common_metadata(df, context)
 74:     df = add_trip_business_id(
 75:         df,
 76:         [
 77:             "service_type",
 78:             "dispatching_base_num",
 79:             "pickup_datetime",
 80:             "dropoff_datetime",
 81:             "pickup_location_id",
 82:             "dropoff_location_id",
 83:         ],
 84:     )
 85:     rules = common_rules(df, context, quality, quality.fhv_max_duration_hours)
 86:     rules.extend(
 87:         [
 88:             Rule(
 89:                 "MISSING_DISPATCHING_BASE",
 90:                 "ERROR",
 91:                 F.col("dispatching_base_num").isNull()
 92:                 | (F.length("dispatching_base_num") == 0),
 93:             ),
 94:             Rule(
 95:                 "INVALID_SHARED_RIDE_FLAG",
 96:                 "WARNING",
 97:                 F.col("shared_ride_flag_raw").isNotNull()
 98:                 & ~F.col("shared_ride_flag_raw").isin("0", "0.0", "1", "1.0"),
 99:             ),
100:         ]
101:     )
102:     return apply_rules(df, rules).drop("shared_ride_flag_raw")
