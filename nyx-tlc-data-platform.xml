191:     def claim(self, candidate, execution_id):
192:         key = self._key(candidate)
193:         with self.lock:
194:             if key in self.claims:
195:                 return False
196:             self.claims.add(key)
197:             return True
198: 
199:     def set_status(self, candidate, execution_id, status, **fields):
200:         key = self._key(candidate)
201:         doc = self.docs.setdefault(key, {})
202:         doc["status"] = status
203:         doc.update(fields)
