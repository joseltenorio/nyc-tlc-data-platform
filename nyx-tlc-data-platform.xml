 74: 
 75:     def read_ml(self, dataset_name: str) -> pd.DataFrame:
 76:         return self._read(self._ml_root / dataset_name)
 77: 
 78:     def ml_dataset_name(self, section: str, key: str) -> str:
 79:         return str(self._ml.get(section, {}).get(key, key))
 80: 
 81:     def location_for_mart(self, logical_name: str) -> DatasetLocation:
 82:         physical = self._gold.get("datasets", {}).get("marts", {}).get(logical_name, logical_name)
 83:         path = self._gold_root / self._gold["storage"]["marts_root"] / physical
 84:         return DatasetLocation(logical_name, physical, path)
 85: 
 86:     @staticmethod
 87:     def _read(path: Path) -> pd.DataFrame:
 88:         return _read_parquet_cached(str(path), _dataset_signature(path))
 89: 
 90: 
 91: def normalize_service_names(frame: pd.DataFrame) -> pd.DataFrame:
 92:     if frame.empty or "service_type" not in frame.columns:
 93:         return frame
 94:     result = frame.copy()
 95:     mapping = {
 96:         "yellow": "Yellow",
 97:         "green": "Green",
 98:         "fhv": "FHV",
 99:         "fhvhv": "HVFHV",
100:     }
101:     result["service_label"] = result["service_type"].astype(str).str.lower().map(mapping).fillna(
102:         result["service_type"].astype(str).str.upper()
103:     )
104:     return result
105: 
106: 
107: def numeric(frame: pd.DataFrame, columns: list[str]) -> pd.DataFrame:
108:     result = frame.copy()
109:     for column in columns:
110:         if column in result.columns:
111:             result[column] = pd.to_numeric(result[column], errors="coerce")
112:     return result
</file>

