 9: class ExecutionRepository:
10:     def __init__(self, collection: Any) -> None:
11:         self._collection = collection
12: 
13:     def start(
14:         self,
15:         execution_id: str,
16:         execution_type: str,
17:         started_at: datetime,
18:         selection: dict[str, Any],
19:     ) -> None:
20:         self._collection.insert_one(
21:             {
22:                 "execution_id": execution_id,
23:                 "execution_type": execution_type,
24:                 "status": "RUNNING",
25:                 "started_at": started_at,
26:                 "selection": selection,
27:             }
28:         )
29: 
30:     def finish(self, summary: ExecutionSummary) -> None:
31:         self._collection.update_one(
32:             {"execution_id": summary.execution_id},
33:             {"$set": summary.to_dict()},
34:         )
35: 
36:     def fail(
37:         self,
38:         execution_id: str,
39:         finished_at: datetime,
40:         error: Exception,
41:         manifest_path: str | None,
42:     ) -> None:
43:         self._collection.update_one(
44:             {"execution_id": execution_id},
45:             {
46:                 "$set": {
47:                     "status": "FAILED",
48:                     "finished_at": finished_at,
49:                     "error_type": type(error).__name__,
50:                     "error_message": str(error),
51:                     "manifest_path": manifest_path,
52:                 }
53:             },
54:         )
55: 
56:     def get(self, execution_id: str) -> dict[str, Any] | None:
57:         return self._collection.find_one(
58:             {"execution_id": execution_id},
59:             {"_id": 0},
60:         )
61: 
62:     def is_active(self, execution_id: str) -> bool:
63:         execution = self.get(execution_id)
64:         if execution is None:
65:             return False
66:         if execution.get("finished_at") is not None:
67:             return False
68:         return execution.get("status") == "RUNNING"
