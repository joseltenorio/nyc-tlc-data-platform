 44: class SilverPipeline:
 45:     def __init__(
 46:         self,
 47:         config: AppConfig,
 48:         *,
 49:         spark_provider: SilverSparkProvider | None = None,
 50:         mongo_provider: MongoClientProvider | None = None,
 51:         storage: SilverStorage | None = None,
 52:         audit: SilverAuditRepositories | None = None,
 53:         source_catalog: SilverSourceCatalog | None = None,
 54:     ) -> None:
 55:         self._config = config
 56:         self._spark = spark_provider or SilverSparkProvider(config.silver.spark)
 57:         self._mongo = mongo_provider or MongoClientProvider(config.mongo)
 58:         self._storage = storage or SilverStorage(config.silver.storage)
 59:         self._audit = audit
 60:         self._source_catalog = source_catalog
 61: 
 62:     def close(self) -> None:
 63:         self._spark.close()
 64:         self._mongo.close()
