13: 
14: class MLSparkProvider:
15:     """Uses a dedicated, bounded Spark application for one model at a time."""
16: 
17:     def __init__(self, config: LayerSparkConfig) -> None:
18:         self._config = config
19:         self._local_dir = config.local_dir / f"run-{uuid4().hex[:10]}"
20:         self._session: Any | None = None
21: 
22:     def get(self) -> Any:
23:         if self._session is None:
24:             from pyspark.sql import SparkSession
25: 
26:             cleanup_stale_spark_dirs(self._config.local_dir)
27:             reset_spark_local_dir(self._local_dir)
28:             self._session = (
29:                 SparkSession.builder.appName(self._config.app_name)
30:                 .master(self._config.master)
31:                 .config("spark.driver.memory", self._config.driver_memory)
32:                 .config("spark.driver.maxResultSize", "1g")
33:                 .config("spark.local.dir", str(self._local_dir.resolve()))
34:                 .config("spark.sql.shuffle.partitions", str(self._config.shuffle_partitions))
35:                 .config("spark.sql.files.maxPartitionBytes", str(64 * 1024**2))
36:                 .config("spark.sql.adaptive.enabled", "true")
37:                 .config("spark.sql.adaptive.coalescePartitions.enabled", "true")
38:                 .config("spark.sql.adaptive.advisoryPartitionSizeInBytes", str(64 * 1024**2))
39:                 .config("spark.sql.session.timeZone", "America/New_York")
40:                 .config("spark.memory.fraction", "0.55")
41:                 .config("spark.memory.storageFraction", "0.15")
42:                 .config("spark.ui.enabled", "false")
43:                 .getOrCreate()
44:             )
45:             self._session.sparkContext.setLogLevel(self._config.log_level)
46:         return self._session
47: 
48:     def guard(self) -> SparkResourceGuard:
49:         return SparkResourceGuard(
50:             self.get(),
51:             self._local_dir,
52:             max_temp_bytes=self._config.max_temp_bytes,
53:             minimum_free_space_bytes=self._config.minimum_free_space_bytes,
54:         )
55: 
56:     def close(self) -> None:
57:         if self._session is not None:
58:             self._session.stop()
59:             self._session = None
60:         reset_spark_local_dir(self._local_dir)
