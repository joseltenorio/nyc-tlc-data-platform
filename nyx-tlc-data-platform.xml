<file path="src/tlc_data_platform/silver/references.py">
  1: from __future__ import annotations
  2: 
  3: import csv
  4: import hashlib
  5: import json
  6: import os
  7: from dataclasses import dataclass
  8: from pathlib import Path
  9: from typing import Any
 10: 
 11: import requests
 12: 
 13: from tlc_data_platform.bronze.manifest import JsonEncoder
 14: from tlc_data_platform.core.settings import AppConfig
 15: from tlc_data_platform.silver.models import ReferenceRefreshSummary, utc_now
 16: from tlc_data_platform.silver.spark import SilverSparkProvider
 17: from tlc_data_platform.silver.storage import SilverStorage
 18: 
 19: 
 20: @dataclass(frozen=True)
 21: class DownloadedReference:
 22:     path: Path
 23:     sha256: str
 24:     size_bytes: int
 25:     source_url: str
 26: 
 27: 
 28: class SilverReferencePipeline:
 29:     """Lands immutable raw reference CSVs in Bronze and publishes curated Silver Parquet."""
 30: 
 31:     def __init__(
 32:         self,
 33:         config: AppConfig,
 34:         *,
 35:         session: requests.Session | None = None,
 36:         spark_provider: SilverSparkProvider | None = None,
 37:         storage: SilverStorage | None = None,
 38:         close_shared_spark: bool = False,
 39:     ) -> None:
 40:         self._config = config
 41:         self._session = session or requests.Session()
 42:         self._owns_session = session is None
 43:         self._spark = spark_provider or SilverSparkProvider(config.silver.spark)
 44:         self._owns_spark = spark_provider is None or close_shared_spark
 45:         self._storage = storage or SilverStorage(config.silver.storage)
 46: 
 47:     def close(self) -> None:
 48:         if self._owns_session:
 49:             self._session.close()
 50:         if self._owns_spark:
 51:             self._spark.close()
 52: 
 53:     def run(self) -> ReferenceRefreshSummary:
 54:         self._storage.ensure_directories()
 55:         spark = self._spark.get()
 56:         refreshed_at = utc_now()
 57:         execution_id = f"references-{refreshed_at.strftime('%Y%m%dT%H%M%S')}-{os.getpid()}"
 58:         temp_root = self._config.silver.storage.temporary_root / execution_id
 59:         temp_root.mkdir(parents=True, exist_ok=True)
 60:         try:
 61:             taxi_download = self._download(
 62:                 self._config.silver.references.taxi_zones_url,
 63:                 temp_root / "taxi_zone_lookup.csv",
 64:             )
 65:             base_download = self._download(
 66:                 self._config.silver.references.base_lookup_url,
 67:                 temp_root / "base_lookup.csv",
 68:             )
 69:             taxi_bronze = self._persist_bronze(
 70:                 "taxi_zones", "taxi_zone_lookup.csv", taxi_download
 71:             )
 72:             base_bronze = self._persist_bronze(
 73:                 "base_lookup", "base_lookup.csv", base_download
 74:             )
 75: 
 76:             taxi_df = self._normalize_taxi_zones(spark, taxi_bronze, taxi_download.sha256)
 77:             base_df = self._normalize_bases(spark, base_bronze, base_download.sha256)
 78:             taxi_df = taxi_df.persist()
 79:             base_df = base_df.persist()
 80:             try:
 81:                 taxi_rows = taxi_df.count()
 82:                 base_rows = base_df.count()
 83:                 if taxi_rows < 260:
 84:                     raise ValueError(
 85:                         f"Taxi Zone Lookup quedó incompleto: {taxi_rows} filas normalizadas"
 86:                     )
 87:                 if base_rows == 0:
 88:                     raise ValueError("Current Bases no contiene filas normalizadas")
 89: 
 90:                 taxi_temp = temp_root / "taxi_zones_parquet"
 91:                 base_temp = temp_root / "base_lookup_parquet"
 92:                 options = {
 93:                     "compression": self._config.silver.execution.parquet_compression
 94:                 }
 95:                 taxi_df.write.mode("overwrite").options(**options).parquet(str(taxi_temp))
 96:                 base_df.write.mode("overwrite").options(**options).parquet(str(base_temp))
 97:                 taxi_final, base_final = self._storage.promote_references(
 98:                     taxi_temp, base_temp
 99:                 )
100:             finally:
101:                 taxi_df.unpersist()
102:                 base_df.unpersist()
103: 
104:             manifest_path = self._write_manifest(
105:                 execution_id=execution_id,
106:                 refreshed_at=refreshed_at,
107:                 taxi_download=taxi_download,
108:                 base_download=base_download,
109:                 taxi_bronze=taxi_bronze,
110:                 base_bronze=base_bronze,
111:                 taxi_final=taxi_final,
112:                 base_final=base_final,
113:                 taxi_rows=taxi_rows,
114:                 base_rows=base_rows,
115:             )
116:             return ReferenceRefreshSummary(
117:                 status="SUCCESS",
118:                 taxi_zones_rows=taxi_rows,
119:                 base_lookup_rows=base_rows,
120:                 taxi_zones_path=str(taxi_final),
121:                 base_lookup_path=str(base_final),
122:                 taxi_zones_bronze_path=str(taxi_bronze),
123:                 base_lookup_bronze_path=str(base_bronze),
124:                 taxi_zones_sha256=taxi_download.sha256,
125:                 base_lookup_sha256=base_download.sha256,
126:                 manifest_path=str(manifest_path),
127:                 refreshed_at=refreshed_at,
128:             )
129:         finally:
130:             import shutil
131: 
132:             if temp_root.exists():
133:                 shutil.rmtree(temp_root)
134: 
135:     def _download(self, url: str, path: Path) -> DownloadedReference:
136:         response = self._session.get(
137:             url,
138:             timeout=self._config.silver.references.request_timeout_seconds,
139:             headers={"User-Agent": self._config.discovery.user_agent},
140:         )
141:         response.raise_for_status()
142:         content = response.content
143:         if len(content) < 10 or b"<html" in content[:500].lower():
144:             raise ValueError(f"La referencia no devolvió un CSV válido: {url}")
145:         path.parent.mkdir(parents=True, exist_ok=True)
146:         temporary = path.with_suffix(path.suffix + ".part")
147:         with temporary.open("wb") as handle:
148:             handle.write(content)
149:             handle.flush()
150:             os.fsync(handle.fileno())
151:         temporary.replace(path)
152:         with path.open("r", encoding="utf-8-sig", newline="") as handle:
153:             if not next(csv.reader(handle), None):
154:                 raise ValueError(f"CSV sin cabecera: {url}")
155:         return DownloadedReference(
156:             path=path,
157:             sha256=hashlib.sha256(content).hexdigest(),
158:             size_bytes=len(content),
159:             source_url=url,
160:         )
161: 
162:     def _persist_bronze(
163:         self,
164:         dataset: str,
165:         file_name: str,
166:         downloaded: DownloadedReference,
167:     ) -> Path:
168:         target = (
169:             self._config.silver.references.bronze_root
170:             / dataset
171:             / f"sha256={downloaded.sha256}"
172:             / file_name
173:         )
174:         if target.is_file():
175:             return target
176:         target.parent.mkdir(parents=True, exist_ok=True)
177:         temporary = target.with_suffix(target.suffix + ".part")
178:         with temporary.open("wb") as handle:
179:             handle.write(downloaded.path.read_bytes())
180:             handle.flush()
181:             os.fsync(handle.fileno())
182:         temporary.replace(target)
183:         return target
184: 
185:     def _write_manifest(
186:         self,
187:         *,
188:         execution_id: str,
189:         refreshed_at: Any,
190:         taxi_download: DownloadedReference,
191:         base_download: DownloadedReference,
192:         taxi_bronze: Path,
193:         base_bronze: Path,
194:         taxi_final: Path,
195:         base_final: Path,
196:         taxi_rows: int,
197:         base_rows: int,
198:     ) -> Path:
199:         completed_at = utc_now()
200:         path = (
201:             self._config.silver.storage.manifests_root
