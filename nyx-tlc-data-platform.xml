 1: from __future__ import annotations
 2: 
 3: from datetime import datetime
 4: from typing import Any
 5: from uuid import uuid4
 6: 
 7: 
 8: class ProcessingAttemptRepository:
 9:     """Records individual stages so the audit dashboard can count retries/attempts."""
10: 
11:     def __init__(self, collection: Any) -> None:
12:         self._collection = collection
13: 
14:     def start(self, execution_id: str, layer: str, stage: str, subject: str, started_at: datetime) -> str:
15:         attempt_id = str(uuid4())
16:         attempt_number = self._collection.count_documents(
17:             {"execution_id": execution_id, "layer": layer, "stage": stage, "subject": subject}
18:         ) + 1
19:         self._collection.insert_one(
20:             {
21:                 "attempt_id": attempt_id,
22:                 "execution_id": execution_id,
23:                 "layer": layer,
24:                 "stage": stage,
25:                 "subject": subject,
26:                 "attempt_number": attempt_number,
27:                 "status": "RUNNING",
28:                 "started_at": started_at,
29:             }
30:         )
31:         return attempt_id
32: 
33:     def finish(
34:         self,
35:         attempt_id: str,
36:         finished_at: datetime,
37:         *,
38:         status: str,
39:         rows_read: int | None = None,
40:         rows_written: int | None = None,
41:         error: Exception | None = None,
42:     ) -> None:
43:         document = self._collection.find_one(
44:             {"attempt_id": attempt_id}, {"started_at": 1}
45:         ) or {}
46:         started_at = document.get("started_at")
47:         duration_seconds = (
48:             (finished_at - started_at).total_seconds()
49:             if isinstance(started_at, datetime)
50:             else None
51:         )
52:         update: dict[str, Any] = {
53:             "status": status,
54:             "finished_at": finished_at,
55:             "duration_seconds": duration_seconds,
56:             "rows_read": rows_read,
57:             "rows_written": rows_written,
58:         }
59:         if error is not None:
60:             update["error_type"] = type(error).__name__
61:             update["error_message"] = str(error)[:2000]
62:         self._collection.update_one({"attempt_id": attempt_id}, {"$set": update})
</file>

