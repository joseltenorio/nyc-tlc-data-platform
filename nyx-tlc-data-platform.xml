 1: from __future__ import annotations
 2: 
 3: from typing import Any
 4: from uuid import uuid4
 5: 
 6: from tlc_data_platform.core.resource_guard import (
 7:     SparkResourceGuard,
 8:     cleanup_stale_spark_dirs,
 9:     reset_spark_local_dir,
10: )
11: from tlc_data_platform.core.settings import SparkConfig
12: 
13: 
14: class SparkProvider:
15:     """Lazily creates one small SparkSession for Bronze Parquet validation."""
16: 
17:     def __init__(self, config: SparkConfig) -> None:
18:         self._config = config
19:         self._local_dir = config.local_dir / f"run-{uuid4().hex[:10]}"
20:         self._session: Any | None = None
21: 
22:     def get(self) -> Any:
23:         if self._session is None:
24:             from pyspark.sql import SparkSession
25: 
26:             cleanup_stale_spark_dirs(self._config.local_dir)
27:             reset_spark_local_dir(self._local_dir)
28:             self._session = (
29:                 SparkSession.builder.appName(self._config.app_name)
30:                 .master(self._config.master)
31:                 .config("spark.driver.memory", self._config.driver_memory)
32:                 .config("spark.driver.maxResultSize", "512m")
33:                 .config("spark.local.dir", str(self._local_dir.resolve()))
34:                 .config("spark.sql.files.maxPartitionBytes", str(64 * 1024**2))
35:                 .config("spark.sql.parquet.mergeSchema", "false")
36:                 .config("spark.ui.enabled", "false")
37:                 .getOrCreate()
38:             )
39:             self._session.sparkContext.setLogLevel(self._config.log_level)
40:         return self._session
41: 
42:     def guard(self) -> SparkResourceGuard:
43:         return SparkResourceGuard(
44:             self.get(),
45:             self._local_dir,
46:             max_temp_bytes=self._config.max_temp_bytes,
47:             minimum_free_space_bytes=self._config.minimum_free_space_bytes,
48:         )
49: 
50:     def close(self) -> None:
51:         if self._session is not None:
52:             self._session.stop()
53:             self._session = None
54:         reset_spark_local_dir(self._local_dir)
