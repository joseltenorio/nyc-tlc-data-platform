  85:     def _ensure_audit(self) -> AuditRepositories:
  86:         if self._audit is None:
  87:             database = self._mongo_provider.database()
  88:             MongoIndexManager(database, self._config.mongo).ensure_indexes()
  89:             names = self._config.mongo.collections
  90:             executions = ExecutionRepository(database[names.pipeline_executions])
  91:             self._audit = AuditRepositories(
  92:                 executions=executions,
  93:                 availability=AvailabilityRepository(database[names.file_availability]),
  94:                 registry=FileRegistryRepository(
  95:                     database[names.file_registry],
  96:                     self._config.download.claim_ttl_minutes,
  97:                     execution_repository=executions,
  98:                 ),
  99:                 versions=FileVersionRepository(database[names.file_versions]),
 100:                 unified=UnifiedAuditRepository(database, self._config.audit),
 101:             )
