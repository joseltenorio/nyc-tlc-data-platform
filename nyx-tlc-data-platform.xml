269:         files = list(self.root.rglob("*.json")) if self.root.is_dir() else []
270:         signature = (
271:             len(files),
272:             max((path.stat().st_mtime_ns for path in files), default=0),
273:         )
274:         return _load_manifests_cached(str(self.root), signature)
