 66:     def _ensure_audit(self) -> tuple[SilverAuditRepositories, Any]:
 67:         database = self._mongo.database()
 68:         if self._audit is None:
 69:             names = self._config.silver.collections
 70:             SilverIndexManager(database, names).ensure_indexes()
 71:             executions = SilverExecutionRepository(database[names.pipeline_executions])
 72:             self._audit = SilverAuditRepositories(
 73:                 executions=executions,
 74:                 registry=SilverFileRegistryRepository(
 75:                     database[names.file_registry],
 76:                     claim_ttl_minutes=self._config.silver.execution.claim_ttl_minutes,
 77:                     execution_repository=executions,
 78:                 ),
 79:                 quality=SilverQualityRepository(database[names.quality_results]),
 80:                 reconciliations=SilverReconciliationRepository(
 81:                     database[names.reconciliations]
 82:                 ),
 83:                 unified=UnifiedAuditRepository(database, self._config.audit),
 84:             )
 85:         return self._audit, database
 86: 
 87:     def _catalog(self, database: Any) -> SilverSourceCatalog:
 88:         if self._source_catalog is not None:
 89:             return self._source_catalog
 90:         bronze_registry = self._config.mongo.collections.file_registry
 91:         bronze_availability = self._config.mongo.collections.file_availability
 92:         return SilverSourceCatalog(
 93:             self._config,
 94:             database[bronze_registry],
 95:             database[bronze_availability],
 96:         )
 97: 
 98:     def plan(self, selection: RunSelection) -> SilverPlanSummary:
 99:         self._storage.ensure_directories()
100:         warnings: list[str] = []
101:         database = None
102:         registry = None
103:         try:
104:             audit, database = self._ensure_audit()
105:             registry = audit.registry
106:         except Exception as exc:
107:             warnings.append(f"MongoDB no estuvo disponible: {exc}")
108:             if self._config.silver.execution.require_bronze_ready_registry:
109:                 expected = (
110:                     len(selection.services)
111:                     * (selection.end_year - selection.start_year + 1)
112:                     * len(selection.months)
113:                 )
114:                 return SilverPlanSummary(
115:                     services=selection.services,
116:                     start_year=selection.start_year,
117:                     end_year=selection.end_year,
118:                     months=selection.months,
119:                     expected_periods=expected,
120:                     bronze_ready_periods=0,
121:                     bronze_missing_periods=expected,
122:                     already_processed_periods=0,
123:                     pending_periods=0,
124:                     states=[],
125:                     warnings=warnings,
126:                 )
127: 
128:         catalog = (
129:             self._catalog(database)
130:             if database is not None
131:             else SilverSourceCatalog(self._config, None)
132:         )
133:         sources, states = catalog.list(selection)
134:         already = 0
135:         if registry is not None:
136:             for source in sources:
137:                 if registry.is_unchanged(
138:                     source,
139:                     self._storage.outputs_exist(
140:                         source, self._config.silver.execution.build_master
141:                     ),
142:                 ):
143:                     already += 1
144: 
145:         if sources and not self._storage.references_exist():
146:             if self._config.silver.execution.refresh_references_if_missing:
147:                 warnings.append(
148:                     "Las referencias Silver no existen y se descargarán antes de transformar."
149:                 )
150:             elif self._config.silver.execution.require_reference_data:
151:                 warnings.append(
152:                     "Faltan taxi_zones/base_lookup; ejecute 'silver-references' antes de Silver."
153:                 )
154: 
155:         return SilverPlanSummary(
156:             services=selection.services,
157:             start_year=selection.start_year,
158:             end_year=selection.end_year,
159:             months=selection.months,
160:             expected_periods=len(states),
161:             bronze_ready_periods=len(sources),
162:             bronze_missing_periods=sum(
163:                 state.status in {"BRONZE_NOT_READY", "BRONZE_DEFERRED"}
164:                 for state in states
165:             ),
166:             already_processed_periods=already,
167:             pending_periods=max(0, len(sources) - already),
168:             states=[state.to_dict() for state in states],
169:             warnings=warnings,
170:         )
171: 
172:     def run(
173:         self,
174:         selection: RunSelection,
175:         *,
176:         execution_type: str,
177:         force: bool = False,
178:         refresh_references: bool | None = None,
179:     ) -> SilverExecutionSummary:
180:         started_at = utc_now()
181:         execution_id = (
182:             f"silver-{started_at.strftime('%Y%m%dT%H%M%S')}-{uuid.uuid4().hex[:8]}"
183:         )
184:         self._storage.ensure_directories()
185:         audit, database = self._ensure_audit()
186:         manifest = SilverManifestWriter(
187:             self._config.silver.storage.manifests_root, execution_id
188:         )
189:         audit.executions.start(
190:             execution_id,
191:             execution_type.upper(),
192:             started_at,
193:             {
194:                 "services": selection.services,
195:                 "start_year": selection.start_year,
196:                 "end_year": selection.end_year,
197:                 "months": selection.months,
198:                 "force": force,
199:                 "refresh_references": refresh_references,
200:             },
201:         )
202:         if audit.unified is not None:
203:             audit.unified.start_run(
204:                 execution_id,
205:                 layer="silver",
206:                 execution_type=execution_type.upper(),
207:                 selection={
208:                     "services": selection.services,
209:                     "start_year": selection.start_year,
210:                     "end_year": selection.end_year,
211:                     "months": selection.months,
212:                     "force": force,
213:                 },
214:                 started_at=started_at,
215:             )
216: 
217:         outcomes: list[SilverFileOutcome] = []
218:         source_file_count = 0
219:         reference_status: str | None = None
220:         references: SilverReferenceData | None = None
221:         states: list[Any] = []
222:         try:
223:             sources, states = self._catalog(database).list(selection)
224:             source_file_count = len(sources)
225:             manifest.set_states(states)
226:             spark = self._spark.get() if sources else None
227: 
228:             if sources and spark is not None:
229:                 reference_status = self._ensure_references(
230:                     refresh_references=refresh_references
231:                 )
232:                 if self._storage.references_exist():
233:                     references = SilverReferenceData.load(
234:                         spark, self._config.silver.storage
235:                     )
236:                     references.taxi_zones.persist()
237:                     references.base_lookup.persist()
238:                 elif self._config.silver.execution.require_reference_data:
239:                     raise FileNotFoundError(
240:                         "No existen taxi_zones y base_lookup en Silver. "
241:                         "Ejecute 'silver-references'."
242:                     )
243: 
244:             for source in sources:
245:                 outcome = self._process_source(
246:                     spark,
247:                     source,
248:                     execution_id,
249:                     audit,
250:                     references=references,
251:                     force=force,
252:                 )
253:                 outcomes.append(outcome)
254:                 manifest.add(outcome)
255:                 if outcome.status == "FAILED" and not selection.continue_on_error:
256:                     break
257: 
258:             status = self._execution_status(outcomes, bool(sources))
259:             summary = self._finish_summary(
260:                 execution_id,
261:                 execution_type,
262:                 status,
263:                 started_at,
264:                 selection,
265:                 outcomes,
266:                 manifest,
267:                 source_file_count=source_file_count,
268:                 reference_refresh_status=reference_status,
269:             )
270:             audit.executions.finish(summary)
271:             self._record_unified_audit(audit, summary, states, outcomes)
272:             return summary
273:         except Exception as exc:
274:             LOGGER.exception("La ejecución Silver falló: %s", exc)
275:             finished = utc_now()
276:             temporary_summary = self._finish_summary(
277:                 execution_id,
278:                 execution_type,
279:                 "FAILED",
280:                 started_at,
281:                 selection,
282:                 outcomes,
283:                 manifest,
284:                 source_file_count=source_file_count,
285:                 reference_refresh_status=reference_status,
286:                 finished_at=finished,
287:             )
288:             audit.executions.fail(
289:                 execution_id, finished, exc, temporary_summary.manifest_path
290:             )
291:             if audit.unified is not None:
292:                 audit.unified.fail_run(execution_id, exc, layer="silver")
293:             raise
294:         finally:
295:             if references is not None:
296:                 for frame in (references.taxi_zones, references.base_lookup):
297:                     try:
298:                         frame.unpersist()
299:                     except Exception:
300:                         pass
301:             try:
302:                 audit.registry.release_claims_for_execution(execution_id)
303:             except Exception as exc:
304:                 LOGGER.warning(
305:                     "No se pudieron liberar todos los claims Silver de %s: %s",
306:                     execution_id,
307:                     exc,
308:                 )
309:             self._storage.cleanup_execution(execution_id)
310: 
311:     def _record_unified_audit(
312:         self,
313:         audit: SilverAuditRepositories,
314:         summary: SilverExecutionSummary,
315:         states: list[Any],
316:         outcomes: list[SilverFileOutcome],
317:     ) -> None:
318:         unified = audit.unified
319:         if unified is None:
320:             return
321:         for outcome in outcomes:
322:             source = outcome.source
323:             outputs = [
324:                 ("curated", outcome.curated_path),
325:                 ("rejected", outcome.rejected_path),
326:                 ("master", outcome.master_path),
327:             ]
328:             if outcome.status == "FAILED" and not any(path for _, path in outputs):
329:                 unified.record_dataset(
330:                     summary.execution_id,
331:                     layer="silver",
332:                     dataset_name=f"{source.service}_trips",
333:                     dataset_type="curated_partition",
334:                     operation="transform_publish",
335:                     status="FAILED",
336:                     service=source.service,
337:                     year=source.year,
338:                     month=source.month,
339:                     source_dataset=source.path.name,
340:                     error=RuntimeError(
341:                         f"{outcome.error_type or 'SilverError'}: {outcome.error_message or 'fallo sin detalle'}"
342:                     ),
343:                     metadata={"source_sha256": source.source_sha256},
344:                 )
345:             for dataset_type, output_path in outputs:
346:                 if not output_path:
347:                     continue
348:                 metrics = parquet_metrics(Path(output_path))
349:                 unified.record_dataset(
350:                     summary.execution_id,
351:                     layer="silver",
352:                     dataset_name=f"{source.service}_{dataset_type}",
353:                     dataset_type=dataset_type,
354:                     operation="transform_publish",
355:                     status=outcome.status,
356:                     path=output_path,
357:                     parquet_files=metrics.parquet_files,
358:                     rows=metrics.rows,
359:                     bytes_on_disk=metrics.bytes_on_disk,
360:                     service=source.service,
361:                     year=source.year,
362:                     month=source.month,
363:                     source_dataset=source.path.name,
364:                     metadata={"source_sha256": source.source_sha256},
365:                 )
366:             if outcome.status == "READY":
367:                 for rule_code, failed_rows in outcome.rule_counts.items():
368:                     severity = outcome.rule_severities.get(rule_code, "WARNING")
369:                     unified.record_quality(
370:                         summary.execution_id,
371:                         layer="silver",
372:                         dataset_name=f"{source.service}_trips",
373:                         rule_code=rule_code,
374:                         dimension="validity",
375:                         severity=severity,
376:                         status=(
377:                             "FAILED"
378:                             if severity == "ERROR" and failed_rows
379:                             else ("WARNING" if failed_rows else "PASSED")
380:                         ),
381:                         failed_rows=failed_rows,
382:                         context={
383:                             "service": source.service,
384:                             "year": source.year,
385:                             "month": source.month,
386:                         },
387:                     )
388:                 reconciliation_ok = bool(
389:                     outcome.reconciliation_status
390:                     and outcome.reconciliation_status.startswith("MATCHED")
391:                 )
392:                 unified.record_quality(
393:                     summary.execution_id,
394:                     layer="silver",
395:                     dataset_name=f"{source.service}_trips",
396:                     rule_code="SILVER_ROW_RECONCILIATION",
397:                     dimension="reconciliation",
398:                     severity="ERROR",
399:                     status="PASSED" if reconciliation_ok else "FAILED",
400:                     expected=outcome.rows_read,
401:                     actual=outcome.rows_valid + outcome.rows_rejected,
402:                     failed_rows=abs(
403:                         outcome.rows_read
404:                         - outcome.rows_valid
405:                         - outcome.rows_rejected
406:                     ),
407:                     context={
408:                         "service": source.service,
409:                         "year": source.year,
410:                         "month": source.month,
411:                     },
412:                 )
413:             elif outcome.status == "SKIPPED_UNCHANGED":
414:                 unified.record_quality(
415:                     summary.execution_id,
416:                     layer="silver",
417:                     dataset_name=f"{source.service}_trips",
418:                     rule_code="SILVER_IDEMPOTENT_OUTPUTS_PRESENT",
419:                     dimension="completeness",
420:                     severity="ERROR",
421:                     status="PASSED",
422:                     expected="curated, rejected and master Parquet present",
423:                     actual=True,
424:                     failed_rows=0,
425:                     context={
426:                         "service": source.service,
427:                         "year": source.year,
428:                         "month": source.month,
429:                     },
430:                 )
431:             elif outcome.status == "FAILED":
432:                 unified.record_quality(
433:                     summary.execution_id,
434:                     layer="silver",
435:                     dataset_name=f"{source.service}_trips",
436:                     rule_code="SILVER_PARTITION_PROCESSING",
437:                     dimension="reliability",
438:                     severity="ERROR",
439:                     status="FAILED",
440:                     message=outcome.error_message,
441:                     context={
442:                         "service": source.service,
443:                         "year": source.year,
444:                         "month": source.month,
445:                         "error_type": outcome.error_type,
446:                     },
447:                 )
448: 
449:         outcome_by_period = {outcome.source.period_id: outcome for outcome in outcomes}
450:         not_published = sum(
451:             getattr(state, "status", "") == "BRONZE_NOT_PUBLISHED"
452:             for state in states
453:         )
454:         not_applicable = sum(
455:             getattr(state, "status", "") == "NOT_APPLICABLE" for state in states
456:         )
457:         deferred = sum(
458:             getattr(state, "status", "") == "BRONZE_DEFERRED" for state in states
459:         )
460:         missing: list[str] = []
461:         details: list[dict[str, Any]] = []
462:         ready = 0
463:         for state in states:
464:             period_id = state.period_id
465:             outcome = outcome_by_period.get(period_id)
466:             detail = state.to_dict()
467:             detail["processing_status"] = outcome.status if outcome else None
468:             detail["ready"] = bool(
469:                 outcome
470:                 and outcome.status in {"READY", "SKIPPED_UNCHANGED"}
471:             )
472:             details.append(detail)
473:             if detail["ready"]:
474:                 ready += 1
475:                 continue
476:             if state.status == "NOT_APPLICABLE":
477:                 continue
478:             if (
479:                 state.status == "BRONZE_NOT_PUBLISHED"
480:                 and not self._config.audit.treat_not_published_as_missing
481:             ):
482:                 continue
483:             missing.append(period_id)
484: 
485:         missing = sorted(set(missing))
486:         unified.record_coverage(
487:             summary.execution_id,
488:             layer="silver",
489:             expected_count=len(states),
490:             available_count=summary.source_files,
491:             ready_count=ready,
492:             missing=missing,
493:             not_applicable_count=not_applicable,
494:             not_published_count=not_published,
495:             deferred_count=deferred,
496:             details=details,
497:         )
498:         expected_published = max(
499:             0,
500:             len(states)
501:             - not_applicable
502:             - (
503:                 not_published
504:                 if not self._config.audit.treat_not_published_as_missing
505:                 else 0
506:             ),
507:         )
508:         unified.record_quality(
509:             summary.execution_id,
510:             layer="silver",
511:             dataset_name="silver_layer",
512:             rule_code="SILVER_EXPECTED_PARTITIONS_READY",
513:             dimension="completeness",
514:             severity="ERROR",
515:             status="PASSED" if not missing else "FAILED",
516:             expected=expected_published,
517:             actual=ready,
518:             failed_rows=len(missing),
519:             context={"missing_periods": missing},
520:         )
521:         unified.finish_run(
522:             summary.execution_id,
523:             status=summary.status,
524:             finished_at=summary.finished_at,
525:             metrics={
526:                 "parquet_files_input": summary.source_files,
527:                 "parquet_partitions_processed": summary.processed_files,
528:                 "parquet_partitions_skipped": summary.skipped_files,
529:                 "parquet_partitions_failed": summary.failed_files,
530:                 "rows_read": summary.rows_read,
531:                 "rows_valid": summary.rows_valid,
532:                 "rows_rejected": summary.rows_rejected,
533:                 "warning_rows": summary.warning_rows,
534:             },
535:         )
536: 
537:     def _ensure_references(self, *, refresh_references: bool | None) -> str:
538:         execution = self._config.silver.execution
539:         should_refresh = (
540:             refresh_references
541:             if refresh_references is not None
542:             else execution.refresh_references_before_run
543:         )
544:         if not self._storage.references_exist() and execution.refresh_references_if_missing:
545:             should_refresh = True
546:         if not should_refresh:
547:             return "REUSED" if self._storage.references_exist() else "MISSING"
548: 
549:         pipeline = SilverReferencePipeline(
550:             self._config,
551:             spark_provider=self._spark,
552:             storage=self._storage,
553:         )
554:         try:
555:             return pipeline.run().status
556:         finally:
557:             pipeline.close()
558: 
559:     def _process_source(
560:         self,
561:         spark: Any,
562:         source: SilverSourceFile,
563:         execution_id: str,
564:         audit: SilverAuditRepositories,
565:         *,
566:         references: SilverReferenceData | None,
567:         force: bool,
568:     ) -> SilverFileOutcome:
569:         include_master = self._config.silver.execution.build_master
570:         if not force and audit.registry.is_unchanged(
571:             source, self._storage.outputs_exist(source, include_master)
572:         ):
573:             outcome = SilverFileOutcome(
574:                 source,
575:                 "SKIPPED_UNCHANGED",
576:                 curated_path=str(self._storage.curated_partition(source)),
577:                 rejected_path=str(self._storage.rejected_partition(source)),
578:                 master_path=(
579:                     str(self._storage.master_partition(source))
580:                     if include_master
581:                     else None
582:                 ),
583:             )
584:             outcome.finish()
585:             return outcome
586:         if not audit.registry.claim(source, execution_id):
587:             outcome = SilverFileOutcome(source, "SKIPPED_CLAIMED")
588:             outcome.finish()
589:             return outcome
590: 
591:         outcome = SilverFileOutcome(source, "PROCESSING")
592:         transformed = valid = rejected = None
593:         try:
594:             raw = spark.read.parquet(str(source.path))
595:             context = SilverTransformContext(
596:                 service=source.service,
597:                 year=source.year,
598:                 month=source.month,
599:                 source_file=source.path.name,
600:                 source_sha256=source.source_sha256,
601:                 bronze_execution_id=source.bronze_execution_id,
602:                 silver_execution_id=execution_id,
603:             )
604:             transformed = get_transformer(source.service)(
605:                 raw, context, self._config.silver.quality
606:             )
607:             # Cache only the transformed monthly partition. Caching valid and
608:             # rejected separately duplicated a large part of HVFHV in Spark spill.
609:             transformed = enrich_trip(transformed, source.service, references).persist()
610:             valid, rejected = split_valid_rejected(transformed)
611: 
612:             guard = (
613:                 self._spark.guard() if hasattr(self._spark, "guard") else None
614:             )
615:             run_guarded = guard.run if guard is not None else (lambda action: action())
616:             from pyspark.sql import functions as F
617: 
618:             counts = run_guarded(
619:                 lambda: transformed.agg(
620:                     F.count(F.lit(1)).alias("rows_read"),
621:                     F.sum(
622:                         F.when(F.col("quality_error_count") == 0, 1).otherwise(0)
623:                     ).alias("rows_valid"),
624:                     F.sum(
625:                         F.when(F.col("quality_error_count") > 0, 1).otherwise(0)
626:                     ).alias("rows_rejected"),
627:                     F.sum(
628:                         F.when(F.col("quality_warning_count") > 0, 1).otherwise(0)
629:                     ).alias("warning_rows"),
630:                 ).first()
631:             )
632:             outcome.rows_read = int(counts["rows_read"] or 0)
633:             outcome.rows_valid = int(counts["rows_valid"] or 0)
634:             outcome.rows_rejected = int(counts["rows_rejected"] or 0)
635:             outcome.warning_rows = int(counts["warning_rows"] or 0)
636:             outcome.rule_counts, outcome.rule_severities = run_guarded(
637:                 lambda: self._rule_counts(transformed)
638:             )
639:             outcome.reconciliation_status = self._reconcile(source, outcome)
640: 
641:             writer_options = {
642:                 "compression": self._config.silver.execution.parquet_compression
643:             }
644:             curated_temp = self._storage.temp_partition(
645:                 execution_id, source, "curated"
646:             )
647:             rejected_temp = self._storage.temp_partition(
648:                 execution_id, source, "rejected"
649:             )
650:             master_temp = self._storage.temp_partition(
651:                 execution_id, source, "master"
652:             )
653:             for path in (curated_temp, rejected_temp, master_temp):
654:                 if path.exists():
655:                     import shutil
656: 
657:                     shutil.rmtree(path)
658:                 path.parent.mkdir(parents=True, exist_ok=True)
659: 
660:             run_guarded(
661:                 lambda: valid.write.mode("overwrite").options(**writer_options).parquet(
662:                     str(curated_temp)
663:                 )
664:             )
665:             run_guarded(
666:                 lambda: rejected.write.mode("overwrite").options(**writer_options).parquet(
667:                     str(rejected_temp)
668:                 )
669:             )
670:             if include_master:
671:                 run_guarded(
672:                     lambda: to_master(valid, source.service)
673:                     .write.mode("overwrite")
674:                     .options(**writer_options)
675:                     .parquet(str(master_temp))
676:                 )
677: 
678:             curated, rejected_path, master = self._storage.promote(
679:                 execution_id, source, include_master
680:             )
681:             outcome.status = "READY"
682:             outcome.curated_path = str(curated)
683:             outcome.rejected_path = str(rejected_path)
684:             outcome.master_path = str(master) if master else None
685:             outcome.finish()
686:             audit.quality.replace_for_outcome(outcome, execution_id)
687:             audit.reconciliations.insert(outcome, execution_id)
688:             audit.registry.mark_ready(outcome, execution_id)
689:             return outcome
690:         except Exception as exc:
691:             outcome.status = "FAILED"
692:             outcome.error_type = type(exc).__name__
693:             outcome.error_message = str(exc)[:1000]
694:             outcome.finish()
695:             try:
696:                 audit.registry.mark_failed(outcome, execution_id)
697:             except Exception as audit_error:
698:                 LOGGER.error(
699:                     "También falló el registro de error para %s: %s",
700:                     source.period_id,
701:                     audit_error,
702:                 )
703:             LOGGER.exception("Falló Silver para %s: %s", source.period_id, exc)
704:             return outcome
705:         finally:
706:             for frame in (rejected, valid, transformed):
707:                 if frame is not None:
708:                     try:
709:                         frame.unpersist()
710:                     except Exception:
711:                         pass
712: 
713:     @staticmethod
714:     def _rule_counts(df: Any) -> tuple[dict[str, int], dict[str, str]]:
715:         from pyspark.sql import functions as F
716: 
717:         errors = df.select(
718:             F.explode("quality_error_codes").alias("rule_code"),
719:             F.lit("ERROR").alias("severity"),
720:         )
721:         warnings = df.select(
722:             F.explode("quality_warning_codes").alias("rule_code"),
723:             F.lit("WARNING").alias("severity"),
724:         )
725:         rows = errors.unionByName(warnings).groupBy("rule_code", "severity").count().collect()
726:         counts = {row["rule_code"]: int(row["count"]) for row in rows}
727:         severities = {row["rule_code"]: row["severity"] for row in rows}
728:         return counts, severities
729: 
730:     @staticmethod
731:     def _reconcile(source: SilverSourceFile, outcome: SilverFileOutcome) -> str:
732:         if outcome.rows_read != outcome.rows_valid + outcome.rows_rejected:
733:             raise SilverReconciliationError(
734:                 f"Desbalance {source.period_id}: read={outcome.rows_read}, "
735:                 f"valid={outcome.rows_valid}, rejected={outcome.rows_rejected}"
736:             )
737:         if source.bronze_num_rows is None:
738:             return "MATCHED_WITHOUT_BRONZE_METADATA"
739:         if source.bronze_num_rows != outcome.rows_read:
740:             raise SilverReconciliationError(
741:                 f"Metadata Bronze no coincide para {source.period_id}: "
742:                 f"metadata={source.bronze_num_rows}, Spark={outcome.rows_read}"
743:             )
744:         return "MATCHED"
745: 
746:     @staticmethod
747:     def _execution_status(
748:         outcomes: list[SilverFileOutcome], had_sources: bool
749:     ) -> str:
750:         if not had_sources:
751:             return "NO_INPUT"
752:         failed = sum(outcome.status == "FAILED" for outcome in outcomes)
753:         ready = sum(outcome.status == "READY" for outcome in outcomes)
754:         if failed and ready:
755:             return "PARTIAL_SUCCESS"
756:         if failed:
757:             return "FAILED"
758:         return "SUCCESS"
759: 
760:     def _finish_summary(
761:         self,
762:         execution_id: str,
763:         execution_type: str,
764:         status: str,
765:         started_at: Any,
766:         selection: RunSelection,
767:         outcomes: list[SilverFileOutcome],
768:         manifest: SilverManifestWriter,
769:         *,
770:         source_file_count: int,
771:         reference_refresh_status: str | None,
772:         finished_at: Any | None = None,
773:     ) -> SilverExecutionSummary:
774:         finished = finished_at or utc_now()
775:         summary = SilverExecutionSummary(
776:             execution_id=execution_id,
777:             execution_type=execution_type,
778:             status=status,
779:             started_at=started_at,
780:             finished_at=finished,
781:             requested_services=selection.services,
782:             requested_start_year=selection.start_year,
783:             requested_end_year=selection.end_year,
784:             requested_months=selection.months,
785:             source_files=source_file_count,
786:             processed_files=sum(o.status == "READY" for o in outcomes),
787:             skipped_files=sum(o.status.startswith("SKIPPED") for o in outcomes),
788:             failed_files=sum(o.status == "FAILED" for o in outcomes),
789:             rows_read=sum(o.rows_read for o in outcomes),
790:             rows_valid=sum(o.rows_valid for o in outcomes),
791:             rows_rejected=sum(o.rows_rejected for o in outcomes),
792:             warning_rows=sum(o.warning_rows for o in outcomes),
793:             manifest_path=str(manifest.path),
794:             reference_refresh_status=reference_refresh_status,
795:         )
796:         manifest.write(summary)
797:         return summary
</file>

<file path="src/tlc_data_platform/silver/source_catalog.py">
  1: from __future__ import annotations
  2: 
  3: from pathlib import Path
  4: from typing import Any
  5: 
  6: from tlc_data_platform.core.settings import AppConfig, RunSelection
  7: from tlc_data_platform.ingestion.expected_periods import is_period_applicable
  8: from tlc_data_platform.silver.models import SilverPeriodState, SilverSourceFile
  9: 
 10: 
 11: class SilverSourceCatalog:
 12:     def __init__(
 13:         self,
 14:         config: AppConfig,
 15:         bronze_registry: Any | None,
 16:         bronze_availability: Any | None = None,
 17:     ) -> None:
 18:         self._config = config
 19:         self._registry = bronze_registry
 20:         self._availability = bronze_availability
 21: 
 22:     def list(self, selection: RunSelection) -> tuple[list[SilverSourceFile], list[SilverPeriodState]]:
 23:         sources: list[SilverSourceFile] = []
 24:         states: list[SilverPeriodState] = []
 25:         for service in selection.services:
 26:             for year in range(selection.start_year, selection.end_year + 1):
 27:                 for month in selection.months:
 28:                     if not is_period_applicable(
 29:                         self._config, service, year, month
 30:                     ):
 31:                         states.append(SilverPeriodState(service, year, month, "NOT_APPLICABLE"))
 32:                         continue
 33:                     doc = self._registry.find_one(
 34:                         {"service": service, "year": year, "month": month},
 35:                         {"_id": 0},
 36:                     ) if self._registry is not None else None
 37:                     source = self._from_registry(service, year, month, doc)
 38:                     if source is None and not self._config.silver.execution.require_bronze_ready_registry:
 39:                         source = self._from_filesystem(service, year, month)
 40:                     if source is None:
 41:                         availability_status = self._latest_availability_status(
 42:                             service, year, month
 43:                         )
 44:                         if availability_status == "NOT_PUBLISHED_YET":
 45:                             state_status = "BRONZE_NOT_PUBLISHED"
 46:                             detail = "El archivo todavía no fue publicado por TLC"
 47:                         elif availability_status in {
 48:                             "DEFERRED_REMOTE_ACCESS",
 49:                             "FAILED_TO_PROBE",
 50:                         }:
 51:                             state_status = "BRONZE_DEFERRED"
 52:                             detail = (
 53:                                 "La disponibilidad Bronze quedó diferida por un problema "
 54:                                 "remoto temporal"
 55:                             )
 56:                         else:
 57:                             state_status = "BRONZE_NOT_READY"
 58:                             detail = (
 59:                                 "No existe file_registry READY o el archivo físico no está "
 60:                                 "disponible"
 61:                             )
 62:                         states.append(
 63:                             SilverPeriodState(
 64:                                 service, year, month, state_status, detail=detail
 65:                             )
 66:                         )
 67:                     else:
 68:                         sources.append(source)
 69:                         states.append(
 70:                             SilverPeriodState(
 71:                                 service,
 72:                                 year,
 73:                                 month,
 74:                                 "BRONZE_READY",
 75:                                 source_path=str(source.path),
 76:                                 source_sha256=source.source_sha256,
 77:                             )
 78:                         )
 79:         return sources, states
 80: 
 81: 
 82:     def _latest_availability_status(
 83:         self, service: str, year: int, month: int
 84:     ) -> str | None:
 85:         if self._availability is None:
 86:             return None
 87:         query = {"service": service, "year": year, "month": month}
 88:         projection = {"_id": 0, "status": 1, "checked_at": 1}
 89:         try:
 90:             document = self._availability.find_one(
 91:                 query, projection, sort=[("checked_at", -1)]
 92:             )
 93:         except TypeError:
 94:             # Lightweight test doubles and older collection wrappers may not
 95:             # expose the optional sort parameter.
 96:             document = self._availability.find_one(query, projection)
 97:         return str(document.get("status")) if document else None
 98: 
 99:     def _from_registry(self, service: str, year: int, month: int, doc: dict[str, Any] | None) -> SilverSourceFile | None:
100:         if not doc or doc.get("status") != "READY":
101:             return None
102:         current = doc.get("current") or {}
103:         raw_path = current.get("local_path") or doc.get("local_path")
104:         if not raw_path:
105:             return None
106:         path = Path(raw_path)
107:         if not path.is_file():
108:             return None
109:         validation = current.get("validation") or (doc.get("current") or {}).get("validation") or {}
110:         return SilverSourceFile(
111:             service=service,
112:             year=year,
113:             month=month,
114:             path=path,
115:             source_sha256=current.get("sha256") or doc.get("sha256"),
116:             bronze_execution_id=current.get("execution_id") or doc.get("last_execution_id"),
117:             bronze_num_rows=validation.get("parquet_num_rows"),
118:             bronze_registry_status="READY",
119:         )
120: 
121:     def _from_filesystem(self, service: str, year: int, month: int) -> SilverSourceFile | None:
122:         root = self._config.storage.bronze_root / service / f"year={year}" / f"month={month:02d}"
123:         files = sorted(root.glob("*.parquet")) if root.is_dir() else []
124:         if len(files) != 1:
125:             return None
126:         return SilverSourceFile(service, year, month, files[0], None, None, None, "FILESYSTEM_ONLY")
</file>

<file path="src/tlc_data_platform/silver/spark.py">
 1: from __future__ import annotations
 2: 
 3: from typing import Any
 4: from uuid import uuid4
 5: 
 6: from tlc_data_platform.core.resource_guard import (
 7:     SparkResourceGuard,
 8:     cleanup_stale_spark_dirs,
 9:     reset_spark_local_dir,
10: )
11: from tlc_data_platform.core.settings import SilverSparkConfig
12: 
13: 
14: class SilverSparkProvider:
15:     """Creates one resource-bounded SparkSession for sequential Silver files."""
16: 
17:     def __init__(self, config: SilverSparkConfig) -> None:
18:         self._config = config
19:         self._local_dir = config.local_dir / f"run-{uuid4().hex[:10]}"
20:         self._session: Any | None = None
21: 
22:     def get(self) -> Any:
23:         if self._session is None:
24:             from pyspark.sql import SparkSession
25: 
26:             cleanup_stale_spark_dirs(self._config.local_dir)
27:             reset_spark_local_dir(self._local_dir)
28:             self._session = (
29:                 SparkSession.builder.appName(self._config.app_name)
30:                 .master(self._config.master)
31:                 .config("spark.driver.memory", self._config.driver_memory)
32:                 .config("spark.driver.maxResultSize", "1g")
33:                 .config("spark.local.dir", str(self._local_dir.resolve()))
34:                 .config("spark.sql.shuffle.partitions", str(self._config.shuffle_partitions))
35:                 .config("spark.sql.files.maxPartitionBytes", str(64 * 1024**2))
36:                 .config("spark.sql.adaptive.enabled", "true")
37:                 .config("spark.sql.adaptive.coalescePartitions.enabled", "true")
38:                 .config("spark.sql.adaptive.advisoryPartitionSizeInBytes", str(64 * 1024**2))
39:                 .config("spark.sql.adaptive.skewJoin.enabled", "true")
40:                 .config("spark.sql.parquet.mergeSchema", "false")
41:                 .config("spark.sql.sources.partitionOverwriteMode", "dynamic")
42:                 .config("spark.sql.session.timeZone", "America/New_York")
43:                 .config("spark.memory.fraction", "0.55")
44:                 .config("spark.memory.storageFraction", "0.20")
45:                 .config("spark.ui.enabled", "false")
46:                 .getOrCreate()
47:             )
48:             self._session.sparkContext.setLogLevel(self._config.log_level)
49:         return self._session
50: 
51:     def guard(self) -> SparkResourceGuard:
52:         return SparkResourceGuard(
53:             self.get(),
54:             self._local_dir,
55:             max_temp_bytes=self._config.max_temp_bytes,
56:             minimum_free_space_bytes=self._config.minimum_free_space_bytes,
57:         )
58: 
59:     def close(self) -> None:
60:         if self._session is not None:
61:             self._session.stop()
62:             self._session = None
63:         reset_spark_local_dir(self._local_dir)
</file>

<file path="src/tlc_data_platform/silver/storage.py">
  1: from __future__ import annotations
  2: 
  3: import shutil
  4: from pathlib import Path
  5: 
  6: from tlc_data_platform.core.settings import SilverStorageConfig
  7: from tlc_data_platform.silver.models import SilverSourceFile
  8: 
  9: 
 10: class SilverStorage:
 11:     def __init__(self, config: SilverStorageConfig) -> None:
 12:         self.config = config
 13: 
 14:     def ensure_directories(self) -> None:
 15:         roots = [
 16:             self.config.silver_root,
 17:             self.config.temporary_root,
 18:             self.config.manifests_root,
 19:         ]
 20:         for root in roots:
 21:             root.mkdir(parents=True, exist_ok=True)
 22:         self.recover_interrupted_promotions()
 23: 
 24:     def recover_interrupted_promotions(self) -> None:
 25:         """Restores a previous partition after a host/process interruption."""
 26:         root = self.config.silver_root
 27:         if not root.is_dir():
 28:             return
 29:         for backup in sorted(root.rglob("*.previous")):
 30:             if not backup.is_dir():
 31:                 continue
 32:             destination = backup.with_name(backup.name.removesuffix(".previous"))
 33:             if destination.exists():
 34:                 shutil.rmtree(backup, ignore_errors=True)
 35:             else:
 36:                 backup.replace(destination)
 37: 
 38:     def curated_partition(self, source: SilverSourceFile) -> Path:
 39:         dataset = self.config.datasets[source.service]
 40:         return self.config.silver_root / dataset / f"year={source.year}" / f"month={source.month:02d}"
 41: 
 42:     def rejected_partition(self, source: SilverSourceFile) -> Path:
 43:         return (
 44:             self.config.silver_root
 45:             / self.config.rejected_dataset
 46:             / f"service_type={source.service}"
 47:             / f"year={source.year}"
 48:             / f"month={source.month:02d}"
 49:         )
 50: 
 51:     def master_partition(self, source: SilverSourceFile) -> Path:
 52:         return (
 53:             self.config.silver_root
 54:             / self.config.master_dataset
 55:             / f"service_type={source.service}"
 56:             / f"year={source.year}"
 57:             / f"month={source.month:02d}"
 58:         )
 59: 
 60:     def reference_path(self, name: str) -> Path:
 61:         dataset = {
 62:             "taxi_zones": self.config.taxi_zones_dataset,
 63:             "base_lookup": self.config.base_lookup_dataset,
 64:         }[name]
 65:         return self.config.silver_root / dataset
 66: 
 67:     def references_exist(self) -> bool:
 68:         return all(self._has_parquet(self.reference_path(name)) for name in ("taxi_zones", "base_lookup"))
 69: 
 70:     def temp_partition(self, execution_id: str, source: SilverSourceFile, kind: str) -> Path:
 71:         return (
 72:             self.config.temporary_root
 73:             / execution_id
 74:             / kind
 75:             / source.service
 76:             / f"year={source.year}"
 77:             / f"month={source.month:02d}"
 78:         )
 79: 
 80:     @staticmethod
 81:     def _has_parquet(path: Path) -> bool:
 82:         return path.is_dir() and any(path.rglob("*.parquet"))
 83: 
 84:     @staticmethod
 85:     def _is_complete_dataset(path: Path) -> bool:
 86:         return path.is_dir() and (path / "_SUCCESS").is_file()
 87: 
 88:     @staticmethod
 89:     def _replace_many(pairs: list[tuple[Path, Path]]) -> None:
 90:         """Promotes multiple directories as one recoverable filesystem transaction.
 91: 
 92:         A crash cannot be made fully atomic across multiple directories, but any Python-level
 93:         failure rolls every destination back to its previous version.
 94:         """
 95:         if not pairs:
 96:             return
 97:         for temp_path, _ in pairs:
 98:             if not temp_path.is_dir():
 99:                 raise FileNotFoundError(f"No existe la salida temporal: {temp_path}")
100:             if not (temp_path / "_SUCCESS").is_file():
101:                 raise RuntimeError(f"Spark no completó la salida temporal: {temp_path}")
102: 
103:         backups: dict[Path, Path] = {}
104:         promoted: list[Path] = []
105:         try:
106:             for _, final_path in pairs:
107:                 final_path.parent.mkdir(parents=True, exist_ok=True)
108:                 backup = final_path.with_name(final_path.name + ".previous")
109:                 if backup.exists():
110:                     shutil.rmtree(backup)
111:                 if final_path.exists():
112:                     final_path.replace(backup)
113:                     backups[final_path] = backup
114: 
115:             for temp_path, final_path in pairs:
116:                 temp_path.replace(final_path)
117:                 promoted.append(final_path)
118:         except Exception:
119:             for final_path in reversed(promoted):
120:                 if final_path.exists():
121:                     shutil.rmtree(final_path)
122:             for final_path, backup in backups.items():
123:                 if backup.exists() and not final_path.exists():
124:                     backup.replace(final_path)
125:             raise
126:         else:
127:             for backup in backups.values():
128:                 if backup.exists():
129:                     shutil.rmtree(backup)
130: 
131:     @staticmethod
132:     def _replace_directory(temp_path: Path, final_path: Path) -> None:
133:         SilverStorage._replace_many([(temp_path, final_path)])
134: 
135:     def promote(
136:         self,
137:         execution_id: str,
138:         source: SilverSourceFile,
139:         include_master: bool,
140:     ) -> tuple[Path, Path, Path | None]:
141:         curated = self.curated_partition(source)
142:         rejected = self.rejected_partition(source)
143:         master = self.master_partition(source) if include_master else None
144:         pairs = [
145:             (self.temp_partition(execution_id, source, "curated"), curated),
146:             (self.temp_partition(execution_id, source, "rejected"), rejected),
147:         ]
148:         if include_master and master is not None:
149:             pairs.append((self.temp_partition(execution_id, source, "master"), master))
150:         self._replace_many(pairs)
151:         return curated, rejected, master
152: 
153:     def promote_references(self, taxi_temp: Path, base_temp: Path) -> tuple[Path, Path]:
154:         taxi_final = self.reference_path("taxi_zones")
155:         base_final = self.reference_path("base_lookup")
156:         self._replace_many([(taxi_temp, taxi_final), (base_temp, base_final)])
157:         return taxi_final, base_final
158: 
159:     def outputs_exist(self, source: SilverSourceFile, include_master: bool) -> bool:
160:         paths = [self.curated_partition(source), self.rejected_partition(source)]
161:         if include_master:
162:             paths.append(self.master_partition(source))
163:         return all(self._is_complete_dataset(path) for path in paths)
164: 
165:     def cleanup_execution(self, execution_id: str) -> None:
166:         root = self.config.temporary_root / execution_id
167:         if root.exists():
168:             shutil.rmtree(root)
