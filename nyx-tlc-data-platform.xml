  1: from __future__ import annotations
  2: 
  3: import logging
  4: from dataclasses import asdict
  5: from pathlib import Path
  6: from typing import Any, Iterable
  7: from uuid import uuid4
  8: 
  9: from tlc_data_platform.audit.gold_dataset_repository import GoldDatasetRepository
 10: from tlc_data_platform.audit.gold_execution_repository import GoldExecutionRepository
 11: from tlc_data_platform.audit.parquet_metrics import aggregate_metrics, parquet_metrics
 12: from tlc_data_platform.audit.processing_attempt_repository import ProcessingAttemptRepository
 13: from tlc_data_platform.audit.unified import UnifiedAuditRepository
 14: from tlc_data_platform.core.settings import AppConfig, RunSelection
 15: from tlc_data_platform.gold.audit import GoldAuditRepositories
 16: from tlc_data_platform.gold.dimensions import (
 17:     build_date_dimension,
 18:     build_payment_type_dimension,
 19:     build_provider_dimension,
 20:     build_rate_code_dimension,
 21:     build_service_dimension,
 22:     build_time_dimension,
 23:     build_trip_type_dimension,
 24:     build_zone_dimension,
 25: )
 26: from tlc_data_platform.gold.facts import (
 27:     build_hvfhv_operations_fact,
 28:     build_taxi_financial_fact,
 29:     build_trip_activity_fact,
 30: )
 31: from tlc_data_platform.gold.features import (
 32:     build_hvfhv_wait_features,
 33:     build_zone_hourly_demand_features,
 34:     build_zone_profile_features,
 35: )
 36: from tlc_data_platform.gold.manifest import GoldManifestWriter
 37: from tlc_data_platform.gold.marts import build_marts
 38: from tlc_data_platform.gold.models import (
 39:     GoldDatasetResult,
 40:     GoldExecutionSummary,
 41:     GoldPlanSummary,
 42:     utc_now,
 43: )
 44: from tlc_data_platform.gold.spark import GoldSparkProvider
 45: from tlc_data_platform.gold.storage import GoldSourcePartition, GoldStorage
 46: from tlc_data_platform.mongodb.client import MongoClientProvider
 47: from tlc_data_platform.mongodb.gold_ml_index_manager import GoldMLIndexManager
 48: 
 49: LOGGER = logging.getLogger(__name__)
 50: 
 51: GOLD_STAGES = ("dimensions", "facts", "marts", "features")
 52: 
 53: 
 54: class GoldPipeline:
 55:     """Builds Gold sequentially and publishes each output with a recoverable swap.
 56: 
 57:     The previous implementation cached the complete Silver master plus several
 58:     full facts at once. On a local Docker/WSL host that created hundreds of GB of
 59:     Spark spill. This implementation reads one Silver partition at a time, never
 60:     persists a large frame and builds global marts/features only after facts are
 61:     safely published.
 62:     """
 63: 
 64:     def __init__(self, config: AppConfig) -> None:
 65:         self._config = config
 66:         self._storage = GoldStorage(config.gold, config.silver.storage, config.services)
 67:         self._spark_provider = GoldSparkProvider(config.gold.spark)
 68:         self._mongo_provider = MongoClientProvider(config.mongo)
 69: 
 70:     def close(self) -> None:
 71:         self._spark_provider.close()
 72:         self._mongo_provider.close()
 73: 
 74:     def plan(self, selection: RunSelection) -> GoldPlanSummary:
 75:         partitions, missing = self._storage.selected_master_partitions(selection)
 76:         expected = self._storage.applicable_period_count(selection)
 77:         warnings: list[str] = []
 78:         if not partitions:
 79:             warnings.append("No existen particiones trips_master para la selección.")
 80:         if missing:
 81:             warnings.append(
 82:                 "Las particiones Silver ausentes se registrarán como cobertura parcial; nunca como cero."
 83:             )
 84:         return GoldPlanSummary(
 85:             status="READY" if partitions else "NO_INPUT",
 86:             selected_partitions=expected,
 87:             available_partitions=len(partitions),
 88:             missing_partitions=missing,
 89:             source_paths=[str(item.path) for item in partitions],
 90:             warnings=warnings,
 91:         )
 92: 
 93:     def run(
 94:         self,
 95:         selection: RunSelection,
 96:         *,
 97:         execution_type: str = "run",
 98:         stages: Iterable[str] | None = None,
 99:     ) -> GoldExecutionSummary:
100:         selected_stages = self._validate_stages(stages)
101:         self._storage.ensure_directories()
102:         self._storage.cleanup_stale_temporary()
103:         execution_id = f"gold-{utc_now().strftime('%Y%m%dT%H%M%S')}-{uuid4().hex[:8]}"
104:         started_at = utc_now()
105:         manifest = GoldManifestWriter(self._config.gold.storage.manifests_root, execution_id)
106:         partitions, missing = self._storage.selected_master_partitions(selection)
107:         warnings = [f"Partición Silver ausente: {period}" for period in missing]
108:         audit = self._audit()
109:         audit.executions.start(execution_id, execution_type, started_at, asdict(selection))
110:         if audit.unified is not None:
111:             audit.unified.start_run(
112:                 execution_id,
113:                 layer="gold",
114:                 execution_type=execution_type,
115:                 selection={**asdict(selection), "stages": selected_stages},
116:                 started_at=started_at,
117:             )
118: 
119:         if not partitions:
120:             summary = self._summary(
121:                 execution_id,
122:                 execution_type,
123:                 "NO_INPUT",
124:                 started_at,
125:                 selection,
126:                 partitions,
127:                 0,
128:                 [],
129:                 warnings + ["No se encontraron particiones Silver trips_master."],
130:             )
131:             audit.executions.finish(summary)
132:             if audit.unified is not None:
133:                 audit.unified.record_coverage(
134:                     execution_id,
135:                     layer="gold",
136:                     expected_count=self.plan(selection).selected_partitions,
137:                     available_count=0,
138:                     ready_count=0,
139:                     missing=missing,
140:                 )
141:                 audit.unified.finish_run(
142:                     execution_id,
143:                     status="NO_INPUT",
144:                     finished_at=summary.finished_at,
145:                     metrics={"parquet_partitions_input": 0, "datasets_built": 0},
146:                 )
147:             manifest.write(summary)
148:             return summary
149: 
150:         spark = self._spark_provider.get()
151:         guard = self._spark_provider.guard()
152:         results: list[GoldDatasetResult] = []
153:         source_metrics = aggregate_metrics([item.path for item in partitions])
154:         try:
155:             if "dimensions" in selected_stages:
156:                 results.extend(
157:                     self._build_dimensions(spark, guard, audit, execution_id, partitions)
158:                 )
159: 
160:             if "facts" in selected_stages:
161:                 for partition in partitions:
162:                     results.extend(
163:                         self._build_fact_partition(
164:                             spark, guard, audit, execution_id, partition
165:                         )
166:                     )
167:                     spark.catalog.clearCache()
168: 
169:             if "marts" in selected_stages:
170:                 results.extend(self._build_marts(spark, guard, audit, execution_id, partitions))
171:                 spark.catalog.clearCache()
172: 
173:             if "features" in selected_stages:
174:                 results.extend(
175:                     self._build_features(spark, guard, audit, execution_id, partitions)
176:                 )
177:                 spark.catalog.clearCache()
178: 
179:             status = "PARTIAL_SUCCESS" if missing else "SUCCESS"
180:             summary = self._summary(
181:                 execution_id,
182:                 execution_type,
183:                 status,
184:                 started_at,
185:                 selection,
186:                 partitions,
187:                 source_metrics.rows,
188:                 results,
189:                 warnings,
190:             )
191:             audit.executions.finish(summary)
192:             self._record_coverage_and_finish(audit, summary, selected_stages, missing)
193:             manifest.write(summary)
194:             return summary
195:         except Exception as error:
196:             audit.executions.fail(execution_id, utc_now(), error)
197:             if audit.unified is not None:
198:                 audit.unified.fail_run(execution_id, error, layer="gold")
199:             LOGGER.exception("Gold falló: %s", error)
200:             raise
201:         finally:
202:             self._storage.cleanup_execution(execution_id)
203: 
204:     def _build_dimensions(
205:         self,
206:         spark: Any,
207:         guard: Any,
208:         audit: GoldAuditRepositories,
209:         execution_id: str,
210:         partitions: list[GoldSourcePartition],
211:     ) -> list[GoldDatasetResult]:
212:         taxi_zones = spark.read.parquet(str(self._storage.taxi_zone_path()))
213:         all_paths = self._storage.scoped_master_paths(
214:             self._config.period.historical_start_year,
215:             self._config.period.incremental_year,
216:         ) or [item.path for item in partitions]
217:         # Column pruning prevents the provider dimension from materializing the
218:         # complete wide Silver master.
219:         provider_columns = [
220:             "service_type",
221:             "vendor_id_or_license",
222:             "dispatching_base_num",
223:             "dispatching_base_name",
224:             "dispatching_base_dba",
225:             "originating_base_num",
226:             "affiliated_base_num",
227:             "hvfhs_company_name",
228:         ]
229:         provider_source = spark.read.parquet(*[str(path) for path in all_paths]).select(
230:             *provider_columns
231:         )
232:         dimensions = {
233:             "date": build_date_dimension(
234:                 spark,
235:                 self._config.period.historical_start_year,
236:                 self._config.period.incremental_year,
237:             ),
238:             "time": build_time_dimension(spark),
239:             "service": build_service_dimension(spark),
240:             "zone": build_zone_dimension(taxi_zones),
241:             "provider": build_provider_dimension(provider_source),
242:             "payment_type": build_payment_type_dimension(spark),
243:             "rate_code": build_rate_code_dimension(spark),
244:             "trip_type": build_trip_type_dimension(spark),
245:         }
246:         results: list[GoldDatasetResult] = []
247:         for logical_name, frame in dimensions.items():
248:             results.append(
249:                 self._write_atomic_dataset(
250:                     guard,
251:                     audit,
252:                     execution_id,
253:                     logical_name,
254:                     "dimension",
255:                     frame,
256:                     self._storage.dimension_path(logical_name),
257:                 )
258:             )
259:         return results
260: 
261:     def _build_fact_partition(
262:         self,
263:         spark: Any,
264:         guard: Any,
265:         audit: GoldAuditRepositories,
266:         execution_id: str,
267:         source: GoldSourcePartition,
268:     ) -> list[GoldDatasetResult]:
269:         master = spark.read.parquet(str(source.path))
270:         input_metrics = parquet_metrics(source.path)
271:         facts: dict[str, Any] = {"trip_activity": build_trip_activity_fact(master)}
272:         if source.service in {"yellow", "green"}:
273:             facts["taxi_financial"] = build_taxi_financial_fact(master)
274:         if source.service == "fhvhv":
275:             facts["hvfhv_operations"] = build_hvfhv_operations_fact(master)
276: 
277:         results: list[GoldDatasetResult] = []
278:         for logical_name, frame in facts.items():
279:             destination = self._storage.fact_partition_path(
280:                 logical_name, source.service, source.year, source.month
281:             )
282:             attempt_id = audit.attempts.start(
283:                 execution_id,
284:                 "gold",
285:                 "write_fact_partition",
286:                 f"{logical_name}:{source.period_id}",
287:                 utc_now(),
288:             )
289:             try:
290:                 guard.run(
291:                     lambda frame=frame, logical_name=logical_name: self._storage.write_fact_partition_atomic(
292:                         frame,
293:                         logical_name,
294:                         source.service,
295:                         source.year,
296:                         source.month,
297:                         execution_id,
298:                     )
299:                 )
300:                 metrics = parquet_metrics(destination)
301:                 result = GoldDatasetResult(
302:                     dataset_name=self._storage.fact_path(logical_name).name,
303:                     dataset_type="fact_partition",
304:                     path=str(destination),
305:                     status="READY",
306:                     rows_written=metrics.rows,
307:                     partition_columns=("service_type", "source_year", "source_month"),
308:                 )
309:                 results.append(result)
310:                 audit.datasets.upsert(execution_id, result)
311:                 audit.attempts.finish(
312:                     attempt_id,
313:                     utc_now(),
314:                     status="SUCCESS",
315:                     rows_read=input_metrics.rows,
316:                     rows_written=metrics.rows,
317:                 )
318:                 if audit.unified is not None:
319:                     audit.unified.record_dataset(
320:                         execution_id,
321:                         layer="gold",
322:                         dataset_name=self._storage.fact_path(logical_name).name,
323:                         dataset_type="fact_partition",
324:                         operation="silver_to_gold",
325:                         status="READY",
326:                         path=str(destination),
327:                         parquet_files=metrics.parquet_files,
328:                         rows=metrics.rows,
329:                         bytes_on_disk=metrics.bytes_on_disk,
330:                         service=source.service,
331:                         year=source.year,
332:                         month=source.month,
333:                         source_dataset="silver.trips_master",
334:                     )
335:             except Exception as error:
336:                 audit.attempts.finish(attempt_id, utc_now(), status="FAILED", error=error)
337:                 if audit.unified is not None:
338:                     audit.unified.record_dataset(
339:                         execution_id,
340:                         layer="gold",
341:                         dataset_name=self._storage.fact_path(logical_name).name,
342:                         dataset_type="fact_partition",
343:                         operation="silver_to_gold",
344:                         status="FAILED",
345:                         service=source.service,
346:                         year=source.year,
347:                         month=source.month,
348:                         source_dataset="silver.trips_master",
349:                         error=error,
350:                     )
351:                 raise
352: 
353:         activity_path = self._storage.fact_partition_path(
354:             "trip_activity", source.service, source.year, source.month
355:         )
356:         activity_metrics = parquet_metrics(activity_path)
357:         source_rows = input_metrics.rows
358:         target_rows = activity_metrics.rows
359:         measurable = source_rows is not None and target_rows is not None
360:         matched = measurable and target_rows == source_rows
361:         difference = target_rows - source_rows if measurable else None
362:         audit.reconciliations.insert_one(
363:             {
364:                 "execution_id": execution_id,
365:                 "layer": "gold",
366:                 "service": source.service,
367:                 "year": source.year,
368:                 "month": source.month,
369:                 "source_dataset": "silver.trips_master",
370:                 "target_dataset": "gold.fact_trip_activity",
371:                 "source_rows": source_rows,
372:                 "target_rows": target_rows,
373:                 "difference": difference,
374:                 "status": "MATCHED" if matched else "FAILED",
375:                 "checked_at": utc_now(),
376:             }
377:         )
378:         if audit.unified is not None:
379:             audit.unified.record_quality(
380:                 execution_id,
381:                 layer="gold",
382:                 dataset_name="fact_trip_activity",
383:                 rule_code="GOLD_SILVER_ROW_RECONCILIATION",
384:                 dimension="reconciliation",
385:                 severity="ERROR",
386:                 status="PASSED" if matched else "FAILED",
387:                 expected=source_rows,
388:                 actual=target_rows,
389:                 failed_rows=(
390:                     0
391:                     if matched
392:                     else (abs(difference) if difference is not None else None)
393:                 ),
394:                 message=(
395:                     None
396:                     if measurable
397:                     else "No fue posible medir filas de origen y destino para reconciliar."
398:                 ),
399:                 context={
400:                     "service": source.service,
401:                     "year": source.year,
402:                     "month": source.month,
403:                 },
404:             )
405:         if not matched:
406:             raise ValueError(
407:                 f"Reconciliación Silver->Gold falló para {source.period_id}: "
408:                 f"source={source_rows}, target={target_rows}"
409:             )
410:         return results
411: 
412:     def _build_marts(
413:         self,
414:         spark: Any,
415:         guard: Any,
416:         audit: GoldAuditRepositories,
417:         execution_id: str,
418:         partitions: list[GoldSourcePartition],
419:     ) -> list[GoldDatasetResult]:
420:         activity, taxi, hvfhv, dim_zone = self._analytical_inputs(spark, partitions)
421:         frames = build_marts(activity, taxi, hvfhv, dim_zone)
422:         results: list[GoldDatasetResult] = []
423:         for logical_name, frame in frames.items():
424:             results.append(
425:                 self._write_atomic_dataset(
426:                     guard,
427:                     audit,
428:                     execution_id,
429:                     logical_name,
430:                     "mart",
431:                     frame,
432:                     self._storage.mart_path(logical_name),
433:                 )
434:             )
435:         return results
