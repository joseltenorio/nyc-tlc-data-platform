  8: 
  9: 
 10: class Result:
 11:     def __init__(self, matched=0, upserted_id=None, modified=0):
 12:         self.matched_count = matched
 13:         self.upserted_id = upserted_id
 14:         self.modified_count = modified
 15: 
 16: 
 17: class Executions:
 18:     def __init__(self, docs=None):
 19:         self.docs = docs or {}
 20: 
 21:     def get(self, execution_id):
 22:         return self.docs.get(execution_id)
 23: 
 24: 
 25: class Collection:
 26:     def __init__(self, doc=None):
 27:         self.doc = doc
 28: 
 29:     def find_one(self, key, projection=None):
 30:         if self.doc is None:
 31:             return None
 32:         if any(
 33:             self.doc.get(k) != v
 34:             for k, v in key.items()
 35:             if "." not in k and k != "$or"
 36:         ):
 37:             return None
 38:         if projection == {"_id": 0, "claim": 1}:
 39:             return {"claim": self.doc.get("claim")}
 40:         return dict(self.doc)
 41: 
 42:     def update_one(self, key, update, upsert=False):
 43:         if self._matches(key):
 44:             if self.doc is None:
 45:                 self.doc = {}
 46:             self.doc.update(update.get("$set", {}))
 47:             for field in update.get("$unset", {}):
 48:                 self.doc.pop(field, None)
 49:             for field, value in update.get("$setOnInsert", {}).items():
 50:                 self.doc.setdefault(field, value)
 51:             return Result(matched=1)
 52:         if upsert and self.doc is None:
 53:             self.doc = {}
 54:             self.doc.update(update.get("$set", {}))
 55:             self.doc.update(update.get("$setOnInsert", {}))
 56:             return Result(upserted_id="new")
 57:         return Result()
 58: 
 59:     def update_many(self, key, update):
 60:         if not self._matches(key):
 61:             return Result()
 62:         for field in update.get("$unset", {}):
 63:             self.doc.pop(field, None)
 64:         self.doc.update(update.get("$set", {}))
 65:         return Result(modified=1)
 66: 
 67:     def _matches(self, key):
 68:         if self.doc is None:
 69:             return False
 70:         for field, value in key.items():
 71:             if field == "$or":
 72:                 if not any(self._matches(option) for option in value):
 73:                     return False
 74:                 continue
 75:             if field == "claim":
 76:                 exists = "claim" in self.doc
 77:                 if value == {"$exists": False} and exists:
 78:                     return False
 79:                 if value == {"$exists": True} and not exists:
 80:                     return False
 81:                 continue
 82:             if field.startswith("claim."):
 83:                 nested = (self.doc.get("claim") or {}).get(field.split(".", 1)[1])
 84:                 if isinstance(value, dict) and "$lt" in value:
 85:                     if nested is None or not nested < value["$lt"]:
 86:                         return False
 87:                 elif nested != value:
 88:                     return False
 89:                 continue
 90:             if self.doc.get(field) != value:
 91:                 return False
 92:         return True
 93: 
