431: 
432: def _read_yaml(path: Path) -> dict[str, Any]:
433:     if not path.is_file():
434:         raise ConfigurationError(f"No existe el archivo de configuración: {path}")
435:     with path.open("r", encoding="utf-8") as handle:
436:         value = yaml.safe_load(handle) or {}
437:     if not isinstance(value, dict):
438:         raise ConfigurationError(f"El YAML debe contener un objeto raíz: {path}")
439:     return value
440: 
441: 
442: def _require(mapping: dict[str, Any], key: str, context: str) -> Any:
443:     if key not in mapping:
444:         raise ConfigurationError(f"Falta '{key}' en {context}")
445:     return mapping[key]
446: 
447: 
448: def _period_point(raw: dict[str, Any], context: str) -> PeriodPoint:
449:     return PeriodPoint(
450:         year=int(_require(raw, "year", context)),
451:         month=int(_require(raw, "month", context)),
452:     )
453: 
454: 
455: def _layer_spark(raw: dict[str, Any], context: str) -> LayerSparkConfig:
456:     return LayerSparkConfig(
457:         app_name=str(_require(raw, "app_name", context)),
458:         master=str(_require(raw, "master", context)),
459:         log_level=str(_require(raw, "log_level", context)),
460:         driver_memory=str(_require(raw, "driver_memory", context)),
461:         shuffle_partitions=int(_require(raw, "shuffle_partitions", context)),
462:         local_dir=Path(raw.get("local_dir", f"data/tmp/spark/{context.split('.')[0]}")),
463:         max_temp_bytes=int(raw.get("max_temp_bytes", 32 * 1024**3)),
464:         minimum_free_space_bytes=int(raw.get("minimum_free_space_bytes", 20 * 1024**3)),
465:     )
466: 
467: 
468: def _string_mapping(raw: dict[str, Any], context: str) -> dict[str, str]:
469:     if not isinstance(raw, dict):
470:         raise ConfigurationError(f"{context} debe ser un objeto YAML")
471:     return {str(key): str(value) for key, value in raw.items()}
