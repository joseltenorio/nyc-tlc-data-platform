 399:     def _probe_candidates(
 400:         self,
 401:         candidates: list[FileCandidate],
 402:         workers: int,
 403:     ) -> dict[str, RemoteMetadata]:
 404:         if not candidates:
 405:             return {}
 406:         result: dict[str, RemoteMetadata] = {
 407:             candidate.period_id: RemoteMetadata(True)
 408:             for candidate in candidates
 409:             if candidate.discovery_method == "html"
 410:         }
 411:         probe_candidates = [
 412:             candidate
 413:             for candidate in candidates
 414:             if candidate.discovery_method != "html"
 415:         ]
 416:         if not probe_candidates:
 417:             return result
 418:         with ThreadPoolExecutor(max_workers=workers) as executor:
 419:             futures = {
 420:                 executor.submit(self._probe.probe, candidate.url): candidate
 421:                 for candidate in probe_candidates
 422:             }
 423:             for future in as_completed(futures):
 424:                 candidate = futures[future]
 425:                 try:
 426:                     result[candidate.period_id] = future.result()
 427:                 except Exception as exc:
 428:                     result[candidate.period_id] = RemoteMetadata(
 429:                         available=False,
 430:                         probe_failed=True,
 431:                         error_message=str(exc),
 432:                     )
 433:         return result
 434: 
 435:     @staticmethod
 436:     def _merge_probe_results(
 437:         availability: list[AvailabilityRecord],
 438:         remote_map: dict[str, RemoteMetadata],
 439:     ) -> list[AvailabilityRecord]:
 440:         merged: list[AvailabilityRecord] = []
 441:         for item in availability:
 442:             remote = remote_map.get(item.period_id)
 443:             if remote is None or item.status == "NOT_APPLICABLE":
 444:                 merged.append(item)
 445:                 continue
 446:             if item.discovery_method != "html":
 447:                 item.status = classify_remote_availability(remote)
 448:             item.remote_metadata = remote
 449:             merged.append(item)
 450:         return merged
 451: 
 452:     def _download_pending(
 453:         self,
 454:         pending: list[tuple[FileCandidate, RemoteMetadata, dict[str, Any] | None]],
 455:         execution_id: str,
 456:         selection: RunSelection,
 457:         audit: AuditRepositories,
 458:     ) -> tuple[
 459:         list[tuple[DownloadResult, dict[str, Any] | None]],
 460:         list[FileOutcome],
 461:     ]:
 462:         downloaded: list[tuple[DownloadResult, dict[str, Any] | None]] = []
 463:         failures: list[FileOutcome] = []
 464:         hvfhv_semaphore = threading.Semaphore(selection.max_hvfhv_workers)
 465: 
 466:         def task(
 467:             candidate: FileCandidate,
 468:             remote: RemoteMetadata,
 469:             existing: dict[str, Any] | None,
 470:         ) -> tuple[DownloadResult, dict[str, Any] | None]:
 471:             semaphore = hvfhv_semaphore if candidate.service == "fhvhv" else None
 472:             if semaphore is not None:
 473:                 semaphore.acquire()
 474:             try:
 475:                 audit.registry.set_status(
 476:                     candidate,
 477:                     execution_id,
 478:                     "DOWNLOADING",
 479:                     remote_metadata=remote.to_dict(),
 480:                 )
 481: 
 482:                 def on_attempt(event: dict[str, Any]) -> None:
 483:                     if audit.unified is not None:
 484:                         audit.unified.record_download_attempt(
 485:                             execution_id,
 486:                             service=candidate.service,
 487:                             year=candidate.year,
 488:                             month=candidate.month,
 489:                             url=candidate.url,
 490:                             **event,
 491:                         )
 492: 
 493:                 download_parameters = inspect.signature(
 494:                     self._downloader.download
 495:                 ).parameters
 496:                 if "attempt_callback" in download_parameters:
 497:                     result = self._downloader.download(
 498:                         candidate, execution_id, remote, attempt_callback=on_attempt
 499:                     )
 500:                 else:
 501:                     # Keeps injected/test downloaders compatible while the real
 502:                     # downloader records every retry through the callback.
 503:                     result = self._downloader.download(
 504:                         candidate, execution_id, remote
 505:                     )
 506:                 audit.registry.set_status(
 507:                     candidate,
 508:                     execution_id,
 509:                     "DOWNLOADED",
 510:                     bytes_downloaded=result.bytes_downloaded,
 511:                     sha256=result.sha256,
 512:                 )
 513:                 return result, existing
 514:             finally:
 515:                 if semaphore is not None:
 516:                     semaphore.release()
 517: 
 518:         max_workers = selection.workers if self._config.download.parallel_enabled else 1
 519:         if max_workers == 1:
 520:             consecutive_deferred = 0
 521:             for index, (candidate, remote, existing) in enumerate(pending):
 522:                 try:
 523:                     downloaded.append(task(candidate, remote, existing))
 524:                     consecutive_deferred = 0
 525:                 except Exception as exc:
 526:                     outcome = self._failure_outcome(candidate, exc)
 527:                     self._storage.discard_temporary(candidate, execution_id)
 528:                     if outcome.status == DEFERRED_REMOTE_ACCESS:
 529:                         audit.registry.mark_deferred(outcome, execution_id)
 530:                         consecutive_deferred += 1
 531:                     else:
 532:                         audit.registry.mark_failed(outcome, execution_id)
 533:                         consecutive_deferred = 0
 534:                     failures.append(outcome)
 535:                     if consecutive_deferred >= 2:
 536:                         for deferred_candidate, deferred_remote, _ in pending[index + 1 :]:
 537:                             deferred = FileOutcome(
 538:                                 candidate=deferred_candidate,
 539:                                 status=DEFERRED_REMOTE_ACCESS,
 540:                                 remote_metadata=deferred_remote,
 541:                             )
 542:                             deferred.error_type = "RemoteAccessDeferred"
 543:                             deferred.error_message = (
 544:                                 "Se abrió un corte preventivo tras bloqueos remotos consecutivos."
 545:                             )
 546:                             deferred.finish()
 547:                             audit.registry.mark_deferred(deferred, execution_id)
 548:                             failures.append(deferred)
 549:                         break
 550:             return downloaded, failures
 551: 
 552:         with ThreadPoolExecutor(max_workers=max_workers) as executor:
 553:             future_map: dict[
 554:                 Future[tuple[DownloadResult, dict[str, Any] | None]],
 555:                 FileCandidate,
 556:             ] = {}
 557:             for candidate, remote, existing in pending:
 558:                 future_map[executor.submit(task, candidate, remote, existing)] = candidate
 559: 
 560:             for future in as_completed(future_map):
 561:                 candidate = future_map[future]
 562:                 try:
 563:                     downloaded.append(future.result())
 564:                 except Exception as exc:
 565:                     outcome = self._failure_outcome(candidate, exc)
 566:                     self._storage.discard_temporary(candidate, execution_id)
 567:                     if outcome.status == DEFERRED_REMOTE_ACCESS:
 568:                         audit.registry.mark_deferred(outcome, execution_id)
 569:                     else:
 570:                         audit.registry.mark_failed(outcome, execution_id)
 571:                     failures.append(outcome)
 572:         return downloaded, failures
