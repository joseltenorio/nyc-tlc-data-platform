237: class JsonlAuditRepository:
238:     def __init__(self) -> None:
239:         dashboard = load_dashboard_config()
240:         raw = audit_config().get("filesystem", {})
241:         root_value = dashboard.get("paths", {}).get("audit_root") or raw.get("root", "data/audit")
242:         self.root = project_path(root_value)
243:         self._settings = (
244:             str(raw.get("pipeline_runs_file", "pipeline_runs.jsonl")),
245:             str(raw.get("dataset_events_file", "dataset_events.jsonl")),
246:             str(raw.get("quality_events_file", "quality_events.jsonl")),
247:             str(raw.get("coverage_snapshots_file", "coverage_snapshots.jsonl")),
248:             str(raw.get("download_attempts_file", "download_attempts.jsonl")),
249:             str(raw.get("inventory_current_file", "medallion_inventory.json")),
250:         )
251:         self._limit = int(audit_config().get("retention", {}).get("max_dashboard_documents", 20000))
252: 
253:     def load(self) -> JsonlAuditData:
254:         files = list(self.root.rglob("*.jsonl")) if self.root.is_dir() else []
255:         current = self.root / "inventory" / self._settings[-1]
256:         all_files = files + ([current] if current.is_file() else [])
257:         signature = (
258:             len(all_files),
259:             max((path.stat().st_mtime_ns for path in all_files), default=0),
260:             sum((path.stat().st_size for path in all_files), 0),
261:         )
262:         return _load_jsonl_cached(
263:             str(self.root), signature, self._settings, self._limit
264:         )
