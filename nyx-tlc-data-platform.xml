 229:                 "end_year": selection.end_year,
 230:                 "months": selection.months,
 231:                 "workers": selection.workers,
 232:                 "max_hvfhv_workers": selection.max_hvfhv_workers,
 233:                 "force": force,
 234:                 "dry_run": dry_run,
 235:             },
 236:         )
 237:         if audit.unified is not None:
 238:             audit.unified.start_run(
 239:                 execution_id,
 240:                 layer="bronze",
 241:                 execution_type="DRY_RUN" if dry_run else execution_type.upper(),
 242:                 selection={
 243:                     "services": selection.services,
 244:                     "start_year": selection.start_year,
 245:                     "end_year": selection.end_year,
 246:                     "months": selection.months,
 247:                     "max_retries": self._config.download.max_retries,
 248:                 },
 249:                 started_at=started_at,
 250:             )
 251: 
 252:         outcomes: list[FileOutcome] = []
 253:         availability: list[AvailabilityRecord] = []
 254:         discovery = None
 255:         try:
 256:             discovery = self._discovery.discover(
 257:                 execution_id,
 258:                 selection.services,
 259:                 selection.start_year,
 260:                 selection.end_year,
 261:                 selection.months,
 262:             )
 263:             remote_map = self._probe_candidates(
 264:                 discovery.candidates, selection.workers
 265:             )
 266:             availability = self._merge_probe_results(
 267:                 discovery.availability, remote_map
 268:             )
 269:             audit.availability.insert_many(availability)
 270:             manifest.set_availability(availability)
 271: 
 272:             available_candidates = [
 273:                 candidate
 274:                 for candidate in discovery.candidates
 275:                 if remote_map.get(candidate.period_id, RemoteMetadata(False)).available
 276:             ]
 277: 
 278:             if dry_run:
 279:                 for candidate in available_candidates:
 280:                     outcome = FileOutcome(candidate=candidate, status="DRY_RUN")
 281:                     outcome.remote_metadata = remote_map[candidate.period_id]
 282:                     outcome.finish()
 283:                     outcomes.append(outcome)
 284:                     manifest.add_outcome(outcome)
 285:                 return self._finish_execution(
 286:                     audit,
 287:                     manifest,
 288:                     execution_id,
 289:                     "DRY_RUN",
 290:                     started_at,
 291:                     selection,
 292:                     discovery,
 293:                     availability,
 294:                     outcomes,
 295:                 )
 296: 
 297:             pending: list[tuple[FileCandidate, RemoteMetadata, dict[str, Any] | None]] = []
 298:             for candidate in available_candidates:
 299:                 remote = remote_map[candidate.period_id]
 300:                 existing = audit.registry.get(candidate)
 301:                 destination = self._storage.final_path(candidate)
 302:                 if not force and self._is_unchanged(existing, destination, remote):
 303:                     outcome = FileOutcome(
 304:                         candidate=candidate,
 305:                         status="SKIPPED_UNCHANGED",
 306:                         remote_metadata=remote,
 307:                         local_path=str(destination),
 308:                     )
 309:                     current = (existing or {}).get("current") or {}
 310:                     outcome.sha256 = current.get("sha256")
 311:                     outcome.finish()
 312:                     outcomes.append(outcome)
 313:                     manifest.add_outcome(outcome)
 314:                     continue
 315: 
 316:                 if not audit.registry.claim(candidate, execution_id):
 317:                     outcome = FileOutcome(
 318:                         candidate=candidate,
 319:                         status="SKIPPED_CLAIMED",
 320:                         remote_metadata=remote,
 321:                     )
 322:                     outcome.finish()
 323:                     outcomes.append(outcome)
 324:                     manifest.add_outcome(outcome)
 325:                     continue
 326:                 pending.append((candidate, remote, existing))
 327: 
 328:             downloaded, failed_downloads = self._download_pending(
 329:                 pending,
 330:                 execution_id,
 331:                 selection,
 332:                 audit,
 333:             )
 334:             for outcome in failed_downloads:
 335:                 outcomes.append(outcome)
 336:                 manifest.add_outcome(outcome)
 337: 
 338:             if downloaded:
 339:                 spark = self._spark.get()
 340:                 spark_guard = (
 341:                     self._spark.guard() if hasattr(self._spark, "guard") else None
 342:                 )
 343:                 for result, existing in downloaded:
 344:                     outcome = self._validate_and_publish(
 345:                         result,
 346:                         existing,
 347:                         execution_id,
 348:                         spark,
 349:                         audit,
 350:                         spark_guard=spark_guard,
 351:                     )
 352:                     outcomes.append(outcome)
 353:                     manifest.add_outcome(outcome)
 354:                     if (
 355:                         outcome.status == "FAILED"
