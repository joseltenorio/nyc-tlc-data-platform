  2: 
  3: import shutil
  4: from datetime import datetime, timedelta, timezone
  5: from dataclasses import dataclass
  6: from pathlib import Path
  7: from typing import Any
  8: 
  9: from tlc_data_platform.audit.parquet_metrics import parquet_files
 10: from tlc_data_platform.core.settings import (
 11:     GoldConfig,
 12:     RunSelection,
 13:     ServiceConfig,
 14:     SilverStorageConfig,
 15: )
 16: 
 17: 
 18: @dataclass(frozen=True)
 19: class GoldSourcePartition:
 20:     service: str
 21:     year: int
 22:     month: int
 23:     path: Path
 24: 
 25:     @property
 26:     def period_id(self) -> str:
 27:         return f"{self.service}/{self.year}-{self.month:02d}"
 28: 
 29: 
 30: class GoldStorage:
 31:     """Resolves inputs and publishes Gold directories using recoverable swaps."""
 32: 
 33:     def __init__(
 34:         self,
 35:         gold: GoldConfig,
 36:         silver: SilverStorageConfig,
 37:         services: dict[str, ServiceConfig],
 38:     ) -> None:
 39:         self.gold = gold
 40:         self.silver = silver
 41:         self.services = services
 42: 
 43:     def ensure_directories(self) -> None:
 44:         for path in (
 45:             self.gold.storage.gold_root,
 46:             self.gold.storage.temporary_root,
 47:             self.gold.storage.manifests_root,
 48:         ):
 49:             path.mkdir(parents=True, exist_ok=True)
 50:         self.recover_interrupted_promotions()
 51: 
 52:     def recover_interrupted_promotions(self) -> None:
 53:         root = self.gold.storage.gold_root
 54:         if not root.is_dir():
 55:             return
 56:         for backup in sorted(root.rglob("*.previous-*")):
 57:             if not backup.is_dir():
 58:                 continue
 59:             destination_name = backup.name.split(".previous-", 1)[0]
 60:             destination = backup.with_name(destination_name)
 61:             if destination.exists():
 62:                 shutil.rmtree(backup, ignore_errors=True)
 63:             else:
 64:                 backup.rename(destination)
 65: 
 66:     def cleanup_execution(self, execution_id: str) -> None:
 67:         shutil.rmtree(self.gold.storage.temporary_root / execution_id, ignore_errors=True)
 68: 
 69:     def cleanup_stale_temporary(self, *, older_than_hours: int = 24) -> None:
 70:         root = self.gold.storage.temporary_root
 71:         if not root.is_dir():
 72:             return
 73:         cutoff = datetime.now(timezone.utc) - timedelta(hours=older_than_hours)
 74:         for child in root.iterdir():
 75:             if not child.is_dir():
 76:                 continue
 77:             try:
 78:                 modified = datetime.fromtimestamp(child.stat().st_mtime, timezone.utc)
 79:             except OSError:
 80:                 continue
 81:             if modified < cutoff:
 82:                 shutil.rmtree(child, ignore_errors=True)
 83: 
 84:     def dimension_path(self, logical_name: str) -> Path:
 85:         return self.gold.storage.gold_root / self.gold.storage.dimensions_root / self.gold.datasets.dimensions[logical_name]
 86: 
 87:     def fact_path(self, logical_name: str) -> Path:
 88:         return self.gold.storage.gold_root / self.gold.storage.facts_root / self.gold.datasets.facts[logical_name]
 89: 
 90:     def mart_path(self, logical_name: str) -> Path:
 91:         return self.gold.storage.gold_root / self.gold.storage.marts_root / self.gold.datasets.marts[logical_name]
 92: 
 93:     def feature_path(self, logical_name: str) -> Path:
 94:         return self.gold.storage.gold_root / self.gold.storage.features_root / self.gold.datasets.ml_features[logical_name]
 95: 
 96:     def silver_master_partition(self, service: str, year: int, month: int) -> Path:
 97:         return (
 98:             self.silver.silver_root
 99:             / self.silver.master_dataset
100:             / f"service_type={service}"
101:             / f"year={year}"
102:             / f"month={month:02d}"
103:         )
104: 
105:     def selected_master_partitions(self, selection: RunSelection) -> tuple[list[GoldSourcePartition], list[str]]:
106:         available: list[GoldSourcePartition] = []
107:         missing: list[str] = []
108:         for service in selection.services:
109:             for year in range(selection.start_year, selection.end_year + 1):
110:                 for month in selection.months:
111:                     if not self.period_in_scope(service, year, month):
112:                         continue
113:                     path = self.silver_master_partition(service, year, month)
114:                     item = GoldSourcePartition(service, year, month, path)
115:                     if self.has_parquet(path):
116:                         available.append(item)
117:                     else:
118:                         missing.append(item.period_id)
119:         return available, missing
120: 
121:     def selected_master_paths(self, selection: RunSelection) -> tuple[list[Path], list[str]]:
122:         partitions, missing = self.selected_master_partitions(selection)
123:         return [item.path for item in partitions], missing
124: 
125:     def applicable_period_count(self, selection: RunSelection) -> int:
126:         return sum(
127:             self.period_in_scope(service, year, month)
128:             for service in selection.services
129:             for year in range(selection.start_year, selection.end_year + 1)
130:             for month in selection.months
131:         )
132: 
133:     def scoped_master_paths(self, start_year: int, end_year: int) -> list[Path]:
134:         paths: list[Path] = []
135:         for service in sorted(self.services):
136:             for year in range(start_year, end_year + 1):
137:                 for month in range(1, 13):
138:                     if not self.period_in_scope(service, year, month):
139:                         continue
140:                     path = self.silver_master_partition(service, year, month)
141:                     if self.has_parquet(path):
142:                         paths.append(path)
143:         return paths
144: 
145:     def scoped_fact_paths(
146:         self, logical_name: str, start_year: int, end_year: int
147:     ) -> list[Path]:
148:         supported_services = {
149:             "trip_activity": set(self.services),
150:             "taxi_financial": {"yellow", "green"},
151:             "hvfhv_operations": {"fhvhv"},
152:         }[logical_name]
153:         paths: list[Path] = []
154:         for service in sorted(supported_services):
155:             if service not in self.services:
156:                 continue
157:             for year in range(start_year, end_year + 1):
158:                 for month in range(1, 13):
159:                     if not self.period_in_scope(service, year, month):
160:                         continue
161:                     path = self.fact_partition_path(
162:                         logical_name, service, year, month
163:                     )
164:                     if self.has_parquet(path):
165:                         paths.append(path)
166:         return paths
167: 
168:     def period_in_scope(self, service: str, year: int, month: int) -> bool:
169:         config = self.services[service]
170:         point = (year, month)
171:         return (
172:             point >= (config.available_from.year, config.available_from.month)
173:             and point >= (config.scope_from.year, config.scope_from.month)
174:             and point <= (config.scope_to.year, config.scope_to.month)
175:         )
176: 
177:     def taxi_zone_path(self) -> Path:
178:         return self.silver.silver_root / self.silver.taxi_zones_dataset
179: 
180:     @staticmethod
181:     def has_parquet(path: Path) -> bool:
182:         return bool(parquet_files(path))
183: 
184:     def fact_partition_path(self, logical_name: str, service: str, year: int, month: int) -> Path:
185:         return (
186:             self.fact_path(logical_name)
187:             / f"service_type={service}"
188:             / f"source_year={year}"
189:             / f"source_month={month}"
190:         )
191: 
192:     def write_atomic(self, frame: Any, destination: Path, execution_id: str, logical_name: str) -> Path:
193:         staging = self._staging_path(execution_id, logical_name)
194:         shutil.rmtree(staging, ignore_errors=True)
195:         staging.parent.mkdir(parents=True, exist_ok=True)
196:         (
197:             frame.write.mode("overwrite")
198:             .option("compression", self.gold.execution.parquet_compression)
199:             .parquet(str(staging))
200:         )
201:         self._validate_staging(staging)
202:         self._promote(staging, destination, execution_id)
203:         return destination
204: 
205:     def write_fact_partition_atomic(
206:         self,
207:         frame: Any,
208:         logical_name: str,
209:         service: str,
210:         year: int,
211:         month: int,
212:         execution_id: str,
213:     ) -> Path:
214:         destination = self.fact_partition_path(logical_name, service, year, month)
215:         staging = self._staging_path(
216:             execution_id, f"fact-{logical_name}-{service}-{year}-{month:02d}"
217:         )
218:         shutil.rmtree(staging, ignore_errors=True)
219:         staging.parent.mkdir(parents=True, exist_ok=True)
220:         data = frame.drop("service_type", "source_year", "source_month")
221:         (
222:             data.write.mode("overwrite")
223:             .option("compression", self.gold.execution.parquet_compression)
224:             .parquet(str(staging))
225:         )
226:         self._validate_staging(staging, allow_empty=False)
227:         self._promote(staging, destination, execution_id)
228:         return destination
229: 
230:     def _staging_path(self, execution_id: str, logical_name: str) -> Path:
231:         return self.gold.storage.temporary_root / execution_id / logical_name
232: 
233:     @staticmethod
234:     def _validate_staging(path: Path, *, allow_empty: bool = False) -> None:
235:         if not path.is_dir() or not (path / "_SUCCESS").exists():
236:             raise RuntimeError(f"Spark no completó la escritura temporal: {path}")
237:         if not allow_empty and not parquet_files(path):
238:             raise RuntimeError(f"La escritura temporal no contiene Parquet: {path}")
239: 
240:     @staticmethod
241:     def _promote(staging: Path, destination: Path, execution_id: str) -> None:
242:         destination.parent.mkdir(parents=True, exist_ok=True)
243:         backup = destination.with_name(f"{destination.name}.previous-{execution_id}")
244:         shutil.rmtree(backup, ignore_errors=True)
245:         had_previous = destination.exists()
246:         try:
247:             if had_previous:
248:                 destination.rename(backup)
249:             staging.rename(destination)
250:             shutil.rmtree(backup, ignore_errors=True)
251:         except Exception:
252:             if destination.exists():
253:                 shutil.rmtree(destination, ignore_errors=True)
254:             if had_previous and backup.exists():
255:                 backup.rename(destination)
256:             raise
