 90: def format_compact(value: float | int | None, *, decimals: int = 1) -> str:
 91:     if value is None:
 92:         return "—"
 93:     try:
 94:         number = float(value)
 95:     except (TypeError, ValueError):
 96:         return "—"
 97:     absolute = abs(number)
 98:     for divisor, suffix in ((1_000_000_000, "B"), (1_000_000, "M"), (1_000, "K")):
 99:         if absolute >= divisor:
100:             return f"{number / divisor:.{decimals}f}{suffix}"
101:     if number.is_integer():
102:         return f"{int(number):,}"
103:     return f"{number:,.{decimals}f}"
104: 
105: 
106: def format_duration(seconds: float | int | None) -> str:
107:     if seconds is None:
108:         return "—"
109:     try:
110:         total = max(0, int(float(seconds)))
111:     except (TypeError, ValueError):
112:         return "—"
113:     hours, remainder = divmod(total, 3600)
114:     minutes, secs = divmod(remainder, 60)
115:     if hours:
116:         return f"{hours}h {minutes:02d}m"
117:     if minutes:
118:         return f"{minutes}m {secs:02d}s"
119:     return f"{secs}s"
