  1: from __future__ import annotations
  2: 
  3: from datetime import timedelta
  4: from typing import Any
  5: 
  6: from tlc_data_platform.silver.models import SilverFileOutcome, SilverSourceFile, utc_now
  7: 
  8: 
  9: class SilverFileRegistryRepository:
 10:     def __init__(
 11:         self,
 12:         collection: Any,
 13:         claim_ttl_minutes: int = 360,
 14:         execution_repository: Any | None = None,
 15:     ) -> None:
 16:         self._collection = collection
 17:         self._claim_ttl_minutes = claim_ttl_minutes
 18:         self._execution_repository = execution_repository
 19: 
 20:     @staticmethod
 21:     def key(source: SilverSourceFile) -> dict[str, Any]:
 22:         return {"service": source.service, "year": source.year, "month": source.month}
 23: 
 24:     def get(self, source: SilverSourceFile) -> dict[str, Any] | None:
 25:         return self._collection.find_one(self.key(source), {"_id": 0})
 26: 
 27:     def claim(self, source: SilverSourceFile, execution_id: str) -> bool:
 28:         from pymongo.errors import DuplicateKeyError
 29: 
 30:         now = utc_now()
 31:         expires_at = now + timedelta(minutes=self._claim_ttl_minutes)
 32:         key = self.key(source)
 33:         filter_doc = {
 34:             **key,
 35:             "$or": [
 36:                 {"claim": {"$exists": False}},
 37:                 {"claim.expires_at": {"$lt": now}},
 38:                 {"claim.execution_id": execution_id},
 39:             ],
 40:         }
 41:         update = {
 42:             "$set": {
 43:                 **key,
 44:                 "status": "PROCESSING",
 45:                 "claim": {
 46:                     "execution_id": execution_id,
 47:                     "claimed_at": now,
 48:                     "expires_at": expires_at,
 49:                 },
 50:                 "updated_at": now,
 51:             },
 52:             "$setOnInsert": {"created_at": now},
 53:         }
 54:         try:
 55:             result = self._collection.update_one(filter_doc, update, upsert=True)
 56:         except DuplicateKeyError:
 57:             result = None
 58:         if result is not None and (result.matched_count or result.upserted_id):
 59:             return True
 60: 
 61:         current = self._collection.find_one(key, {"_id": 0, "claim": 1})
 62:         if current is None:
 63:             try:
 64:                 retry = self._collection.update_one(filter_doc, update, upsert=True)
 65:             except DuplicateKeyError:
 66:                 return False
 67:             return bool(retry.matched_count or retry.upserted_id)
 68: 
 69:         claim = current.get("claim") or {}
 70:         if not self._is_recoverable_claim(claim, execution_id, now):
 71:             return False
 72:         recovery_filter = self._recovery_filter(key, claim)
 73:         recovered = self._collection.update_one(recovery_filter, update, upsert=False)
 74:         return bool(recovered.matched_count)
 75: 
 76:     def _is_recoverable_claim(
 77:         self,
 78:         claim: dict[str, Any],
 79:         execution_id: str,
 80:         now: Any,
 81:     ) -> bool:
 82:         owner = claim.get("execution_id")
 83:         if not owner or owner == execution_id:
 84:             return True
 85:         expires_at = claim.get("expires_at")
 86:         if expires_at is not None and expires_at < now:
 87:             return True
 88:         if self._execution_repository is None:
 89:             return False
 90:         execution = self._execution_repository.get(owner)
 91:         if execution is None:
 92:             return True
 93:         if execution.get("finished_at") is not None:
 94:             return True
 95:         return execution.get("status") in {
 96:             "SUCCESS",
 97:             "PARTIAL_SUCCESS",
 98:             "FAILED",
 99:             "NO_INPUT",
100:         }
101: 
102:     @staticmethod
103:     def _recovery_filter(
104:         key: dict[str, Any], claim: dict[str, Any]
105:     ) -> dict[str, Any]:
106:         filter_doc = dict(key)
107:         for field in ("execution_id", "claimed_at", "expires_at"):
108:             if claim.get(field) is not None:
109:                 filter_doc[f"claim.{field}"] = claim[field]
110:         if len(filter_doc) == len(key):
111:             filter_doc["claim"] = {"$exists": True}
112:         return filter_doc
113: 
114:     def is_unchanged(self, source: SilverSourceFile, outputs_exist: bool) -> bool:
115:         current = self.get(source)
116:         return bool(
117:             current
118:             and current.get("status") == "READY"
119:             and current.get("source_sha256")
120:             and current.get("source_sha256") == source.source_sha256
121:             and outputs_exist
122:         )
123: 
124:     def mark_ready(self, outcome: SilverFileOutcome, execution_id: str) -> None:
125:         self._collection.update_one(
126:             self.key(outcome.source),
127:             {
128:                 "$set": {
129:                     **self.key(outcome.source),
130:                     "status": "READY",
131:                     "source_sha256": outcome.source.source_sha256,
132:                     "bronze_execution_id": outcome.source.bronze_execution_id,
133:                     "curated_path": outcome.curated_path,
134:                     "rejected_path": outcome.rejected_path,
135:                     "master_path": outcome.master_path,
136:                     "rows_read": outcome.rows_read,
137:                     "rows_valid": outcome.rows_valid,
138:                     "rows_rejected": outcome.rows_rejected,
139:                     "warning_rows": outcome.warning_rows,
140:                     "rule_counts": outcome.rule_counts,
141:                     "rule_severities": outcome.rule_severities,
142:                     "reconciliation_status": outcome.reconciliation_status,
143:                     "last_execution_id": execution_id,
144:                     "ready_at": outcome.finished_at,
145:                     "updated_at": utc_now(),
146:                 },
147:                 "$unset": {"claim": "", "last_error": ""},
148:                 "$setOnInsert": {"created_at": utc_now()},
149:             },
150:             upsert=True,
151:         )
152: 
153:     def mark_failed(self, outcome: SilverFileOutcome, execution_id: str) -> None:
154:         self._collection.update_one(
155:             self.key(outcome.source),
156:             {
157:                 "$set": {
158:                     "status": "FAILED",
159:                     "last_execution_id": execution_id,
160:                     "last_error": {
161:                         "type": outcome.error_type,
162:                         "message": outcome.error_message,
163:                         "at": outcome.finished_at,
164:                     },
165:                     "updated_at": utc_now(),
166:                 },
167:                 "$unset": {"claim": ""},
168:             },
169:             upsert=True,
170:         )
171: 
172:     def release_claim(self, source: SilverSourceFile, execution_id: str) -> None:
173:         self._collection.update_one(
174:             {**self.key(source), "claim.execution_id": execution_id},
175:             {"$unset": {"claim": ""}, "$set": {"updated_at": utc_now()}},
176:         )
177: 
178:     def release_claims_for_execution(self, execution_id: str) -> int:
179:         result = self._collection.update_many(
180:             {"claim.execution_id": execution_id},
181:             {"$unset": {"claim": ""}, "$set": {"updated_at": utc_now()}},
182:         )
183:         return int(result.modified_count)
</file>

