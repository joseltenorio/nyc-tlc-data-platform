  1: from __future__ import annotations
  2: 
  3: import email.utils
  4: import logging
  5: import threading
  6: import time
  7: from datetime import datetime, timezone
  8: from typing import Any, Callable
  9: 
 10: import requests
 11: 
 12: from tlc_data_platform.core.settings import DiscoveryConfig, DownloadConfig
 13: 
 14: LOGGER = logging.getLogger(__name__)
 15: 
 16: 
 17: class HttpClient:
 18:     """Thread-local HTTP sessions with bounded retries and Retry-After support."""
 19: 
 20:     RETRYABLE_STATUS_CODES = {429, 500, 502, 503, 504}
 21: 
 22:     def __init__(
 23:         self,
 24:         discovery: DiscoveryConfig,
 25:         download: DownloadConfig,
 26:     ) -> None:
 27:         self._discovery = discovery
 28:         self._download = download
 29:         self._local = threading.local()
 30:         self._sessions: list[requests.Session] = []
 31:         self._sessions_lock = threading.Lock()
 32: 
 33:     def _session(self) -> requests.Session:
 34:         session = getattr(self._local, "session", None)
 35:         if session is None:
 36:             session = requests.Session()
 37:             session.headers.update({"User-Agent": self._discovery.user_agent})
 38:             self._local.session = session
 39:             with self._sessions_lock:
 40:                 self._sessions.append(session)
 41:         return session
 42: 
 43:     @property
 44:     def timeout(self) -> tuple[int, int]:
 45:         return (
 46:             self._download.connect_timeout_seconds,
 47:             self._download.read_timeout_seconds,
 48:         )
 49: 
 50:     def request(self, method: str, url: str, **kwargs: Any) -> requests.Response:
 51:         max_retries = int(kwargs.pop("max_retries_override", self._download.max_retries))
 52:         if max_retries < 0:
 53:             raise ValueError("max_retries_override no puede ser negativo")
 54:         max_attempts = max_retries + 1
 55:         backoff = self._download.initial_backoff_seconds
 56:         last_error: Exception | None = None
 57:         retryable_status_codes = set(
 58:             kwargs.pop("retryable_status_codes", self.RETRYABLE_STATUS_CODES)
 59:         )
 60:         attempt_callback: Callable[[dict[str, Any]], None] | None = kwargs.pop(
 61:             "attempt_callback", None
 62:         )
 63:         timeout = kwargs.pop("timeout", self.timeout)
 64:         verify = kwargs.pop("verify", self._discovery.verify_tls)
 65: 
 66:         for attempt in range(1, max_attempts + 1):
 67:             try:
 68:                 response = self._session().request(
 69:                     method,
 70:                     url,
 71:                     timeout=timeout,
 72:                     verify=verify,
 73:                     **kwargs,
 74:                 )
 75:                 retryable = response.status_code in retryable_status_codes
 76:                 is_final = not retryable or attempt == max_attempts
 77:                 delay = None if is_final else self._retry_delay(response, backoff)
 78:                 if attempt_callback is not None:
 79:                     attempt_callback(
 80:                         {
 81:                             "attempt_number": attempt,
 82:                             "max_attempts": max_attempts,
 83:                             "status_code": response.status_code,
 84:                             "outcome": "SUCCESS" if not retryable else ("EXHAUSTED" if is_final else "RETRY"),
 85:                             "retry_delay_seconds": delay,
 86:                             "error_type": None,
 87:                             "error_message": None,
 88:                         }
 89:                     )
 90:                 if is_final:
 91:                     return response
 92:                 LOGGER.warning(
 93:                     "HTTP %s para %s; reintento %s/%s en %.1fs",
 94:                     response.status_code,
 95:                     url,
 96:                     attempt,
 97:                     max_retries,
 98:                     delay,
 99:                 )
100:                 response.close()
101:                 time.sleep(float(delay))
102:                 backoff = min(backoff * 2, self._download.max_backoff_seconds)
103:             except (requests.Timeout, requests.ConnectionError) as exc:
104:                 last_error = exc
105:                 is_final = attempt == max_attempts
106:                 delay = None if is_final else min(backoff, self._download.max_backoff_seconds)
107:                 if attempt_callback is not None:
108:                     attempt_callback(
109:                         {
110:                             "attempt_number": attempt,
111:                             "max_attempts": max_attempts,
112:                             "status_code": None,
113:                             "outcome": "EXHAUSTED" if is_final else "RETRY",
114:                             "retry_delay_seconds": delay,
115:                             "error_type": type(exc).__name__,
116:                             "error_message": str(exc)[:2000],
117:                         }
118:                     )
119:                 if is_final:
120:                     raise
121:                 LOGGER.warning(
122:                     "Error temporal para %s; reintento %s/%s en %.1fs: %s",
123:                     url,
124:                     attempt,
125:                     max_retries,
126:                     delay,
127:                     exc,
128:                 )
129:                 time.sleep(float(delay))
130:                 backoff = min(backoff * 2, self._download.max_backoff_seconds)
131: 
132:         if last_error is not None:
133:             raise last_error
134:         raise RuntimeError("El cliente HTTP agotó los reintentos sin respuesta")
135: 
136:     @staticmethod
137:     def _retry_delay(response: requests.Response, fallback: float) -> float:
138:         retry_after = response.headers.get("Retry-After")
139:         if not retry_after:
140:             return fallback
141:         try:
142:             return max(0.0, float(retry_after))
143:         except ValueError:
144:             try:
145:                 parsed = email.utils.parsedate_to_datetime(retry_after)
146:                 now = datetime.now(timezone.utc)
147:                 return max(0.0, (parsed - now).total_seconds())
148:             except (TypeError, ValueError, OverflowError):
149:                 return fallback
150: 
151:     def get_text(self, url: str) -> str:
152:         response = self.request("GET", url)
153:         try:
154:             response.raise_for_status()
155:             return response.text
156:         finally:
157:             response.close()
158: 
159:     def close(self) -> None:
160:         with self._sessions_lock:
161:             sessions = list(self._sessions)
162:             self._sessions.clear()
163:         for session in sessions:
164:             session.close()
