 77: def build_service_dimension(spark: Any) -> Any:
 78:     """Documents which analytical capabilities are valid for each TLC service."""
 79:     rows = [
 80:         (1, "yellow", "Yellow Taxi", "TAXI", True, True, False, False),
 81:         (2, "green", "Green Taxi", "TAXI", True, True, False, False),
 82:         (3, "fhv", "For-Hire Vehicle", "FHV", False, False, True, False),
 83:         (4, "fhvhv", "High Volume FHV", "HVFHV", True, False, True, True),
 84:     ]
 85:     return spark.createDataFrame(
 86:         rows,
 87:         "service_key int, service_code string, service_name string, service_category string, "
 88:         "supports_financial_analysis boolean, supports_passenger_analysis boolean, "
 89:         "supports_shared_ride_analysis boolean, supports_accessibility_analysis boolean",
 90:     )
