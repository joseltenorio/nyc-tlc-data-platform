 14: FILE_PATTERN = re.compile(
 15:     r"(?P<service>yellow|green|fhv|fhvhv)_tripdata_"
 16:     r"(?P<year>\d{4})-(?P<month>\d{2})\.parquet$",
 17:     re.IGNORECASE,
 18: )
 19: 
 20: TYPE_ALIASES = {
 21:     "int": "integer",
 22:     "integer": "integer",
 23:     "bigint": "long",
 24:     "long": "long",
 25: }
 26: 
 27: 
 28: def _normalized_lookup(columns: list[str]) -> dict[str, str]:
 29:     return {column.casefold(): column for column in columns}
 30: 
 31: 
 32: def normalize_spark_type_name(type_name: str) -> str:
 33:     normalized = type_name.strip().lower()
 34:     base, _, suffix = normalized.partition("(")
 35:     canonical = TYPE_ALIASES.get(base, base)
 36:     return canonical if not suffix else f"{canonical}({suffix}"
 37: 
 38: 
 39: def match_contract_fields(
 40:     columns: list[str],
 41:     definitions: dict[str, dict[str, Any]],
 42: ) -> tuple[dict[str, str], list[str]]:
 43:     lookup = _normalized_lookup(columns)
 44:     matches: dict[str, str] = {}
 45:     missing: list[str] = []
 46:     for logical_name, definition in definitions.items():
 47:         aliases = [str(value) for value in definition.get("aliases", [])]
 48:         match = next((lookup[a.casefold()] for a in aliases if a.casefold() in lookup), None)
 49:         if match is None:
 50:             missing.append(logical_name)
 51:         else:
 52:             matches[logical_name] = match
 53:     return matches, missing
 54: 
 55: 
 56: def _validate_candidate_name(candidate: FileCandidate) -> None:
 57:     match = FILE_PATTERN.fullmatch(candidate.file_name)
 58:     if not match:
 59:         raise ParquetValidationError(
 60:             f"Nombre de archivo no reconocido: {candidate.file_name}"
 61:         )
 62:     if match.group("service").lower() != candidate.service:
 63:         raise ParquetValidationError("El nombre no corresponde al servicio esperado")
 64:     if int(match.group("year")) != candidate.year or int(match.group("month")) != candidate.month:
 65:         raise ParquetValidationError("El nombre no corresponde al año y mes esperados")
 66: 
 67: 
 68: def _physical_metadata(path: Path) -> tuple[int, int, int, str | None, list[str]]:
 69:     try:
 70:         import pyarrow.parquet as pq
 71: 
 72:         parquet = pq.ParquetFile(path)
 73:         metadata = parquet.metadata
 74:         codecs: set[str] = set()
 75:         for row_group_index in range(metadata.num_row_groups):
 76:             row_group = metadata.row_group(row_group_index)
 77:             for column_index in range(row_group.num_columns):
 78:                 codecs.add(str(row_group.column(column_index).compression))
 79:         return (
 80:             metadata.num_rows,
 81:             metadata.num_row_groups,
 82:             metadata.num_columns,
 83:             metadata.created_by,
 84:             sorted(codecs),
 85:         )
 86:     except Exception as exc:
 87:         raise ParquetValidationError(f"No se pudo leer metadata Parquet: {exc}") from exc
 88: 
 89: 
 90: class ParquetValidator:
 91:     def __init__(
 92:         self,
 93:         contracts: dict[str, Any],
 94:         config: ValidationConfig,
 95:     ) -> None:
 96:         self._contracts = contracts
 97:         self._config = config
 98: 
 99:     def validate(self, path: Path, candidate: FileCandidate, spark: Any) -> ValidationResult:
100:         if not path.is_file() or path.stat().st_size == 0:
101:             raise ParquetValidationError("El archivo no existe o está vacío")
102:         if not has_parquet_signature(path):
103:             raise ParquetValidationError("Firma Parquet inválida")
104:         _validate_candidate_name(candidate)
105: 
106:         num_rows, num_row_groups, num_columns, created_by, codecs = _physical_metadata(path)
107:         if num_rows <= 0 or num_columns <= 0:
108:             raise ParquetValidationError("El Parquet no contiene filas o columnas")
109: 
110:         try:
111:             dataframe = spark.read.parquet(str(path))
112:             schema = dataframe.schema
113:             sample_rows_read = len(dataframe.limit(1).collect()) if self._config.read_sample_row else 0
114:         except Exception as exc:
115:             raise ParquetValidationError(f"PySpark no pudo leer el archivo: {exc}") from exc
116: 
117:         observed_columns = list(schema.fieldNames())
118:         observed_types = {
119:             field.name: normalize_spark_type_name(field.dataType.simpleString())
120:             for field in schema.fields
121:         }
122:         schema_json = schema.json()
123:         schema_hash = hashlib.sha256(schema_json.encode("utf-8")).hexdigest()
124: 
125:         contract = self._contracts[candidate.service]
126:         required_definitions = contract.get("required_fields", {})
127:         optional_definitions = contract.get("optional_fields", {})
128:         required_matches, missing_required = match_contract_fields(
129:             observed_columns, required_definitions
130:         )
131:         optional_matches, missing_optional = match_contract_fields(
132:             observed_columns, optional_definitions
133:         )
134:         if missing_required:
135:             raise ParquetValidationError(
136:                 "Faltan campos requeridos: " + ", ".join(sorted(missing_required))
137:             )
138: 
139:         known_aliases = {
140:             str(alias).casefold()
141:             for definitions in (required_definitions, optional_definitions)
142:             for definition in definitions.values()
143:             for alias in definition.get("aliases", [])
144:         }
145:         new_columns = sorted(
146:             column for column in observed_columns if column.casefold() not in known_aliases
147:         )
148:         if new_columns and not self._config.allow_new_columns:
149:             raise ParquetValidationError(
150:                 "Se detectaron columnas nuevas no permitidas: " + ", ".join(new_columns)
151:             )
152: 
153:         type_mismatches: dict[str, dict[str, Any]] = {}
154:         for logical_name, physical_name in required_matches.items():
155:             accepted = [
156:                 normalize_spark_type_name(str(value))
157:                 for value in required_definitions[logical_name].get("accepted_types", [])
158:             ]
159:             observed = observed_types[physical_name]
160:             if accepted and not any(observed == item or observed.startswith(f"{item}(") for item in accepted):
161:                 type_mismatches[logical_name] = {
162:                     "column": physical_name,
163:                     "observed": observed,
164:                     "accepted": accepted,
165:                 }
166:         if type_mismatches:
167:             raise ParquetValidationError(
168:                 "Tipos incompatibles: " + json.dumps(type_mismatches, ensure_ascii=False)
169:             )
170: 
171:         return ValidationResult(
172:             expected_required_columns=sorted(required_definitions),
173:             expected_optional_columns=sorted(optional_definitions),
174:             observed_columns=observed_columns,
175:             missing_required_columns=[],
176:             missing_optional_columns=sorted(missing_optional),
177:             new_columns=new_columns,
178:             observed_types=observed_types,
179:             required_field_matches=required_matches,
180:             optional_field_matches=optional_matches,
181:             type_mismatches={},
182:             schema_json=schema_json,
183:             schema_hash=schema_hash,
184:             schema_evolution_detected=bool(new_columns),
185:             schema_events=["SCHEMA_EVOLUTION_DETECTED"] if new_columns else [],
186:             parquet_num_rows=num_rows,
187:             parquet_num_row_groups=num_row_groups,
188:             parquet_num_columns=num_columns,
189:             parquet_created_by=created_by,
190:             parquet_compression_codecs=codecs,
191:             sample_rows_read=sample_rows_read,
192:         )
</file>

