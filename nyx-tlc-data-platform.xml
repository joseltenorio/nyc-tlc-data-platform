  1: from __future__ import annotations
  2: 
  3: from dataclasses import dataclass
  4: from typing import Any
  5: 
  6: from tlc_data_platform.core.settings import SilverStorageConfig
  7: from tlc_data_platform.silver.transformers.common import append_quality_rules
  8: 
  9: 
 10: @dataclass(frozen=True)
 11: class SilverReferenceData:
 12:     taxi_zones: Any
 13:     base_lookup: Any
 14: 
 15:     @classmethod
 16:     def load(cls, spark: Any, storage: SilverStorageConfig) -> "SilverReferenceData":
 17:         taxi_path = storage.silver_root / storage.taxi_zones_dataset
 18:         base_path = storage.silver_root / storage.base_lookup_dataset
 19:         return cls(
 20:             taxi_zones=spark.read.parquet(str(taxi_path)),
 21:             base_lookup=spark.read.parquet(str(base_path)),
 22:         )
 23: 
 24: 
 25: def _add_null_columns(df: Any, columns: dict[str, str]) -> Any:
 26:     from pyspark.sql import functions as F
 27: 
 28:     for name, dtype in columns.items():
 29:         if name not in df.columns:
 30:             df = df.withColumn(name, F.lit(None).cast(dtype))
 31:     return df
 32: 
 33: 
 34: def enrich_trip(
 35:     df: Any,
 36:     service: str,
 37:     references: SilverReferenceData | None,
 38: ) -> Any:
 39:     from pyspark.sql import functions as F
 40: 
 41:     zone_columns = {
 42:         "pickup_zone_name": "string",
 43:         "pickup_borough": "string",
 44:         "pickup_service_zone": "string",
 45:         "dropoff_zone_name": "string",
 46:         "dropoff_borough": "string",
 47:         "dropoff_service_zone": "string",
 48:     }
 49:     base_columns = {
 50:         "dispatching_base_name": "string",
 51:         "dispatching_base_dba": "string",
 52:         "dispatching_base_type": "string",
 53:         "dispatching_base_status": "string",
 54:         "originating_base_name": "string",
 55:         "affiliated_base_name": "string",
 56:     }
 57:     if references is None:
 58:         return _add_null_columns(_add_null_columns(df, zone_columns), base_columns)
 59: 
 60:     zones = references.taxi_zones
 61:     pickup = F.broadcast(
 62:         zones.select(
 63:             F.col("location_id").alias("pickup_location_id"),
 64:             F.col("zone_name").alias("pickup_zone_name"),
 65:             F.col("borough").alias("pickup_borough"),
 66:             F.col("service_zone").alias("pickup_service_zone"),
 67:         )
 68:     )
 69:     dropoff = F.broadcast(
 70:         zones.select(
 71:             F.col("location_id").alias("dropoff_location_id"),
 72:             F.col("zone_name").alias("dropoff_zone_name"),
 73:             F.col("borough").alias("dropoff_borough"),
 74:             F.col("service_zone").alias("dropoff_service_zone"),
 75:         )
 76:     )
 77:     df = df.join(pickup, "pickup_location_id", "left").join(
 78:         dropoff, "dropoff_location_id", "left"
 79:     )
 80:     df = append_quality_rules(
 81:         df,
 82:         error_conditions={
 83:             "PICKUP_ZONE_NOT_IN_LOOKUP": F.col("pickup_location_id").isNotNull()
 84:             & F.col("pickup_zone_name").isNull(),
 85:             "DROPOFF_ZONE_NOT_IN_LOOKUP": F.col("dropoff_location_id").isNotNull()
 86:             & F.col("dropoff_zone_name").isNull(),
 87:         },
 88:     )
 89: 
 90:     if service not in {"fhv", "fhvhv"}:
 91:         return _add_null_columns(df, base_columns)
 92: 
 93:     bases = references.base_lookup
 94: 
 95:     def join_base(
 96:         frame: Any,
 97:         source_column: str,
 98:         prefix: str,
 99:         *,
100:         include_details: bool,
101:     ) -> Any:
102:         if source_column not in frame.columns:
103:             return frame
104:         selections = [
105:             F.col("base_license_number").alias(source_column),
106:             F.col("base_name").alias(f"{prefix}_name"),
107:         ]
108:         if include_details:
109:             selections.extend(
110:                 [
111:                     F.col("doing_business_as").alias(f"{prefix}_dba"),
112:                     F.col("base_type").alias(f"{prefix}_type"),
113:                     F.col("status").alias(f"{prefix}_status"),
114:                 ]
115:             )
116:         return frame.join(F.broadcast(bases.select(*selections)), source_column, "left")
117: 
118:     df = join_base(
119:         df,
120:         "dispatching_base_num",
121:         "dispatching_base",
122:         include_details=True,
123:     )
124:     df = join_base(
125:         df,
126:         "originating_base_num",
127:         "originating_base",
128:         include_details=False,
129:     )
130:     df = join_base(
131:         df,
132:         "affiliated_base_number",
133:         "affiliated_base",
134:         include_details=False,
135:     )
136:     df = _add_null_columns(df, base_columns)
137: 
138:     warnings: dict[str, Any] = {}
139:     if "dispatching_base_num" in df.columns:
140:         warnings["DISPATCHING_BASE_NOT_IN_CURRENT_LOOKUP"] = (
141:             F.col("dispatching_base_num").isNotNull()
142:             & F.col("dispatching_base_name").isNull()
143:         )
144:     if "originating_base_num" in df.columns:
145:         warnings["ORIGINATING_BASE_NOT_IN_CURRENT_LOOKUP"] = (
146:             F.col("originating_base_num").isNotNull()
147:             & F.col("originating_base_name").isNull()
148:         )
149:     if "affiliated_base_number" in df.columns:
150:         warnings["AFFILIATED_BASE_NOT_IN_CURRENT_LOOKUP"] = (
151:             F.col("affiliated_base_number").isNotNull()
152:             & F.col("affiliated_base_name").isNull()
153:         )
154:     return append_quality_rules(df, warning_conditions=warnings)
</file>

