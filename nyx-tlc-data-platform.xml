 22: class FakeCollection:
 23:     def __init__(self, doc=None):
 24:         self.doc = doc
 25: 
 26:     def find_one(self, filter_doc, projection=None):
 27:         if self.doc is None:
 28:             return None
 29:         if any(self.doc.get(key) != value for key, value in filter_doc.items() if "." not in key):
 30:             return None
 31:         if projection == {"_id": 0, "claim": 1}:
 32:             return {"claim": self.doc.get("claim")}
 33:         return self.doc.copy()
 34: 
 35:     def update_one(self, filter_doc, update, upsert=False):
 36:         key_match = self.doc is None or all(
 37:             self.doc.get(key) == value for key, value in filter_doc.items() if key in {"service", "year", "month"}
 38:         )
 39:         if not key_match and not upsert:
 40:             return FakeUpdateResult()
 41: 
 42:         if self._matches(filter_doc):
 43:             if self.doc is None:
 44:                 self.doc = {}
 45:             self.doc.update(update.get("$set", {}))
 46:             for field in update.get("$unset", {}):
 47:                 self.doc.pop(field, None)
 48:             for key, value in update.get("$setOnInsert", {}).items():
 49:                 self.doc.setdefault(key, value)
 50:             return FakeUpdateResult(matched=1 if self.doc else 0, upserted_id="new" if upsert else None)
 51:         if upsert and self.doc is None:
 52:             self.doc = {}
 53:             self.doc.update(update.get("$set", {}))
 54:             self.doc.update(update.get("$setOnInsert", {}))
 55:             return FakeUpdateResult(upserted_id="new")
 56:         return FakeUpdateResult()
 57: 
 58:     def update_many(self, filter_doc, update):
 59:         if not self._matches(filter_doc):
 60:             return FakeUpdateResult(modified=0)
 61:         for field in update.get("$unset", {}):
 62:             self.doc.pop(field, None)
 63:         self.doc.update(update.get("$set", {}))
 64:         return FakeUpdateResult(modified=1)
 65: 
 66:     def _matches(self, filter_doc):
 67:         if self.doc is None:
 68:             return False
 69:         for key, value in filter_doc.items():
 70:             if key == "$or":
 71:                 return any(self._matches(option) for option in value)
 72:             if key == "claim":
 73:                 exists = "claim" in self.doc
 74:                 if value == {"$exists": False} and exists:
 75:                     return False
 76:                 if value == {"$exists": True} and not exists:
 77:                     return False
 78:                 continue
 79:             if key == "claim.execution_id":
 80:                 if (self.doc.get("claim") or {}).get("execution_id") != value:
 81:                     return False
 82:                 continue
 83:             if key == "claim.claimed_at":
 84:                 if (self.doc.get("claim") or {}).get("claimed_at") != value:
 85:                     return False
 86:                 continue
 87:             if key == "claim.expires_at":
 88:                 current = (self.doc.get("claim") or {}).get("expires_at")
 89:                 if isinstance(value, dict) and "$lt" in value:
 90:                     if current is None or not current < value["$lt"]:
 91:                         return False
 92:                 elif current != value:
 93:                     return False
 94:                 continue
 95:             if self.doc.get(key) != value:
 96:                 return False
 97:         return True
