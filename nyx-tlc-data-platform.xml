<file path="src/tlc_data_platform/ml/storage.py">
  1: from __future__ import annotations
  2: 
  3: import shutil
  4: from datetime import datetime, timedelta, timezone
  5: from pathlib import Path
  6: from typing import Any
  7: 
  8: from tlc_data_platform.audit.parquet_metrics import parquet_files
  9: from tlc_data_platform.core.settings import GoldConfig, MLConfig
 10: 
 11: 
 12: class MLStorage:
 13:     """Resolves Gold feature inputs and atomically publishes model outputs."""
 14: 
 15:     FEATURE_LOGICAL_NAMES = {
 16:         "forecast": "zone_hourly_demand",
 17:         "segmentation": "zone_profiles",
 18:         "wait-risk": "hvfhv_wait_risk",
 19:     }
 20: 
 21:     def __init__(self, ml: MLConfig, gold: GoldConfig) -> None:
 22:         self.ml = ml
 23:         self.gold = gold
 24: 
 25:     def ensure_directories(self) -> None:
 26:         for path in (
 27:             self.ml.storage.ml_root,
 28:             self.ml.storage.model_root,
 29:             self.ml.storage.temporary_root,
 30:             self.ml.storage.manifests_root,
 31:         ):
 32:             path.mkdir(parents=True, exist_ok=True)
 33:         self.recover_interrupted_promotions()
 34: 
 35:     def recover_interrupted_promotions(self) -> None:
 36:         root = self.ml.storage.ml_root
 37:         if not root.is_dir():
 38:             return
 39:         for backup in sorted(root.rglob("*.previous-*")):
 40:             if not backup.is_dir():
 41:                 continue
 42:             destination_name = backup.name.split(".previous-", 1)[0]
 43:             destination = backup.with_name(destination_name)
 44:             if destination.exists():
 45:                 shutil.rmtree(backup, ignore_errors=True)
 46:             else:
 47:                 backup.rename(destination)
 48: 
 49:     def cleanup_execution(self, run_id: str) -> None:
 50:         shutil.rmtree(self.ml.storage.temporary_root / run_id, ignore_errors=True)
 51: 
 52:     def cleanup_stale_temporary(self, *, older_than_hours: int = 24) -> None:
 53:         root = self.ml.storage.temporary_root
 54:         if not root.is_dir():
 55:             return
 56:         cutoff = datetime.now(timezone.utc) - timedelta(hours=older_than_hours)
 57:         for child in root.iterdir():
 58:             if not child.is_dir():
 59:                 continue
 60:             try:
 61:                 modified = datetime.fromtimestamp(child.stat().st_mtime, timezone.utc)
 62:             except OSError:
 63:                 continue
 64:             if modified < cutoff:
 65:                 shutil.rmtree(child, ignore_errors=True)
 66: 
 67:     def feature_path(self, model_name: str) -> Path:
 68:         logical = self.FEATURE_LOGICAL_NAMES[model_name]
 69:         return (
 70:             self.gold.storage.gold_root
 71:             / self.gold.storage.features_root
 72:             / self.gold.datasets.ml_features[logical]
 73:         )
 74: 
 75:     def output_path(self, dataset_name: str) -> Path:
 76:         return self.ml.storage.ml_root / dataset_name
 77: 
 78:     def model_path(self, model_name: str, model_id: str) -> Path:
 79:         return self.ml.storage.model_root / model_name / model_id
 80: 
 81:     @staticmethod
 82:     def has_parquet(path: Path) -> bool:
 83:         return bool(parquet_files(path))
 84: 
 85:     def write_atomic(self, frame: Any, path: Path, run_id: str, logical_name: str) -> Path:
 86:         staging = self.ml.storage.temporary_root / run_id / logical_name
 87:         shutil.rmtree(staging, ignore_errors=True)
 88:         staging.parent.mkdir(parents=True, exist_ok=True)
 89:         (
 90:             frame.write.mode("overwrite")
 91:             .option("compression", self.ml.execution.parquet_compression)
 92:             .parquet(str(staging))
 93:         )
 94:         if not (staging / "_SUCCESS").exists() or not parquet_files(staging):
 95:             raise RuntimeError(f"Salida ML temporal incompleta: {staging}")
 96:         self._promote(staging, path, run_id)
 97:         return path
 98: 
 99:     @staticmethod
100:     def _promote(staging: Path, destination: Path, run_id: str) -> None:
101:         destination.parent.mkdir(parents=True, exist_ok=True)
102:         backup = destination.with_name(f"{destination.name}.previous-{run_id}")
103:         shutil.rmtree(backup, ignore_errors=True)
104:         had_previous = destination.exists()
105:         try:
106:             if had_previous:
107:                 destination.rename(backup)
108:             staging.rename(destination)
109:             shutil.rmtree(backup, ignore_errors=True)
110:         except Exception:
111:             if destination.exists():
112:                 shutil.rmtree(destination, ignore_errors=True)
113:             if had_previous and backup.exists():
114:                 backup.rename(destination)
115:             raise
</file>

<file path="src/tlc_data_platform/ml/wait_risk.py">
  1: from __future__ import annotations
  2: 
  3: import logging
  4: from dataclasses import dataclass
  5: from pathlib import Path
  6: from typing import Any
  7: from uuid import uuid4
  8: 
  9: from tlc_data_platform.core.settings import WaitRiskConfig
 10: from tlc_data_platform.ml.common import classification_metrics, metrics_frame
 11: from tlc_data_platform.ml.models import MLModelResult, utc_now
 12: 
 13: LOGGER = logging.getLogger(__name__)
 14: 
 15: 
 16: @dataclass(frozen=True)
 17: class WaitRiskOutput:
 18:     result: MLModelResult
 19:     predictions: Any
 20:     metrics: Any
 21:     feature_importance: Any
 22: 
 23: 
 24: NUMERIC_FEATURES = [
 25:     "request_hour",
 26:     "request_day_of_week",
 27:     "request_month",
 28:     "is_weekend_num",
 29:     "is_peak_hour_num",
 30:     "airport_zone_flag_num",
 31:     "shared_requested_num",
 32:     "access_a_ride_num",
 33:     "wav_requested_num",
 34: ]
 35: CATEGORICAL_FEATURES = ["pickup_zone_code", "pickup_borough", "hvfhs_license_num"]
 36: LABEL_COLUMN = "excessive_wait_flag"
 37: 
 38: 
 39: def _prepare(frame: Any, threshold_seconds: int) -> Any:
 40:     """Creates the binary target while keeping post-request outcomes out of features."""
 41:     from pyspark.sql import functions as F
 42: 
 43:     return (
 44:         frame.withColumn(
 45:             LABEL_COLUMN,
 46:             (F.col("request_to_pickup_seconds") >= threshold_seconds).cast("double"),
 47:         )
 48:         .withColumn("pickup_zone_code", F.col("pickup_zone_key").cast("string"))
 49:         .withColumn("pickup_borough", F.coalesce("pickup_borough", F.lit("UNKNOWN")))
 50:         .withColumn("hvfhs_license_num", F.coalesce("hvfhs_license_num", F.lit("UNKNOWN")))
 51:         .withColumn("is_weekend_num", F.col("is_weekend").cast("double"))
 52:         .withColumn("is_peak_hour_num", F.col("is_peak_hour").cast("double"))
 53:         .withColumn("airport_zone_flag_num", F.coalesce("airport_zone_flag", F.lit(False)).cast("double"))
 54:         .withColumn("shared_requested_num", F.coalesce("shared_requested", F.lit(False)).cast("double"))
 55:         .withColumn("access_a_ride_num", F.coalesce("access_a_ride", F.lit(False)).cast("double"))
 56:         .withColumn("wav_requested_num", F.coalesce("wav_requested", F.lit(False)).cast("double"))
 57:         .fillna(0.0, subset=NUMERIC_FEATURES)
 58:     )
 59: 
 60: 
 61: def _add_class_weights(frame: Any) -> Any:
 62:     """Balances the loss without duplicating minority-class rows."""
 63:     from pyspark.sql import functions as F
 64: 
 65:     counts = {float(row[LABEL_COLUMN]): int(row["count"]) for row in frame.groupBy(LABEL_COLUMN).count().collect()}
 66:     negative = counts.get(0.0, 0)
 67:     positive = counts.get(1.0, 0)
 68:     if negative == 0 or positive == 0:
 69:         raise ValueError("El entrenamiento de wait-risk necesita ejemplos de ambas clases.")
 70:     total = negative + positive
 71:     negative_weight = total / (2.0 * negative)
 72:     positive_weight = total / (2.0 * positive)
 73:     return frame.withColumn(
 74:         "class_weight",
 75:         F.when(F.col(LABEL_COLUMN) == 1.0, F.lit(positive_weight)).otherwise(F.lit(negative_weight)),
 76:     )
 77: 
 78: 
 79: def _pipeline(algorithm: str, config: WaitRiskConfig, seed: int) -> Any:
 80:     from pyspark.ml import Pipeline
 81:     from pyspark.ml.classification import GBTClassifier, LogisticRegression, RandomForestClassifier
 82:     from pyspark.ml.feature import OneHotEncoder, StringIndexer, VectorAssembler
 83: 
 84:     indexers = [
 85:         StringIndexer(inputCol=name, outputCol=f"{name}_index", handleInvalid="keep")
 86:         for name in CATEGORICAL_FEATURES
 87:     ]
 88:     encoder = OneHotEncoder(
 89:         inputCols=[f"{name}_index" for name in CATEGORICAL_FEATURES],
 90:         outputCols=[f"{name}_ohe" for name in CATEGORICAL_FEATURES],
 91:         handleInvalid="keep",
 92:     )
 93:     assembler = VectorAssembler(
 94:         inputCols=[*NUMERIC_FEATURES, *[f"{name}_ohe" for name in CATEGORICAL_FEATURES]],
 95:         outputCol="features",
 96:         handleInvalid="keep",
 97:     )
 98:     common = {
 99:         "labelCol": LABEL_COLUMN,
100:         "featuresCol": "features",
101:         "weightCol": "class_weight",
102:         "predictionCol": "prediction",
103:         "probabilityCol": "probability",
104:         "rawPredictionCol": "rawPrediction",
105:     }
106:     if algorithm == "logistic_regression":
107:         estimator = LogisticRegression(
108:             **common,
109:             maxIter=config.logistic_max_iter,
110:             regParam=0.05,
111:             elasticNetParam=0.0,
112:         )
113:     elif algorithm == "random_forest":
114:         estimator = RandomForestClassifier(
115:             **common,
116:             numTrees=config.random_forest_num_trees,
117:             maxDepth=config.random_forest_max_depth,
118:             seed=seed,
119:         )
120:     elif algorithm == "gbt":
121:         estimator = GBTClassifier(
122:             **common,
123:             maxIter=config.gbt_max_iter,
124:             maxDepth=config.gbt_max_depth,
125:             seed=seed,
126:         )
127:     else:
128:         raise ValueError(f"Algoritmo wait-risk no soportado: {algorithm}")
129:     return Pipeline(stages=[*indexers, encoder, assembler, estimator])
130: 
131: 
132: def _split(frame: Any, config: WaitRiskConfig) -> tuple[Any, Any, Any]:
133:     from pyspark.sql import functions as F
134: 
135:     train = frame.filter(F.col("request_datetime") <= F.to_timestamp(F.lit(config.train_end)))
136:     validation = frame.filter(
137:         (F.col("request_datetime") > F.to_timestamp(F.lit(config.train_end)))
138:         & (F.col("request_datetime") <= F.to_timestamp(F.lit(config.validation_end)))
139:     )
140:     test = frame.filter(
141:         (F.col("request_datetime") > F.to_timestamp(F.lit(config.validation_end)))
142:         & (F.col("request_datetime") <= F.to_timestamp(F.lit(config.test_end)))
143:     )
144:     return train, validation, test
145: 
146: 
147: def _feature_names(frame: Any) -> list[str]:
148:     metadata = frame.schema["features"].metadata.get("ml_attr", {}).get("attrs", {})
149:     attrs: list[dict[str, Any]] = []
150:     for values in metadata.values():
151:         attrs.extend(values)
152:     if not attrs:
153:         size = frame.select("features").first()["features"].size
154:         return [f"feature_{index}" for index in range(size)]
155:     return [item["name"] for item in sorted(attrs, key=lambda item: item["idx"])]
156: 
157: 
158: def _importance_frame(predictions: Any, model: Any, algorithm: str) -> Any:
159:     from pyspark.sql import functions as F
160: 
161:     names = _feature_names(predictions)
162:     estimator_model = model.stages[-1]
163:     if hasattr(estimator_model, "featureImportances"):
164:         values = estimator_model.featureImportances.toArray().tolist()
165:     elif hasattr(estimator_model, "coefficients"):
166:         values = [abs(float(value)) for value in estimator_model.coefficients.toArray().tolist()]
167:     else:
168:         values = [0.0] * len(names)
169:     rows = [(name, float(values[index]) if index < len(values) else 0.0) for index, name in enumerate(names)]
170:     return predictions.sparkSession.createDataFrame(
171:         rows, "feature_name string, importance double"
172:     ).orderBy(F.desc("importance"))
173: 
174: 
175: def train_wait_risk(
176:     features: Any,
177:     config: WaitRiskConfig,
178:     *,
179:     seed: int,
180:     model_root: Path,
181: ) -> WaitRiskOutput:
182:     """Classifies excessive request-to-pickup wait for HVFHV trips.
183: 
184:     This replaces the high-tip classifier. It is better aligned with the traffic
185:     case and uses HVFHV's request timestamp, which taxi datasets do not provide.
186:     """
187:     from pyspark.ml.functions import vector_to_array
188:     from pyspark.sql import functions as F
189: 
190:     prepared = _prepare(features, config.excessive_wait_threshold_seconds).persist()
191:     train, validation, test = _split(prepared, config)
192:     train = _add_class_weights(train).persist()
193:     validation = _add_class_weights(validation).persist()
194:     test = _add_class_weights(test).persist()
195:     training_rows = train.count()
196:     validation_rows = validation.count()
197:     test_rows = test.count()
198:     if min(training_rows, validation_rows, test_rows) == 0:
199:         raise ValueError("Los cortes temporales de wait-risk no pueden estar vacíos.")
200: 
201:     candidates: list[tuple[str, Any, dict[str, float]]] = []
202:     for algorithm in config.algorithms:
203:         try:
204:             model = _pipeline(algorithm, config, seed).fit(train)
205:             metrics = classification_metrics(model.transform(validation), LABEL_COLUMN)
206:             candidates.append((algorithm, model, metrics))
207:         except Exception as error:
208:             LOGGER.exception("Wait-risk candidate %s failed: %s", algorithm, error)
209:     if not candidates:
210:         raise RuntimeError("Ningún clasificador de wait-risk pudo entrenarse.")
211: 
212:     winner_algorithm, _, validation_metrics = max(
213:         candidates, key=lambda item: (item[2]["auc_pr"], item[2]["f1"])
214:     )
215:     final_training = _add_class_weights(train.drop("class_weight").unionByName(validation.drop("class_weight")))
216:     final_model = _pipeline(winner_algorithm, config, seed).fit(final_training)
217:     raw_predictions = final_model.transform(test).persist()
218:     test_metrics = classification_metrics(raw_predictions, LABEL_COLUMN)
219:     test_metrics.update(
220:         {
221:             "validation_auc_pr": validation_metrics["auc_pr"],
222:             "validation_f1": validation_metrics["f1"],
223:             "excessive_wait_threshold_seconds": float(config.excessive_wait_threshold_seconds),
224:             "positive_rate": float(test.agg(F.avg(LABEL_COLUMN).alias("rate")).first()["rate"] or 0.0),
225:         }
226:     )
227: 
228:     model_id = str(uuid4())
229:     model_path = model_root / model_id
230:     model_path.parent.mkdir(parents=True, exist_ok=True)
231:     final_model.write().overwrite().save(str(model_path))
232:     trained_at = utc_now()
233: 
234:     predictions = (
235:         raw_predictions.withColumn("risk_probability", vector_to_array("probability")[1])
236:         .withColumn(
237:             "predicted_risk_level",
238:             F.when(F.col("risk_probability") >= 0.80, "CRITICAL")
239:             .when(F.col("risk_probability") >= 0.60, "HIGH")
240:             .when(F.col("risk_probability") >= 0.40, "ELEVATED")
241:             .otherwise("NORMAL"),
242:         )
243:         .withColumn("model_id", F.lit(model_id))
244:         .withColumn("generated_at", F.lit(trained_at))
245:         .select(
246:             "trip_key",
247:             "request_datetime",
248:             "pickup_zone_key",
249:             "pickup_zone_name",
250:             "pickup_borough",
251:             "hvfhs_license_num",
252:             "hvfhs_company_name",
253:             "request_to_pickup_seconds",
254:             F.col(LABEL_COLUMN).cast("int").alias("observed_excessive_wait"),
255:             F.col("prediction").cast("int").alias("predicted_excessive_wait"),
256:             "risk_probability",
257:             "predicted_risk_level",
258:             "model_id",
259:             "generated_at",
260:         )
261:     )
262:     importance = _importance_frame(raw_predictions, final_model, winner_algorithm).withColumn(
263:         "model_id", F.lit(model_id)
264:     )
265:     metric_frame = metrics_frame(features.sparkSession, "wait-risk", winner_algorithm, test_metrics)
266:     result = MLModelResult(
267:         model_id=model_id,
268:         model_name="wait-risk",
269:         algorithm=winner_algorithm,
270:         status="SUCCESS",
271:         trained_at=trained_at,
272:         training_rows=training_rows,
273:         validation_rows=validation_rows,
274:         test_rows=test_rows,
275:         metrics=test_metrics,
276:         model_path=str(model_path),
277:         output_paths={},
278:         feature_columns=[*NUMERIC_FEATURES, *CATEGORICAL_FEATURES],
279:         target_column=LABEL_COLUMN,
280:     )
281: 
282:     raw_predictions.unpersist()
283:     train.unpersist()
284:     validation.unpersist()
285:     test.unpersist()
286:     prepared.unpersist()
287:     return WaitRiskOutput(result, predictions, metric_frame, importance)
</file>

