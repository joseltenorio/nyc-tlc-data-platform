 93: def build_zone_dimension(taxi_zones: Any) -> Any:
 94:     """Uses TLC LocationID as a stable natural/surrogate key for zone analytics."""
 95:     from pyspark.sql import functions as F
 96: 
 97:     return (
 98:         taxi_zones.select(
 99:             F.col("location_id").cast("int").alias("zone_key"),
100:             F.col("location_id").cast("int").alias("location_id"),
101:             F.col("zone_name").cast("string"),
102:             F.col("borough").cast("string"),
103:             F.col("service_zone").cast("string"),
104:         )
105:         .withColumn("is_airport", F.col("location_id").isin(1, 132, 138))
106:         .withColumn(
107:             "airport_name",
108:             F.when(F.col("location_id") == 132, "JFK")
109:             .when(F.col("location_id") == 138, "LGA")
110:             .when(F.col("location_id") == 1, "EWR")
111:             .otherwise(F.lit(None).cast("string")),
112:         )
113:         .dropDuplicates(["location_id"])
114:     )
115: 
116: 
117: def build_provider_dimension(master: Any) -> Any:
118:     """Conforms taxi vendors and FHV/HVFHV bases into one provider dimension."""
119:     from pyspark.sql import functions as F
120: 
121:     provider_code = F.coalesce(
122:         F.col("vendor_id_or_license"),
123:         F.col("dispatching_base_num"),
124:         F.col("originating_base_num"),
125:     )
126:     provider_name = F.coalesce(
127:         F.col("hvfhs_company_name"),
128:         F.col("dispatching_base_name"),
129:         F.col("dispatching_base_dba"),
130:         provider_code,
131:     )
132:     return (
133:         master.select(
134:             F.col("service_type"),
135:             provider_code.cast("string").alias("provider_code"),
136:             provider_name.cast("string").alias("provider_name"),
137:             F.col("dispatching_base_num").cast("string"),
138:             F.col("originating_base_num").cast("string"),
139:             F.col("affiliated_base_num").cast("string"),
140:         )
141:         .filter(F.col("provider_code").isNotNull())
142:         .dropDuplicates(["service_type", "provider_code"])
143:         .withColumn(
144:             "provider_key",
145:             F.abs(F.xxhash64("service_type", "provider_code")).cast("long"),
146:         )
147:         .withColumn(
148:             "provider_type",
149:             F.when(F.col("service_type").isin("yellow", "green"), "TAXI_VENDOR")
150:             .when(F.col("service_type") == "fhvhv", "HVFHS")
151:             .otherwise("FHV_BASE"),
152:         )
153:         .select(
154:             "provider_key",
155:             "provider_code",
156:             "provider_name",
157:             "provider_type",
158:             "service_type",
159:             "dispatching_base_num",
160:             "originating_base_num",
161:             "affiliated_base_num",
162:         )
163:     )
