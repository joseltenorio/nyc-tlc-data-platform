 89:             audit.runs.assign(status=audit.runs["status"].astype(str).str.upper())
 90:             .groupby(["layer", "status"], as_index=False)
 91:             .size()
 92:         )
 93:         fig = px.bar(
 94:             summary,
 95:             x="layer",
 96:             y="size",
 97:             color="status",
 98:             barmode="stack",
 99:             labels={"layer": "Capa", "size": "Corridas", "status": "Estado"},
100:             color_discrete_map={
101:                 "SUCCESS": "#8EDB8A",
102:                 "PARTIAL_SUCCESS": "#F2B35D",
103:                 "FAILED": "#FF826B",
104:                 "RUNNING": "#6E9FD0",
105:                 "NO_INPUT": "#A7A7B3",
106:             },
107:         )
108:         st.plotly_chart(style_plotly(fig, height=390), width="stretch")
109: 
110: st.caption(f"Fuente de auditoría: {audit.source_note}. Los valores mostrados provienen de salidas Gold/ML y manifiestos reales.")
