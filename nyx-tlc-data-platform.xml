 360:             return self._finish_execution(
 361:                 audit,
 362:                 manifest,
 363:                 execution_id,
 364:                 execution_type.upper(),
 365:                 started_at,
 366:                 selection,
 367:                 discovery,
 368:                 availability,
 369:                 outcomes,
 370:             )
