466:     def _analytical_inputs(
467:         self, spark: Any, partitions: list[GoldSourcePartition]
468:     ) -> tuple[Any, Any, Any, Any]:
469:         sample_master = spark.read.parquet(str(partitions[0].path)).limit(0)
470:         activity_template = build_trip_activity_fact(sample_master)
471:         taxi_template = build_taxi_financial_fact(sample_master)
472:         hv_template = build_hvfhv_operations_fact(sample_master)
473:         activity = self._read_fact_or_empty(spark, "trip_activity", activity_template)
474:         taxi = self._read_fact_or_empty(spark, "taxi_financial", taxi_template)
475:         hvfhv = self._read_fact_or_empty(spark, "hvfhv_operations", hv_template)
476:         dim_zone = spark.read.parquet(str(self._storage.dimension_path("zone")))
477:         return activity, taxi, hvfhv, dim_zone
478: 
479:     def _write_atomic_dataset(
480:         self,
481:         guard: Any,
482:         audit: GoldAuditRepositories,
483:         execution_id: str,
484:         logical_name: str,
485:         dataset_type: str,
486:         frame: Any,
487:         path: Path,
488:     ) -> GoldDatasetResult:
489:         physical_name = path.name
490:         attempt_id = audit.attempts.start(
491:             execution_id, "gold", f"write_{dataset_type}", physical_name, utc_now()
492:         )
493:         try:
494:             guard.run(
495:                 lambda: self._storage.write_atomic(
496:                     frame, path, execution_id, f"{dataset_type}-{physical_name}"
497:                 )
498:             )
499:             metrics = parquet_metrics(path)
500:             result = GoldDatasetResult(
501:                 dataset_name=physical_name,
502:                 dataset_type=dataset_type,
503:                 path=str(path),
504:                 status="READY",
505:                 rows_written=metrics.rows,
506:             )
507:             audit.datasets.upsert(execution_id, result)
508:             audit.attempts.finish(
509:                 attempt_id,
510:                 utc_now(),
511:                 status="SUCCESS",
512:                 rows_written=metrics.rows,
513:             )
514:             if audit.unified is not None:
515:                 audit.unified.record_dataset(
516:                     execution_id,
517:                     layer="gold",
518:                     dataset_name=physical_name,
519:                     dataset_type=dataset_type,
520:                     operation="build_publish",
521:                     status="READY",
522:                     path=str(path),
523:                     parquet_files=metrics.parquet_files,
524:                     rows=metrics.rows,
525:                     bytes_on_disk=metrics.bytes_on_disk,
526:                 )
527:                 audit.unified.record_quality(
528:                     execution_id,
529:                     layer="gold",
530:                     dataset_name=physical_name,
531:                     rule_code="GOLD_PHYSICAL_PARQUET",
532:                     dimension="completeness",
533:                     severity="ERROR",
534:                     status="PASSED" if metrics.parquet_files > 0 else "FAILED",
535:                     expected="> 0 parquet files",
536:                     actual=metrics.parquet_files,
537:                     failed_rows=0 if metrics.parquet_files > 0 else 1,
538:                 )
539:             return result
540:         except Exception as error:
541:             audit.attempts.finish(attempt_id, utc_now(), status="FAILED", error=error)
542:             if audit.unified is not None:
543:                 audit.unified.record_dataset(
544:                     execution_id,
545:                     layer="gold",
546:                     dataset_name=physical_name,
547:                     dataset_type=dataset_type,
548:                     operation="build_publish",
549:                     status="FAILED",
550:                     path=str(path),
551:                     error=error,
552:                 )
553:             raise
554: 
555:     def _read_fact_or_empty(self, spark: Any, logical_name: str, template: Any) -> Any:
556:         root = self._storage.fact_path(logical_name)
557:         paths = self._storage.scoped_fact_paths(
558:             logical_name,
559:             self._config.period.historical_start_year,
560:             self._config.period.incremental_year,
561:         )
562:         if paths:
563:             # basePath restores service/year/month partition columns even though
564:             # only the explicitly scoped leaf directories are read.
565:             return (
566:                 spark.read.option("basePath", str(root))
567:                 .parquet(*[str(path) for path in paths])
568:             )
569:         return template.limit(0)
570: 
571:     def _record_coverage_and_finish(
572:         self,
573:         audit: GoldAuditRepositories,
574:         summary: GoldExecutionSummary,
575:         stages: list[str],
576:         missing_partitions: list[str],
577:     ) -> None:
578:         unified = audit.unified
579:         if unified is None:
580:             return
581:         expected_paths: list[Path] = []
582:         if "dimensions" in stages:
583:             expected_paths.extend(
584:                 self._storage.dimension_path(name)
585:                 for name in self._config.gold.datasets.dimensions
586:             )
587:         if "facts" in stages:
588:             expected_paths.extend(
589:                 self._storage.fact_path(name) for name in self._config.gold.datasets.facts
590:             )
591:         if "marts" in stages:
592:             expected_paths.extend(
593:                 self._storage.mart_path(name) for name in self._config.gold.datasets.marts
594:             )
595:         if "features" in stages:
596:             expected_paths.extend(
597:                 self._storage.feature_path(name)
598:                 for name in self._config.gold.datasets.ml_features
599:             )
600:         absent_outputs = [str(path) for path in expected_paths if not self._storage.has_parquet(path)]
601:         unified.record_coverage(
602:             summary.execution_id,
603:             layer="gold",
604:             expected_count=len(expected_paths),
605:             available_count=len(expected_paths) - len(absent_outputs),
606:             ready_count=len(expected_paths) - len(absent_outputs),
607:             missing=absent_outputs,
608:             details=[
609:                 {"path": str(path), "status": "READY" if self._storage.has_parquet(path) else "MISSING"}
610:                 for path in expected_paths
611:             ],
612:         )
613:         unified.record_quality(
614:             summary.execution_id,
615:             layer="gold",
616:             dataset_name="gold_layer",
617:             rule_code="GOLD_EXPECTED_DATASETS_PRESENT",
618:             dimension="completeness",
619:             severity="ERROR",
620:             status="PASSED" if not absent_outputs else "FAILED",
621:             expected=len(expected_paths),
622:             actual=len(expected_paths) - len(absent_outputs),
623:             failed_rows=len(absent_outputs),
624:             context={"missing_outputs": absent_outputs, "missing_silver_partitions": missing_partitions},
625:         )
626:         unified.finish_run(
627:             summary.execution_id,
628:             status=summary.status,
629:             finished_at=summary.finished_at,
630:             warnings=summary.warnings,
631:             metrics={
632:                 "parquet_partitions_input": summary.source_partitions,
633:                 "rows_input": summary.source_rows,
634:                 "datasets_built": summary.datasets_built,
635:                 "datasets_failed": summary.failed_datasets,
636:                 "missing_silver_partitions": len(missing_partitions),
637:             },
638:         )
639: 
640:     def _audit(self) -> GoldAuditRepositories:
641:         database = self._mongo_provider.database()
642:         GoldMLIndexManager(
643:             database, self._config.gold.collections, self._config.ml.collections
644:         ).ensure_indexes()
645:         names = self._config.gold.collections
646:         return GoldAuditRepositories(
647:             executions=GoldExecutionRepository(database[names.pipeline_executions]),
648:             datasets=GoldDatasetRepository(database[names.dataset_registry]),
649:             attempts=ProcessingAttemptRepository(database[names.processing_attempts]),
650:             reconciliations=database[names.reconciliations],
651:             quality=database[names.quality_results],
652:             unified=UnifiedAuditRepository(database, self._config.audit),
653:         )
654: 
655:     @staticmethod
656:     def _validate_stages(stages: Iterable[str] | None) -> list[str]:
657:         selected = list(dict.fromkeys(stages or GOLD_STAGES))
658:         unknown = sorted(set(selected) - set(GOLD_STAGES))
659:         if unknown:
660:             raise ValueError(f"Etapas Gold desconocidas: {', '.join(unknown)}")
661:         return selected
662: 
663:     @staticmethod
664:     def _summary(
665:         execution_id: str,
666:         execution_type: str,
667:         status: str,
668:         started_at: Any,
669:         selection: RunSelection,
670:         partitions: list[GoldSourcePartition],
671:         source_rows: int | None,
672:         results: list[GoldDatasetResult],
673:         warnings: list[str],
674:     ) -> GoldExecutionSummary:
675:         return GoldExecutionSummary(
676:             execution_id=execution_id,
677:             execution_type=execution_type,
678:             status=status,
679:             started_at=started_at,
680:             finished_at=utc_now(),
681:             selected_start_year=selection.start_year,
682:             selected_end_year=selection.end_year,
683:             selected_months=selection.months,
684:             selected_services=selection.services,
685:             source_partitions=len(partitions),
686:             source_rows=source_rows,
687:             datasets_built=sum(result.status == "READY" for result in results),
688:             failed_datasets=sum(result.status == "FAILED" for result in results),
689:             results=results,
690:             warnings=warnings,
691:         )
