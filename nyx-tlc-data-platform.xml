 884:     @staticmethod
 885:     def _build_summary(
 886:         execution_id: str,
 887:         execution_type: str,
 888:         status: str,
 889:         started_at: Any,
 890:         finished_at: Any,
 891:         selection: RunSelection,
 892:         discovery: Any,
 893:         availability: list[AvailabilityRecord],
 894:         outcomes: list[FileOutcome],
 895:         manifest_path: str,
 896:     ) -> ExecutionSummary:
 897:         attempted_outcomes = [
 898:             outcome for outcome in outcomes if outcome.attempt_count > 0
 899:         ]
 900:         recorded_durations = [
 901:             outcome.download_duration_seconds for outcome in attempted_outcomes
 902:         ]
 903:         total_download_seconds = (
 904:             sum(float(value) for value in recorded_durations if value is not None)
 905:             if attempted_outcomes and all(value is not None for value in recorded_durations)
 906:             else None
 907:         )
 908:         total_bytes_downloaded = sum(outcome.bytes_downloaded or 0 for outcome in outcomes)
 909:         attempted_files = sum(outcome.status in {"READY", "FAILED"} for outcome in outcomes)
 910:         failed_files = sum(outcome.status == "FAILED" for outcome in outcomes)
 911:         average_download_mbps = (
 912:             (total_bytes_downloaded * 8) / total_download_seconds / 1_000_000
 913:             if total_download_seconds is not None and total_download_seconds > 0
 914:             else None
 915:         )
 916:         return ExecutionSummary(
 917:             execution_id=execution_id,
 918:             execution_type=execution_type,
 919:             status=status,
 920:             started_at=started_at,
 921:             finished_at=finished_at,
 922:             requested_services=selection.services,
 923:             requested_start_year=selection.start_year,
 924:             requested_end_year=selection.end_year,
 925:             requested_months=selection.months,
 926:             expected_periods=len(discovery.expected_periods),
 927:             applicable_periods=sum(p.applicable for p in discovery.expected_periods),
 928:             available_files=sum(item.status == "AVAILABLE" for item in availability),
 929:             downloaded_files=sum(
 930:                 outcome.bytes_downloaded is not None
 931:                 and outcome.status in {"READY", "FAILED", "SKIPPED_UNCHANGED"}
 932:                 for outcome in outcomes
 933:             ),
 934:             ready_files=sum(outcome.status == "READY" for outcome in outcomes),
 935:             skipped_files=sum(
 936:                 outcome.status in {"SKIPPED_UNCHANGED", "SKIPPED_CLAIMED"}
 937:                 for outcome in outcomes
 938:             ),
 939:             failed_files=failed_files,
 940:             failed_probe_periods=sum(
 941:                 item.status == "FAILED_TO_PROBE" for item in availability
 942:             ),
 943:             not_published_files=sum(
 944:                 item.status == "NOT_PUBLISHED_YET" for item in availability
 945:             ),
 946:             not_applicable_periods=sum(
 947:                 item.status == "NOT_APPLICABLE" for item in availability
 948:             ),
 949:             total_bytes_downloaded=total_bytes_downloaded,
 950:             manifest_path=manifest_path,
 951:             total_download_attempts=sum(outcome.attempt_count for outcome in outcomes),
 952:             total_retries=sum(outcome.retry_count for outcome in outcomes),
 953:             total_download_seconds=total_download_seconds,
 954:             average_download_mbps=average_download_mbps,
 955:             error_rate=(failed_files / attempted_files if attempted_files else None),
 956:         )
 957: 
 958:     @staticmethod
 959:     def _failure_outcome(candidate: FileCandidate, exc: Exception) -> FileOutcome:
 960:         outcome = FileOutcome(
 961:             candidate=candidate,
 962:             status=(
 963:                 DEFERRED_REMOTE_ACCESS
 964:                 if BronzePipeline._is_temporary_remote_failure(exc)
 965:                 else "FAILED"
 966:             ),
 967:         )
 968:         outcome.error_type = type(exc).__name__
 969:         outcome.error_message = str(exc)
 970:         outcome.attempt_count = int(getattr(exc, "attempt_count", 0) or 0)
 971:         outcome.retry_count = int(getattr(exc, "retry_count", 0) or 0)
 972:         outcome.download_started_at = getattr(exc, "download_started_at", None)
 973:         outcome.download_finished_at = getattr(exc, "download_finished_at", None)
 974:         outcome.download_duration_seconds = getattr(exc, "download_duration_seconds", None)
 975:         if isinstance(exc, requests.HTTPError) and exc.response is not None:
 976:             outcome.remote_metadata = RemoteMetadata(
 977:                 available=False,
 978:                 status_code=exc.response.status_code,
 979:                 content_length=None,
 980:                 etag=exc.response.headers.get("ETag"),
 981:                 last_modified=exc.response.headers.get("Last-Modified"),
 982:                 content_type=exc.response.headers.get("Content-Type"),
 983:             )
 984:         outcome.finish()
 985:         return outcome
 986: 
 987:     @staticmethod
 988:     def _is_temporary_remote_failure(exc: Exception) -> bool:
 989:         if isinstance(exc, requests.HTTPError) and exc.response is not None:
 990:             return exc.response.status_code in {202, 403, 429, 500, 502, 503, 504}
 991:         if isinstance(exc, DownloadError):
 992:             message = str(exc)
 993:             return any(
 994:                 marker in message
 995:                 for marker in (
 996:                     "HTML",
 997:                     "Firma Parquet inválida",
 998:                     "Archivo incompleto",
 999:                 )
1000:             )
1001:         return False
1002: 
1003:     def _cleanup_orphan_temporary_files(self, audit: AuditRepositories) -> None:
1004:         removed = 0
1005:         for path, owner_execution_id in self._storage.temporary_entries():
1006:             if audit.executions.is_active(owner_execution_id):
1007:                 continue
1008:             LOGGER.info(
1009:                 "Eliminando temporal huérfano %s de la ejecución %s",
1010:                 path,
1011:                 owner_execution_id,
1012:             )
1013:             self._storage.discard_temporary_path(path)
1014:             removed += 1
1015:         if removed:
1016:             LOGGER.info("Se eliminaron %s temporales huérfanos", removed)
1017: 
1018:     def _cleanup_execution_state(
1019:         self,
1020:         audit: AuditRepositories,
1021:         execution_id: str,
1022:     ) -> None:
1023:         released = audit.registry.release_claims_for_execution(execution_id)
1024:         removed = self._storage.discard_temporary_for_execution(execution_id)
1025:         if released:
1026:             LOGGER.info(
1027:                 "Se liberaron %s claim(s) pendientes de la ejecución %s",
1028:                 released,
1029:                 execution_id,
1030:             )
1031:         if removed:
1032:             LOGGER.info(
1033:                 "Se eliminaron %s temporal(es) residuales de la ejecución %s",
1034:                 removed,
1035:                 execution_id,
1036:             )
1037: 
1038:     @staticmethod
1039:     def _is_unchanged(
1040:         existing: dict[str, Any] | None,
1041:         destination: Path,
1042:         remote: RemoteMetadata,
1043:     ) -> bool:
1044:         if not existing or not destination.is_file():
1045:             return False
1046:         if destination.stat().st_size <= 0:
1047:             return False
1048:         current = existing.get("current") or {}
1049:         if current.get("status") != "READY":
1050:             return False
1051:         local_path = current.get("local_path")
1052:         if local_path is not None and Path(local_path).parts[-4:] != destination.parts[-4:]:
1053:             return False
1054:         previous_remote = current.get("remote_metadata") or {}
1055:         compared = 0
1056:         for field in ("etag", "last_modified", "content_length"):
1057:             old = previous_remote.get(field)
1058:             new = getattr(remote, field)
1059:             if old is not None and new is not None:
1060:                 compared += 1
1061:                 if old != new:
1062:                     return False
1063:         if compared:
1064:             return True
1065:         expected_size = current.get("bytes_downloaded")
1066:         return expected_size is None or destination.stat().st_size == expected_size
