 104:     def plan(self, selection: RunSelection) -> PlanSummary:
 105:         self._storage.ensure_directories()
 106:         plan_id = f"plan-{utc_now().strftime('%Y%m%dT%H%M%S')}-{uuid.uuid4().hex[:8]}"
 107:         discovery = self._discovery.discover(
 108:             plan_id,
 109:             selection.services,
 110:             selection.start_year,
 111:             selection.end_year,
 112:             selection.months,
 113:         )
 114:         remote_map = self._probe_candidates(discovery.candidates, selection.workers)
 115:         availability = self._merge_probe_results(discovery.availability, remote_map)
 116: 
 117:         warnings: list[str] = []
 118:         if discovery.html_error:
 119:             warnings.append(
 120:                 "El HTML oficial no pudo consultarse; se usó el fallback determinista."
 121:             )
 122: 
 123:         registry: FileRegistryRepository | None = None
 124:         try:
 125:             registry = self._ensure_audit().registry
 126:         except Exception as exc:
 127:             warnings.append(
 128:                 f"MongoDB no estuvo disponible para consultar archivos procesados: {exc}"
 129:             )
 130: 
 131:         already_processed = 0
 132:         estimated_bytes = 0
 133:         unknown_size = 0
 134:         candidate_details: list[dict[str, Any]] = []
 135:         for candidate in discovery.candidates:
 136:             remote = remote_map.get(candidate.period_id, RemoteMetadata(False))
 137:             existing = registry.get(candidate) if registry is not None else None
 138:             processed = self._is_unchanged(
 139:                 existing,
 140:                 self._storage.final_path(candidate),
 141:                 remote,
 142:             )
 143:             if processed:
 144:                 already_processed += 1
 145:             if remote.available:
 146:                 if remote.content_length is None:
 147:                     unknown_size += 1
 148:                 else:
 149:                     estimated_bytes += remote.content_length
 150:             candidate_details.append(
 151:                 {
 152:                     **candidate.to_dict(),
 153:                     "remote": remote.to_dict(),
 154:                     "already_processed": processed,
 155:                 }
 156:             )
 157: 
 158:         free_space = self._storage.free_space_bytes()
 159:         if unknown_size:
 160:             warnings.append(
 161:                 f"{unknown_size} archivo(s) no informaron Content-Length; la estimación es parcial."
 162:             )
 163:         if estimated_bytes + self._storage.minimum_free_space_bytes > free_space:
 164:             warnings.append(
 165:                 "El tamaño remoto estimado más la reserva mínima supera el espacio libre."
 166:             )
 167:         failed_probes = sum(item.status == "FAILED_TO_PROBE" for item in availability)
 168:         if failed_probes:
 169:             warnings.append(f"{failed_probes} periodo(s) no pudieron verificarse por red.")
 170:         deferred_periods = sum(
 171:             item.status == DEFERRED_REMOTE_ACCESS for item in availability
 172:         )
 173:         if deferred_periods:
 174:             warnings.append(
 175:                 f"{deferred_periods} periodo(s) quedaron diferidos por acceso remoto temporal."
 176:             )
 177: 
 178:         available_files = sum(item.status == "AVAILABLE" for item in availability)
 179:         pending = max(0, available_files - already_processed)
 180:         return PlanSummary(
 181:             plan_type="PLAN",
 182:             services=selection.services,
 183:             start_year=selection.start_year,
 184:             end_year=selection.end_year,
 185:             months=selection.months,
 186:             expected_periods=len(discovery.expected_periods),
 187:             applicable_periods=sum(p.applicable for p in discovery.expected_periods),
 188:             not_applicable_periods=sum(not p.applicable for p in discovery.expected_periods),
 189:             available_files=available_files,
 190:             not_published_files=sum(
 191:                 item.status == "NOT_PUBLISHED_YET" for item in availability
 192:             ),
 193:             failed_probes=failed_probes,
 194:             already_processed_files=already_processed,
 195:             pending_files=pending,
 196:             estimated_remote_bytes=estimated_bytes,
 197:             unknown_size_files=unknown_size,
 198:             free_space_bytes=free_space,
 199:             minimum_free_space_bytes=self._storage.minimum_free_space_bytes,
 200:             workers=selection.workers,
 201:             max_hvfhv_workers=selection.max_hvfhv_workers,
 202:             warnings=warnings,
 203:             candidates=candidate_details,
 204:         )
