840: def resolve_selection(
841:     config: AppConfig,
842:     mode: str,
843:     services: list[str] | None = None,
844:     start_year: int | None = None,
845:     end_year: int | None = None,
846:     months: list[int] | None = None,
847:     workers: int | None = None,
848:     max_hvfhv_workers: int | None = None,
849:     continue_on_error: bool | None = None,
850: ) -> RunSelection:
851:     selected_services = sorted(set(services or config.enabled_services()))
852:     unknown = sorted(set(selected_services) - set(config.services))
853:     disabled = sorted(
854:         service
855:         for service in selected_services
856:         if service in config.services and not config.services[service].enabled
857:     )
858:     if unknown:
859:         raise ConfigurationError(f"Servicios desconocidos: {', '.join(unknown)}")
860:     if disabled:
861:         raise ConfigurationError(f"Servicios deshabilitados: {', '.join(disabled)}")
862: 
863:     if mode == "historical":
864:         default_start = config.period.historical_start_year
865:         default_end = config.period.historical_end_year
866:     elif mode == "incremental":
867:         default_start = default_end = config.period.incremental_year
868:     elif mode in {"run", "plan"}:
869:         default_start = config.period.historical_start_year
870:         default_end = config.period.incremental_year
871:     else:
872:         raise ConfigurationError(f"Modo no soportado: {mode}")
873: 
874:     selected_start = start_year if start_year is not None else default_start
875:     selected_end = end_year if end_year is not None else default_end
876:     selected_months = sorted(set(months or list(config.period.months)))
877:     selected_workers = workers or config.download.max_workers
878:     selected_hvfhv_workers = max_hvfhv_workers or config.download.max_hvfhv_workers
879:     selected_continue = (
880:         config.download.continue_on_file_error
881:         if continue_on_error is None
882:         else continue_on_error
883:     )
884: 
885:     if selected_start > selected_end:
886:         raise ConfigurationError("--start-year no puede superar --end-year")
887:     if not selected_months or any(month < 1 or month > 12 for month in selected_months):
888:         raise ConfigurationError("--months solo acepta valores entre 1 y 12")
889:     if selected_workers < 1:
890:         raise ConfigurationError("--workers debe ser mayor que cero")
891:     if selected_hvfhv_workers < 1:
892:         raise ConfigurationError("--max-hvfhv-workers debe ser mayor que cero")
893:     if "fhvhv" in selected_services and selected_hvfhv_workers > selected_workers:
894:         raise ConfigurationError("--max-hvfhv-workers debe estar entre 1 y --workers")
895: 
896:     return RunSelection(
897:         services=selected_services,
898:         start_year=selected_start,
899:         end_year=selected_end,
900:         months=selected_months,
901:         workers=selected_workers,
902:         max_hvfhv_workers=selected_hvfhv_workers,
903:         continue_on_error=selected_continue,
904:     )
905: 
