<file path="src/tlc_data_platform/audit/file_registry_repository.py">
  1: from __future__ import annotations
  2: 
  3: from datetime import timedelta
  4: from typing import Any
  5: 
  6: from tlc_data_platform.bronze.models import FileCandidate, FileOutcome, utc_now
  7: 
  8: 
  9: class FileRegistryRepository:
 10:     def __init__(
 11:         self,
 12:         collection: Any,
 13:         claim_ttl_minutes: int,
 14:         execution_repository: Any | None = None,
 15:     ) -> None:
 16:         self._collection = collection
 17:         self._claim_ttl_minutes = claim_ttl_minutes
 18:         self._execution_repository = execution_repository
 19: 
 20:     @staticmethod
 21:     def _key(candidate: FileCandidate) -> dict[str, Any]:
 22:         return {
 23:             "service": candidate.service,
 24:             "year": candidate.year,
 25:             "month": candidate.month,
 26:         }
 27: 
 28:     def get(self, candidate: FileCandidate) -> dict[str, Any] | None:
 29:         return self._collection.find_one(self._key(candidate), {"_id": 0})
 30: 
 31:     def claim(self, candidate: FileCandidate, execution_id: str) -> bool:
 32:         from pymongo.errors import DuplicateKeyError
 33: 
 34:         now = utc_now()
 35:         expires_at = now + timedelta(minutes=self._claim_ttl_minutes)
 36:         key = self._key(candidate)
 37:         filter_doc = {
 38:             **key,
 39:             "$or": [
 40:                 {"claim": {"$exists": False}},
 41:                 {"claim.expires_at": {"$lt": now}},
 42:                 {"claim.execution_id": execution_id},
 43:             ],
 44:         }
 45:         update = {
 46:             "$set": {
 47:                 **key,
 48:                 "status": "PENDING",
 49:                 "claim": {
 50:                     "execution_id": execution_id,
 51:                     "claimed_at": now,
 52:                     "expires_at": expires_at,
 53:                 },
 54:                 "updated_at": now,
 55:             },
 56:             "$setOnInsert": {"created_at": now},
 57:         }
 58:         try:
 59:             result = self._collection.update_one(filter_doc, update, upsert=True)
 60:         except DuplicateKeyError:
 61:             return False
 62:         if result.matched_count or result.upserted_id:
 63:             return True
 64: 
 65:         current = self._collection.find_one(key, {"_id": 0, "claim": 1})
 66:         if current is None:
 67:             try:
 68:                 retry = self._collection.update_one(filter_doc, update, upsert=True)
 69:             except DuplicateKeyError:
 70:                 return False
 71:             return bool(retry.matched_count or retry.upserted_id)
 72: 
 73:         claim = current.get("claim") or {}
 74:         if not self._is_recoverable_claim(claim, execution_id, now):
 75:             return False
 76: 
 77:         recovery_filter = self._recovery_filter(key, claim)
 78:         result = self._collection.update_one(recovery_filter, update, upsert=False)
 79:         return bool(result.matched_count)
 80: 
 81:     def _is_recoverable_claim(
 82:         self,
 83:         claim: dict[str, Any],
 84:         execution_id: str,
 85:         now: Any,
 86:     ) -> bool:
 87:         owner_execution_id = claim.get("execution_id")
 88:         if not owner_execution_id or owner_execution_id == execution_id:
 89:             return True
 90:         expires_at = claim.get("expires_at")
 91:         if expires_at is not None and expires_at < now:
 92:             return True
 93:         if self._execution_repository is None:
 94:             return False
 95:         execution = self._execution_repository.get(owner_execution_id)
 96:         if execution is None:
 97:             return True
 98:         if execution.get("finished_at") is not None:
 99:             return True
100:         return execution.get("status") in {"SUCCESS", "PARTIAL_SUCCESS", "FAILED"}
101: 
102:     @staticmethod
103:     def _recovery_filter(
104:         key: dict[str, Any],
105:         claim: dict[str, Any],
106:     ) -> dict[str, Any]:
107:         filter_doc = dict(key)
108:         if claim.get("execution_id") is not None:
109:             filter_doc["claim.execution_id"] = claim["execution_id"]
110:         if claim.get("claimed_at") is not None:
111:             filter_doc["claim.claimed_at"] = claim["claimed_at"]
112:         if claim.get("expires_at") is not None:
113:             filter_doc["claim.expires_at"] = claim["expires_at"]
114:         if len(filter_doc) == len(key):
115:             filter_doc["claim"] = {"$exists": True}
116:         return filter_doc
117: 
118:     def set_status(
119:         self,
120:         candidate: FileCandidate,
121:         execution_id: str,
122:         status: str,
123:         **fields: Any,
124:     ) -> None:
125:         self._collection.update_one(
126:             self._key(candidate),
127:             {
128:                 "$set": {
129:                     "status": status,
130:                     "last_execution_id": execution_id,
131:                     "updated_at": utc_now(),
132:                     **fields,
133:                 }
134:             },
135:             upsert=True,
136:         )
137: 
138:     def mark_ready(self, outcome: FileOutcome, execution_id: str) -> None:
139:         current = {
140:             "status": "READY",
141:             "sha256": outcome.sha256,
142:             "bytes_downloaded": outcome.bytes_downloaded,
143:             "local_path": outcome.local_path,
144:             "remote_metadata": (
145:                 outcome.remote_metadata.to_dict() if outcome.remote_metadata else None
146:             ),
147:             "validation": outcome.validation.to_dict() if outcome.validation else None,
148:             "ready_at": outcome.finished_at,
149:             "execution_id": execution_id,
150:         }
151:         self._collection.update_one(
152:             self._key(outcome.candidate),
153:             {
154:                 "$set": {
155:                     **self._key(outcome.candidate),
156:                     "status": "READY",
157:                     "sha256": outcome.sha256,
158:                     "bytes_downloaded": outcome.bytes_downloaded,
159:                     "local_path": outcome.local_path,
160:                     "remote_metadata": (
161:                         outcome.remote_metadata.to_dict()
162:                         if outcome.remote_metadata
163:                         else None
164:                     ),
165:                     "current": current,
166:                     "last_execution_id": execution_id,
167:                     "updated_at": utc_now(),
168:                 },
169:                 "$unset": {"claim": ""},
170:                 "$setOnInsert": {"created_at": utc_now()},
171:             },
172:             upsert=True,
173:         )
174: 
175:     def mark_failed(self, outcome: FileOutcome, execution_id: str) -> None:
176:         self._collection.update_one(
177:             self._key(outcome.candidate),
178:             {
179:                 "$set": {
180:                     "status": "FAILED",
181:                     "last_execution_id": execution_id,
182:                     "last_error": {
183:                         "type": outcome.error_type,
184:                         "message": outcome.error_message,
185:                         "at": outcome.finished_at,
186:                     },
187:                     "updated_at": utc_now(),
188:                 },
189:                 "$unset": {"claim": ""},
190:             },
191:             upsert=True,
192:         )
193: 
194:     def mark_deferred(self, outcome: FileOutcome, execution_id: str) -> None:
195:         self._collection.update_one(
196:             self._key(outcome.candidate),
197:             {
198:                 "$set": {
199:                     "status": outcome.status,
200:                     "last_execution_id": execution_id,
201:                     "last_error": {
202:                         "type": outcome.error_type,
203:                         "message": outcome.error_message,
204:                         "at": outcome.finished_at,
205:                     },
206:                     "updated_at": utc_now(),
207:                 },
208:                 "$unset": {"claim": ""},
209:             },
210:             upsert=True,
211:         )
212: 
213:     def release_claim(self, candidate: FileCandidate, execution_id: str) -> None:
214:         self._collection.update_one(
215:             {**self._key(candidate), "claim.execution_id": execution_id},
216:             {"$unset": {"claim": ""}, "$set": {"updated_at": utc_now()}},
217:         )
218: 
219:     def release_claims_for_execution(self, execution_id: str) -> int:
220:         result = self._collection.update_many(
221:             {"claim.execution_id": execution_id},
222:             {"$unset": {"claim": ""}, "$set": {"updated_at": utc_now()}},
223:         )
224:         return int(result.modified_count)
</file>

