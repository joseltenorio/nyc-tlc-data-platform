 18: def _provider_key() -> Any:
 19:     from pyspark.sql import functions as F
 20: 
 21:     provider_code = F.coalesce(
 22:         F.col("vendor_id_or_license"),
 23:         F.col("dispatching_base_num"),
 24:         F.col("originating_base_num"),
