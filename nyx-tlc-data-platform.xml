 41: def _parse_datetime(value: Any) -> pd.Timestamp | pd.NaT:
 42:     if value in (None, ""):
 43:         return pd.NaT
 44:     return pd.to_datetime(value, utc=True, errors="coerce")
 45: 
 46: 
 47: def _duration(started: Any, finished: Any, explicit: Any = None) -> float | None:
 48:     if explicit is not None:
 49:         try:
 50:             return float(explicit)
 51:         except (TypeError, ValueError):
 52:             pass
 53:     start = _parse_datetime(started)
 54:     end = _parse_datetime(finished)
 55:     if pd.isna(start) or pd.isna(end):
 56:         return None
 57:     return float((end - start).total_seconds())
