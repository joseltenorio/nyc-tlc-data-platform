  1: from __future__ import annotations
  2: 
  3: import logging
  4: from dataclasses import dataclass
  5: from pathlib import Path
  6: from typing import Any
  7: from uuid import uuid4
  8: 
  9: from tlc_data_platform.core.settings import ForecastConfig
 10: from tlc_data_platform.ml.common import baseline_metrics, metrics_frame, regression_metrics
 11: from tlc_data_platform.ml.models import MLModelResult, utc_now
 12: 
 13: LOGGER = logging.getLogger(__name__)
 14: 
 15: 
 16: @dataclass(frozen=True)
 17: class ForecastOutput:
 18:     result: MLModelResult
 19:     predictions: Any
 20:     anomalies: Any
 21:     metrics: Any
 22: 
 23: 
 24: NUMERIC_FEATURES = [
 25:     "lag_1_hour",
 26:     "lag_2_hours",
 27:     "lag_24_hours",
 28:     "lag_48_hours",
 29:     "lag_168_hours",
 30:     "rolling_mean_6h",
 31:     "rolling_mean_24h",
 32:     "rolling_mean_168h",
 33:     "rolling_stddev_24h",
 34:     "hour_of_day",
 35:     "day_of_week",
 36:     "month",
 37:     "is_weekend_num",
 38:     "is_peak_hour_num",
 39:     "airport_zone_flag_num",
 40: ]
 41: CATEGORICAL_FEATURES = ["service_type", "pickup_zone_code", "pickup_borough"]
 42: 
 43: 
 44: def _prepare(frame: Any) -> Any:
 45:     """Normalizes feature types once so every candidate algorithm sees the same input."""
 46:     from pyspark.sql import functions as F
 47: 
 48:     prepared = (
 49:         frame.withColumn("pickup_zone_code", F.col("pickup_location_id").cast("string"))
 50:         .withColumn("pickup_borough", F.coalesce("pickup_borough", F.lit("UNKNOWN")))
 51:         .withColumn("is_weekend_num", F.col("is_weekend").cast("double"))
 52:         .withColumn("is_peak_hour_num", F.col("is_peak_hour").cast("double"))
 53:         .withColumn("airport_zone_flag_num", F.coalesce(F.col("airport_zone_flag"), F.lit(False)).cast("double"))
 54:     )
 55:     return prepared.fillna(0.0, subset=NUMERIC_FEATURES)
 56: 
 57: 
 58: def _pipeline(algorithm: str, config: ForecastConfig, seed: int) -> Any:
 59:     from pyspark.ml import Pipeline
 60:     from pyspark.ml.feature import OneHotEncoder, StringIndexer, VectorAssembler
 61:     from pyspark.ml.regression import GBTRegressor, GeneralizedLinearRegression, RandomForestRegressor
 62: 
 63:     indexers = [
 64:         StringIndexer(inputCol=name, outputCol=f"{name}_index", handleInvalid="keep")
 65:         for name in CATEGORICAL_FEATURES
 66:     ]
 67:     encoder = OneHotEncoder(
 68:         inputCols=[f"{name}_index" for name in CATEGORICAL_FEATURES],
 69:         outputCols=[f"{name}_ohe" for name in CATEGORICAL_FEATURES],
 70:         handleInvalid="keep",
 71:     )
 72:     assembler = VectorAssembler(
 73:         inputCols=[*NUMERIC_FEATURES, *[f"{name}_ohe" for name in CATEGORICAL_FEATURES]],
 74:         outputCol="features",
 75:         handleInvalid="keep",
 76:     )
 77:     if algorithm == "gbt":
 78:         estimator = GBTRegressor(
 79:             labelCol="trip_count",
 80:             featuresCol="features",
 81:             predictionCol="prediction",
 82:             maxIter=config.gbt_max_iter,
 83:             maxDepth=config.gbt_max_depth,
 84:             seed=seed,
 85:         )
 86:     elif algorithm == "random_forest":
 87:         estimator = RandomForestRegressor(
 88:             labelCol="trip_count",
 89:             featuresCol="features",
 90:             predictionCol="prediction",
 91:             numTrees=config.random_forest_num_trees,
 92:             maxDepth=config.random_forest_max_depth,
 93:             seed=seed,
 94:         )
 95:     elif algorithm == "poisson_glr":
 96:         estimator = GeneralizedLinearRegression(
 97:             labelCol="trip_count",
 98:             featuresCol="features",
 99:             predictionCol="prediction",
100:             family="poisson",
101:             link="log",
102:             maxIter=60,
103:             regParam=0.05,
104:         )
105:     else:
106:         raise ValueError(f"Algoritmo de forecast no soportado: {algorithm}")
107:     return Pipeline(stages=[*indexers, encoder, assembler, estimator])
108: 
109: 
110: def _split(frame: Any, config: ForecastConfig) -> tuple[Any, Any, Any]:
111:     from pyspark.sql import functions as F
112: 
113:     train = frame.filter(
114:         (F.col("event_timestamp") >= F.to_timestamp(F.lit(config.train_start)))
115:         & (F.col("event_timestamp") <= F.to_timestamp(F.lit(config.train_end)))
116:     )
117:     validation = frame.filter(
118:         (F.col("event_timestamp") > F.to_timestamp(F.lit(config.train_end)))
119:         & (F.col("event_timestamp") <= F.to_timestamp(F.lit(config.validation_end)))
120:     )
121:     test = frame.filter(
122:         (F.col("event_timestamp") > F.to_timestamp(F.lit(config.validation_end)))
123:         & (F.col("event_timestamp") <= F.to_timestamp(F.lit(config.test_end)))
124:     )
125:     return train, validation, test
126: 
127: 
128: def _require_non_empty(frame: Any, name: str) -> int:
129:     rows = frame.count()
130:     if rows == 0:
131:         raise ValueError(f"El conjunto {name} del forecast está vacío; revisa ml.yml y Gold.")
132:     return rows
133: 
134: 
135: def _future_feature_frame(history: Any, horizon_hours: int) -> Any:
136:     """Builds direct future rows from the latest observed seasonal history.
137: 
138:     This is intentionally a global direct forecast, not 265 independent models.
139:     Exact 24/48/168-hour lags remain available for the whole horizon. Missing
140:     short lags are replaced by seasonal/rolling values, avoiding hundreds of
141:     expensive recursive Spark fits or one model per zone.
142:     """
143:     from pyspark.sql import functions as F
144: 
145:     spark = history.sparkSession
146:     latest = history.agg(F.max("event_timestamp").alias("latest")).first()["latest"]
147:     if latest is None:
148:         raise ValueError("No existe una última hora observada para generar el forecast.")
149: 
150:     active = history.groupBy(
151:         "pickup_location_id",
152:         "pickup_zone_name",
153:         "pickup_borough",
154:         "service_type",
155:         "airport_zone_flag",
156:     ).agg(
157:         F.count("event_timestamp").alias("active_hours"),
158:         F.sum("trip_count").alias("total_trips"),
159:     )
160:     horizon = spark.range(1, horizon_hours + 1).select(F.col("id").cast("int").alias("horizon_hour"))
161:     # Keep the latest value inside Spark. Converting a timezone-naive TLC
162:     # timestamp through Python's ``datetime.timestamp()`` would reinterpret it
163:     # using the host timezone and could shift the forecast by several hours.
164:     latest_frame = history.agg(F.max("event_timestamp").alias("latest_timestamp"))
165:     future = (
166:         active.crossJoin(horizon)
167:         .crossJoin(latest_frame)
168:         .withColumn(
169:             "event_timestamp",
170:             F.expr("timestampadd(HOUR, horizon_hour, latest_timestamp)"),
171:         )
172:         .drop("latest_timestamp")
173:     )
174: 
175:     history_values = history.select(
176:         "pickup_location_id", "service_type", "event_timestamp", "trip_count"
177:     )
178:     for hours, output_name in (
179:         (1, "lag_1_hour"),
180:         (2, "lag_2_hours"),
181:         (24, "lag_24_hours"),
182:         (48, "lag_48_hours"),
183:         (168, "lag_168_hours"),
184:     ):
185:         lagged = history_values.select(
186:             "pickup_location_id",
187:             "service_type",
188:             F.expr(f"event_timestamp + INTERVAL {hours} HOURS").alias("event_timestamp"),
189:             F.col("trip_count").alias(output_name),
190:         )
191:         future = future.join(
192:             lagged,
193:             ["pickup_location_id", "service_type", "event_timestamp"],
194:             "left",
195:         )
196: 
197:     # Python only subtracts timedeltas here; Spark still receives the original
198:     # local wall-clock values, so no UTC conversion is introduced.
199:     from datetime import timedelta
200: 
201:     cutoff_6h = latest - timedelta(hours=6)
202:     cutoff_24h = latest - timedelta(hours=24)
203:     cutoff_168h = latest - timedelta(hours=168)
204:     recent = history.filter(F.col("event_timestamp") > F.lit(cutoff_168h))
205:     rolling = recent.groupBy("pickup_location_id", "service_type").agg(
206:         F.avg(
207:             F.when(F.col("event_timestamp") > F.lit(cutoff_6h), F.col("trip_count"))
208:         ).alias("rolling_mean_6h"),
209:         F.avg(
210:             F.when(F.col("event_timestamp") > F.lit(cutoff_24h), F.col("trip_count"))
211:         ).alias("rolling_mean_24h"),
212:         F.avg("trip_count").alias("rolling_mean_168h"),
213:         F.stddev_pop(
214:             F.when(F.col("event_timestamp") > F.lit(cutoff_24h), F.col("trip_count"))
215:         ).alias("rolling_stddev_24h"),
216:     )
217:     future = future.join(rolling, ["pickup_location_id", "service_type"], "left")
218: 
219:     fallback = F.coalesce(
220:         "lag_24_hours", "lag_168_hours", "rolling_mean_168h", F.lit(0.0)
221:     )
222:     return (
223:         future.withColumn("lag_1_hour", F.coalesce("lag_1_hour", fallback))
224:         .withColumn("lag_2_hours", F.coalesce("lag_2_hours", fallback))
225:         .withColumn("lag_24_hours", F.coalesce("lag_24_hours", "lag_168_hours", "rolling_mean_168h", F.lit(0.0)))
226:         .withColumn("lag_48_hours", F.coalesce("lag_48_hours", "lag_168_hours", "rolling_mean_168h", F.lit(0.0)))
227:         .withColumn("lag_168_hours", F.coalesce("lag_168_hours", "rolling_mean_168h", F.lit(0.0)))
228:         .withColumn("event_date", F.to_date("event_timestamp"))
229:         .withColumn("event_hour", F.hour("event_timestamp"))
230:         .withColumn("hour_of_day", F.hour("event_timestamp"))
231:         .withColumn("day_of_week", F.dayofweek("event_timestamp"))
232:         .withColumn("month", F.month("event_timestamp"))
233:         .withColumn("is_weekend", F.dayofweek("event_timestamp").isin(1, 7))
234:         .withColumn("is_peak_hour", F.hour("event_timestamp").isin(7, 8, 9, 16, 17, 18, 19))
235:         .withColumn("same_hour_previous_day", F.col("lag_24_hours"))
236:         .withColumn("same_hour_previous_week", F.col("lag_168_hours"))
237:     )
238: 
239: 
240: def train_forecast(
241:     features: Any,
242:     config: ForecastConfig,
243:     *,
244:     seed: int,
245:     model_root: Path,
246: ) -> ForecastOutput:
247:     """Trains and selects a global zone-hour-service demand model."""
248:     from pyspark.sql import functions as F
249: 
250:     active = features.groupBy("pickup_location_id", "service_type").agg(
251:         F.count("event_timestamp").alias("active_hours_filter"),
252:         F.sum("trip_count").alias("total_trips_filter"),
253:     ).filter(
254:         (F.col("active_hours_filter") >= config.minimum_active_hours)
255:         & (F.col("total_trips_filter") >= config.minimum_total_trips)
256:     )
257:     prepared = _prepare(
258:         features.join(active.select("pickup_location_id", "service_type"), ["pickup_location_id", "service_type"], "inner")
259:     ).persist()
260:     train, validation, test = _split(prepared, config)
261:     training_rows = _require_non_empty(train, "training")
262:     validation_rows = _require_non_empty(validation, "validation")
263:     test_rows = _require_non_empty(test, "test")
264: 
265:     candidates: list[tuple[str, Any, dict[str, float]]] = []
266:     for algorithm in config.algorithms:
267:         try:
268:             model = _pipeline(algorithm, config, seed).fit(train)
269:             metrics = regression_metrics(model.transform(validation), "trip_count")
270:             candidates.append((algorithm, model, metrics))
271:         except Exception as error:
272:             # One candidate may be numerically unsuitable (for example Poisson
273:             # convergence), but the comparison remains valid if other declared
274:             # candidates train successfully. The failure is logged, not hidden.
275:             LOGGER.exception("Forecast candidate %s failed: %s", algorithm, error)
276:     if not candidates:
277:         raise RuntimeError("Ningún algoritmo de forecast pudo entrenarse.")
278: 
279:     winner_algorithm, _, validation_metrics = min(
280:         candidates, key=lambda item: (item[2]["wape"], item[2]["rmse"])
281:     )
282:     train_plus_validation = train.unionByName(validation)
283:     final_model = _pipeline(winner_algorithm, config, seed).fit(train_plus_validation)
284:     test_predictions = (
285:         final_model.transform(test)
286:         .withColumn("prediction", F.greatest(F.col("prediction"), F.lit(0.0)))
287:         .persist()
288:     )
289:     test_metrics = regression_metrics(test_predictions, "trip_count")
290:     baseline_24 = baseline_metrics(test, "lag_24_hours", "trip_count")
291:     baseline_168 = baseline_metrics(test, "lag_168_hours", "trip_count")
292:     test_metrics.update(
293:         {
294:             "validation_wape": validation_metrics["wape"],
295:             "baseline_24h_wape": baseline_24["wape"],
296:             "baseline_168h_wape": baseline_168["wape"],
297:             "wape_improvement_vs_weekly": baseline_168["wape"] - test_metrics["wape"],
298:         }
299:     )
300: 
301:     model_id = str(uuid4())
302:     model_path = model_root / model_id
303:     model_path.parent.mkdir(parents=True, exist_ok=True)
304:     final_model.write().overwrite().save(str(model_path))
305: 
306:     residuals = test_predictions.withColumn(
307:         "residual", F.col("trip_count") - F.col("prediction")
308:     )
309:     global_std = residuals.agg(F.stddev_pop("residual").alias("std")).first()["std"] or 1.0
310:     residual_stats = residuals.groupBy("pickup_location_id", "service_type").agg(
311:         F.stddev_pop("residual").alias("residual_stddev")
312:     )
313:     anomalies = (
314:         residuals.join(residual_stats, ["pickup_location_id", "service_type"], "left")
315:         .withColumn(
316:             "deviation_score",
317:             F.col("residual") / F.coalesce(F.when(F.col("residual_stddev") > 0, F.col("residual_stddev")), F.lit(global_std)),
318:         )
319:         .withColumn("anomaly_flag", F.abs("deviation_score") >= config.anomaly_zscore_threshold)
320:         .withColumn(
321:             "anomaly_type",
322:             F.when(F.col("deviation_score") >= config.anomaly_zscore_threshold, "DEMAND_SURGE")
323:             .when(F.col("deviation_score") <= -config.anomaly_zscore_threshold, "DEMAND_DROP")
324:             .otherwise("NORMAL"),
325:         )
326:         .withColumn(
327:             "severity",
328:             F.when(F.abs("deviation_score") >= 5, "CRITICAL")
329:             .when(F.abs("deviation_score") >= 4, "HIGH")
330:             .when(F.abs("deviation_score") >= config.anomaly_zscore_threshold, "ELEVATED")
331:             .otherwise("NORMAL"),
332:         )
333:         .select(
334:             "event_timestamp",
335:             "pickup_location_id",
336:             "pickup_zone_name",
337:             "pickup_borough",
338:             "service_type",
339:             F.col("trip_count").alias("observed_trip_count"),
340:             F.col("prediction").alias("expected_trip_count"),
341:             "residual",
342:             "deviation_score",
343:             "anomaly_flag",
344:             "anomaly_type",
345:             "severity",
346:         )
347:     )
348: 
349:     future = _prepare(_future_feature_frame(prepared, config.forecast_horizon_hours))
350:     thresholds = prepared.groupBy("pickup_location_id", "service_type").agg(
351:         F.expr("percentile_approx(trip_count, array(0.50, 0.75, 0.90), 10000)").alias("demand_quantiles")
352:     )
353:     interval = test_predictions.select(
354:         F.abs(F.col("trip_count") - F.col("prediction")).alias("absolute_error")
355:     ).approxQuantile("absolute_error", [0.90], 0.01)[0]
356:     generated_at = utc_now()
357:     future_predictions = (
358:         final_model.transform(future)
359:         .withColumn("predicted_trip_count", F.greatest(F.col("prediction"), F.lit(0.0)))
360:         .join(thresholds, ["pickup_location_id", "service_type"], "left")
361:         .withColumn("lower_bound", F.greatest(F.col("predicted_trip_count") - F.lit(interval), F.lit(0.0)))
362:         .withColumn("upper_bound", F.col("predicted_trip_count") + F.lit(interval))
363:         .withColumn(
364:             "demand_level",
365:             F.when(F.col("predicted_trip_count") > F.element_at("demand_quantiles", 3), "CRITICAL")
366:             .when(F.col("predicted_trip_count") > F.element_at("demand_quantiles", 2), "HIGH")
367:             .when(F.col("predicted_trip_count") > F.element_at("demand_quantiles", 1), "NORMAL")
368:             .otherwise("LOW"),
369:         )
370:         .withColumn("model_id", F.lit(model_id))
371:         .withColumn("generated_at", F.lit(generated_at))
372:         .select(
373:             F.col("event_timestamp").alias("forecast_timestamp"),
374:             "horizon_hour",
375:             "pickup_location_id",
376:             "pickup_zone_name",
377:             "pickup_borough",
378:             "service_type",
379:             "predicted_trip_count",
380:             "lower_bound",
381:             "upper_bound",
382:             "demand_level",
383:             "model_id",
384:             "generated_at",
385:         )
386:     )
387: 
388:     metric_frame = metrics_frame(features.sparkSession, "forecast", winner_algorithm, test_metrics)
389:     result = MLModelResult(
390:         model_id=model_id,
391:         model_name="forecast",
392:         algorithm=winner_algorithm,
393:         status="SUCCESS",
394:         trained_at=generated_at,
395:         training_rows=training_rows,
396:         validation_rows=validation_rows,
397:         test_rows=test_rows,
398:         metrics=test_metrics,
399:         model_path=str(model_path),
400:         output_paths={},
401:         feature_columns=[*NUMERIC_FEATURES, *CATEGORICAL_FEATURES],
402:         target_column="trip_count",
403:     )
404:     test_predictions.unpersist()
405:     prepared.unpersist()
406:     return ForecastOutput(result, future_predictions, anomalies, metric_frame)
</file>

<file path="src/tlc_data_platform/ml/manifest.py">
 1: """Genera el manifiesto JSON de cada corrida de entrenamiento ML."""
 2: 
 3: from __future__ import annotations
 4: 
 5: import json
 6: from datetime import date, datetime
 7: from pathlib import Path
 8: from typing import Any
 9: 
10: 
11: class _Encoder(json.JSONEncoder):
12:     def default(self, value: Any) -> Any:
13:         if isinstance(value, (datetime, date)):
14:             return value.isoformat()
15:         if isinstance(value, Path):
16:             return str(value)
17:         return super().default(value)
18: 
19: 
20: class MLManifestWriter:
21:     """Writes one consistent manifest under data/manifests/ml/."""
22: 
23:     def __init__(self, root: Path, run_id: str) -> None:
24:         root.mkdir(parents=True, exist_ok=True)
25:         self.path = root / f"{run_id}.json"
26: 
27:     def write(self, payload: Any) -> Path:
28:         document = {
29:             "manifest_schema_version": "1.0",
30:             "layer": "ml",
31:             "manifest_type": "pipeline_execution",
32:             "summary": payload.to_dict(),
33:         }
34:         temp = self.path.with_suffix(".json.part")
35:         temp.write_text(
36:             json.dumps(document, cls=_Encoder, ensure_ascii=False, indent=2),
37:             encoding="utf-8",
38:         )
39:         temp.replace(self.path)
40:         return self.path
</file>

