272:     def _normalize_taxi_zones(self, spark: Any, path: Path, source_sha256: str) -> Any:
273:         from pyspark.sql import functions as F
274: 
275:         raw = (
276:             spark.read.option("header", True)
277:             .option("inferSchema", False)
278:             .csv(str(path))
279:         )
280:         location = self._find_column(raw, ["LocationID", "location_id"])
281:         borough = self._find_column(raw, ["Borough"])
282:         zone = self._find_column(raw, ["Zone"])
283:         service_zone = self._find_column(raw, ["service_zone"])
284:         if not all([location, borough, zone, service_zone]):
285:             raise ValueError(f"Esquema inesperado en Taxi Zone Lookup: {raw.columns}")
286:         return (
287:             raw.select(
288:                 F.col(location).cast("int").alias("location_id"),
289:                 F.trim(F.col(borough)).alias("borough"),
290:                 F.trim(F.col(zone)).alias("zone_name"),
291:                 F.trim(F.col(service_zone)).alias("service_zone"),
292:             )
293:             .filter(F.col("location_id").isNotNull())
294:             .dropDuplicates(["location_id"])
295:             .withColumn("is_airport", F.col("location_id").isin(1, 132, 138))
296:             .withColumn(
297:                 "airport_name",
298:                 F.when(F.col("location_id") == 1, F.lit("Newark Liberty International Airport"))
299:                 .when(F.col("location_id") == 132, F.lit("John F. Kennedy International Airport"))
300:                 .when(F.col("location_id") == 138, F.lit("LaGuardia Airport"))
301:                 .otherwise(F.lit(None).cast("string")),
302:             )
303:             .withColumn("source_url", F.lit(self._config.silver.references.taxi_zones_url))
304:             .withColumn("source_sha256", F.lit(source_sha256))
305:             .withColumn("refreshed_at", F.current_timestamp())
306:         )
307: 
308:     def _normalize_bases(self, spark: Any, path: Path, source_sha256: str) -> Any:
309:         from pyspark.sql import functions as F
310: 
311:         raw = (
312:             spark.read.option("header", True)
313:             .option("inferSchema", False)
314:             .csv(str(path))
315:         )
316:         license_col = self._find_column(
317:             raw,
318:             ["License Number", "license_number", "base_license_number", "base_license"],
319:         )
320:         name_col = self._find_column(raw, ["Base Name", "base_name", "name"])
321:         type_col = self._find_column(
322:             raw, ["Type", "base_type", "license_type", "base_license_type"]
323:         )
324:         status_col = self._find_column(raw, ["Status", "base_status"])
325:         dba_col = self._find_column(raw, ["DBA", "doing_business_as"])
326:         phone_col = self._find_column(
327:             raw, ["Base Telephone Number", "base_telephone_number", "telephone"]
328:         )
329:         if not license_col:
330:             raise ValueError(f"Esquema inesperado en Current Bases: {raw.columns}")
331:         return (
332:             raw.select(
333:                 F.upper(F.trim(F.col(license_col))).alias("base_license_number"),
334:                 (
335:                     F.trim(F.col(name_col))
336:                     if name_col
337:                     else F.lit(None).cast("string")
338:                 ).alias("base_name"),
339:                 (
340:                     F.trim(F.col(dba_col))
341:                     if dba_col
342:                     else F.lit(None).cast("string")
343:                 ).alias("doing_business_as"),
344:                 (
345:                     F.trim(F.col(type_col))
346:                     if type_col
347:                     else F.lit(None).cast("string")
348:                 ).alias("base_type"),
349:                 (
350:                     F.trim(F.col(status_col))
351:                     if status_col
352:                     else F.lit(None).cast("string")
353:                 ).alias("status"),
354:                 (
355:                     F.trim(F.col(phone_col))
356:                     if phone_col
357:                     else F.lit(None).cast("string")
358:                 ).alias("telephone"),
359:             )
360:             .filter(
361:                 F.col("base_license_number").isNotNull()
362:                 & (F.length("base_license_number") > 0)
363:             )
364:             .dropDuplicates(["base_license_number"])
365:             .withColumn("source_url", F.lit(self._config.silver.references.base_lookup_url))
366:             .withColumn("source_sha256", F.lit(source_sha256))
