<file path="src/tlc_data_platform/silver/transformers/common.py">
  1: from __future__ import annotations
  2: 
  3: from dataclasses import dataclass
  4: from typing import Any, Iterable
  5: 
  6: from tlc_data_platform.core.settings import SilverQualityConfig
  7: from tlc_data_platform.silver.models import SilverTransformContext
  8: 
  9: 
 10: @dataclass(frozen=True)
 11: class Rule:
 12:     code: str
 13:     severity: str
 14:     condition: Any
 15: 
 16: 
 17: def _column_lookup(df: Any) -> dict[str, str]:
 18:     return {name.lower(): name for name in df.columns}
 19: 
 20: 
 21: def col_from_aliases(df: Any, aliases: Iterable[str], dtype: str, default: Any = None) -> Any:
 22:     from pyspark.sql import functions as F
 23: 
 24:     lookup = _column_lookup(df)
 25:     for alias in aliases:
 26:         actual = lookup.get(alias.lower())
 27:         if actual is not None:
 28:             return F.col(actual).cast(dtype)
 29:     return F.lit(default).cast(dtype)
 30: 
 31: 
 32: def normalize_string(column: Any) -> Any:
 33:     from pyspark.sql import functions as F
 34: 
 35:     return F.upper(F.trim(column.cast("string")))
 36: 
 37: 
 38: def normalize_yn(column: Any) -> Any:
 39:     from pyspark.sql import functions as F
 40: 
 41:     value = normalize_string(column)
 42:     return F.when(value.isin("Y", "N"), value).otherwise(F.lit(None).cast("string"))
 43: 
 44: 
 45: def normalize_boolean(column: Any) -> Any:
 46:     from pyspark.sql import functions as F
 47: 
 48:     value = normalize_string(column)
 49:     return (
 50:         F.when(value.isin("Y", "YES", "TRUE", "1"), F.lit(True))
 51:         .when(value.isin("N", "NO", "FALSE", "0"), F.lit(False))
 52:         .otherwise(F.lit(None).cast("boolean"))
 53:     )
 54: 
 55: 
 56: def add_common_metadata(df: Any, context: SilverTransformContext) -> Any:
 57:     from pyspark.sql import functions as F
 58: 
 59:     return (
 60:         df.withColumn("service_type", F.lit(context.service))
 61:         .withColumn("pickup_date", F.to_date("pickup_datetime"))
 62:         .withColumn("dropoff_date", F.to_date("dropoff_datetime"))
 63:         .withColumn("pickup_hour", F.hour("pickup_datetime").cast("int"))
 64:         .withColumn("pickup_day_of_week", F.dayofweek("pickup_datetime").cast("int"))
 65:         .withColumn("weekend_trip_flag", F.dayofweek("pickup_datetime").isin(1, 7))
 66:         .withColumn(
 67:             "night_trip_flag",
 68:             (F.hour("pickup_datetime") < 6) | (F.hour("pickup_datetime") >= 22),
 69:         )
 70:         .withColumn("source_file", F.lit(context.source_file))
 71:         .withColumn("source_year", F.lit(context.year).cast("int"))
 72:         .withColumn("source_month", F.lit(context.month).cast("int"))
 73:         .withColumn("bronze_sha256", F.lit(context.source_sha256).cast("string"))
 74:         .withColumn("bronze_execution_id", F.lit(context.bronze_execution_id).cast("string"))
 75:         .withColumn("silver_execution_id", F.lit(context.silver_execution_id))
 76:         .withColumn("silver_processed_at", F.current_timestamp())
 77:     )
 78: 
 79: 
 80: def add_trip_business_id(df: Any, fields: list[str]) -> Any:
 81:     from pyspark.sql import functions as F
 82: 
 83:     values = [F.coalesce(F.col(name).cast("string"), F.lit("∅")) for name in fields]
 84:     return df.withColumn("trip_business_id", F.sha2(F.concat_ws("||", *values), 256))
 85: 
 86: 
 87: def common_rules(df: Any, context: SilverTransformContext, quality: SilverQualityConfig, max_duration_hours: float) -> list[Rule]:
 88:     from pyspark.sql import functions as F
 89: 
 90:     duration = F.col("trip_duration_seconds")
 91:     pickup = F.col("pickup_datetime")
 92:     return [
 93:         Rule("MISSING_PICKUP_DATETIME", "ERROR", pickup.isNull()),
 94:         Rule("MISSING_DROPOFF_DATETIME", "ERROR", F.col("dropoff_datetime").isNull()),
 95:         Rule("INVALID_DATE_ORDER", "ERROR", duration <= 0),
 96:         Rule("DURATION_ABOVE_LIMIT", "ERROR", duration > int(max_duration_hours * 3600)),
 97:         Rule(
 98:             "PICKUP_OUTSIDE_SOURCE_PERIOD",
 99:             "ERROR",
100:             pickup.isNotNull()
101:             & ((F.year(pickup) != F.lit(context.year)) | (F.month(pickup) != F.lit(context.month))),
102:         ),
103:         Rule(
104:             "INVALID_PICKUP_LOCATION",
105:             "ERROR",
106:             F.col("pickup_location_id").isNull()
107:             | ~F.col("pickup_location_id").between(quality.valid_location_id_min, quality.valid_location_id_max),
108:         ),
109:         Rule(
110:             "INVALID_DROPOFF_LOCATION",
111:             "ERROR",
112:             F.col("dropoff_location_id").isNull()
113:             | ~F.col("dropoff_location_id").between(quality.valid_location_id_min, quality.valid_location_id_max),
114:         ),
115:     ]
116: 
117: 
118: def apply_rules(df: Any, rules: list[Rule], deduplicate: bool = True) -> Any:
119:     from pyspark.sql import Window
120:     from pyspark.sql import functions as F
121: 
122:     if deduplicate:
123:         window = Window.partitionBy("trip_business_id").orderBy(F.monotonically_increasing_id())
124:         df = df.withColumn("_duplicate_rank", F.row_number().over(window))
125:         rules = [*rules, Rule("DUPLICATE_TRIP", "ERROR", F.col("_duplicate_rank") > 1)]
126: 
127:     error_exprs = [F.when(rule.condition, F.lit(rule.code)) for rule in rules if rule.severity == "ERROR"]
128:     warning_exprs = [F.when(rule.condition, F.lit(rule.code)) for rule in rules if rule.severity == "WARNING"]
129:     empty = F.array().cast("array<string>")
130:     error_array = F.filter(F.array(*error_exprs), lambda item: item.isNotNull()) if error_exprs else empty
131:     warning_array = F.filter(F.array(*warning_exprs), lambda item: item.isNotNull()) if warning_exprs else empty
132:     df = (
133:         df.withColumn("quality_error_codes", error_array)
134:         .withColumn("quality_warning_codes", warning_array)
135:         .withColumn("quality_error_count", F.size("quality_error_codes"))
136:         .withColumn("quality_warning_count", F.size("quality_warning_codes"))
137:         .withColumn(
138:             "quality_status",
139:             F.when(F.col("quality_error_count") > 0, F.lit("REJECTED"))
140:             .when(F.col("quality_warning_count") > 0, F.lit("WARNING"))
141:             .otherwise(F.lit("VALID")),
142:         )
143:     )
144:     return df.drop("_duplicate_rank") if "_duplicate_rank" in df.columns else df
145: 
146: 
147: def split_valid_rejected(df: Any) -> tuple[Any, Any]:
148:     from pyspark.sql import functions as F
149: 
150:     return (
151:         df.filter(F.col("quality_error_count") == 0),
152:         df.filter(F.col("quality_error_count") > 0),
153:     )
154: 
155: 
156: def taxi_rules(df: Any, context: SilverTransformContext, quality: SilverQualityConfig) -> list[Rule]:
157:     from pyspark.sql import functions as F
158: 
159:     rules = common_rules(df, context, quality, quality.taxi_max_duration_hours)
160:     rules.extend(
161:         [
162:             Rule("PASSENGER_COUNT_OUT_OF_RANGE", "ERROR", (F.col("passenger_count") < 0) | (F.col("passenger_count") > quality.max_passenger_count)),
163:             Rule("PASSENGER_COUNT_IMPUTED", "WARNING", F.col("passenger_count_imputed")),
164:             Rule("INVALID_TRIP_DISTANCE", "ERROR", F.col("trip_distance").isNull() | (F.col("trip_distance") < 0) | (F.col("trip_distance") > quality.max_trip_distance_miles)),
165:             Rule("ZERO_TRIP_DISTANCE", "ERROR" if quality.reject_zero_distance else "WARNING", F.col("trip_distance") == 0),
166:             Rule("NEGATIVE_FARE_AMOUNT", "ERROR", F.col("fare_amount").isNull() | (F.col("fare_amount") < 0)),
167:             Rule("NON_POSITIVE_TOTAL_AMOUNT", "ERROR", F.col("total_amount").isNull() | (F.col("total_amount") <= 0)),
168:             Rule("TOTAL_AMOUNT_ABOVE_LIMIT", "ERROR", F.col("total_amount") > quality.max_total_amount),
169:             Rule("TIP_EXCEEDS_FARE", "WARNING", (F.col("tip_amount") > 50) & (F.col("tip_amount") > F.col("fare_amount"))),
170:             Rule("SUSPICIOUS_TOLL_AMOUNT", "WARNING", (F.col("tolls_amount") > 40) & (F.col("trip_distance") < 5)),
171:             Rule("INVALID_VENDOR_NORMALIZED", "WARNING", F.col("vendor_normalized")),
172:             Rule("INVALID_RATE_CODE_NORMALIZED", "WARNING", F.col("rate_code_normalized")),
173:             Rule("INVALID_PAYMENT_TYPE_NORMALIZED", "WARNING", F.col("payment_type_normalized")),
174:             Rule("INVALID_STORE_FLAG_NORMALIZED", "WARNING", F.col("store_flag_normalized")),
175:         ]
176:     )
177:     if quality.reject_negative_component_amounts:
178:         components = ["extra", "mta_tax", "tip_amount", "tolls_amount", "improvement_surcharge", "congestion_surcharge", "airport_fee", "cbd_congestion_fee"]
179:         rules.append(Rule("NEGATIVE_COMPONENT_AMOUNT", "ERROR", F.greatest(*[F.when(F.col(c) < 0, F.lit(1)).otherwise(F.lit(0)) for c in components]) == 1))
180:     return rules
181: 
182: 
183: def append_quality_rules(
184:     df: Any,
185:     *,
186:     error_conditions: dict[str, Any] | None = None,
187:     warning_conditions: dict[str, Any] | None = None,
188: ) -> Any:
189:     """Appends post-transformation quality rules and recalculates the row status."""
190:     from pyspark.sql import functions as F
191: 
192:     error_conditions = error_conditions or {}
193:     warning_conditions = warning_conditions or {}
194:     error_items = [
195:         F.when(condition, F.lit(code)) for code, condition in error_conditions.items()
196:     ]
197:     warning_items = [
198:         F.when(condition, F.lit(code)) for code, condition in warning_conditions.items()
199:     ]
200:     empty = F.array().cast("array<string>")
201:     new_errors = (
202:         F.filter(F.array(*error_items), lambda item: item.isNotNull())
203:         if error_items
204:         else empty
205:     )
206:     new_warnings = (
207:         F.filter(F.array(*warning_items), lambda item: item.isNotNull())
208:         if warning_items
209:         else empty
210:     )
211:     return (
212:         df.withColumn(
213:             "quality_error_codes",
214:             F.array_distinct(F.concat(F.col("quality_error_codes"), new_errors)),
215:         )
216:         .withColumn(
217:             "quality_warning_codes",
218:             F.array_distinct(F.concat(F.col("quality_warning_codes"), new_warnings)),
219:         )
220:         .withColumn("quality_error_count", F.size("quality_error_codes"))
221:         .withColumn("quality_warning_count", F.size("quality_warning_codes"))
222:         .withColumn(
223:             "quality_status",
224:             F.when(F.col("quality_error_count") > 0, F.lit("REJECTED"))
225:             .when(F.col("quality_warning_count") > 0, F.lit("WARNING"))
226:             .otherwise(F.lit("VALID")),
227:         )
228:     )
</file>

