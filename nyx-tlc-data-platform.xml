 16:     "fhvhv": "HVFHV",
 17: }
 18: 
 19: 
 20: @dataclass(frozen=True)
 21: class ScopeSelection:
 22:     years: list[int]
 23:     months: list[int]
 24:     services: list[str]
 25: 
 26: 
 27: def _available(frame: pd.DataFrame, column: str) -> list:
 28:     if frame.empty or column not in frame.columns:
 29:         return []
 30:     return sorted(value for value in frame[column].dropna().unique().tolist())
 31: 
 32: 
 33: def render_scope_filters(
 34:     frame: pd.DataFrame,
 35:     *,
 36:     key: str,
 37:     year_col: str = "source_year",
 38:     month_col: str = "source_month",
 39:     service_col: str = "service_type",
 40:     show_month: bool = True,
 41: ) -> ScopeSelection:
 42:     years = [int(value) for value in _available(frame, year_col)]
 43:     months = [int(value) for value in _available(frame, month_col)] if show_month else []
 44:     services = [str(value) for value in _available(frame, service_col)]
 45: 
 46:     st.sidebar.markdown("### Filtros")
 47:     selected_years = st.sidebar.multiselect(
 48:         "Año",
 49:         years,
 50:         default=years,
 51:         key=f"{key}_years",
 52:     )
 53:     selected_months = months
 54:     if show_month and months:
 55:         selected_months = st.sidebar.multiselect(
 56:             "Mes",
 57:             months,
 58:             default=months,
 59:             format_func=lambda value: f"{int(value):02d}",
 60:             key=f"{key}_months",
 61:         )
 62:     selected_services = st.sidebar.multiselect(
 63:         "Servicio",
 64:         services,
 65:         default=services,
 66:         format_func=lambda value: SERVICE_LABELS.get(str(value).lower(), str(value).upper()),
 67:         key=f"{key}_services",
 68:     )
 69:     return ScopeSelection(
 70:         years=[int(value) for value in selected_years],
 71:         months=[int(value) for value in selected_months],
 72:         services=[str(value) for value in selected_services],
 73:     )
 74: 
 75: 
 76: def apply_scope(
 77:     frame: pd.DataFrame,
 78:     selection: ScopeSelection,
 79:     *,
 80:     year_col: str = "source_year",
 81:     month_col: str = "source_month",
 82:     service_col: str = "service_type",
 83: ) -> pd.DataFrame:
 84:     result = frame.copy()
 85:     if result.empty:
 86:         return result
 87:     if selection.years and year_col in result.columns:
 88:         result = result[result[year_col].isin(selection.years)]
 89:     if selection.months and month_col in result.columns:
 90:         result = result[result[month_col].isin(selection.months)]
 91:     if selection.services and service_col in result.columns:
 92:         result = result[result[service_col].astype(str).isin(selection.services)]
 93:     return result
 94: 
 95: 
 96: def coverage_note(selection: ScopeSelection) -> str | None:
 97:     scope = load_dashboard_config().get("analysis_scope", {})
 98:     partial = scope.get("partial_services", {})
 99:     messages: list[str] = []
100:     for service, details in partial.items():
101:         if service not in selection.services:
102:             continue
103:         available_years = {int(value) for value in details.get("available_years", [])}
104:         missing = sorted(set(selection.years) - available_years)
105:         if missing:
106:             years = ", ".join(str(value) for value in missing)
107:             messages.append(
108:                 f"{SERVICE_LABELS.get(service, service.upper())}: sin cobertura Gold para {years}; se excluye del cálculo, no se imputa como cero."
109:             )
110:     return " ".join(messages) if messages else None
111: 
112: 
