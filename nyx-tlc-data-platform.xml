437:     def _build_features(
438:         self,
439:         spark: Any,
440:         guard: Any,
441:         audit: GoldAuditRepositories,
442:         execution_id: str,
443:         partitions: list[GoldSourcePartition],
444:     ) -> list[GoldDatasetResult]:
445:         activity, _taxi, hvfhv, dim_zone = self._analytical_inputs(spark, partitions)
446:         frames = {
447:             "zone_hourly_demand": build_zone_hourly_demand_features(activity, dim_zone),
448:             "zone_profiles": build_zone_profile_features(activity, hvfhv, dim_zone),
449:             "hvfhv_wait_risk": build_hvfhv_wait_features(hvfhv, dim_zone),
450:         }
