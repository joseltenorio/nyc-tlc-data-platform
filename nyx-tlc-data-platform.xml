 709:     def _record_unified_audit(
 710:         self,
 711:         audit: AuditRepositories,
 712:         execution_id: str,
 713:         summary: ExecutionSummary,
 714:         availability: list[AvailabilityRecord],
 715:         outcomes: list[FileOutcome],
 716:     ) -> None:
 717:         unified = audit.unified
 718:         if unified is None:
 719:             return
 720:         for outcome in outcomes:
 721:             validation = outcome.validation
 722:             physical = (
 723:                 parquet_metrics(Path(outcome.local_path))
 724:                 if outcome.local_path
 725:                 else None
 726:             )
 727:             unified.record_dataset(
 728:                 execution_id,
 729:                 layer="bronze",
 730:                 dataset_name=outcome.candidate.file_name,
 731:                 dataset_type="source_parquet",
 732:                 operation="download_validate_publish",
 733:                 status=outcome.status,
 734:                 path=outcome.local_path,
 735:                 parquet_files=physical.parquet_files if physical else None,
 736:                 rows=(
 737:                     validation.parquet_num_rows
 738:                     if validation is not None
 739:                     else (physical.rows if physical else None)
 740:                 ),
 741:                 bytes_on_disk=(
 742:                     physical.bytes_on_disk
 743:                     if physical is not None
 744:                     else outcome.bytes_downloaded
 745:                 ),
 746:                 service=outcome.candidate.service,
 747:                 year=outcome.candidate.year,
 748:                 month=outcome.candidate.month,
 749:                 metadata={
 750:                     "sha256": outcome.sha256,
 751:                     "attempt_count": outcome.attempt_count,
 752:                     "retry_count": outcome.retry_count,
 753:                     "schema_hash": validation.schema_hash if validation else None,
 754:                     "download_started_at": outcome.download_started_at,
 755:                     "download_finished_at": outcome.download_finished_at,
 756:                     "download_duration_seconds": outcome.download_duration_seconds,
 757:                     "throughput_bytes_per_second": outcome.throughput_bytes_per_second,
 758:                 },
 759:             )
 760:             if outcome.status == "READY" and validation is not None:
 761:                 required_ok = not validation.missing_required_columns and not validation.type_mismatches
 762:                 unified.record_quality(
 763:                     execution_id,
 764:                     layer="bronze",
 765:                     dataset_name=outcome.candidate.file_name,
 766:                     rule_code="BRONZE_SCHEMA_CONTRACT",
 767:                     dimension="validity",
 768:                     severity="ERROR",
 769:                     status="PASSED" if required_ok else "FAILED",
 770:                     expected="required columns and compatible types",
 771:                     actual={
 772:                         "missing_required": validation.missing_required_columns,
 773:                         "type_mismatches": validation.type_mismatches,
 774:                     },
 775:                     failed_rows=0 if required_ok else validation.parquet_num_rows,
 776:                     context={"service": outcome.candidate.service, "year": outcome.candidate.year, "month": outcome.candidate.month},
 777:                 )
 778:                 unified.record_quality(
 779:                     execution_id,
 780:                     layer="bronze",
 781:                     dataset_name=outcome.candidate.file_name,
 782:                     rule_code="BRONZE_NON_EMPTY_PARQUET",
 783:                     dimension="completeness",
 784:                     severity="ERROR",
 785:                     status="PASSED" if validation.parquet_num_rows > 0 else "FAILED",
 786:                     expected="> 0 rows",
 787:                     actual=validation.parquet_num_rows,
 788:                     failed_rows=0 if validation.parquet_num_rows > 0 else 1,
 789:                 )
 790:             elif outcome.status in {"FAILED", DEFERRED_REMOTE_ACCESS}:
 791:                 unified.record_quality(
 792:                     execution_id,
 793:                     layer="bronze",
 794:                     dataset_name=outcome.candidate.file_name,
 795:                     rule_code="BRONZE_FILE_PROCESSING",
 796:                     dimension="availability",
 797:                     severity="ERROR" if outcome.status == "FAILED" else "WARNING",
 798:                     status="FAILED" if outcome.status == "FAILED" else "WARNING",
 799:                     message=outcome.error_message,
 800:                     context={"error_type": outcome.error_type},
 801:                 )
 802: 
 803:         outcome_by_period = {
 804:             outcome.candidate.period_id: outcome for outcome in outcomes
 805:         }
 806:         ready_periods = {
 807:             period_id
 808:             for period_id, outcome in outcome_by_period.items()
 809:             if outcome.status in {"READY", "SKIPPED_UNCHANGED"}
 810:         }
 811:         missing_set: set[str] = set()
 812:         details: list[dict[str, Any]] = []
 813:         for item in availability:
 814:             outcome = outcome_by_period.get(item.period_id)
 815:             physical_status = outcome.status if outcome is not None else None
 816:             detail = item.to_dict()
 817:             detail["processing_status"] = physical_status
 818:             detail["ready"] = item.period_id in ready_periods
 819:             details.append(detail)
 820:             if not item.applicable:
 821:                 continue
 822:             if (
 823:                 item.status == "NOT_PUBLISHED_YET"
 824:                 and not self._config.audit.treat_not_published_as_missing
 825:             ):
 826:                 continue
 827:             if item.status != "AVAILABLE" or item.period_id not in ready_periods:
 828:                 missing_set.add(item.period_id)
 829:         missing = sorted(missing_set)
 830:         unified.record_coverage(
 831:             execution_id,
 832:             layer="bronze",
 833:             expected_count=summary.expected_periods,
 834:             available_count=summary.available_files,
 835:             ready_count=len(ready_periods),
 836:             missing=missing,
 837:             not_applicable_count=summary.not_applicable_periods,
 838:             not_published_count=summary.not_published_files,
 839:             deferred_count=sum(item.status == DEFERRED_REMOTE_ACCESS for item in availability),
 840:             details=details,
 841:         )
 842:         expected_published = max(
 843:             0,
 844:             summary.expected_periods
 845:             - summary.not_applicable_periods
 846:             - (
 847:                 summary.not_published_files
 848:                 if not self._config.audit.treat_not_published_as_missing
 849:                 else 0
 850:             ),
 851:         )
 852:         unified.record_quality(
 853:             execution_id,
 854:             layer="bronze",
 855:             dataset_name="bronze_layer",
 856:             rule_code="BRONZE_EXPECTED_DATASETS_READY",
 857:             dimension="completeness",
 858:             severity="ERROR",
 859:             status="PASSED" if not missing else "FAILED",
 860:             expected=expected_published,
 861:             actual=len(ready_periods),
 862:             failed_rows=len(missing),
 863:             context={"missing_periods": missing},
 864:         )
 865:         unified.finish_run(
 866:             execution_id,
 867:             status=summary.status,
 868:             finished_at=summary.finished_at,
 869:             metrics={
 870:                 "parquet_files_expected": summary.applicable_periods,
 871:                 "parquet_files_available": summary.available_files,
 872:                 "parquet_files_processed": summary.ready_files,
 873:                 "parquet_files_skipped": summary.skipped_files,
 874:                 "parquet_files_failed": summary.failed_files,
 875:                 "download_attempts": summary.total_download_attempts,
 876:                 "download_retries": summary.total_retries,
 877:                 "bytes_downloaded": summary.total_bytes_downloaded,
 878:                 "download_seconds": summary.total_download_seconds,
 879:                 "average_download_mbps": summary.average_download_mbps,
 880:                 "error_rate": summary.error_rate,
 881:             },
 882:         )
