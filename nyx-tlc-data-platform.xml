<file path="src/tlc_data_platform/ml/pipeline.py">
  1: from __future__ import annotations
  2: 
  3: import logging
  4: from dataclasses import replace
  5: from pathlib import Path
  6: from typing import Any
  7: from uuid import uuid4
  8: 
  9: from tlc_data_platform.audit.ml_model_repository import MLModelRepository
 10: from tlc_data_platform.audit.ml_run_repository import MLRunRepository
 11: from tlc_data_platform.audit.parquet_metrics import parquet_metrics
 12: from tlc_data_platform.audit.processing_attempt_repository import ProcessingAttemptRepository
 13: from tlc_data_platform.audit.unified import UnifiedAuditRepository
 14: from tlc_data_platform.core.settings import AppConfig
 15: from tlc_data_platform.ml.audit import MLAuditRepositories
 16: from tlc_data_platform.ml.forecast import train_forecast
 17: from tlc_data_platform.ml.manifest import MLManifestWriter
 18: from tlc_data_platform.ml.models import MLExecutionSummary, MLPlanSummary, utc_now
 19: from tlc_data_platform.ml.segmentation import train_segmentation
 20: from tlc_data_platform.ml.spark import MLSparkProvider
 21: from tlc_data_platform.ml.storage import MLStorage
 22: from tlc_data_platform.ml.wait_risk import train_wait_risk
 23: from tlc_data_platform.mongodb.client import MongoClientProvider
 24: from tlc_data_platform.mongodb.gold_ml_index_manager import GoldMLIndexManager
 25: 
 26: LOGGER = logging.getLogger(__name__)
 27: MODEL_NAMES = ("forecast", "segmentation", "wait-risk")
 28: 
 29: 
 30: class MLPipeline:
 31:     """Trains one model at a time with bounded Spark spill and atomic outputs."""
 32: 
 33:     def __init__(self, config: AppConfig) -> None:
 34:         self._config = config
 35:         self._storage = MLStorage(config.ml, config.gold)
 36:         self._spark_provider = MLSparkProvider(config.ml.spark)
 37:         self._mongo_provider = MongoClientProvider(config.mongo)
 38: 
 39:     def close(self) -> None:
 40:         self._spark_provider.close()
 41:         self._mongo_provider.close()
 42: 
 43:     def plan(self, models: list[str] | None = None) -> MLPlanSummary:
 44:         requested = self._validate_models(models)
 45:         available = {
 46:             model_name: self._storage.has_parquet(self._storage.feature_path(model_name))
 47:             for model_name in requested
 48:         }
 49:         missing = [
 50:             str(self._storage.feature_path(name))
 51:             for name, exists in available.items()
 52:             if not exists
 53:         ]
 54:         return MLPlanSummary(
 55:             status="READY" if not missing else "BLOCKED",
 56:             requested_models=requested,
 57:             available_features=available,
 58:             missing_paths=missing,
 59:         )
 60: 
 61:     def run(self, models: list[str] | None = None) -> MLExecutionSummary:
 62:         requested = self._validate_models(models)
 63:         plan = self.plan(requested)
 64:         if plan.missing_paths:
 65:             raise FileNotFoundError(
 66:                 "Faltan bases Gold para ML: " + ", ".join(plan.missing_paths)
 67:             )
 68: 
 69:         self._storage.ensure_directories()
 70:         self._storage.cleanup_stale_temporary()
 71:         run_id = f"ml-{utc_now().strftime('%Y%m%dT%H%M%S')}-{uuid4().hex[:8]}"
 72:         started_at = utc_now()
 73:         manifest = MLManifestWriter(self._config.ml.storage.manifests_root, run_id)
 74:         audit = self._audit()
 75:         audit.runs.start(run_id, started_at, requested)
 76:         if audit.unified is not None:
 77:             audit.unified.start_run(
 78:                 run_id,
 79:                 layer="ml",
 80:                 execution_type="train",
 81:                 selection={"models": requested},
 82:                 started_at=started_at,
 83:             )
 84:         spark = self._spark_provider.get()
 85:         guard = self._spark_provider.guard()
 86:         results = []
 87:         errors: list[dict[str, str]] = []
 88: 
 89:         try:
 90:             for model_name in requested:
 91:                 attempt_id = audit.attempts.start(
 92:                     run_id, "ml", "train_model", model_name, utc_now()
 93:                 )
 94:                 try:
 95:                     feature_path = self._storage.feature_path(model_name)
 96:                     feature_metrics = parquet_metrics(feature_path)
 97:                     features = spark.read.parquet(str(feature_path))
 98:                     output = guard.run(
 99:                         lambda model_name=model_name, features=features: self._train_one(
100:                             model_name, features
101:                         )
102:                     )
103:                     paths = self._publish_outputs(
104:                         guard, run_id, model_name, output
105:                     )
106:                     result = replace(output.result, output_paths=paths)
107:                     results.append(result)
108:                     audit.models.register(result)
109:                     audit.prediction_runs.insert_one(
110:                         {
111:                             "run_id": run_id,
112:                             "model_id": result.model_id,
113:                             "model_name": result.model_name,
114:                             "generated_at": result.trained_at,
115:                             "output_paths": paths,
116:                             "status": "SUCCESS",
117:                         }
118:                     )
119:                     metric_docs = [
120:                         {
121:                             "run_id": run_id,
122:                             "model_id": result.model_id,
123:                             "model_name": result.model_name,
124:                             "algorithm": result.algorithm,
125:                             "metric_name": name,
126:                             "metric_value": float(value),
127:                             "recorded_at": utc_now(),
128:                         }
129:                         for name, value in result.metrics.items()
130:                     ]
131:                     if metric_docs:
132:                         audit.metrics.insert_many(metric_docs)
133:                     audit.attempts.finish(
134:                         attempt_id,
135:                         utc_now(),
136:                         status="SUCCESS",
137:                         rows_read=feature_metrics.rows,
138:                     )
139:                     self._record_model_audit(
140:                         audit, run_id, model_name, result, paths, feature_metrics
141:                     )
142:                 except Exception as error:
143:                     LOGGER.exception("Falló el modelo %s: %s", model_name, error)
144:                     errors.append(
145:                         {
146:                             "model_name": model_name,
147:                             "error_type": type(error).__name__,
148:                             "error_message": str(error)[:2000],
149:                         }
150:                     )
151:                     audit.attempts.finish(
152:                         attempt_id, utc_now(), status="FAILED", error=error
153:                     )
154:                     if audit.unified is not None:
155:                         audit.unified.record_quality(
156:                             run_id,
157:                             layer="ml",
158:                             dataset_name=model_name,
159:                             rule_code="ML_MODEL_TRAINING",
160:                             dimension="reliability",
161:                             severity="ERROR",
162:                             status="FAILED",
163:                             message=str(error)[:2000],
164:                         )
165:                     if not self._config.ml.execution.continue_on_model_error:
166:                         raise
167:                 finally:
168:                     spark.catalog.clearCache()
169: 
170:             status = "SUCCESS" if not errors else (
171:                 "PARTIAL_SUCCESS" if results else "FAILED"
172:             )
173:             summary = MLExecutionSummary(
174:                 run_id=run_id,
175:                 status=status,
176:                 started_at=started_at,
177:                 finished_at=utc_now(),
178:                 requested_models=requested,
179:                 trained_models=len(results),
180:                 failed_models=len(errors),
181:                 results=results,
182:                 errors=errors,
183:             )
184:             audit.runs.finish(summary)
185:             self._finish_unified(audit, summary)
186:             manifest.write(summary)
187:             return summary
188:         except Exception as error:
189:             summary = MLExecutionSummary(
190:                 run_id=run_id,
191:                 status="FAILED",
192:                 started_at=started_at,
193:                 finished_at=utc_now(),
194:                 requested_models=requested,
195:                 trained_models=len(results),
196:                 failed_models=max(1, len(errors)),
197:                 results=results,
198:                 errors=errors
199:                 or [
200:                     {
201:                         "model_name": "pipeline",
202:                         "error_type": type(error).__name__,
203:                         "error_message": str(error)[:2000],
204:                     }
205:                 ],
206:             )
207:             audit.runs.finish(summary)
208:             if audit.unified is not None:
209:                 audit.unified.fail_run(run_id, error, layer="ml")
210:             manifest.write(summary)
211:             raise
212:         finally:
213:             self._storage.cleanup_execution(run_id)
214: 
215:     def _train_one(self, model_name: str, features: Any) -> Any:
216:         if model_name == "forecast":
217:             return train_forecast(
218:                 features,
219:                 self._config.ml.forecast,
220:                 seed=self._config.ml.execution.random_seed,
221:                 model_root=self._config.ml.storage.model_root / "forecast",
222:             )
223:         if model_name == "segmentation":
224:             return train_segmentation(
225:                 features,
226:                 self._config.ml.segmentation,
227:                 seed=self._config.ml.execution.random_seed,
228:                 model_root=self._config.ml.storage.model_root / "segmentation",
229:             )
230:         return train_wait_risk(
231:             features,
232:             self._config.ml.wait_risk,
233:             seed=self._config.ml.execution.random_seed,
234:             model_root=self._config.ml.storage.model_root / "wait-risk",
235:         )
236: 
237:     def _publish_outputs(
238:         self, guard: Any, run_id: str, model_name: str, output: Any
239:     ) -> dict[str, str]:
240:         if model_name == "forecast":
241:             definitions = {
242:                 "predictions": (
243:                     output.predictions,
244:                     self._config.ml.forecast.prediction_dataset,
245:                 ),
246:                 "anomalies": (
247:                     output.anomalies,
248:                     self._config.ml.forecast.anomaly_dataset,
249:                 ),
250:                 "metrics": (output.metrics, self._config.ml.forecast.metrics_dataset),
251:             }
252:         elif model_name == "segmentation":
253:             definitions = {
254:                 "assignments": (
255:                     output.assignments,
256:                     self._config.ml.segmentation.assignment_dataset,
257:                 ),
258:                 "profiles": (
259:                     output.profiles,
260:                     self._config.ml.segmentation.profile_dataset,
261:                 ),
262:                 "metrics": (
263:                     output.metrics,
264:                     self._config.ml.segmentation.metrics_dataset,
265:                 ),
266:             }
267:         else:
268:             definitions = {
269:                 "predictions": (
270:                     output.predictions,
271:                     self._config.ml.wait_risk.prediction_dataset,
272:                 ),
273:                 "metrics": (output.metrics, self._config.ml.wait_risk.metrics_dataset),
274:                 "feature_importance": (
275:                     output.feature_importance,
276:                     self._config.ml.wait_risk.importance_dataset,
277:                 ),
278:             }
279: 
280:         paths: dict[str, str] = {}
281:         for role, (frame, dataset_name) in definitions.items():
282:             path = self._storage.output_path(dataset_name)
283:             guard.run(
284:                 lambda frame=frame, path=path, role=role: self._storage.write_atomic(
285:                     frame, path, run_id, f"{model_name}-{role}"
286:                 )
287:             )
288:             paths[role] = str(path)
289:         return paths
290: 
291:     def _record_model_audit(
292:         self,
293:         audit: MLAuditRepositories,
294:         run_id: str,
295:         model_name: str,
296:         result: Any,
297:         paths: dict[str, str],
298:         feature_metrics: Any,
299:     ) -> None:
300:         unified = audit.unified
301:         if unified is None:
302:             return
303:         unified.record_dataset(
304:             run_id,
305:             layer="ml",
306:             dataset_name=self._storage.feature_path(model_name).name,
307:             dataset_type="feature_input",
308:             operation="train",
309:             status="READ",
310:             path=str(self._storage.feature_path(model_name)),
311:             parquet_files=feature_metrics.parquet_files,
312:             rows=feature_metrics.rows,
313:             bytes_on_disk=feature_metrics.bytes_on_disk,
314:         )
315:         for role, path_text in paths.items():
316:             metrics = parquet_metrics(Path(path_text))
317:             unified.record_dataset(
318:                 run_id,
319:                 layer="ml",
320:                 dataset_name=Path(path_text).name,
321:                 dataset_type=f"model_{role}",
322:                 operation="publish",
323:                 status="READY",
324:                 path=path_text,
325:                 parquet_files=metrics.parquet_files,
326:                 rows=metrics.rows,
327:                 bytes_on_disk=metrics.bytes_on_disk,
328:                 metadata={
329:                     "model_name": model_name,
330:                     "model_id": result.model_id,
331:                     "algorithm": result.algorithm,
332:                 },
333:             )
334:         split_ok = (
335:             result.training_rows > 0
336:             and result.validation_rows > 0
337:             and result.test_rows > 0
338:         )
339:         unified.record_quality(
340:             run_id,
341:             layer="ml",
342:             dataset_name=model_name,
343:             rule_code="ML_TEMPORAL_SPLITS_NON_EMPTY",
344:             dimension="completeness",
345:             severity="ERROR",
346:             status="PASSED" if split_ok else "FAILED",
347:             expected="training, validation and test > 0",
348:             actual={
349:                 "training_rows": result.training_rows,
350:                 "validation_rows": result.validation_rows,
351:                 "test_rows": result.test_rows,
352:             },
353:             failed_rows=0 if split_ok else 1,
354:         )
355:         unified.record_quality(
356:             run_id,
357:             layer="ml",
358:             dataset_name=model_name,
359:             rule_code="ML_METRICS_RECORDED",
360:             dimension="observability",
361:             severity="ERROR",
362:             status="PASSED" if result.metrics else "FAILED",
363:             expected="> 0 metrics",
364:             actual=len(result.metrics),
365:             failed_rows=0 if result.metrics else 1,
366:         )
367: 
368:     def _finish_unified(
369:         self, audit: MLAuditRepositories, summary: MLExecutionSummary
370:     ) -> None:
371:         unified = audit.unified
372:         if unified is None:
373:             return
374:         expected = len(summary.requested_models)
375:         ready = summary.trained_models
376:         missing = [
377:             model
378:             for model in summary.requested_models
379:             if model not in {result.model_name for result in summary.results}
380:         ]
381:         unified.record_coverage(
382:             summary.run_id,
383:             layer="ml",
384:             expected_count=expected,
385:             available_count=expected,
386:             ready_count=ready,
387:             missing=missing,
388:             details=[
389:                 {
390:                     "model": model,
391:                     "status": "READY"
392:                     if model in {result.model_name for result in summary.results}
393:                     else "FAILED",
394:                 }
395:                 for model in summary.requested_models
396:             ],
397:         )
398:         unified.record_quality(
399:             summary.run_id,
400:             layer="ml",
401:             dataset_name="ml_layer",
402:             rule_code="ML_EXPECTED_MODELS_TRAINED",
403:             dimension="completeness",
404:             severity="ERROR",
405:             status="PASSED" if not missing else "FAILED",
406:             expected=expected,
407:             actual=ready,
408:             failed_rows=len(missing),
409:             context={"missing_models": missing},
410:         )
411:         unified.finish_run(
412:             summary.run_id,
413:             status=summary.status,
414:             finished_at=summary.finished_at,
415:             metrics={
416:                 "models_requested": expected,
417:                 "models_trained": summary.trained_models,
418:                 "models_failed": summary.failed_models,
419:                 "parquet_outputs": sum(
420:                     len(result.output_paths) for result in summary.results
421:                 ),
422:             },
423:         )
424: 
425:     @staticmethod
426:     def _validate_models(models: list[str] | None) -> list[str]:
427:         requested = list(dict.fromkeys(models or MODEL_NAMES))
428:         unknown = sorted(set(requested) - set(MODEL_NAMES))
429:         if unknown:
430:             raise ValueError(f"Modelos desconocidos: {', '.join(unknown)}")
431:         return requested
432: 
433:     def _audit(self) -> MLAuditRepositories:
434:         database = self._mongo_provider.database()
435:         GoldMLIndexManager(
436:             database, self._config.gold.collections, self._config.ml.collections
437:         ).ensure_indexes()
438:         names = self._config.ml.collections
439:         return MLAuditRepositories(
440:             runs=MLRunRepository(database[names.training_runs]),
441:             models=MLModelRepository(database[names.model_registry]),
442:             attempts=ProcessingAttemptRepository(database[names.processing_attempts]),
443:             prediction_runs=database[names.prediction_runs],
444:             metrics=database[names.metrics],
445:             unified=UnifiedAuditRepository(database, self._config.audit),
