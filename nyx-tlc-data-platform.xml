 1: from __future__ import annotations
 2: 
 3: from tlc_data_platform.bronze.models import ExpectedPeriod
 4: from tlc_data_platform.core.settings import AppConfig
 5: 
 6: 
 7: def is_period_applicable(
 8:     config: AppConfig, service: str, year: int, month: int
 9: ) -> bool:
10:     """Returns whether a period belongs to both the official and project scope.
11: 
12:     `available_from` describes TLC's official history. `scope_from/scope_to`
13:     describes the bounded dataset selected for this project. This prevents a
14:     generic historical or incremental command from downloading years/services
15:     intentionally excluded from the analytical coverage.
16:     """
17:     service_config = config.services[service]
18:     point = (year, month)
19:     return (
20:         point >= (service_config.available_from.year, service_config.available_from.month)
21:         and point >= (service_config.scope_from.year, service_config.scope_from.month)
22:         and point <= (service_config.scope_to.year, service_config.scope_to.month)
23:     )
24: 
25: 
26: def generate_expected_periods(
27:     config: AppConfig,
28:     services: list[str],
29:     start_year: int,
30:     end_year: int,
31:     months: list[int],
32: ) -> list[ExpectedPeriod]:
33:     periods: list[ExpectedPeriod] = []
34:     for service in sorted(services):
35:         for year in range(start_year, end_year + 1):
36:             for month in sorted(set(months)):
37:                 periods.append(
38:                     ExpectedPeriod(
39:                         service=service,
40:                         year=year,
41:                         month=month,
42:                         applicable=is_period_applicable(
43:                             config, service, year, month
44:                         ),
45:                     )
46:                 )
47:     return periods
