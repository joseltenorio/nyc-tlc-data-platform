<file path="src/tlc_data_platform/ml/common.py">
 1: """Contiene métricas compartidas para regresión, clasificación y comparación con baselines."""
 2: 
 3: from __future__ import annotations
 4: 
 5: import math
 6: from typing import Any
 7: 
 8: 
 9: def regression_metrics(frame: Any, label_col: str = "trip_count") -> dict[str, float]:
10:     """Calculates scale-aware metrics without collecting all predictions."""
11:     from pyspark.sql import functions as F
12: 
13:     row = frame.agg(
14:         F.avg(F.abs(F.col("prediction") - F.col(label_col))).alias("mae"),
15:         F.sqrt(F.avg(F.pow(F.col("prediction") - F.col(label_col), 2))).alias("rmse"),
16:         (
17:             F.sum(F.abs(F.col("prediction") - F.col(label_col)))
18:             / F.greatest(F.sum(F.abs(F.col(label_col))), F.lit(1.0))
19:         ).alias("wape"),
20:     ).first()
21:     return {name: float(row[name] or 0.0) for name in ("mae", "rmse", "wape")}
22: 
23: 
24: def baseline_metrics(frame: Any, baseline_col: str, label_col: str = "trip_count") -> dict[str, float]:
25:     from pyspark.sql import functions as F
26: 
27:     baseline = frame.filter(F.col(baseline_col).isNotNull()).select(
28:         F.col(label_col), F.col(baseline_col).cast("double").alias("prediction")
29:     )
30:     if baseline.limit(1).count() == 0:
31:         return {"mae": math.inf, "rmse": math.inf, "wape": math.inf}
32:     return regression_metrics(baseline, label_col)
33: 
34: 
35: def classification_metrics(frame: Any, label_col: str) -> dict[str, float]:
36:     from pyspark.ml.evaluation import BinaryClassificationEvaluator, MulticlassClassificationEvaluator
37: 
38:     auc_pr = BinaryClassificationEvaluator(
39:         labelCol=label_col, rawPredictionCol="rawPrediction", metricName="areaUnderPR"
40:     ).evaluate(frame)
41:     auc_roc = BinaryClassificationEvaluator(
42:         labelCol=label_col, rawPredictionCol="rawPrediction", metricName="areaUnderROC"
43:     ).evaluate(frame)
44:     metrics = {"auc_pr": float(auc_pr), "auc_roc": float(auc_roc)}
45:     for name, spark_name in (
46:         ("f1", "f1"),
47:         ("precision", "weightedPrecision"),
48:         ("recall", "weightedRecall"),
49:         ("accuracy", "accuracy"),
50:     ):
51:         metrics[name] = float(
52:             MulticlassClassificationEvaluator(
53:                 labelCol=label_col, predictionCol="prediction", metricName=spark_name
54:             ).evaluate(frame)
55:         )
56:     return metrics
57: 
58: 
59: def metrics_frame(spark: Any, model_name: str, algorithm: str, metrics: dict[str, float]) -> Any:
60:     rows = [(model_name, algorithm, name, float(value)) for name, value in sorted(metrics.items())]
61:     return spark.createDataFrame(
62:         rows, "model_name string, algorithm string, metric_name string, metric_value double"
63:     )
