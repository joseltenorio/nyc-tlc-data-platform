 1: from __future__ import annotations
 2: 
 3: import hashlib
 4: from pathlib import Path
 5: 
 6: 
 7: def calculate_sha256(path: Path, chunk_size: int = 8 * 1024 * 1024) -> str:
 8:     digest = hashlib.sha256()
 9:     with path.open("rb") as handle:
10:         while chunk := handle.read(chunk_size):
11:             digest.update(chunk)
12:     return digest.hexdigest()
</file>

