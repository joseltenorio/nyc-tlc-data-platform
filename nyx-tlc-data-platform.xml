<file path="src/tlc_data_platform/ml/segmentation.py">
  1: from __future__ import annotations
  2: 
  3: from dataclasses import dataclass
  4: from pathlib import Path
  5: from typing import Any
  6: from uuid import uuid4
  7: 
  8: from tlc_data_platform.core.settings import SegmentationConfig
  9: from tlc_data_platform.ml.common import metrics_frame
 10: from tlc_data_platform.ml.models import MLModelResult, utc_now
 11: 
 12: 
 13: @dataclass(frozen=True)
 14: class SegmentationOutput:
 15:     result: MLModelResult
 16:     assignments: Any
 17:     profiles: Any
 18:     metrics: Any
 19: 
 20: 
 21: FEATURE_COLUMNS = [
 22:     "total_pickups",
 23:     "total_dropoffs",
 24:     "average_duration_seconds",
 25:     "average_distance_miles",
 26:     "average_speed_mph",
 27:     "night_trip_share",
 28:     "weekend_trip_share",
 29:     "airport_trip_share",
 30:     "yellow_share",
 31:     "green_share",
 32:     "fhv_share",
 33:     "fhvhv_share",
 34:     "service_diversity",
 35:     "demand_coefficient_of_variation",
 36:     "average_request_to_pickup_seconds",
 37:     "shared_match_share",
 38:     "wav_match_share",
 39: ]
 40: 
 41: 
 42: def _pipeline(k: int, config: SegmentationConfig, seed: int) -> Any:
 43:     from pyspark.ml import Pipeline
 44:     from pyspark.ml.clustering import KMeans
 45:     from pyspark.ml.feature import StandardScaler, VectorAssembler
 46: 
 47:     assembler = VectorAssembler(
 48:         inputCols=FEATURE_COLUMNS,
 49:         outputCol="raw_features",
 50:         handleInvalid="keep",
 51:     )
 52:     scaler = StandardScaler(
 53:         inputCol="raw_features",
 54:         outputCol="features",
 55:         withMean=True,
 56:         withStd=True,
 57:     )
 58:     kmeans = KMeans(
 59:         featuresCol="features",
 60:         predictionCol="cluster_id",
 61:         k=k,
 62:         maxIter=config.max_iter,
 63:         seed=seed,
 64:     )
 65:     return Pipeline(stages=[assembler, scaler, kmeans])
 66: 
 67: 
 68: def _cluster_names(profile_rows: list[Any]) -> dict[int, str]:
 69:     """Converts numeric clusters into business-friendly, unique labels."""
 70:     if not profile_rows:
 71:         return {}
 72:     remaining = {int(row["cluster_id"]): row.asDict() for row in profile_rows}
 73:     names: dict[int, str] = {}
 74: 
 75:     def assign(metric: str, label: str) -> None:
 76:         candidates = [(cluster, data.get(metric) or 0.0) for cluster, data in remaining.items()]
 77:         if not candidates:
 78:             return
 79:         cluster = max(candidates, key=lambda item: item[1])[0]
 80:         names[cluster] = label
 81:         remaining.pop(cluster, None)
 82: 
 83:     assign("airport_trip_share", "Zonas aeroportuarias")
 84:     assign("total_pickups", "Núcleos de alta demanda")
 85:     assign("night_trip_share", "Centros de actividad nocturna")
 86:     assign("service_diversity", "Mercados multimodales")
 87:     assign("weekend_trip_share", "Zonas recreativas de fin de semana")
 88:     assign("average_request_to_pickup_seconds", "Zonas con fricción de recogida")
 89: 
 90:     fallback = [
 91:         "Corredores residenciales estables",
 92:         "Zonas emergentes",
 93:         "Zonas de baja actividad",
 94:         "Corredores de demanda variable",
 95:     ]
 96:     for index, cluster in enumerate(sorted(remaining)):
 97:         names[cluster] = fallback[index] if index < len(fallback) else f"Perfil territorial {index + 1}"
 98:     return names
 99: 
100: 
101: def train_segmentation(
102:     features: Any,
103:     config: SegmentationConfig,
104:     *,
105:     seed: int,
106:     model_root: Path,
107: ) -> SegmentationOutput:
108:     """Selects K by silhouette and segments TLC zones, not individual trips."""
109:     from pyspark.ml.evaluation import ClusteringEvaluator
110:     from pyspark.sql import functions as F
111: 
112:     prepared = features.fillna(0.0, subset=FEATURE_COLUMNS).filter(F.col("total_pickups") > 0).persist()
113:     rows = prepared.count()
114:     if rows < config.k_min:
115:         raise ValueError(
116:             f"Solo existen {rows} zonas activas; no se puede evaluar k={config.k_min}."
117:         )
118: 
119:     evaluator = ClusteringEvaluator(
120:         featuresCol="features", predictionCol="cluster_id", metricName="silhouette"
121:     )
122:     candidates: list[tuple[int, float, Any]] = []
123:     upper = min(config.k_max, rows - 1)
124:     for k in range(config.k_min, upper + 1):
125:         model = _pipeline(k, config, seed).fit(prepared)
126:         transformed = model.transform(prepared)
127:         silhouette = float(evaluator.evaluate(transformed))
128:         candidates.append((k, silhouette, model))
129:     if not candidates:
130:         raise ValueError("No fue posible evaluar ningún valor de k.")
131: 
132:     best_k, best_silhouette, best_model = max(candidates, key=lambda item: item[1])
133:     model_id = str(uuid4())
134:     model_path = model_root / model_id
135:     model_path.parent.mkdir(parents=True, exist_ok=True)
136:     best_model.write().overwrite().save(str(model_path))
137: 
138:     raw_assignments = best_model.transform(prepared).persist()
139:     profile_expressions = [F.avg(column).alias(column) for column in FEATURE_COLUMNS]
140:     profiles = raw_assignments.groupBy("cluster_id").agg(
141:         F.count("zone_key").alias("zone_count"), *profile_expressions
142:     )
143:     names = _cluster_names(profiles.collect())
144:     name_rows = [(cluster, label) for cluster, label in sorted(names.items())]
145:     name_frame = features.sparkSession.createDataFrame(name_rows, "cluster_id int, segment_name string")
146:     profiles = profiles.join(name_frame, "cluster_id", "left")
147:     assignments = raw_assignments.join(name_frame, "cluster_id", "left").select(
148:         "zone_key",
149:         "location_id",
150:         "zone_name",
151:         "borough",
152:         "service_zone",
153:         "is_airport",
154:         "cluster_id",
155:         "segment_name",
156:         *FEATURE_COLUMNS,
157:     )
158: 
159:     metrics = {
160:         "best_k": float(best_k),
161:         "silhouette": best_silhouette,
162:         **{f"silhouette_k_{k}": score for k, score, _ in candidates},
163:     }
164:     metric_frame = metrics_frame(features.sparkSession, "segmentation", "kmeans", metrics)
165:     trained_at = utc_now()
166:     result = MLModelResult(
167:         model_id=model_id,
168:         model_name="segmentation",
169:         algorithm="kmeans",
170:         status="SUCCESS",
171:         trained_at=trained_at,
172:         training_rows=rows,
173:         validation_rows=0,
174:         test_rows=0,
175:         metrics=metrics,
176:         model_path=str(model_path),
177:         output_paths={},
178:         feature_columns=FEATURE_COLUMNS,
179:         target_column="cluster_id",
180:     )
181:     raw_assignments.unpersist()
182:     prepared.unpersist()
183:     return SegmentationOutput(result, assignments, profiles, metric_frame)
</file>

