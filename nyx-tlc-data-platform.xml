<file path="src/tlc_data_platform/audit/unified.py">
  1: from __future__ import annotations
  2: 
  3: import logging
  4: from datetime import datetime, timezone
  5: from typing import Any
  6: from uuid import uuid4
  7: 
  8: from tlc_data_platform.audit.file_sink import FileAuditSink
  9: from tlc_data_platform.core.settings import AuditConfig
 10: 
 11: LOGGER = logging.getLogger(__name__)
 12: 
 13: 
 14: def utc_now() -> datetime:
 15:     return datetime.now(timezone.utc)
 16: 
 17: 
 18: class UnifiedAuditRepository:
 19:     """Writes the same real audit facts to MongoDB and append-only JSONL.
 20: 
 21:     MongoDB supports operational queries and claims. JSONL is an independent
 22:     evidence trail for dashboards and post-mortem analysis when MongoDB is not
 23:     reachable. Both stores receive the same identifiers, so dashboard reads can
 24:     deduplicate safely without estimating or fabricating metrics.
 25:     """
 26: 
 27:     def __init__(self, database: Any, config: AuditConfig) -> None:
 28:         self._db = database
 29:         self._config = config
 30:         self._names = config.collections
 31:         self._files = FileAuditSink(config.filesystem)
 32:         self._run_state: dict[str, dict[str, Any]] = {}
 33:         self.ensure_indexes()
 34: 
 35:     def _append_file(self, event_type: str, layer: str, payload: dict[str, Any]) -> None:
 36:         try:
 37:             self._files.append(event_type, layer, payload)
 38:         except Exception:
 39:             LOGGER.exception("No se pudo persistir el evento JSONL %s", event_type)
 40: 
 41:     def _refresh_inventory(self, execution_id: str, layer: str, status: str) -> None:
 42:         try:
 43:             self._files.refresh_inventory(
 44:                 execution_id=execution_id,
 45:                 trigger_layer=layer,
 46:                 status=status,
 47:             )
 48:         except Exception:
 49:             LOGGER.exception("No se pudo actualizar el inventario físico Medallion")
 50: 
 51:     def _find_run(self, execution_id: str) -> dict[str, Any]:
 52:         try:
 53:             return self._db[self._names.pipeline_runs].find_one(
 54:                 {"execution_id": execution_id},
 55:                 {
 56:                     "_id": 0,
 57:                     "started_at": 1,
 58:                     "layer": 1,
 59:                     "execution_type": 1,
 60:                     "selection": 1,
 61:                     "parent_execution_id": 1,
 62:                 },
 63:             ) or {}
 64:         except Exception:
 65:             LOGGER.exception(
 66:                 "No se pudo consultar la corrida %s en MongoDB; se continuará con el estado local",
 67:                 execution_id,
 68:             )
 69:             return {}
 70: 
 71:     def ensure_indexes(self) -> None:
 72:         self._db[self._names.pipeline_runs].create_index(
 73:             [("execution_id", 1)], unique=True, name="uq_audit_pipeline_execution"
 74:         )
 75:         self._db[self._names.pipeline_runs].create_index(
 76:             [("layer", 1), ("started_at", -1)], name="ix_audit_runs_layer_started"
 77:         )
 78:         self._db[self._names.dataset_events].create_index(
 79:             [("event_id", 1)], unique=True, name="uq_audit_dataset_event"
 80:         )
 81:         self._db[self._names.dataset_events].create_index(
 82:             [("execution_id", 1), ("layer", 1), ("dataset_name", 1)],
 83:             name="ix_audit_dataset_execution",
 84:         )
 85:         self._db[self._names.quality_events].create_index(
 86:             [("quality_id", 1)], unique=True, name="uq_audit_quality_event"
 87:         )
 88:         self._db[self._names.quality_events].create_index(
 89:             [("execution_id", 1), ("layer", 1), ("status", 1)],
 90:             name="ix_audit_quality_execution",
 91:         )
 92:         self._db[self._names.coverage_snapshots].create_index(
 93:             [("execution_id", 1), ("layer", 1)],
 94:             unique=True,
 95:             name="uq_audit_coverage_execution_layer",
 96:         )
 97:         self._db[self._names.download_attempts].create_index(
 98:             [
 99:                 ("execution_id", 1),
100:                 ("service", 1),
101:                 ("year", 1),
102:                 ("month", 1),
103:                 ("attempt_number", 1),
104:             ],
105:             unique=True,
106:             name="uq_audit_download_attempt",
107:         )
108:         self._db[self._names.download_attempts].create_index(
109:             [("attempted_at", -1), ("outcome", 1)], name="ix_audit_download_attempt_time"
110:         )
111: 
112:     def start_run(
113:         self,
114:         execution_id: str,
115:         *,
116:         layer: str,
117:         execution_type: str,
118:         selection: dict[str, Any] | None = None,
119:         parent_execution_id: str | None = None,
120:         started_at: datetime | None = None,
121:     ) -> None:
122:         now = started_at or utc_now()
123:         payload = {
124:             "execution_id": execution_id,
125:             "parent_execution_id": parent_execution_id,
126:             "layer": layer,
127:             "execution_type": execution_type,
128:             "status": "RUNNING",
129:             "started_at": now,
130:             "selection": selection or {},
131:             "updated_at": now,
132:             "event_action": "START",
133:         }
134:         self._run_state[execution_id] = dict(payload)
135:         self._append_file("pipeline_run", layer, payload)
136:         self._db[self._names.pipeline_runs].update_one(
137:             {"execution_id": execution_id},
138:             {
139:                 "$set": {key: value for key, value in payload.items() if key != "event_action"},
140:                 "$setOnInsert": {"created_at": now},
141:             },
142:             upsert=True,
143:         )
144: 
145:     def link_parent(self, execution_id: str, parent_execution_id: str) -> None:
146:         now = utc_now()
147:         persisted = self._find_run(execution_id)
148:         current = self._run_state.setdefault(
149:             execution_id,
150:             {**persisted, "execution_id": execution_id},
151:         )
152:         current["parent_execution_id"] = parent_execution_id
153:         current["updated_at"] = now
154:         layer = str(current.get("layer") or persisted.get("layer") or "unknown")
155:         self._append_file(
156:             "pipeline_run",
157:             layer,
158:             {
159:                 "execution_id": execution_id,
160:                 "parent_execution_id": parent_execution_id,
161:                 "updated_at": now,
162:                 "event_action": "LINK_PARENT",
163:             },
164:         )
165:         self._db[self._names.pipeline_runs].update_one(
166:             {"execution_id": execution_id},
167:             {"$set": {"parent_execution_id": parent_execution_id, "updated_at": now}},
168:             upsert=False,
169:         )
170: 
171:     def finish_run(
172:         self,
173:         execution_id: str,
174:         *,
175:         status: str,
176:         metrics: dict[str, Any] | None = None,
177:         warnings: list[str] | None = None,
178:         finished_at: datetime | None = None,
179:     ) -> None:
180:         now = finished_at or utc_now()
181:         document = self._find_run(execution_id)
182:         state = {**document, **self._run_state.get(execution_id, {})}
183:         started = state.get("started_at")
184:         duration = (now - started).total_seconds() if isinstance(started, datetime) else None
185:         layer = str(state.get("layer") or "unknown")
186:         payload = {
187:             **state,
188:             "execution_id": execution_id,
189:             "layer": layer,
190:             "status": status,
191:             "finished_at": now,
192:             "duration_seconds": duration,
193:             "metrics": metrics or {},
194:             "warnings": warnings or [],
195:             "updated_at": now,
196:             "event_action": "FINISH",
197:         }
198:         self._run_state[execution_id] = dict(payload)
199:         self._append_file("pipeline_run", layer, payload)
200:         self._db[self._names.pipeline_runs].update_one(
201:             {"execution_id": execution_id},
202:             {
203:                 "$set": {
204:                     "status": status,
205:                     "finished_at": now,
206:                     "duration_seconds": duration,
207:                     "metrics": metrics or {},
208:                     "warnings": warnings or [],
209:                     "updated_at": now,
210:                 }
211:             },
212:             upsert=True,
213:         )
214:         self._refresh_inventory(execution_id, layer, status)
215: 
216:     def fail_run(self, execution_id: str, error: Exception, *, layer: str | None = None) -> None:
217:         now = utc_now()
218:         existing = self._find_run(execution_id)
219:         state = {**existing, **self._run_state.get(execution_id, {})}
220:         effective_layer = str(layer or state.get("layer") or "unknown")
221:         started_at = state.get("started_at")
222:         duration_seconds = (
223:             (now - started_at).total_seconds() if isinstance(started_at, datetime) else None
224:         )
225:         payload = {
226:             **state,
227:             "execution_id": execution_id,
228:             "layer": effective_layer,
229:             "status": "FAILED",
230:             "finished_at": now,
231:             "duration_seconds": duration_seconds,
232:             "error_type": type(error).__name__,
233:             "error_message": str(error)[:4000],
234:             "updated_at": now,
235:             "event_action": "FAIL",
236:         }
237:         self._run_state[execution_id] = dict(payload)
238:         self._append_file("pipeline_run", effective_layer, payload)
239:         self._db[self._names.pipeline_runs].update_one(
240:             {"execution_id": execution_id},
241:             {
242:                 "$set": {
243:                     "layer": effective_layer,
244:                     "status": "FAILED",
245:                     "finished_at": now,
246:                     "duration_seconds": duration_seconds,
247:                     "error_type": type(error).__name__,
248:                     "error_message": str(error)[:4000],
249:                     "updated_at": now,
250:                 }
251:             },
252:             upsert=True,
253:         )
254:         self._refresh_inventory(execution_id, effective_layer, "FAILED")
255: 
