10: class MongoClientProvider:
11:     def __init__(self, config: MongoConfig) -> None:
12:         self._config = config
13:         self._client: Any | None = None
14:         self._database: Any | None = None
15: 
16:     def database(self) -> Any:
17:         if self._database is None:
18:             from pymongo import MongoClient
19: 
20:             uri = os.getenv(
21:                 self._config.uri_environment_variable,
22:                 self._config.default_uri,
23:             )
24: 
25:             self._client = MongoClient(
26:                 uri,
27:                 serverSelectionTimeoutMS=self._config.connect_timeout_ms,
28:                 tz_aware=True,
29:                 tzinfo=timezone.utc,
30:             )
31: 
32:             self._client.admin.command("ping")
33:             self._database = self._client[self._config.database]
34: 
35:         return self._database
36: 
37:     def close(self) -> None:
38:         if self._client is not None:
39:             self._client.close()
40:             self._client = None
41:             self._database = None
