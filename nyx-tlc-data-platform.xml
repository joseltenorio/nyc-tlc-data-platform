 65: class FileAuditSink:
 66:     """Persists append-only audit events and a physical Parquet inventory.
 67: 
 68:     MongoDB remains the operational store, while these JSONL files are an
 69:     independent, dashboard-readable evidence trail. Every record is produced
 70:     from pipeline facts or a physical filesystem scan; no synthetic values are
 71:     introduced.
 72:     """
 73: 
 74:     SCHEMA_VERSION = "1.0"
 75: 
 76:     def __init__(self, config: AuditFilesystemConfig) -> None:
 77:         self._config = config
 78:         self._event_files = {
 79:             "pipeline_run": config.pipeline_runs_file,
 80:             "dataset_event": config.dataset_events_file,
 81:             "quality_event": config.quality_events_file,
 82:             "coverage_snapshot": config.coverage_snapshots_file,
 83:             "download_attempt": config.download_attempts_file,
 84:         }
 85: 
 86:     @property
 87:     def enabled(self) -> bool:
 88:         return self._config.enabled
 89: 
 90:     def append(self, event_type: str, layer: str, document: dict[str, Any]) -> None:
 91:         if not self.enabled:
 92:             return
 93:         file_name = self._event_files[event_type]
 94:         normalized_layer = (layer or "unknown").strip().lower()
 95:         path = self._config.root / normalized_layer / file_name
 96:         payload = {
 97:             "audit_schema_version": self.SCHEMA_VERSION,
 98:             "event_type": event_type,
 99:             "written_at": utc_now(),
100:             **document,
101:         }
102:         payload["layer"] = normalized_layer
103:         line = json.dumps(
104:             _json_safe(payload),
105:             ensure_ascii=False,
106:             allow_nan=False,
107:             separators=(",", ":"),
108:         )
109:         path.parent.mkdir(parents=True, exist_ok=True)
110:         with _path_lock(path):
111:             with path.open("a", encoding="utf-8", newline="\n") as handle:
112:                 handle.write(line + "\n")
113:                 handle.flush()
114: 
115:     def refresh_inventory(
116:         self,
117:         *,
118:         execution_id: str,
119:         trigger_layer: str,
120:         status: str,
121:     ) -> dict[str, Any] | None:
122:         if not self.enabled:
123:             return None
124:         captured_at = utc_now()
125:         layers = [
126:             self._scan_layer(layer, root)
127:             for layer, root in sorted(self._config.layer_roots.items())
128:         ]
129:         snapshot = {
130:             "audit_schema_version": self.SCHEMA_VERSION,
131:             "snapshot_id": str(uuid4()),
132:             "execution_id": execution_id,
133:             "trigger_layer": trigger_layer.lower(),
134:             "status": status.upper(),
135:             "captured_at": captured_at,
136:             "layers": layers,
137:             "totals": {
138:                 "parquet_files": sum(item["parquet_files"] for item in layers),
139:                 "bytes_on_disk": sum(item["bytes_on_disk"] for item in layers),
140:                 "datasets": sum(item["dataset_count"] for item in layers),
141:                 "scan_errors": sum(item["scan_error_count"] for item in layers),
142:             },
143:         }
144:         inventory_dir = self._config.root / "inventory"
145:         history_path = inventory_dir / self._config.inventory_snapshots_file
146:         current_path = inventory_dir / self._config.inventory_current_file
147:         inventory_dir.mkdir(parents=True, exist_ok=True)
148:         serialized = json.dumps(
149:             _json_safe(snapshot),
150:             ensure_ascii=False,
151:             allow_nan=False,
152:             separators=(",", ":"),
153:         )
154:         with _path_lock(history_path):
155:             with history_path.open("a", encoding="utf-8", newline="\n") as handle:
156:                 handle.write(serialized + "\n")
157:                 handle.flush()
158:         temporary = current_path.with_suffix(current_path.suffix + ".tmp")
159:         with _path_lock(current_path):
160:             temporary.write_text(
161:                 json.dumps(
162:                     _json_safe(snapshot),
163:                     ensure_ascii=False,
164:                     allow_nan=False,
165:                     indent=2,
166:                 ),
167:                 encoding="utf-8",
168:             )
169:             os.replace(temporary, current_path)
170:         return snapshot
171: 
172:     @staticmethod
173:     def _scan_layer(layer: str, root: Path) -> dict[str, Any]:
174:         files: list[Path] = []
175:         errors: list[dict[str, str]] = []
176:         if root.is_file() and root.suffix.lower() == ".parquet":
177:             files = [root]
178:         elif root.is_dir():
179:             try:
180:                 files = sorted(item for item in root.rglob("*.parquet") if item.is_file())
181:             except OSError as exc:
182:                 errors.append({"path": str(root), "error": str(exc)[:1000]})
183: 
184:         datasets: dict[str, dict[str, Any]] = {}
185:         total_bytes = 0
186:         latest_modified_ns = 0
187:         for file_path in files:
188:             try:
189:                 stat = file_path.stat()
190:             except OSError as exc:
191:                 errors.append({"path": str(file_path), "error": str(exc)[:1000]})
192:                 continue
193:             total_bytes += stat.st_size
194:             latest_modified_ns = max(latest_modified_ns, stat.st_mtime_ns)
195:             dataset_name = FileAuditSink._dataset_name(layer, root, file_path)
196:             bucket = datasets.setdefault(
197:                 dataset_name,
198:                 {"dataset_name": dataset_name, "parquet_files": 0, "bytes_on_disk": 0},
199:             )
200:             bucket["parquet_files"] += 1
201:             bucket["bytes_on_disk"] += stat.st_size
202: 
203:         latest_modified_at = None
204:         if latest_modified_ns:
205:             latest_modified_at = datetime.fromtimestamp(
206:                 latest_modified_ns / 1_000_000_000, tz=timezone.utc
207:             )
208:         return {
209:             "layer": layer.lower(),
210:             "root": str(root),
211:             "root_exists": root.exists(),
212:             "parquet_files": sum(item["parquet_files"] for item in datasets.values()),
213:             "bytes_on_disk": total_bytes,
214:             "dataset_count": len(datasets),
215:             "latest_modified_at": latest_modified_at,
216:             "scan_error_count": len(errors),
217:             "scan_errors": errors,
218:             "datasets": sorted(datasets.values(), key=lambda item: item["dataset_name"]),
219:         }
220: 
221:     @staticmethod
222:     def _dataset_name(layer: str, root: Path, file_path: Path) -> str:
223:         try:
224:             parts = file_path.relative_to(root).parts
225:         except ValueError:
226:             return root.name
227:         if not parts:
228:             return root.name
229:         normalized_layer = layer.lower()
230:         if normalized_layer == "bronze":
231:             if parts[0] == "trip_records" and len(parts) >= 2:
232:                 return parts[1]
233:             if parts[0] == "versions" and len(parts) >= 3:
234:                 return f"versions/{parts[2]}"
235:             if parts[0] == "reference" and len(parts) >= 2:
236:                 return f"reference/{parts[1]}"
237:         if normalized_layer == "gold" and len(parts) >= 2:
238:             return parts[1]
239:         first = parts[0]
240:         return root.name if "=" in first else first
</file>

