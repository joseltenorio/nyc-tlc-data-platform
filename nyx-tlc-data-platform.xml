 91: def _coalesce_runs(records: Iterable[dict[str, Any]]) -> pd.DataFrame:
 92:     merged: dict[str, dict[str, Any]] = {}
 93:     order: list[str] = []
 94:     for record in records:
 95:         execution_id = str(record.get("execution_id") or "").strip()
 96:         if not execution_id:
 97:             continue
 98:         if execution_id not in merged:
 99:             order.append(execution_id)
100:             merged[execution_id] = {}
101:         merged[execution_id] = _deep_merge(merged[execution_id], record)
102:     rows = [merged[execution_id] for execution_id in order]
103:     frame = pd.json_normalize(rows, sep=".") if rows else pd.DataFrame()
104:     if frame.empty:
105:         return frame
106:     if "run_id" in frame.columns and "execution_id" not in frame.columns:
107:         frame = frame.rename(columns={"run_id": "execution_id"})
108:     for column in ("started_at", "finished_at", "updated_at", "written_at"):
109:         if column in frame.columns:
110:             frame[column] = pd.to_datetime(frame[column], utc=True, errors="coerce")
111:     if "duration_seconds" not in frame.columns:
112:         frame["duration_seconds"] = pd.NA
113:     if {"started_at", "finished_at"}.issubset(frame.columns):
114:         calculated = (frame["finished_at"] - frame["started_at"]).dt.total_seconds()
115:         frame["duration_seconds"] = pd.to_numeric(
116:             frame["duration_seconds"], errors="coerce"
117:         ).fillna(calculated)
118:     return frame.sort_values("started_at", ascending=False, na_position="last").reset_index(drop=True)
