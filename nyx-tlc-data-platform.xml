<file path="src/tlc_data_platform/orchestration/platform_pipeline.py">
  1: from __future__ import annotations
  2: 
  3: from dataclasses import dataclass
  4: from typing import Any
  5: from uuid import uuid4
  6: 
  7: from tlc_data_platform.audit.unified import UnifiedAuditRepository, utc_now
  8: from tlc_data_platform.core.settings import AppConfig, RunSelection
  9: from tlc_data_platform.gold.models import GoldExecutionSummary
 10: from tlc_data_platform.ml.models import MLExecutionSummary
 11: from tlc_data_platform.mongodb.client import MongoClientProvider
 12: from tlc_data_platform.orchestration.gold_pipeline import run_gold_pipeline
 13: from tlc_data_platform.orchestration.medallion_pipeline import (
 14:     MedallionExecutionSummary,
 15:     run_medallion_to_silver,
 16: )
 17: from tlc_data_platform.orchestration.ml_pipeline import run_ml_pipeline
 18: 
 19: 
 20: @dataclass(frozen=True)
 21: class PlatformExecutionSummary:
 22:     execution_id: str
 23:     status: str
 24:     bronze_silver: MedallionExecutionSummary
 25:     gold: GoldExecutionSummary | None
 26:     ml: MLExecutionSummary | None
 27: 
 28:     def to_dict(self) -> dict[str, Any]:
 29:         return {
 30:             "execution_id": self.execution_id,
 31:             "status": self.status,
 32:             "bronze_silver": self.bronze_silver.to_dict(),
 33:             "gold": self.gold.to_dict() if self.gold else None,
 34:             "ml": self.ml.to_dict() if self.ml else None,
 35:         }
 36: 
 37: 
 38: def run_platform_pipeline(
 39:     config: AppConfig,
 40:     selection: RunSelection,
 41:     *,
 42:     execution_type: str,
 43:     force_bronze: bool = False,
 44:     force_silver: bool = False,
 45:     refresh_references: bool | None = None,
 46:     train_ml: bool = True,
 47:     models: list[str] | None = None,
 48: ) -> PlatformExecutionSummary:
 49:     """Runs Bronze -> Silver -> Gold -> optional ML and audits the parent run."""
 50:     execution_id = f"platform-{utc_now().strftime('%Y%m%dT%H%M%S')}-{uuid4().hex[:8]}"
 51:     started_at = utc_now()
 52:     mongo = MongoClientProvider(config.mongo)
 53:     unified: UnifiedAuditRepository | None = None
 54:     try:
 55:         unified = UnifiedAuditRepository(mongo.database(), config.audit)
 56:         unified.start_run(
 57:             execution_id,
 58:             layer="platform",
 59:             execution_type=execution_type,
 60:             selection={
 61:                 "services": selection.services,
 62:                 "start_year": selection.start_year,
 63:                 "end_year": selection.end_year,
 64:                 "months": selection.months,
 65:                 "train_ml": train_ml,
 66:                 "models": models,
 67:             },
 68:             started_at=started_at,
 69:         )
 70: 
 71:         medallion = run_medallion_to_silver(
 72:             config,
 73:             selection,
 74:             execution_type=execution_type,
 75:             force_bronze=force_bronze,
 76:             force_silver=force_silver,
 77:             refresh_references=refresh_references,
 78:         )
 79:         unified.link_parent(medallion.bronze.execution_id, execution_id)
 80:         if medallion.silver is not None:
 81:             unified.link_parent(medallion.silver.execution_id, execution_id)
 82:         if medallion.status == "FAILED":
 83:             summary = PlatformExecutionSummary(execution_id, "FAILED", medallion, None, None)
 84:             unified.finish_run(
 85:                 execution_id,
 86:                 status="FAILED",
 87:                 metrics={"completed_layers": 2, "failed_layer": "bronze_or_silver"},
 88:             )
 89:             return summary
 90: 
 91:         gold = run_gold_pipeline(
 92:             config,
 93:             selection,
 94:             execution_type=execution_type,
 95:             stages=("dimensions", "facts", "marts", "features"),
 96:         )
 97:         unified.link_parent(gold.execution_id, execution_id)
 98:         if gold.status not in {"SUCCESS", "PARTIAL_SUCCESS", "NO_INPUT"}:
 99:             summary = PlatformExecutionSummary(execution_id, "FAILED", medallion, gold, None)
100:             unified.finish_run(
101:                 execution_id,
102:                 status="FAILED",
103:                 metrics={"completed_layers": 3, "failed_layer": "gold"},
104:             )
105:             return summary
106: 
107:         ml = (
108:             run_ml_pipeline(config, models)
109:             if train_ml and gold.status in {"SUCCESS", "PARTIAL_SUCCESS"}
110:             else None
111:         )
112:         if ml is not None:
113:             unified.link_parent(ml.run_id, execution_id)
114:         statuses = [medallion.status, gold.status, ml.status if ml else "SUCCESS"]
115:         if "FAILED" in statuses:
116:             status = "FAILED"
117:         elif "PARTIAL_SUCCESS" in statuses or "NO_INPUT" in statuses:
118:             status = "PARTIAL_SUCCESS"
119:         else:
120:             status = "SUCCESS"
121:         summary = PlatformExecutionSummary(execution_id, status, medallion, gold, ml)
122:         unified.finish_run(
123:             execution_id,
124:             status=status,
125:             metrics={
126:                 "completed_layers": 4 if ml else 3,
127:                 "bronze_execution_id": medallion.bronze.execution_id,
128:                 "silver_execution_id": medallion.silver.execution_id if medallion.silver else None,
129:                 "gold_execution_id": gold.execution_id,
130:                 "ml_run_id": ml.run_id if ml else None,
131:                 "bronze_silver_status": medallion.status,
132:                 "gold_status": gold.status,
133:                 "ml_status": ml.status if ml else "SKIPPED",
134:             },
135:         )
136:         return summary
137:     except Exception as error:
138:         if unified is not None:
139:             unified.fail_run(execution_id, error, layer="platform")
140:         raise
141:     finally:
142:         mongo.close()
</file>

