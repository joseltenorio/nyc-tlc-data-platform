 28: def _to_frame(documents: list[dict[str, Any]]) -> pd.DataFrame:
 29:     if not documents:
 30:         return pd.DataFrame()
 31:     clean: list[dict[str, Any]] = []
 32:     for document in documents:
 33:         item = dict(document)
 34:         item.pop("_id", None)
 35:         clean.append(item)
 36:     return pd.json_normalize(clean, sep=".")
