<file path="src/tlc_data_platform/audit/parquet_metrics.py">
 1: from __future__ import annotations
 2: 
 3: from dataclasses import asdict, dataclass
 4: from pathlib import Path
 5: from typing import Iterable
 6: 
 7: 
 8: @dataclass(frozen=True)
 9: class ParquetMetrics:
10:     parquet_files: int
11:     bytes_on_disk: int
12:     rows: int | None
13: 
14:     def to_dict(self) -> dict[str, int | None]:
15:         return asdict(self)
16: 
17: 
18: def parquet_files(path: Path) -> list[Path]:
19:     if path.is_file() and path.suffix.lower() == ".parquet":
20:         return [path]
21:     if not path.is_dir():
22:         return []
23:     return sorted(item for item in path.rglob("*.parquet") if item.is_file())
24: 
25: 
26: def directory_size(path: Path) -> int:
27:     if path.is_file():
28:         return path.stat().st_size
29:     if not path.is_dir():
30:         return 0
31:     total = 0
32:     for item in path.rglob("*"):
33:         if item.is_file():
34:             try:
35:                 total += item.stat().st_size
36:             except OSError:
37:                 continue
38:     return total
39: 
40: 
41: def parquet_metrics(path: Path, *, include_rows: bool = True) -> ParquetMetrics:
42:     files = parquet_files(path)
43:     total_bytes = sum(item.stat().st_size for item in files)
44:     if not include_rows or not files:
45:         return ParquetMetrics(len(files), total_bytes, 0 if not files else None)
46: 
47:     rows = 0
48:     try:
49:         import pyarrow.parquet as pq
50: 
51:         for item in files:
52:             metadata = pq.ParquetFile(item).metadata
53:             rows += int(metadata.num_rows)
54:     except Exception:
55:         return ParquetMetrics(len(files), total_bytes, None)
56:     return ParquetMetrics(len(files), total_bytes, rows)
57: 
58: 
59: def aggregate_metrics(paths: Iterable[Path], *, include_rows: bool = True) -> ParquetMetrics:
60:     file_count = 0
61:     total_bytes = 0
62:     total_rows = 0
63:     rows_known = True
64:     for path in paths:
65:         current = parquet_metrics(path, include_rows=include_rows)
66:         file_count += current.parquet_files
67:         total_bytes += current.bytes_on_disk
68:         if current.rows is None:
69:             rows_known = False
70:         else:
71:             total_rows += current.rows
72:     return ParquetMetrics(file_count, total_bytes, total_rows if rows_known else None)
</file>

