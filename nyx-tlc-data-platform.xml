<file path="src/tlc_data_platform/core/resource_guard.py">
  1: from __future__ import annotations
  2: 
  3: import shutil
  4: import threading
  5: from datetime import datetime, timedelta, timezone
  6: from pathlib import Path
  7: from typing import Any, Callable, TypeVar
  8: 
  9: from tlc_data_platform.audit.parquet_metrics import directory_size
 10: from tlc_data_platform.core.exceptions import SparkTemporarySpaceError
 11: 
 12: T = TypeVar("T")
 13: 
 14: 
 15: class SparkResourceGuard:
 16:     """Stops a Spark action before temporary spill can consume the host disk.
 17: 
 18:     `spark.local.dir` is bind-mounted under data/tmp/spark. A small monitor checks
 19:     both directory growth and remaining free space. When either limit is crossed,
 20:     all Spark jobs are cancelled and the caller receives a clear exception.
 21:     """
 22: 
 23:     def __init__(
 24:         self,
 25:         spark: Any,
 26:         local_dir: Path,
 27:         *,
 28:         max_temp_bytes: int,
 29:         minimum_free_space_bytes: int,
 30:         poll_seconds: float = 2.0,
 31:     ) -> None:
 32:         self._spark = spark
 33:         self._local_dir = local_dir
 34:         self._max_temp_bytes = max_temp_bytes
 35:         self._minimum_free_space_bytes = minimum_free_space_bytes
 36:         self._poll_seconds = poll_seconds
 37:         self._stop = threading.Event()
 38:         self._reason: str | None = None
 39: 
 40:     def run(self, action: Callable[[], T]) -> T:
 41:         self._preflight()
 42:         self._stop.clear()
 43:         self._reason = None
 44:         monitor = threading.Thread(target=self._monitor, daemon=True)
 45:         monitor.start()
 46:         try:
 47:             result = action()
 48:             if self._reason:
 49:                 raise SparkTemporarySpaceError(self._reason)
 50:             return result
 51:         finally:
 52:             self._stop.set()
 53:             monitor.join(timeout=self._poll_seconds * 2)
 54: 
 55:     def _preflight(self) -> None:
 56:         self._local_dir.mkdir(parents=True, exist_ok=True)
 57:         free = shutil.disk_usage(self._local_dir).free
 58:         if free < self._minimum_free_space_bytes:
 59:             raise SparkTemporarySpaceError(
 60:                 "Espacio libre insuficiente antes de iniciar Spark: "
 61:                 f"free={free}, minimum={self._minimum_free_space_bytes}"
 62:             )
 63:         used = directory_size(self._local_dir)
 64:         if used > self._max_temp_bytes:
 65:             raise SparkTemporarySpaceError(
 66:                 "El directorio temporal Spark ya supera el límite: "
 67:                 f"used={used}, maximum={self._max_temp_bytes}"
 68:             )
 69: 
 70:     def _monitor(self) -> None:
 71:         while not self._stop.wait(self._poll_seconds):
 72:             try:
 73:                 used = directory_size(self._local_dir)
 74:                 free = shutil.disk_usage(self._local_dir).free
 75:             except OSError:
 76:                 continue
 77:             if used > self._max_temp_bytes:
 78:                 self._reason = (
 79:                     "Spark fue cancelado para proteger el disco: "
 80:                     f"temporales={used} > límite={self._max_temp_bytes}."
 81:                 )
 82:             elif free < self._minimum_free_space_bytes:
 83:                 self._reason = (
 84:                     "Spark fue cancelado para conservar espacio libre: "
 85:                     f"free={free} < mínimo={self._minimum_free_space_bytes}."
 86:                 )
 87:             if self._reason:
 88:                 try:
 89:                     self._spark.sparkContext.cancelAllJobs()
 90:                 except Exception:
 91:                     pass
 92:                 return
 93: 
 94: 
 95: def reset_spark_local_dir(path: Path) -> None:
 96:     """Removes only layer-owned Spark spill from a previous stopped execution."""
 97:     if path.exists():
 98:         shutil.rmtree(path, ignore_errors=True)
 99:     path.mkdir(parents=True, exist_ok=True)
100: 
101: 
102: def cleanup_stale_spark_dirs(root: Path, *, older_than_hours: int = 24) -> None:
103:     """Removes only abandoned Spark-run directories older than the safety window."""
104:     if not root.is_dir():
105:         return
106:     cutoff = datetime.now(timezone.utc) - timedelta(hours=older_than_hours)
107:     for child in root.iterdir():
108:         if not child.is_dir():
109:             continue
110:         try:
111:             modified = datetime.fromtimestamp(child.stat().st_mtime, timezone.utc)
112:         except OSError:
113:             continue
114:         if modified < cutoff:
115:             shutil.rmtree(child, ignore_errors=True)
</file>

